<div {{ attributes }}>
    <div class="game-card">
        <div class="game-card-header">
            <h2 class="text-sm sm:text-base font-bold text-white flex items-center">
                <svg class="w-5 h-5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
                <span class="player-name truncate">{{ this.name }}</span>
            </h2>
        </div>
        <div class="game-card-body text-gray-300">
            <div class="flex items-center justify-between mb-2 text-xs sm:text-sm">
                <span class="text-gray-400">{{ "game.home.player.birthdate"|trans }}</span>
                <span class="font-medium">{{ this.createdAt|date('d/m/Y') }}</span>
            </div>

            {# Life bar #}
            <div class="mb-3">
                <div class="flex items-center justify-between mb-0.5">
                    <div class="flex items-center">
                        <svg class="w-3.5 h-3.5 text-red-500 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-xs">Vie</span>
                    </div>
                    <span class="text-xs font-medium">
                        <span class="player-life">{{ this.life }}</span>/<span class="player-maxlife">{{ this.maxLife }}</span>
                    </span>
                </div>
                <div class="progress-bar">
                    <div class="progress-bar-fill bg-red-600 player-progress-life" style="width: {{ this.life/this.maxLife*100 }}%"></div>
                </div>
            </div>

            {# Status effects #}
            <div class="player-statuses mb-3"></div>

            {# Map & position #}
            <div class="grid grid-cols-2 gap-2">
                <div class="bg-gray-700/80 p-2.5 rounded-lg">
                    <div class="flex items-center text-[10px] sm:text-xs text-gray-400 mb-0.5">
                        <svg class="w-3 h-3 mr-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path>
                        </svg>
                        <span>Carte</span>
                    </div>
                    <div class="font-medium text-xs sm:text-sm truncate">{{ this.mapName }}</div>
                </div>
                <div class="bg-gray-700/80 p-2.5 rounded-lg">
                    <div class="flex items-center text-[10px] sm:text-xs text-gray-400 mb-0.5">
                        <svg class="w-3 h-3 mr-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <span>Position</span>
                    </div>
                    <div class="font-medium text-xs sm:text-sm">{{ this.x }} - {{ this.y }}</div>
                </div>
            </div>
        </div>
    </div>
</div>

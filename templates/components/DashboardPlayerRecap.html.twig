<div {{ attributes }}>
    <div class="game-card">
        <div class="game-card-header">
            <div class="flex items-center justify-between">
                <h2 class="text-sm sm:text-base font-bold text-white flex items-center">
                    <svg class="w-5 h-5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                    <span class="player-name truncate">{{ this.name }}</span>
                </h2>
                <span class="text-xs text-purple-200/70 bg-purple-800/50 px-2 py-0.5 rounded-full">{{ this.classType }}</span>
            </div>
        </div>
        <div class="game-card-body text-gray-300 space-y-3">
            {# Status indicator #}
            {% if this.isDead %}
                <div class="flex items-center gap-1.5 text-xs bg-red-900/40 text-red-300 px-2.5 py-1.5 rounded-lg border border-red-800/40">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                    </svg>
                    {{ 'game.home.player.dead'|trans }}
                </div>
            {% elseif this.isInFight %}
                <div class="flex items-center gap-1.5 text-xs bg-orange-900/40 text-orange-300 px-2.5 py-1.5 rounded-lg border border-orange-800/40">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd"/>
                    </svg>
                    {{ 'game.home.player.in_fight'|trans }}
                </div>
            {% endif %}

            {# Life bar #}
            <div>
                <div class="flex items-center justify-between mb-0.5">
                    <div class="flex items-center">
                        <svg class="w-3.5 h-3.5 text-red-500 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-xs">{{ 'game.home.player.life'|trans }}</span>
                    </div>
                    <span class="text-xs font-medium">
                        <span class="player-life">{{ this.life }}</span>/<span class="player-maxlife">{{ this.maxLife }}</span>
                    </span>
                </div>
                <div class="progress-bar">
                    <div class="progress-bar-fill bg-red-600 player-progress-life" style="width: {{ (this.life/this.maxLife*100)|round }}%"></div>
                </div>
            </div>

            {# Energy bar #}
            <div>
                <div class="flex items-center justify-between mb-0.5">
                    <div class="flex items-center">
                        <svg class="w-3.5 h-3.5 text-blue-400 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/>
                        </svg>
                        <span class="text-xs">{{ 'game.home.player.energy'|trans }}</span>
                    </div>
                    <span class="text-xs font-medium">
                        {{ this.energy }}/{{ this.maxEnergy }}
                    </span>
                </div>
                <div class="progress-bar">
                    <div class="progress-bar-fill bg-blue-500" style="width: {{ (this.energy/this.maxEnergy*100)|round }}%"></div>
                </div>
            </div>

            {# Gils #}
            <div class="flex items-center justify-between bg-gray-700/60 px-2.5 py-2 rounded-lg">
                <div class="flex items-center text-xs text-yellow-400">
                    <svg class="w-3.5 h-3.5 mr-1.5" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.736 6.979C9.208 6.193 9.696 6 10 6c.304 0 .792.193 1.264.979a1 1 0 001.715-1.029C12.279 4.784 11.232 4 10 4s-2.279.784-2.979 1.95c-.285.475-.507 1-.67 1.55H6a1 1 0 000 2h.013a9.358 9.358 0 000 1H6a1 1 0 100 2h.351c.163.55.385 1.075.67 1.55C7.721 15.216 8.768 16 10 16s2.279-.784 2.979-1.95a1 1 0 10-1.715-1.029c-.472.786-.96.979-1.264.979-.304 0-.792-.193-1.264-.979a4.265 4.265 0 01-.264-.521H10a1 1 0 100-2H8.017a7.36 7.36 0 010-1H10a1 1 0 100-2H8.472c.08-.185.17-.364.264-.521z"/>
                    </svg>
                    Gils
                </div>
                <span class="text-sm font-bold text-yellow-400">{{ this.gils|number_format(0, ',', ' ') }}</span>
            </div>

            {# Map & position #}
            <div class="grid grid-cols-2 gap-2">
                <div class="bg-gray-700/60 p-2.5 rounded-lg">
                    <div class="flex items-center text-[10px] sm:text-xs text-gray-400 mb-0.5">
                        <svg class="w-3 h-3 mr-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path>
                        </svg>
                        <span>{{ 'game.home.player.map'|trans }}</span>
                    </div>
                    <div class="font-medium text-xs sm:text-sm truncate">{{ this.mapName }}</div>
                </div>
                <div class="bg-gray-700/60 p-2.5 rounded-lg">
                    <div class="flex items-center text-[10px] sm:text-xs text-gray-400 mb-0.5">
                        <svg class="w-3 h-3 mr-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <span>Position</span>
                    </div>
                    <div class="font-medium text-xs sm:text-sm">{{ this.x }} - {{ this.y }}</div>
                </div>
            </div>

            {# Member since #}
            <div class="text-center text-[10px] text-gray-500 pt-1 border-t border-gray-700/50">
                {{ 'game.home.player.member_since'|trans({'%date%': this.createdAt|date('d/m/Y')}) }}
            </div>
        </div>
    </div>
</div>

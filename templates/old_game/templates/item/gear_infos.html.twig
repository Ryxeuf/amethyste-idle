<div class="ibox float-e-margins">
    {% if not item %}
        <div class="ibox-content">{{ "game.item.item_not_found"|trans }}</div>
    {% else %}
        <div class="ibox-title">
            <div class="col-xs-11">
                <h5>
            <span class="pull-left">
                <div class="item_bo {{ item|itemClassCss }}"></div>
            </span>
                    <span class="pull-left">
                &nbsp;
                {{ item.name }}
            </span>
                </h5>
            </div>
            <div class="col-xs-1">
                <div class="ibox-tools">
                    <a class="close close-item-infos">
                        <i class="fa fa-times"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="ibox-content">
            <div class="row">
                {{ include('item/partials/informations.html.twig', {'item': item}) }}

                {% if item.requirements and item.requirements|length > 0 %}
                    {{ include('item/partials/requirements_infos.html.twig', {'requirements': item.requirements}) }}
                    <div class="clearfix"></div>
                {% endif %}

                {% if item.slots and item.slots|length > 0 %}
                    <div class=" col-xs-12 m-top-10">

                        <table class="table table-striped">
                            <thead>
                            <tr>
                                <th class="col-xs-12" colspan="12">{{ "game.item.slots"|trans }}</th>
                            </tr>
                            <tr>
                                <th class="col-xs-1"></th>
                                <th class="col-xs-9">{{ "game.item.slot.name"|trans }}</th>
                                <th class="col-xs-2"></th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for slot in item.slots %}
                                {% if slot.itemSet %}
                                    <tr>
                                        <td class="col-xs-1">
                                            <div class="item equipped_{{ slot.itemSet|itemClassCss }}"></div>
                                        </td>
                                        <td class="col-xs-8">
{#                                            <a class="item-infos materia-infos-link" data-href="{{ path("materia_infos") }}" data-item="{{ slot.itemSet.id }}">{{ slot.itemSet.name }}</a>#}

                                            <a class="materia-set-infos-link" data-item="{{ slot.itemSet.id }}">{{ slot.itemSet.name }}</a>
                                            <div class="display-none materia-set-infos-{{ slot.itemSet.id }}">
                                                {{ include('item/partials/informations.html.twig', {'item': slot.itemSet}) }}
                                            </div>
                                        </td>
                                        <td class="col-xs-2">
                                            <a class="materia-unset-link" data-href="{{ path("gear_materia_unset") }}" data-slot="{{ slot.id }}" data-item="{{ item.id }}" title="{{ "game.materia.remove"|trans }}"><span class="fa fa-ban"></span></a>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td class="col-xs-1"><div class="item empty_materia_slot"></div></td>
                                        <td class="col-xs-9"><i>{{ "game.item.slot.empty"|trans }}</i></td>
                                        <td class="col-xs-2">
                                            {% if materia_inventory.items|length > 0 %}
                                                <a class="btn btn-sm btn-success btn-showsubrow" data-subrow="{{ loop.index }}">{{ "game.gear.slot.set"|trans }}</a>
                                            {% endif %}
                                        </td>
                                    </tr>
                                    {% if materia_inventory.items|length > 0 %}
                                        <tr class="sub-row sub-row-{{ loop.index }}" style="display: none">
                                            <td class="col-xs-1"></td>
                                            <td class="col-xs-9">
                                                <select class="form-control select-slot-{{ slot.id }}">
                                                    {% for materia in materia_inventory.items %}
                                                        <option value="{{ materia.id }}">{{ materia.name }}</option>
                                                    {% endfor %}
                                                </select>
                                            </td>
                                            <td class="col-xs-2">
                                                <form class="form-slot" method="post" action="{{ path("gear_materia_set") }}" data-slotid="{{ slot.id }}" data-item="{{ item.id }}">
                                                    <input type="hidden" name="slot" value="{{ slot.id }}">
                                                    <input type="hidden" name="materia" value="" id="input-materia-{{ slot.id }}">
                                                    <button type="submit" class="btn btn-sm btn-primary set-materia">{{ "game.gear.slot.set"|trans }}</button>
                                                </form>
                                            </td>
                                        </tr>
                                    {% endif %}
                                {% endif %}
                            {% endfor %}
                            </tbody>
                        </table>

                    </div>

                    <div class="clearfix"></div>
                {% endif %}

            </div>
        </div>
        <div class="ibox-footer gear-infos-error-container"></div>
    {% endif %}
</div>


{% extends "tools/index.html.twig" %}

{% block title %}{{ "app.tools.map_editor.title"|trans }}{% endblock %}

{% block body_content %}
    <div class="tabs-container text-center">
        <h1>Editeur de carte</h1>
    </div>

    <div class="col-xs-12">
        <div class="col-xs-6">
            <h3>Comment designer la carte :</h3>
            <ol>
                <li>Sélectionner une design du sprite à appliquer</li>
                <li>Choisir le niveau sur lequel appliquer le design</li>
                <li>Cliquer sur la case de la carte où appliquer ce design</li>
            </ol>
        </div>

        <div class="col-xs-6">
            <h4>Infos utiles</h4>
            <ul>
                <li>Le niveau objet est toujours au dessus du niveau de la carte, il s'applique par transparence</li>
                <li>"ctrl" + survol d'une case applique le style</li>
                <li>"alt" + survol d'une case enlève le style</li>
                <li>Le niveau de difficulté indique si la case est bloquante (rouge) ou normal</li>
            </ul>
        </div>
    </div>

    <div class="container-fluid">
        <div class="col-xs-12">
            <div class="col-xs-6">
                <div class="row">
                    <div class="col-xs-6">
                        <h3>
                            <label for="check-map-layer">Niveau de carte affiché <input type="checkbox" class="check-layer" id="check-map-layer" checked></label>
                            <label for="check-object-layer">Niveau d'objet affiché <input type="checkbox" class="check-layer" id="check-object-layer"></label>
                            <label for="check-difficulty-layer">Niveau de difficulté affiché <input type="checkbox" class="check-layer" id="check-difficulty-layer"></label>
                        </h3>
                    </div>
                    <div class="col-xs-6">
                        <h4>
                            Cellule sélectionnée
                            <div id="selected-cell-preview" style="width: 34px; height: 34px; border: 1px solid black; display: inline-block"></div>
                        </h4>
                    </div>
                </div>
            </div>
            <div class="clearfix"></div>
        </div>

        <div class="col-xs-6">
            <div style="width: 642px; height: 642px; margin: 0px 10px 10px 0px; padding: 1px; background: black">
                <table class="map-layer" style="">
                    <tbody>
                    {% for y in 0..19 %}
                        <tr>
                            {% for x in 0..19 %}
                                <td class="cell-map forest" style="width: 32px; height: 32px;" data-x="{{ x }}" data-y="{{ y }}" data-bg="0-0">
                                    <div style="background-color: black; opacity: 0; width: 32px; height: 32px"></div>
                                </td>
                            {% endfor %}
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
                <table class="object-layer display-none" style="position: absolute; top: 0;">
                    <tbody>
                    {% for y in 0..19 %}
                        <tr>
                            {% for x in 0..19 %}
{#                                <td class="cell-map" style="width: 32px; height: 32px;" data-x="{{ x }}" data-y="{{ y }}" data-bg="0-0">#}
                                <td class="cell-map" style="width: 32px; height: 32px;" data-x="{{ x }}" data-y="{{ y }}">
                                    <div style="background-color: black; opacity: 0; width: 32px; height: 32px"></div>
                                </td>
                            {% endfor %}
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
                <table class="difficulty-layer display-none" style="position: absolute; top: 0;">
                    <tbody>
                    {% for y in 0..19 %}
                        <tr>
                            {% for x in 0..19 %}
                                <td class="cell-difficulty" style="width: 32px; height: 32px;" data-x="{{ x }}" data-y="{{ y }}" data-difficulty="0">
                                    <div style="background-color: red; opacity: 0; width: 32px; height: 32px"></div>
                                </td>
                            {% endfor %}
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-xs-6" style="width: 560px; height: 560px; overflow: scroll;">
            <h3>Sprite chargé</h3>
            <table class="forest" style="width: 512px; height: 6144px;">
                <tbody>
                {% for y in 0..191 %}
                    <tr>
                        {% for x in 0..15 %}
                            <td class="cell-sprite" style="width: 32px; height: 32px;" data-x="{{ x }}" data-y="{{ y }}">
                            </td>
                        {% endfor %}
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="clearfix"></div>

        <div class="col-xs-12">
            <label for="startX">Coordonnée x de début</label>
            <input type="text" name="startX" id="startX" class="input" value="0">
            <label for="startY">Coordonnée y de début</label>
            <input type="text" name="startY" id="startY" class="input" value="0">
        </div>
        <div class="col-xs-12">
            <button class="btn btn-lg btn-primary export">Exporter</button>
        </div>
        <div class="col-xs-12">
            <div class="row">
                <div class="col-xs-6">
                    <pre class="">/* CSS */</pre>
                    <textarea class="result-css" style="width: 100%" rows="10"></textarea>
                </div>
                <div class="col-xs-6">
                    <pre class="">/* Fixtures Cell */</pre>
                    <textarea class="result-fixture-cell" style="width: 100%" rows="10"></textarea>
                </div>
                <div class="col-xs-6">
                    <pre class="">/* Fixtures Ground_Layer */</pre>
                    <textarea class="result-fixture-ground-layer" style="width: 100%" rows="10"></textarea>
                </div>
                <div class="col-xs-6">
                    <pre class="">/* Fixtures Object_Layer */</pre>
                    <textarea class="result-fixture-object-layer" style="width: 100%" rows="10"></textarea>
                </div>
            </div>
        </div>
        <div class="col-xs-12">
            <button class="btn btn-lg btn-primary save">Sauvegarder la carte pour plus tard</button>
            <button class="btn btn-lg btn-primary load">Charger la carte</button>
        </div>
        <div class="col-xs-12">
            <textarea class="result-save" style="width: 100%" rows="20"></textarea>
        </div>
    </div>

{% endblock %}

{% block stylesheets %}
    {{ parent() }}

{#    <link href="css/map_square.css" rel="stylesheet"/>#}
    {{ encore_entry_link_tags('map-editor') }}
{% endblock %}
{% block javascripts %}
    {{ parent() }}

{#    <script src="{{ asset('js/editor/map-editor.js') }}"></script>#}
    {{ encore_entry_script_tags('map-editor') }}

{% endblock %}
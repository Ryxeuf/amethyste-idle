        }
    </style>
{% endblock %}


{% block javascripts %}
    {{ parent() }}

    {{ encore_entry_script_tags('map') }}
    <script>
        let canvas = document.getElementById('map-ground')
        let context = canvas.getContext('2d');
        let image = new Image();
        image.src = '/build/images/forest.f3fa78c6.png';
        let tileSize = 32;
        let forestStyle = []
        for (let i = 0; i < document.styleSheets.length; i++) {
            let sheet = document.styleSheets.item(i)
            for (let j = 0; j < sheet.cssRules.length; j++) {
                let rule = sheet.cssRules.item(j)
                if (rule.selectorText !== undefined && rule.selectorText.startsWith('.forest')) {
                    let x = rule.style.backgroundPositionX.replace('-', '').replace('px', '')
                    let y = rule.style.backgroundPositionY.replace('-', '').replace('px', '')
                    let slug = rule.selectorText.replace('.', '')
                    forestStyle[slug] = {'x': x, 'y': y, 'rule': rule}
                }
            }
        }

        let map = JSON.parse('{{ mapJson|raw }}')

        let zoom = 1

        function draw() {
            context.clearRect(0,0, canvas.width, canvas.height)
            context.scale(zoom, zoom)
            map.cells.forEach(function (cell) {
                let startX = 0;
                let startY = 0;
                if (forestStyle[cell.slug] !== undefined) {
                    startX = parseInt(forestStyle[cell.slug]['x'])
                    startY = parseInt(forestStyle[cell.slug]['y'])
                }
                // console.log(image, startX, startY, tileSize, tileSize, cell.x * tileSize, cell.y * tileSize , tileSize, tileSize)
                context.drawImage(image, startX, startY, tileSize, tileSize, cell.x * tileSize, cell.y * tileSize , tileSize, tileSize);
            });
        }

        draw()

    </script>

{% endblock %}
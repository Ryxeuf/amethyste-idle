{% block stylesheets %}
    {{ parent() }}

    {{ encore_entry_link_tags('map') }}
    <style>
        #map-canvas {
            /*width: 3000px;*/
            /*height: 3000px;*/
        }
        .map {
            width: 100%;
            height: 640px;
            overflow: scroll;
            /*overflow-x: auto;*/
            /*overflow-y: auto;*/
            white-space: nowrap;
        }
        .map>.map-row {

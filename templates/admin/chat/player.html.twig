{% extends 'admin/base.html.twig' %}

{% block page_title %}Messages de {{ player.name }}{% endblock %}

{% block body %}
<div class="space-y-6">
    <div class="flex items-center gap-4">
        <a href="{{ path('admin_chat_index') }}" class="text-gray-400 hover:text-gray-200 transition-colors text-sm">
            &larr; Retour a la liste
        </a>
        <a href="{{ path('admin_player_show', {id: player.id}) }}" class="text-purple-400 hover:text-purple-300 transition-colors text-sm">
            Voir le profil joueur
        </a>
    </div>

    <div class="text-sm text-gray-400">
        {{ total }} message{{ total > 1 ? 's' : '' }} pour {{ player.name }}
    </div>

    <div class="bg-gray-900 rounded-lg border border-gray-800 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-gray-800 text-left">
                        <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase">Date</th>
                        <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase">Canal</th>
                        <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase">Direction</th>
                        <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase">Message</th>
                        <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-800">
                    {% for message in messages %}
                        <tr class="{% if message.isDeleted %}opacity-50 bg-red-900/10{% endif %} hover:bg-gray-800/50 transition-colors">
                            <td class="px-4 py-3 text-sm text-gray-400 whitespace-nowrap">{{ message.createdAt|date('d/m H:i:s') }}</td>
                            <td class="px-4 py-3">
                                {% if message.channel == 'global' %}
                                    <span class="inline-flex px-2 py-0.5 text-xs rounded-full bg-blue-900 text-blue-300">General</span>
                                {% elseif message.channel == 'map' %}
                                    <span class="inline-flex px-2 py-0.5 text-xs rounded-full bg-green-900 text-green-300">Carte</span>
                                {% elseif message.channel == 'private' %}
                                    <span class="inline-flex px-2 py-0.5 text-xs rounded-full bg-pink-900 text-pink-300">Prive</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3 text-sm">
                                {% if message.sender.id == player.id %}
                                    <span class="text-green-400">Envoye</span>
                                    {% if message.recipient %}
                                        <span class="text-gray-500">a</span>
                                        <a href="{{ path('admin_chat_player', {id: message.recipient.id}) }}" class="text-pink-400 hover:text-pink-300">{{ message.recipient.name }}</a>
                                    {% endif %}
                                {% else %}
                                    <span class="text-blue-400">Recu</span>
                                    <span class="text-gray-500">de</span>
                                    <a href="{{ path('admin_chat_player', {id: message.sender.id}) }}" class="text-purple-400 hover:text-purple-300">{{ message.sender.name }}</a>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-200 max-w-md">
                                <div class="{% if message.isDeleted %}line-through{% endif %}">{{ message.content }}</div>
                                {% if message.isDeleted and message.deletedBy %}
                                    <div class="text-xs text-red-400 mt-0.5">Supprime par {{ message.deletedBy }}</div>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3 whitespace-nowrap">
                                {% if not message.isDeleted %}
                                    <form method="post" action="{{ path('admin_chat_delete', {id: message.id}) }}" class="inline"
                                          onsubmit="return confirm('Supprimer ce message ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_chat' ~ message.id) }}">
                                        <button type="submit" class="text-red-400 hover:text-red-300 text-sm transition-colors">
                                            Supprimer
                                        </button>
                                    </form>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="px-4 py-8 text-center text-gray-500">Aucun message</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if totalPages > 1 %}
        <div class="flex justify-center gap-2">
            {% for p in range(max(1, currentPage - 3), min(totalPages, currentPage + 3)) %}
                <a href="{{ path('admin_chat_player', {id: player.id, page: p}) }}"
                   class="px-3 py-1.5 rounded text-sm {% if p == currentPage %}bg-purple-600 text-white{% else %}bg-gray-800 text-gray-400 hover:bg-gray-700{% endif %} transition-colors">
                    {{ p }}
                </a>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}

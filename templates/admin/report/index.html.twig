{% extends 'admin/base.html.twig' %}

{% block page_title %}Signalements joueurs{% endblock %}

{% block body %}
<div class="space-y-6">
    {# Filtres par statut #}
    <div class="flex flex-wrap gap-2">
        {% set filters = [
            {key: 'pending', label: 'En attente (' ~ pendingCount ~ ')'},
            {key: 'accepted', label: 'Acceptes'},
            {key: 'rejected', label: 'Rejetes'},
            {key: 'all', label: 'Tous'}
        ] %}
        {% for f in filters %}
            <a href="{{ path('admin_report_index', {status: f.key}) }}"
               class="px-3 py-1.5 rounded text-sm {% if statusParam == f.key %}bg-purple-600 text-white{% else %}bg-gray-800 text-gray-400 hover:bg-gray-700{% endif %} transition-colors">
                {{ f.label }}
            </a>
        {% endfor %}
    </div>

    <div class="text-sm text-gray-400">
        {{ total }} signalement{{ total > 1 ? 's' : '' }}
    </div>

    <div class="bg-gray-900 rounded-lg border border-gray-800 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-gray-800 text-left">
                        <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase">Date</th>
                        <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase">Statut</th>
                        <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase">Rapporteur</th>
                        <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase">Signale</th>
                        <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase">Raison</th>
                        <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase">Description</th>
                        <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-800">
                    {% for report in reports %}
                        <tr class="hover:bg-gray-800/50 transition-colors">
                            <td class="px-4 py-3 text-sm text-gray-400 whitespace-nowrap">{{ report.createdAt|date('d/m H:i') }}</td>
                            <td class="px-4 py-3">
                                <span class="inline-flex px-2 py-0.5 text-xs rounded-full {{ report.status.cssClass }}">
                                    {{ report.status.label }}
                                </span>
                                {% if report.status.value == 'accepted' and report.renownMalusApplied > 0 %}
                                    <div class="text-xs text-red-400 mt-0.5">-{{ report.renownMalusApplied }} renommee</div>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-300">{{ report.reporter.name }}</td>
                            <td class="px-4 py-3 text-sm text-gray-300">
                                <a href="{{ path('app_game_player_profile', {id: report.reportedPlayer.id}) }}" class="text-purple-400 hover:text-purple-300">
                                    {{ report.reportedPlayer.name }}
                                </a>
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-300">{{ report.reason.label }}</td>
                            <td class="px-4 py-3 text-sm text-gray-300 max-w-md">
                                <div class="whitespace-pre-wrap break-words">{{ report.description }}</div>
                            </td>
                            <td class="px-4 py-3 whitespace-nowrap">
                                {% if report.status.value == 'pending' %}
                                    <form method="post" action="{{ path('admin_report_accept', {id: report.id}) }}" class="inline"
                                          onsubmit="return confirm('Accepter et appliquer le malus renommee ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('report_accept_' ~ report.id) }}">
                                        {% for key, value in app.request.query.all %}<input type="hidden" name="{{ key }}" value="{{ value }}">{% endfor %}
                                        <button type="submit" class="text-red-400 hover:text-red-300 text-sm">Accepter</button>
                                    </form>
                                    <form method="post" action="{{ path('admin_report_reject', {id: report.id}) }}" class="inline ml-2">
                                        <input type="hidden" name="_token" value="{{ csrf_token('report_reject_' ~ report.id) }}">
                                        {% for key, value in app.request.query.all %}<input type="hidden" name="{{ key }}" value="{{ value }}">{% endfor %}
                                        <button type="submit" class="text-gray-400 hover:text-gray-300 text-sm">Rejeter</button>
                                    </form>
                                {% else %}
                                    <span class="text-xs text-gray-500">
                                        {% if report.reviewedBy %}par {{ report.reviewedBy.username ?? report.reviewedBy.userIdentifier }}{% endif %}
                                        {% if report.reviewedAt %} le {{ report.reviewedAt|date('d/m H:i') }}{% endif %}
                                    </span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="7" class="px-4 py-8 text-center text-gray-500">Aucun signalement</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if totalPages > 1 %}
        <div class="flex justify-center gap-2">
            {% for p in range(max(1, currentPage - 3), min(totalPages, currentPage + 3)) %}
                <a href="{{ path('admin_report_index', app.request.query.all|merge({page: p})) }}"
                   class="px-3 py-1.5 rounded text-sm {% if p == currentPage %}bg-purple-600 text-white{% else %}bg-gray-800 text-gray-400 hover:bg-gray-700{% endif %} transition-colors">
                    {{ p }}
                </a>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}

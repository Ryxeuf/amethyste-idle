{% extends 'admin/base.html.twig' %}

{% block title %}Nouvelle carte - Admin{% endblock %}
{% block page_title %}Nouvelle carte{% endblock %}

{% block body %}
<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-6">
    <h1 class="text-xl sm:text-2xl font-bold">Creer une carte vierge</h1>
    <a href="{{ path('admin_map_index') }}" class="text-gray-400 hover:text-white text-sm">Retour</a>
</div>

<div class="bg-gray-900 border border-gray-800 rounded-xl p-6 max-w-lg">
    <form method="post">
        <div class="mb-4">
            <label for="name" class="block text-sm font-medium text-gray-300 mb-1">Nom de la carte</label>
            <input type="text" id="name" name="name" required maxlength="255" placeholder="Ex: Mines profondes"
                   class="bg-gray-800 border border-gray-700 text-gray-200 rounded-lg px-3 py-2 w-full focus:outline-none focus:border-purple-500">
        </div>

        <div class="grid grid-cols-2 gap-4 mb-4">
            <div>
                <label for="width" class="block text-sm font-medium text-gray-300 mb-1">Largeur (tiles)</label>
                <input type="number" id="width" name="width" value="60" min="10" max="200" required
                       class="bg-gray-800 border border-gray-700 text-gray-200 rounded-lg px-3 py-2 w-full focus:outline-none focus:border-purple-500">
            </div>
            <div>
                <label for="height" class="block text-sm font-medium text-gray-300 mb-1">Hauteur (tiles)</label>
                <input type="number" id="height" name="height" value="60" min="10" max="200" required
                       class="bg-gray-800 border border-gray-700 text-gray-200 rounded-lg px-3 py-2 w-full focus:outline-none focus:border-purple-500">
            </div>
        </div>

        <div class="mb-6">
            <label for="world_id" class="block text-sm font-medium text-gray-300 mb-1">Monde</label>
            <select id="world_id" name="world_id" required
                    class="bg-gray-800 border border-gray-700 text-gray-200 rounded-lg px-3 py-2 w-full focus:outline-none focus:border-purple-500">
                {% for world in worlds %}
                    <option value="{{ world.id }}">{{ world.name }}</option>
                {% endfor %}
            </select>
        </div>

        <p class="text-xs text-gray-500 mb-6">La carte sera remplie d'herbe avec toutes les cellules accessibles. Utilisez l'editeur de carte pour peindre les tiles et placer les entites.</p>

        <div class="flex gap-3">
            <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg text-sm transition-colors">Creer la carte</button>
            <a href="{{ path('admin_map_index') }}" class="bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded-lg text-sm transition-colors">Annuler</a>
        </div>
    </form>
</div>
{% endblock %}

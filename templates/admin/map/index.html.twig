{% extends 'admin/base.html.twig' %}

{% block title %}Cartes - Admin{% endblock %}
{% block page_title %}Cartes{% endblock %}

{% block body %}
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-6">
        <form method="get" class="flex flex-wrap items-center gap-2 w-full sm:w-auto">
            <input type="text" name="q" value="{{ search }}" placeholder="Rechercher une carte..."
                   class="bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:border-purple-500 w-full sm:w-64">
            <button type="submit" class="bg-gray-700 hover:bg-gray-600 text-gray-200 px-4 py-2 rounded-lg text-sm transition-colors">Rechercher</button>
            {% if search %}
                <a href="{{ path('admin_map_index') }}" class="text-gray-500 hover:text-gray-300 text-sm">Effacer</a>
            {% endif %}
        </form>
        <div class="flex gap-2">
            <a href="{{ path('admin_map_create') }}" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm transition-colors whitespace-nowrap">Nouvelle carte</a>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin_map_import') }}" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg text-sm transition-colors whitespace-nowrap">Importer TMX</a>
            {% endif %}
        </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {% for map in maps %}
            {% set stats = mapStats[map.id] %}
            <a href="{{ path('admin_map_show', {id: map.id}) }}" class="bg-gray-900 border border-gray-800 rounded-xl p-5 hover:border-purple-700 transition-colors block">
                <h3 class="text-gray-200 font-semibold mb-2">{{ map.name }}</h3>
                <p class="text-sm text-gray-400 mb-3"><span aria-hidden="true">{{ map.currentWeather.icon() }}</span> {{ map.currentWeather.label() }}</p>
                <div class="grid grid-cols-3 gap-3">
                    <div>
                        <p class="text-xs text-gray-500 uppercase">Joueurs</p>
                        <p class="text-lg font-bold text-purple-400">{{ stats.players }}</p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase">Mobs</p>
                        <p class="text-lg font-bold text-red-400">{{ stats.mobs }}</p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase">PNJ</p>
                        <p class="text-lg font-bold text-green-400">{{ stats.pnjs }}</p>
                    </div>
                </div>
            </a>
        {% else %}
            <div class="col-span-full text-center text-gray-500 py-8">Aucune carte trouvee.</div>
        {% endfor %}
    </div>
{% endblock %}

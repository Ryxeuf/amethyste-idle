{% extends 'admin/base.html.twig' %}

{% block title %}{{ map.name }} - Admin{% endblock %}
{% block page_title %}{{ map.name }}{% endblock %}

{% block body %}
<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-6">
    <h1 class="text-xl sm:text-2xl font-bold">{{ map.name }}</h1>
    <a href="{{ path('admin_map_index') }}" class="text-gray-400 hover:text-white text-sm">Retour</a>
</div>

<div class="grid grid-cols-1 sm:grid-cols-4 gap-4 sm:gap-6 mb-8">
    <div class="bg-gray-800 rounded-lg p-3 sm:p-4">
        <h3 class="text-xs sm:text-sm text-gray-400 mb-1">Joueurs</h3>
        <p class="text-xl sm:text-2xl font-bold text-purple-400">{{ players|length }}</p>
    </div>
    <div class="bg-gray-800 rounded-lg p-3 sm:p-4">
        <h3 class="text-xs sm:text-sm text-gray-400 mb-1">Mobs</h3>
        <p class="text-xl sm:text-2xl font-bold text-red-400">{{ mobs|length }}</p>
    </div>
    <div class="bg-gray-800 rounded-lg p-3 sm:p-4">
        <h3 class="text-xs sm:text-sm text-gray-400 mb-1">PNJ</h3>
        <p class="text-xl sm:text-2xl font-bold text-green-400">{{ pnjs|length }}</p>
    </div>
    <div class="bg-gray-800 rounded-lg p-3 sm:p-4">
        <h3 class="text-xs sm:text-sm text-gray-400 mb-1">Portails</h3>
        <p class="text-xl sm:text-2xl font-bold text-blue-400">{{ portals|length }}</p>
    </div>
</div>

{# --- Mobs Section --- #}
<div class="flex items-center justify-between mb-3">
    <h2 class="text-lg sm:text-xl font-bold">Mobs sur la carte</h2>
    <a href="{{ path('admin_map_mob_new', {id: map.id}) }}" class="bg-red-600 hover:bg-red-700 text-white px-3 py-1.5 rounded-lg text-sm transition-colors">+ Placer un mob</a>
</div>
{% if mobs|length > 0 %}
<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-8">
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
            <thead class="border-b border-gray-800">
                <tr>
                    <th class="px-4 py-3 text-gray-400 font-medium">Monstre</th>
                    <th class="px-4 py-3 text-gray-400 font-medium">Niveau</th>
                    <th class="px-4 py-3 text-gray-400 font-medium">Position</th>
                    <th class="px-4 py-3 text-gray-400 font-medium">PV</th>
                    <th class="px-4 py-3 text-gray-400 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
                {% for mob in mobs %}
                <tr class="hover:bg-gray-800 transition-colors">
                    <td class="px-4 py-3 text-gray-200">{{ mob.monster ? mob.monster.name : '-' }}</td>
                    <td class="px-4 py-3 text-gray-400">{{ mob.level }}</td>
                    <td class="px-4 py-3 text-gray-400">{{ mob.coordinates ?? '-' }}</td>
                    <td class="px-4 py-3 text-gray-400">{{ mob.life }}/{{ mob.maxLife }}</td>
                    <td class="px-4 py-3 text-right">
                        <a href="{{ path('admin_map_mob_edit', {mapId: map.id, mobId: mob.id}) }}" class="text-blue-400 hover:text-blue-300 text-sm mr-3">Modifier</a>
                        <form method="post" action="{{ path('admin_map_mob_delete', {mapId: map.id, mobId: mob.id}) }}" class="inline" onsubmit="return confirm('Supprimer ce mob ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_mob' ~ mob.id) }}">
                            <button type="submit" class="text-red-400 hover:text-red-300 text-sm">Supprimer</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% else %}
<p class="text-gray-500 mb-8">Aucun mob sur cette carte.</p>
{% endif %}

{# --- PNJ Section --- #}
<div class="flex items-center justify-between mb-3">
    <h2 class="text-lg sm:text-xl font-bold">PNJ sur la carte</h2>
</div>
{% if pnjs|length > 0 %}
<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-8">
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
            <thead class="border-b border-gray-800">
                <tr>
                    <th class="px-4 py-3 text-gray-400 font-medium">Nom</th>
                    <th class="px-4 py-3 text-gray-400 font-medium">Classe</th>
                    <th class="px-4 py-3 text-gray-400 font-medium">Position</th>
                    <th class="px-4 py-3 text-gray-400 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
                {% for pnj in pnjs %}
                <tr class="hover:bg-gray-800 transition-colors">
                    <td class="px-4 py-3 text-gray-200">{{ pnj.name }}</td>
                    <td class="px-4 py-3 text-gray-400">{{ pnj.classType }}</td>
                    <td class="px-4 py-3 text-gray-400">{{ pnj.coordinates ?? '-' }}</td>
                    <td class="px-4 py-3 text-right">
                        <a href="{{ path('admin_map_pnj_move', {mapId: map.id, pnjId: pnj.id}) }}" class="text-blue-400 hover:text-blue-300 text-sm mr-3">Deplacer</a>
                        <a href="{{ path('admin_pnj_edit', {id: pnj.id}) }}" class="text-gray-400 hover:text-gray-300 text-sm">Editer PNJ</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% else %}
<p class="text-gray-500 mb-8">Aucun PNJ sur cette carte.</p>
{% endif %}

{# --- Portals Section --- #}
<div class="flex items-center justify-between mb-3">
    <h2 class="text-lg sm:text-xl font-bold">Portails</h2>
    <a href="{{ path('admin_map_portal_new', {id: map.id}) }}" class="bg-blue-600 hover:bg-blue-700 text-white px-3 py-1.5 rounded-lg text-sm transition-colors">+ Creer un portail</a>
</div>
{% if portals|length > 0 %}
<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-8">
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
            <thead class="border-b border-gray-800">
                <tr>
                    <th class="px-4 py-3 text-gray-400 font-medium">Nom</th>
                    <th class="px-4 py-3 text-gray-400 font-medium">Position</th>
                    <th class="px-4 py-3 text-gray-400 font-medium">Destination map</th>
                    <th class="px-4 py-3 text-gray-400 font-medium">Destination coords</th>
                    <th class="px-4 py-3 text-gray-400 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
                {% for portal in portals %}
                <tr class="hover:bg-gray-800 transition-colors">
                    <td class="px-4 py-3 text-gray-200">{{ portal.name }}</td>
                    <td class="px-4 py-3 text-gray-400">{{ portal.coordinates }}</td>
                    <td class="px-4 py-3 text-gray-400">{{ portal.destinationMapId ?? '-' }}</td>
                    <td class="px-4 py-3 text-gray-400">{{ portal.destinationCoordinates ?? '-' }}</td>
                    <td class="px-4 py-3 text-right">
                        <a href="{{ path('admin_map_portal_edit', {mapId: map.id, portalId: portal.id}) }}" class="text-blue-400 hover:text-blue-300 text-sm mr-3">Modifier</a>
                        <form method="post" action="{{ path('admin_map_portal_delete', {mapId: map.id, portalId: portal.id}) }}" class="inline" onsubmit="return confirm('Supprimer ce portail ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_portal' ~ portal.id) }}">
                            <button type="submit" class="text-red-400 hover:text-red-300 text-sm">Supprimer</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% else %}
<p class="text-gray-500 mb-8">Aucun portail sur cette carte.</p>
{% endif %}

{# --- Players Section --- #}
{% if players|length > 0 %}
<h2 class="text-lg sm:text-xl font-bold mb-3">Joueurs sur la carte</h2>
<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-8">
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
            <thead class="border-b border-gray-800">
                <tr>
                    <th class="px-4 py-3 text-gray-400 font-medium">Nom</th>
                    <th class="px-4 py-3 text-gray-400 font-medium">Position</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
                {% for player in players %}
                <tr class="hover:bg-gray-800 transition-colors">
                    <td class="px-4 py-3 text-gray-200">{{ player.name }}</td>
                    <td class="px-4 py-3 text-gray-400">{{ player.coordinates ?? '-' }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}

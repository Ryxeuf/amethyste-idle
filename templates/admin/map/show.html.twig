{% extends 'admin/base.html.twig' %}

{% block title %}{{ map.name }} - Admin{% endblock %}
{% block page_title %}{{ map.name }}{% endblock %}

{% block body %}
<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-6">
    <h1 class="text-2xl font-bold">{{ map.name }}</h1>
    <a href="{{ path('admin_map_index') }}" class="text-gray-400 hover:text-white">Retour</a>
</div>

<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 mb-8">
    <div class="bg-gray-800 rounded-lg p-4">
        <h3 class="text-sm text-gray-400 mb-1">Joueurs</h3>
        <p class="text-2xl font-bold text-purple-400">{{ players|length }}</p>
    </div>
    <div class="bg-gray-800 rounded-lg p-4">
        <h3 class="text-sm text-gray-400 mb-1">Mobs</h3>
        <p class="text-2xl font-bold text-red-400">{{ mobs|length }}</p>
    </div>
    <div class="bg-gray-800 rounded-lg p-4">
        <h3 class="text-sm text-gray-400 mb-1">PNJ</h3>
        <p class="text-2xl font-bold text-green-400">{{ pnjs|length }}</p>
    </div>
</div>

{% if players|length > 0 %}
<h2 class="text-xl font-bold mb-3">Joueurs sur la carte</h2>
<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-8">
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
            <thead class="border-b border-gray-800">
                <tr>
                    <th class="px-4 py-3 text-gray-400 font-medium">Nom</th>
                    <th class="px-4 py-3 text-gray-400 font-medium">Position</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
                {% for player in players %}
                <tr class="hover:bg-gray-800 transition-colors">
                    <td class="px-4 py-3 text-gray-200">{{ player.name }}</td>
                    <td class="px-4 py-3 text-gray-400">{{ player.coordinates ?? '-' }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{% if mobs|length > 0 %}
<h2 class="text-xl font-bold mb-3">Mobs sur la carte</h2>
<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-8">
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
            <thead class="border-b border-gray-800">
                <tr>
                    <th class="px-4 py-3 text-gray-400 font-medium">Monstre</th>
                    <th class="px-4 py-3 text-gray-400 font-medium">Position</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
                {% for mob in mobs %}
                <tr class="hover:bg-gray-800 transition-colors">
                    <td class="px-4 py-3 text-gray-200">{{ mob.monster ? mob.monster.name : '-' }}</td>
                    <td class="px-4 py-3 text-gray-400">{{ mob.coordinates ?? '-' }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{% if pnjs|length > 0 %}
<h2 class="text-xl font-bold mb-3">PNJ sur la carte</h2>
<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
            <thead class="border-b border-gray-800">
                <tr>
                    <th class="px-4 py-3 text-gray-400 font-medium">Nom</th>
                    <th class="px-4 py-3 text-gray-400 font-medium">Position</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
                {% for pnj in pnjs %}
                <tr class="hover:bg-gray-800 transition-colors">
                    <td class="px-4 py-3 text-gray-200">{{ pnj.name }}</td>
                    <td class="px-4 py-3 text-gray-400">{{ pnj.coordinates ?? '-' }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}

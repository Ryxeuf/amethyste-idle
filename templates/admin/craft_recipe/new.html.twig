{% extends 'admin/base.html.twig' %}

{% block title %}Nouvelle recette - Admin{% endblock %}
{% block page_title %}Nouvelle recette de craft{% endblock %}

{% block body %}
    <div class="max-w-3xl">
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
            {{ form_start(form) }}
                {% include 'admin/craft_recipe/_form.html.twig' %}
                <div class="flex items-center gap-4 mt-6 pt-6 border-t border-gray-800">
                    <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition-colors">Creer</button>
                    <a href="{{ path('admin_craft_recipe_index') }}" class="text-gray-400 hover:text-gray-300 text-sm">Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}

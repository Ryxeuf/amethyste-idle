{% extends 'admin/base.html.twig' %}

{% block title %}Hotel des ventes - Admin{% endblock %}
{% block page_title %}Hotel des ventes{% endblock %}

{% block body %}
    {# Key metrics #}
    <div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mb-8">
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wider">Annonces totales</p>
            <p class="text-2xl font-bold text-gray-100 mt-1">{{ stats.total_listings }}</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wider">Annonces actives</p>
            <p class="text-2xl font-bold text-green-400 mt-1">{{ stats.active_count }}</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wider">Ventes realisees</p>
            <p class="text-2xl font-bold text-blue-400 mt-1">{{ stats.total_sold }}</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wider">Volume total</p>
            <p class="text-2xl font-bold text-yellow-400 mt-1">{{ stats.total_volume|number_format(0, ',', ' ') }} G</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wider">Prix moyen</p>
            <p class="text-2xl font-bold text-purple-400 mt-1">{{ stats.avg_price|number_format(0, ',', ' ') }} G</p>
        </div>
    </div>

    {# Top items sold #}
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-gray-200 mb-4">Top items vendus</h2>
        {% if stats.top_items|length > 0 %}
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left">
                    <thead>
                        <tr class="text-gray-500 uppercase text-xs border-b border-gray-800">
                            <th class="py-3 px-4">#</th>
                            <th class="py-3 px-4">Item</th>
                            <th class="py-3 px-4 text-right">Ventes</th>
                            <th class="py-3 px-4 text-right">Prix moyen</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in stats.top_items %}
                            <tr class="border-b border-gray-800/50 hover:bg-gray-800/30">
                                <td class="py-2 px-4 text-gray-500">{{ loop.index }}</td>
                                <td class="py-2 px-4 text-gray-200">{{ item.name }}</td>
                                <td class="py-2 px-4 text-right text-gray-300">{{ item.sold_count }}</td>
                                <td class="py-2 px-4 text-right text-yellow-400">{{ item.avg_price|number_format(0, ',', ' ') }} G</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <p class="text-gray-500 text-sm">Aucune vente enregistree pour le moment.</p>
        {% endif %}
    </div>
{% endblock %}

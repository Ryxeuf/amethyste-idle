<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Admin - Amethyste{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">
        <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
        {% block stylesheets %}
            {# styles/app.css est charge via importmap + assets/app.js #}
        {% endblock %}
        {% block javascripts %}{% endblock %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    </head>
    <body class="bg-gray-950 text-gray-200 min-h-screen">
        <div class="flex min-h-screen" data-controller="admin-sidebar">
            {# Mobile overlay #}
            <div data-admin-sidebar-target="overlay"
                 data-action="click->admin-sidebar#close"
                 class="hidden fixed inset-0 bg-black bg-opacity-50 z-40 lg:hidden"></div>

            {# Sidebar #}
            <aside data-admin-sidebar-target="sidebar"
                   class="fixed inset-y-0 left-0 z-50 w-64 bg-gray-900 border-r border-gray-800 flex flex-col flex-shrink-0 transform -translate-x-full transition-transform duration-200 ease-in-out lg:relative lg:translate-x-0">
                <div class="p-4 border-b border-gray-800 flex items-center justify-between">
                    <div>
                        <a href="{{ path('admin_dashboard') }}" class="text-purple-400 font-bold text-xl flex items-center gap-2">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
                            Admin Panel
                        </a>
                        {# Role badge #}
                        <div class="mt-2">
                            {% if is_granted('ROLE_SUPER_ADMIN') %}
                                <span class="inline-flex px-2 py-0.5 text-xs rounded-full bg-red-900 text-red-300">Super Admin</span>
                            {% elseif is_granted('ROLE_ADMIN') %}
                                <span class="inline-flex px-2 py-0.5 text-xs rounded-full bg-purple-900 text-purple-300">Admin</span>
                            {% elseif is_granted('ROLE_GAME_DESIGNER') %}
                                <span class="inline-flex px-2 py-0.5 text-xs rounded-full bg-blue-900 text-blue-300">Game Designer</span>
                            {% elseif is_granted('ROLE_WORLD_BUILDER') %}
                                <span class="inline-flex px-2 py-0.5 text-xs rounded-full bg-green-900 text-green-300">World Builder</span>
                            {% elseif is_granted('ROLE_MODERATOR') %}
                                <span class="inline-flex px-2 py-0.5 text-xs rounded-full bg-yellow-900 text-yellow-300">Moderateur</span>
                            {% endif %}
                        </div>
                    </div>
                    {# Close button (mobile) #}
                    <button data-action="admin-sidebar#close" class="lg:hidden p-1 text-gray-400 hover:text-gray-200">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                </div>
                <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
                    <a href="{{ path('admin_dashboard') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_dashboard' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                        Dashboard
                    </a>

                    {# Game Content - visible to Game Designers and above #}
                    {% if is_granted('ROLE_GAME_DESIGNER') %}
                        <div class="pt-4 pb-2">
                            <p class="px-3 text-xs font-semibold text-gray-600 uppercase tracking-wider">Contenu du jeu</p>
                        </div>

                        <a href="{{ path('admin_item_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_item' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                            Items
                        </a>
                        <a href="{{ path('admin_monster_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_monster' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            Monstres
                        </a>
                        <a href="{{ path('admin_spell_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_spell' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                            Sorts
                        </a>
                        <a href="{{ path('admin_skill_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_skill' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
                            Talents
                        </a>
                        <a href="{{ path('admin_domain_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_domain' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                            Domaines
                        </a>
                        <a href="{{ path('admin_quest_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_quest' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                            Quetes
                        </a>
                        <a href="{{ path('admin_pnj_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_pnj' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                            PNJs
                        </a>
                        <a href="{{ path('admin_loot_table_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_loot_table' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                            Tables de loot
                        </a>
                        <a href="{{ path('admin_roadmap_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_roadmap' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                            Roadmap
                        </a>
                    {% endif %}

                    {# World - visible to World Builders and above #}
                    {% if is_granted('ROLE_WORLD_BUILDER') %}
                        <div class="pt-4 pb-2">
                            <p class="px-3 text-xs font-semibold text-gray-600 uppercase tracking-wider">Monde</p>
                        </div>

                        <a href="{{ path('admin_map_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_map' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
                            Cartes
                        </a>
                        <a href="{{ path('admin_tileset_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_tileset' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>
                            Tilesets
                        </a>
                        <a href="{{ path('admin_harvest_respawn_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_harvest_respawn' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                            Respawn Recolte
                        </a>
                    {% endif %}

                    {# Players - visible to Moderators and above #}
                    {% if is_granted('ROLE_MODERATOR') %}
                        <div class="pt-4 pb-2">
                            <p class="px-3 text-xs font-semibold text-gray-600 uppercase tracking-wider">Joueurs</p>
                        </div>

                        <a href="{{ path('admin_player_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_player' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                            Joueurs
                        </a>
                        <a href="{{ path('admin_fight_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_fight' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                            Combats
                        </a>
                        <a href="{{ path('admin_chat_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_chat' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                            Chat
                        </a>
                        <a href="{{ path('admin_report_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_report' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
                            Signalements
                        </a>
                    {% endif %}

                    {# Users & Tools - visible to Admins only #}
                    {% if is_granted('ROLE_ADMIN') %}
                        <div class="pt-4 pb-2">
                            <p class="px-3 text-xs font-semibold text-gray-600 uppercase tracking-wider">Administration</p>
                        </div>

                        <a href="{{ path('admin_auction_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_auction' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
                            Hotel des ventes
                        </a>
                        <a href="{{ path('admin_user_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_user' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                            Utilisateurs
                        </a>
                        <a href="{{ path('admin_world_time_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_world_time' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                            Temps monde (UTC)
                        </a>
                        <a href="{{ path('admin_maintenance_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_maintenance' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            Maintenance
                        </a>
                        <a href="{{ path('admin_log_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_log' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                            Logs
                        </a>
                        <a href="{{ path('admin_mercure_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_mercure' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                            Mercure
                        </a>
                        <a href="{{ path('admin_feature_flag_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_feature_flag' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"/></svg>
                            Feature Flags
                        </a>
                        <a href="{{ path('admin_event_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_event' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            Evenements
                        </a>
                        <a href="{{ path('admin_console_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_console' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            Console
                        </a>
                        <a href="{{ path('admin_avatar_test_index') }}" data-action="click->admin-sidebar#close" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {% if app.request.attributes.get('_route') starts with 'admin_avatar_test' %}bg-purple-900 text-purple-200{% else %}text-gray-400 hover:bg-gray-800 hover:text-gray-200{% endif %} transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            Test Avatar
                        </a>
                    {% endif %}
                </nav>

                <div class="p-4 border-t border-gray-800">
                    <a href="{{ path('app_home') }}" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-gray-200 transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12"/></svg>
                        Retour au site
                    </a>
                </div>
            </aside>

            {# Main content #}
            <div class="flex-1 flex flex-col min-w-0">
                {# Top bar #}
                <header class="bg-gray-900 border-b border-gray-800 px-4 sm:px-6 py-4 flex items-center justify-between gap-4">
                    <div class="flex items-center gap-3 min-w-0">
                        {# Hamburger menu (mobile) #}
                        <button data-action="admin-sidebar#toggle" class="lg:hidden p-1.5 -ml-1.5 text-gray-400 hover:text-gray-200">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                        </button>
                        <h1 class="text-lg sm:text-xl font-semibold text-gray-100 truncate">{% block page_title %}Admin{% endblock %}</h1>
                    </div>
                    <div class="flex items-center gap-2 sm:gap-4 flex-shrink-0">
                        <span class="text-sm text-gray-400 hidden sm:inline">{{ app.user.username ?? app.user.email }}</span>
                        <a href="{{ path('app_logout') }}" class="text-sm text-gray-500 hover:text-gray-300">Deconnexion</a>
                    </div>
                </header>

                {# Flash messages #}
                <div class="px-4 sm:px-6 pt-4">
                    {% for type, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="mb-3 px-4 py-3 rounded-lg text-sm {% if type == 'success' %}bg-green-900 text-green-200 border border-green-800{% elseif type == 'error' %}bg-red-900 text-red-200 border border-red-800{% elseif type == 'warning' %}bg-yellow-900 text-yellow-200 border border-yellow-800{% else %}bg-blue-900 text-blue-200 border border-blue-800{% endif %}">
                                {{ message }}
                            </div>
                        {% endfor %}
                    {% endfor %}
                </div>

                {# Page content #}
                <main class="flex-1 p-4 sm:p-6">
                    {% block body %}{% endblock %}
                </main>
            </div>
        </div>
    </body>
</html>

{% extends 'admin/base.html.twig' %}

{% block title %}PNJs - Admin{% endblock %}
{% block page_title %}PNJs{% endblock %}

{% block body %}
    <div class="flex items-center justify-between mb-6">
        <form method="get" class="flex items-center gap-2">
            <input type="text" name="q" value="{{ search }}" placeholder="Rechercher un PNJ..."
                   class="bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:border-purple-500 w-64">
            <button type="submit" class="bg-gray-700 hover:bg-gray-600 text-gray-200 px-4 py-2 rounded-lg text-sm transition-colors">Rechercher</button>
            {% if search %}
                <a href="{{ path('admin_pnj_index') }}" class="text-gray-500 hover:text-gray-300 text-sm">Effacer</a>
            {% endif %}
        </form>
        <a href="{{ path('admin_pnj_new') }}" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">+ Nouveau PNJ</a>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-gray-800 text-gray-400">
                    <th class="text-left px-4 py-3 font-medium">ID</th>
                    <th class="text-left px-4 py-3 font-medium">Nom</th>
                    <th class="text-left px-4 py-3 font-medium">Type</th>
                    <th class="text-left px-4 py-3 font-medium">Carte</th>
                    <th class="text-left px-4 py-3 font-medium">Coordonnees</th>
                    <th class="text-left px-4 py-3 font-medium">Vie</th>
                    <th class="text-right px-4 py-3 font-medium">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
                {% for pnj in pnjs %}
                    <tr class="hover:bg-gray-800 transition-colors">
                        <td class="px-4 py-3 text-gray-500">{{ pnj.id }}</td>
                        <td class="px-4 py-3 text-gray-200 font-medium">{{ pnj.name }}</td>
                        <td class="px-4 py-3 text-gray-400">{{ pnj.classType }}</td>
                        <td class="px-4 py-3 text-gray-400">{{ pnj.map ? pnj.map.name : '-' }}</td>
                        <td class="px-4 py-3 text-gray-400">{{ pnj.coordinates }}</td>
                        <td class="px-4 py-3 text-gray-400">{{ pnj.life }}/{{ pnj.maxLife }}</td>
                        <td class="px-4 py-3 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a href="{{ path('admin_pnj_edit', {id: pnj.id}) }}" class="text-purple-400 hover:text-purple-300 text-sm">Modifier</a>
                                <form method="post" action="{{ path('admin_pnj_delete', {id: pnj.id}) }}" onsubmit="return confirm('Supprimer ce PNJ ?');" class="inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ pnj.id) }}">
                                    <button type="submit" class="text-red-400 hover:text-red-300 text-sm">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="px-4 py-8 text-center text-gray-500">Aucun PNJ trouve.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}

{% extends 'admin/base.html.twig' %}

{% block title %}Talents - Admin{% endblock %}
{% block page_title %}Talents{% endblock %}

{% block body %}
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-6">
        <form method="get" class="flex flex-wrap items-center gap-2 w-full sm:w-auto">
            <input type="text" name="q" value="{{ search }}" placeholder="Rechercher un talent..."
                   class="bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:border-purple-500 w-full sm:w-64">
            <button type="submit" class="bg-gray-700 hover:bg-gray-600 text-gray-200 px-4 py-2 rounded-lg text-sm transition-colors">Rechercher</button>
            {% if search %}
                <a href="{{ path('admin_skill_index') }}" class="text-gray-500 hover:text-gray-300 text-sm">Effacer</a>
            {% endif %}
        </form>
        <a href="{{ path('admin_skill_new') }}" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap">+ Nouveau talent</a>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-800 text-gray-400">
                        <th class="text-left px-4 py-3 font-medium">ID</th>
                        <th class="text-left px-4 py-3 font-medium">Titre</th>
                        <th class="text-left px-4 py-3 font-medium">Domaine</th>
                        <th class="text-left px-4 py-3 font-medium">Points requis</th>
                        <th class="text-left px-4 py-3 font-medium">Degats</th>
                        <th class="text-left px-4 py-3 font-medium">Vie</th>
                        <th class="text-right px-4 py-3 font-medium">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-800">
                    {% for skill in skills %}
                        <tr class="hover:bg-gray-800 transition-colors">
                            <td class="px-4 py-3 text-gray-500">{{ skill.id }}</td>
                            <td class="px-4 py-3 text-gray-200 font-medium whitespace-nowrap">{{ skill.title }}</td>
                            <td class="px-4 py-3 text-gray-400">{{ skill.domain.title ?? '-' }}</td>
                            <td class="px-4 py-3 text-gray-400">{{ skill.requiredPoints }}</td>
                            <td class="px-4 py-3 text-gray-400">{{ skill.damage }}</td>
                            <td class="px-4 py-3 text-gray-400">{{ skill.life }}</td>
                            <td class="px-4 py-3 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="{{ path('admin_skill_edit', {id: skill.id}) }}" class="text-purple-400 hover:text-purple-300 text-sm">Modifier</a>
                                    <form method="post" action="{{ path('admin_skill_delete', {id: skill.id}) }}" onsubmit="return confirm('Supprimer ce talent ?');" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ skill.id) }}">
                                        <button type="submit" class="text-red-400 hover:text-red-300 text-sm">Supprimer</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="px-4 py-8 text-center text-gray-500">Aucun talent trouve.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if totalPages is defined and totalPages > 1 %}
        {% include 'admin/_pagination.html.twig' %}
    {% endif %}
{% endblock %}

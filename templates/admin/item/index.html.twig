{% extends 'admin/base.html.twig' %}

{% block title %}Items - Admin{% endblock %}
{% block page_title %}Items{% endblock %}

{% block body %}
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-6">
        <form method="get" class="flex flex-wrap items-center gap-2 w-full sm:w-auto">
            <input type="text" name="q" value="{{ search }}" placeholder="Rechercher un item..."
                   class="bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:border-purple-500 w-full sm:w-64">
            <button type="submit" class="bg-gray-700 hover:bg-gray-600 text-gray-200 px-4 py-2 rounded-lg text-sm transition-colors">Rechercher</button>
            {% if search %}
                <a href="{{ path('admin_item_index') }}" class="text-gray-500 hover:text-gray-300 text-sm">Effacer</a>
            {% endif %}
        </form>
        <a href="{{ path('admin_item_new') }}" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap">+ Nouvel item</a>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-800 text-gray-400">
                        <th class="text-left px-4 py-3 font-medium">ID</th>
                        <th class="text-left px-4 py-3 font-medium">Nom</th>
                        <th class="text-left px-4 py-3 font-medium">Type</th>
                        <th class="text-left px-4 py-3 font-medium">Element</th>
                        <th class="text-left px-4 py-3 font-medium">Prix</th>
                        <th class="text-left px-4 py-3 font-medium">Niveau</th>
                        <th class="text-center px-4 py-3 font-medium">Slots M.</th>
                        <th class="text-right px-4 py-3 font-medium">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-800">
                    {% for item in items %}
                        <tr class="hover:bg-gray-800 transition-colors">
                            <td class="px-4 py-3 text-gray-500">{{ item.id }}</td>
                            <td class="px-4 py-3 text-gray-200 font-medium whitespace-nowrap">{{ item.name }}</td>
                            <td class="px-4 py-3">
                                <span class="inline-flex px-2 py-1 text-xs rounded-full {% if item.type == 'gear' %}bg-blue-900 text-blue-300{% elseif item.type == 'materia' %}bg-green-900 text-green-300{% else %}bg-gray-700 text-gray-300{% endif %}">
                                    {{ item.type }}
                                </span>
                            </td>
                            <td class="px-4 py-3 text-gray-400">{{ item.element.value }}</td>
                            <td class="px-4 py-3 text-gray-400">{{ item.price ?? '-' }}</td>
                            <td class="px-4 py-3 text-gray-400">{{ item.level ?? '-' }}</td>
                            <td class="px-4 py-3 text-center">
                                {% if item.type == 'gear' and item.materiaSlots > 0 %}
                                    {% set slot_config = item.materiaSlotConfig %}
                                    <div class="inline-flex items-center gap-1 flex-wrap justify-center" title="{{ item.materiaSlots }} slot{{ item.materiaSlots > 1 ? 's' : '' }} materia">
                                        {% for i in 0..(item.materiaSlots - 1) %}
                                            {% set slot_el = slot_config[i].element|default('none') %}
                                            {% set slot_colors = {
                                                'none':  { border: '#4b5563', bg: 'transparent',  shadow: 'none', style: 'dashed' },
                                                'fire':  { border: '#ef4444', bg: '#ef4444',       shadow: '0 0 4px rgba(239,68,68,0.6)', style: 'solid' },
                                                'water': { border: '#3b82f6', bg: '#3b82f6',       shadow: '0 0 4px rgba(59,130,246,0.6)', style: 'solid' },
                                                'earth': { border: '#f59e0b', bg: '#f59e0b',       shadow: '0 0 4px rgba(245,158,11,0.6)', style: 'solid' },
                                                'air':   { border: '#06b6d4', bg: '#06b6d4',       shadow: '0 0 4px rgba(6,182,212,0.6)', style: 'solid' },
                                                'light': { border: '#fde047', bg: '#fde047',       shadow: '0 0 4px rgba(253,224,71,0.6)', style: 'solid' },
                                                'dark':  { border: '#a78bfa', bg: '#a78bfa',       shadow: '0 0 4px rgba(167,139,250,0.6)', style: 'solid' },
                                                'metal': { border: '#9ca3af', bg: '#9ca3af',       shadow: '0 0 4px rgba(156,163,175,0.5)', style: 'solid' },
                                                'beast': { border: '#22c55e', bg: '#22c55e',       shadow: '0 0 4px rgba(34,197,94,0.6)', style: 'solid' }
                                            } %}
                                            {% set sc = slot_colors[slot_el]|default(slot_colors['none']) %}
                                            {% set is_linked = slot_config[i].linked|default(null) is not null %}
                                            <span
                                                class="inline-block w-3 h-3 rounded-full border"
                                                style="border-color: {{ sc.border }}; background-color: {{ sc.bg }}; box-shadow: {{ sc.shadow }}; border-style: {{ sc.style }}; {{ is_linked ? 'outline: 1.5px solid #22d3ee; outline-offset: 1px;' : '' }}"
                                            ></span>
                                        {% endfor %}
                                    </div>
                                {% elseif item.type == 'gear' %}
                                    <span class="text-gray-600 text-xs">0</span>
                                {% else %}
                                    <span class="text-gray-600">—</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="{{ path('admin_item_edit', {id: item.id}) }}" class="text-purple-400 hover:text-purple-300 text-sm">Modifier</a>
                                    <form method="post" action="{{ path('admin_item_delete', {id: item.id}) }}" onsubmit="return confirm('Supprimer cet item ?');" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                                        <button type="submit" class="text-red-400 hover:text-red-300 text-sm">Supprimer</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="8" class="px-4 py-8 text-center text-gray-500">Aucun item trouve.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if totalPages is defined and totalPages > 1 %}
        {% include 'admin/_pagination.html.twig' %}
    {% endif %}
{% endblock %}

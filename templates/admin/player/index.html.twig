{% extends 'admin/base.html.twig' %}

{% block title %}Joueurs ({{ total }}) - Admin{% endblock %}
{% block page_title %}Joueurs ({{ total }}){% endblock %}

{% block body %}
    <div class="mb-6">
        <form method="get" class="flex flex-wrap items-center gap-2 w-full sm:w-auto">
            <input type="text" name="q" value="{{ search }}" placeholder="Rechercher un joueur (nom, email)..."
                   class="bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:border-purple-500 w-full sm:w-80">
            <button type="submit" class="bg-gray-700 hover:bg-gray-600 text-gray-200 px-4 py-2 rounded-lg text-sm transition-colors">Rechercher</button>
            {% if search %}
                <a href="{{ path('admin_player_index') }}" class="text-gray-500 hover:text-gray-300 text-sm">Effacer</a>
            {% endif %}
        </form>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-800 text-gray-400">
                        <th class="text-left px-4 py-3 font-medium">ID</th>
                        <th class="text-left px-4 py-3 font-medium">Nom</th>
                        <th class="text-left px-4 py-3 font-medium">Utilisateur</th>
                        <th class="text-left px-4 py-3 font-medium">Carte</th>
                        <th class="text-left px-4 py-3 font-medium">Vie</th>
                        <th class="text-left px-4 py-3 font-medium">Gils</th>
                        <th class="text-left px-4 py-3 font-medium">Statut</th>
                        <th class="text-right px-4 py-3 font-medium">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-800">
                    {% for player in players %}
                        <tr class="hover:bg-gray-800 transition-colors">
                            <td class="px-4 py-3 text-gray-500">{{ player.id }}</td>
                            <td class="px-4 py-3 text-gray-200 font-medium whitespace-nowrap">{{ player.name }}</td>
                            <td class="px-4 py-3 text-gray-400">{{ player.user.username ?? player.user.email }}</td>
                            <td class="px-4 py-3 text-gray-400">{{ player.map ? player.map.name : '-' }}</td>
                            <td class="px-4 py-3 text-gray-400 whitespace-nowrap">{{ player.life }}/{{ player.maxLife }}</td>
                            <td class="px-4 py-3 text-yellow-400 whitespace-nowrap">{{ player.gils|number_format(0, ',', ' ') }}</td>
                            <td class="px-4 py-3">
                                {% if player.user.isBanned %}
                                    <span class="inline-flex px-2 py-1 text-xs rounded-full bg-red-900 text-red-300">Banni</span>
                                {% else %}
                                    <span class="inline-flex px-2 py-1 text-xs rounded-full bg-green-900 text-green-300">Actif</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3 text-right">
                                <a href="{{ path('admin_player_show', {id: player.id}) }}" class="text-purple-400 hover:text-purple-300 text-sm">Details</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="8" class="px-4 py-8 text-center text-gray-500">Aucun joueur trouve.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if totalPages > 1 %}
        {% include 'admin/_pagination.html.twig' %}
    {% endif %}
{% endblock %}

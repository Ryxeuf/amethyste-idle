{% extends 'admin/base.html.twig' %}

{% block title %}Joueur "{{ player.name }}" - Admin{% endblock %}
{% block page_title %}Joueur : {{ player.name }}{% endblock %}

{% block body %}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {# Player info card #}
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
            <h2 class="text-lg font-semibold text-gray-200 mb-4">Informations</h2>
            <dl class="space-y-3">
                <div class="flex justify-between">
                    <dt class="text-gray-500 text-sm">ID</dt>
                    <dd class="text-gray-200 text-sm">{{ player.id }}</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-gray-500 text-sm">Nom</dt>
                    <dd class="text-gray-200 text-sm font-medium">{{ player.name }}</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-gray-500 text-sm">Classe</dt>
                    <dd class="text-gray-200 text-sm">{{ player.classType }}</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-gray-500 text-sm">Utilisateur</dt>
                    <dd class="text-gray-200 text-sm">{{ player.user.username ?? player.user.email }}</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-gray-500 text-sm">Email</dt>
                    <dd class="text-gray-200 text-sm">{{ player.user.email }}</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-gray-500 text-sm">Statut</dt>
                    <dd>
                        {% if player.user.isBanned %}
                            <span class="inline-flex px-2 py-1 text-xs rounded-full bg-red-900 text-red-300">Banni</span>
                        {% else %}
                            <span class="inline-flex px-2 py-1 text-xs rounded-full bg-green-900 text-green-300">Actif</span>
                        {% endif %}
                    </dd>
                </div>
            </dl>
        </div>

        {# Stats card #}
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
            <h2 class="text-lg font-semibold text-gray-200 mb-4">Statistiques</h2>
            <dl class="space-y-3">
                <div class="flex justify-between">
                    <dt class="text-gray-500 text-sm">Vie</dt>
                    <dd class="text-gray-200 text-sm">{{ player.life }}/{{ player.maxLife }}</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-gray-500 text-sm">Energie</dt>
                    <dd class="text-gray-200 text-sm">{{ player.energy }}/{{ player.maxEnergy }}</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-gray-500 text-sm">Precision</dt>
                    <dd class="text-gray-200 text-sm">{{ player.hit }}</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-gray-500 text-sm">Vitesse</dt>
                    <dd class="text-gray-200 text-sm">{{ player.speed }}</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-gray-500 text-sm">Carte</dt>
                    <dd class="text-gray-200 text-sm">{{ player.map ? player.map.name : '-' }}</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-gray-500 text-sm">Position</dt>
                    <dd class="text-gray-200 text-sm">{{ player.coordinates }}</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-gray-500 text-sm">En mouvement</dt>
                    <dd class="text-gray-200 text-sm">{{ player.isMoving ? 'Oui' : 'Non' }}</dd>
                </div>
            </dl>
        </div>

        {# Inventory summary + Quests #}
        <div class="space-y-6">
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
                <h2 class="text-lg font-semibold text-gray-200 mb-4">Inventaire</h2>
                <p class="text-gray-400 text-sm">{{ player.inventories|length }} objet(s) en inventaire</p>
            </div>

            <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
                <h2 class="text-lg font-semibold text-gray-200 mb-4">Talents</h2>
                <p class="text-gray-400 text-sm">{{ player.skills|length }} talent(s) acquis</p>
            </div>
        </div>
    </div>

    {# Admin actions #}
    <div class="mt-6 bg-gray-900 border border-gray-800 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-gray-200 mb-4">Actions administrateur</h2>
        <div class="flex items-center gap-4">
            <form method="post" action="{{ path('admin_player_ban', {id: player.id}) }}" class="inline">
                <input type="hidden" name="_token" value="{{ csrf_token('ban' ~ player.id) }}">
                {% if player.user.isBanned %}
                    <button type="submit" class="bg-green-700 hover:bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors" onclick="return confirm('Debannir ce joueur ?');">
                        Debannir
                    </button>
                {% else %}
                    <button type="submit" class="bg-red-700 hover:bg-red-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors" onclick="return confirm('Bannir ce joueur ?');">
                        Bannir
                    </button>
                {% endif %}
            </form>

            <form method="post" action="{{ path('admin_player_reset_position', {id: player.id}) }}" class="inline">
                <input type="hidden" name="_token" value="{{ csrf_token('reset' ~ player.id) }}">
                <button type="submit" class="bg-yellow-700 hover:bg-yellow-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors" onclick="return confirm('Reinitialiser la position de ce joueur ?');">
                    Reinitialiser la position
                </button>
            </form>

            <a href="{{ path('admin_player_index') }}" class="text-gray-400 hover:text-gray-300 text-sm ml-auto">Retour a la liste</a>
        </div>
    </div>
{% endblock %}

{% extends 'admin/base.html.twig' %}

{% block title %}Deplacer {{ player.name }} - Admin{% endblock %}
{% block page_title %}Deplacer {{ player.name }}{% endblock %}

{% block body %}
<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-6">
    <h1 class="text-xl sm:text-2xl font-bold">Deplacer "{{ player.name }}" sur la carte</h1>
    <a href="{{ path('admin_player_show', {id: player.id}) }}" class="text-gray-400 hover:text-white text-sm">Retour fiche joueur</a>
</div>

{% if player.map %}
    <p class="text-gray-500 text-sm mb-4">
        Actuellement : {{ player.map.name }} — {{ player.coordinates }}
        {% if player.fight %}<span class="text-amber-500"> · En combat (#{{ player.fight.id }})</span>{% endif %}
    </p>
{% endif %}

<div
    class="flex flex-col xl:flex-row gap-8 items-start"
    data-controller="admin-player-move-preview"
    data-admin-player-move-preview-preview-url-value="{{ path('api_map_preview') }}"
    data-admin-player-move-preview-radius-value="5"
>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 w-full max-w-lg flex-shrink-0">
        {{ form_start(form) }}

        <div class="mb-4">
            {{ form_label(form.coordinates, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-1'}}) }}
            {{ form_widget(form.coordinates, { attr: (form.coordinates.vars.attr|default({}))|merge({
                'data-admin-player-move-preview-target': 'coordsInput',
            }) }) }}
            {{ form_errors(form.coordinates) }}
        </div>

        <div class="mb-6">
            {{ form_label(form.map, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-1'}}) }}
            {{ form_widget(form.map, { attr: (form.map.vars.attr|default({}))|merge({
                'data-admin-player-move-preview-target': 'mapSelect',
            }) }) }}
            {{ form_errors(form.map) }}
        </div>

        <div class="flex gap-3">
            <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg text-sm transition-colors">Deplacer</button>
            <a href="{{ path('admin_player_show', {id: player.id}) }}" class="bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded-lg text-sm transition-colors">Annuler</a>
        </div>

        {{ form_end(form) }}
    </div>

    <div class="w-full xl:flex-1 xl:max-w-none max-w-lg">
        <h2 class="text-sm font-semibold text-gray-300 mb-1">Apercu de la carte</h2>
        <p class="text-xs text-gray-500 mb-2">Rayon de 5 cases autour du point saisi ; le cadre jaune indique la case cible.</p>
        <p class="text-xs text-gray-400 mb-3 min-h-[1rem]" data-admin-player-move-preview-target="status"></p>
        <div class="rounded-xl overflow-hidden border border-gray-700 bg-gray-950 inline-block">
            <canvas
                data-admin-player-move-preview-target="canvas"
                class="block w-full max-w-full"
                width="264"
                height="264"
            ></canvas>
        </div>
    </div>
</div>
{% endblock %}

{% extends 'admin/base.html.twig' %}

{% block title %}Console — Admin{% endblock %}
{% block page_title %}Console Symfony{% endblock %}

{% block body %}
<div class="flex flex-col lg:flex-row gap-4 h-[calc(100vh-180px)] overflow-hidden">

    {# ===== Left: command list ===== #}
    <div class="lg:w-80 flex-shrink-0 flex flex-col bg-gray-900 border border-gray-800 rounded-xl overflow-hidden min-h-[200px] max-h-[40vh] lg:max-h-full">
        <div class="p-3 border-b border-gray-800">
            <input type="text" id="cmd-search" placeholder="Rechercher une commande..."
                   class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:ring-1 focus:ring-purple-500">
        </div>
        <div id="cmd-list" class="flex-1 overflow-y-auto p-2 space-y-3 text-sm">
            {% for ns, cmds in grouped %}
                <div data-ns="{{ ns }}">
                    <p class="px-2 py-1 text-xs font-semibold text-gray-500 uppercase tracking-wider sticky top-0 bg-gray-900">{{ ns }}</p>
                    {% for cmd in cmds %}
                        <button data-cmd="{{ cmd.name }}"
                                class="cmd-btn w-full text-left px-2 py-1.5 rounded-lg text-gray-400 hover:bg-gray-800 hover:text-gray-200 transition-colors truncate"
                                title="{{ cmd.description }}">
                            <span class="text-purple-400">{{ cmd.name }}</span>
                            {% if cmd.description %}<span class="text-gray-600 text-xs ml-1">— {{ cmd.description|length > 40 ? cmd.description[:40] ~ '...' : cmd.description }}</span>{% endif %}
                        </button>
                    {% endfor %}
                </div>
            {% endfor %}
        </div>
    </div>

    {# ===== Right: detail & execution ===== #}
    <div class="flex-1 flex flex-col gap-4 min-w-0 lg:sticky lg:top-[72px] lg:self-start lg:max-h-[calc(100vh-180px)]">

        {# Command detail panel #}
        <div id="detail-panel" class="bg-gray-900 border border-gray-800 rounded-xl p-4 hidden overflow-y-auto max-h-[40vh] lg:max-h-[50vh]">
            <div class="flex items-center justify-between mb-3">
                <div>
                    <h2 id="cmd-title" class="text-lg font-bold text-purple-400"></h2>
                    <p id="cmd-desc" class="text-sm text-gray-400 mt-0.5"></p>
                </div>
                <button id="run-btn"
                        class="px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    Executer
                </button>
            </div>

            {# Arguments #}
            <div id="args-section" class="hidden mb-3">
                <h3 class="text-xs font-semibold text-gray-500 uppercase mb-2">Arguments</h3>
                <div id="args-container" class="space-y-2"></div>
            </div>

            {# Options #}
            <div id="opts-section" class="hidden mb-3">
                <h3 class="text-xs font-semibold text-gray-500 uppercase mb-2">Options</h3>
                <div id="opts-container" class="space-y-2"></div>
            </div>
        </div>

        {# Empty state #}
        <div id="empty-state" class="flex-1 flex items-center justify-center bg-gray-900 border border-gray-800 rounded-xl">
            <p class="text-gray-600 text-sm">Selectionnez une commande dans la liste</p>
        </div>

        {# Output panel #}
        <div id="output-panel" class="flex-1 bg-gray-950 border border-gray-800 rounded-xl overflow-hidden flex flex-col hidden">
            <div class="flex items-center justify-between px-4 py-2 border-b border-gray-800 bg-gray-900">
                <span class="text-xs text-gray-500 uppercase font-semibold">Sortie</span>
                <div class="flex items-center gap-2">
                    <span id="exit-badge" class="hidden px-2 py-0.5 rounded text-xs font-medium"></span>
                    <button id="clear-output" class="text-xs text-gray-500 hover:text-gray-300">Effacer</button>
                </div>
            </div>
            <pre id="output-content" class="flex-1 overflow-auto p-4 text-sm text-gray-300 font-mono whitespace-pre-wrap"></pre>
        </div>
    </div>
</div>

<script>
(function() {
    const detailUrl = '{{ path("admin_console_detail", {commandName: "__CMD__"}) }}'
    const runUrl = '{{ path("admin_console_run") }}'

    const searchInput = document.getElementById('cmd-search')
    const cmdButtons = document.querySelectorAll('.cmd-btn')
    const detailPanel = document.getElementById('detail-panel')
    const emptyState = document.getElementById('empty-state')
    const outputPanel = document.getElementById('output-panel')
    const outputContent = document.getElementById('output-content')
    const exitBadge = document.getElementById('exit-badge')
    const runBtn = document.getElementById('run-btn')
    const cmdTitle = document.getElementById('cmd-title')
    const cmdDesc = document.getElementById('cmd-desc')
    const argsSection = document.getElementById('args-section')
    const argsContainer = document.getElementById('args-container')
    const optsSection = document.getElementById('opts-section')
    const optsContainer = document.getElementById('opts-container')

    let currentCommand = null
    let currentDetail = null

    // Search filter
    searchInput.addEventListener('input', () => {
        const q = searchInput.value.toLowerCase()
        cmdButtons.forEach(btn => {
            const match = btn.dataset.cmd.toLowerCase().includes(q) || btn.title.toLowerCase().includes(q)
            btn.classList.toggle('hidden', !match)
        })
        // Hide empty namespace headers
        document.querySelectorAll('[data-ns]').forEach(group => {
            const visible = group.querySelectorAll('.cmd-btn:not(.hidden)')
            group.classList.toggle('hidden', visible.length === 0)
        })
    })

    // Command selection
    cmdButtons.forEach(btn => {
        btn.addEventListener('click', async () => {
            const name = btn.dataset.cmd
            currentCommand = name

            // Highlight active
            cmdButtons.forEach(b => b.classList.remove('bg-gray-800', 'text-gray-200'))
            btn.classList.add('bg-gray-800', 'text-gray-200')

            // Fetch detail
            const url = detailUrl.replace('__CMD__', name)
            const res = await fetch(url)
            const data = await res.json()
            if (data.error) return

            currentDetail = data
            cmdTitle.textContent = data.name
            cmdDesc.textContent = data.description

            // Build argument fields
            argsContainer.innerHTML = ''
            if (data.arguments.length > 0) {
                argsSection.classList.remove('hidden')
                for (const arg of data.arguments) {
                    if (arg.name === 'command') continue
                    const id = 'arg-' + arg.name
                    const required = arg.required ? '<span class="text-red-400">*</span>' : ''
                    argsContainer.innerHTML += `
                        <div class="flex items-center gap-2">
                            <label for="${id}" class="w-40 text-xs text-gray-400 truncate" title="${arg.description}">${arg.name} ${required}</label>
                            <input id="${id}" data-arg="${arg.name}" type="text" value="${arg.default ?? ''}"
                                   placeholder="${arg.description || arg.name}"
                                   class="flex-1 bg-gray-800 border border-gray-700 rounded px-2 py-1 text-sm text-gray-200 focus:outline-none focus:ring-1 focus:ring-purple-500">
                        </div>`
                }
            } else {
                argsSection.classList.add('hidden')
            }

            // Build option fields
            optsContainer.innerHTML = ''
            if (data.options.length > 0) {
                optsSection.classList.remove('hidden')
                for (const opt of data.options) {
                    const id = 'opt-' + opt.name
                    if (opt.acceptValue) {
                        const def = opt.default !== null && opt.default !== false ? opt.default : ''
                        optsContainer.innerHTML += `
                            <div class="flex items-center gap-2">
                                <label for="${id}" class="w-40 text-xs text-gray-400 truncate" title="${opt.description}">--${opt.name}${opt.shortcut ? ' (-' + opt.shortcut + ')' : ''}</label>
                                <input id="${id}" data-opt="${opt.name}" type="text" value="${def}"
                                       placeholder="${opt.description || opt.name}"
                                       class="flex-1 bg-gray-800 border border-gray-700 rounded px-2 py-1 text-sm text-gray-200 focus:outline-none focus:ring-1 focus:ring-purple-500">
                            </div>`
                    } else {
                        const checked = opt.default === true ? 'checked' : ''
                        optsContainer.innerHTML += `
                            <div class="flex items-center gap-2">
                                <label for="${id}" class="flex items-center gap-2 text-xs text-gray-400 cursor-pointer" title="${opt.description}">
                                    <input id="${id}" data-opt-flag="${opt.name}" type="checkbox" ${checked}
                                           class="rounded bg-gray-800 border-gray-700 text-purple-600 focus:ring-purple-500">
                                    --${opt.name}${opt.shortcut ? ' (-' + opt.shortcut + ')' : ''}
                                    <span class="text-gray-600">${opt.description}</span>
                                </label>
                            </div>`
                    }
                }
            } else {
                optsSection.classList.add('hidden')
            }

            detailPanel.classList.remove('hidden')
            emptyState.classList.add('hidden')
        })
    })

    // Run command
    runBtn.addEventListener('click', async () => {
        if (!currentCommand) return

        // Collect arguments
        const args = {}
        argsContainer.querySelectorAll('[data-arg]').forEach(input => {
            if (input.value) args[input.dataset.arg] = input.value
        })

        // Collect options
        const opts = {}
        optsContainer.querySelectorAll('[data-opt]').forEach(input => {
            if (input.value) opts[input.dataset.opt] = input.value
        })
        optsContainer.querySelectorAll('[data-opt-flag]').forEach(input => {
            if (input.checked) opts[input.dataset.optFlag] = true
        })

        // Show output panel
        outputPanel.classList.remove('hidden')
        outputContent.textContent = 'Execution en cours...\n'
        exitBadge.classList.add('hidden')
        runBtn.disabled = true
        runBtn.querySelector('svg').classList.add('animate-spin')

        try {
            const res = await fetch(runUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ command: currentCommand, arguments: args, options: opts }),
            })
            const data = await res.json()

            if (data.error) {
                outputContent.textContent = 'ERREUR: ' + data.error + '\n'
                exitBadge.textContent = 'Erreur'
                exitBadge.className = 'px-2 py-0.5 rounded text-xs font-medium bg-red-900 text-red-300'
            } else {
                outputContent.textContent = data.output || '(aucune sortie)\n'
                exitBadge.textContent = data.exitCode === 0 ? 'OK (0)' : 'Exit ' + data.exitCode
                exitBadge.className = data.exitCode === 0
                    ? 'px-2 py-0.5 rounded text-xs font-medium bg-green-900 text-green-300'
                    : 'px-2 py-0.5 rounded text-xs font-medium bg-red-900 text-red-300'
            }
            exitBadge.classList.remove('hidden')
        } catch (err) {
            outputContent.textContent = 'Erreur reseau: ' + err.message + '\n'
        }

        runBtn.disabled = false
        runBtn.querySelector('svg').classList.remove('animate-spin')
        // Scroll to bottom
        outputContent.scrollTop = outputContent.scrollHeight
    })

    // Clear output
    document.getElementById('clear-output').addEventListener('click', () => {
        outputContent.textContent = ''
        exitBadge.classList.add('hidden')
    })
})()
</script>
{% endblock %}

{% extends 'admin/base.html.twig' %}

{% block title %}Domaines - Admin{% endblock %}
{% block page_title %}Domaines{% endblock %}

{% block body %}
    <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-between gap-3 mb-6">
        <form method="get" class="flex items-center gap-2 flex-wrap">
            <input type="text" name="q" value="{{ search }}" placeholder="Rechercher un domaine..."
                   class="bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:border-purple-500 w-full sm:w-64">
            <button type="submit" class="bg-gray-700 hover:bg-gray-600 text-gray-200 px-4 py-2 rounded-lg text-sm transition-colors">Rechercher</button>
            {% if search %}
                <a href="{{ path('admin_domain_index') }}" class="text-gray-500 hover:text-gray-300 text-sm">Effacer</a>
            {% endif %}
        </form>
        <a href="{{ path('admin_domain_new') }}" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors text-center flex-shrink-0">+ Nouveau domaine</a>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-gray-800 text-gray-400">
                    <th class="text-left px-4 py-3 font-medium">ID</th>
                    <th class="text-left px-4 py-3 font-medium">Titre</th>
                    <th class="text-left px-4 py-3 font-medium">Talents</th>
                    <th class="text-left px-4 py-3 font-medium">Random Seed</th>
                    <th class="text-left px-4 py-3 font-medium">Hauteur graphe</th>
                    <th class="text-right px-4 py-3 font-medium">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
                {% for domain in domains %}
                    <tr class="hover:bg-gray-800 transition-colors">
                        <td class="px-4 py-3 text-gray-500">{{ domain.id }}</td>
                        <td class="px-4 py-3 text-gray-200 font-medium">{{ domain.title }}</td>
                        <td class="px-4 py-3 text-gray-400">{{ domain.skills|length }}</td>
                        <td class="px-4 py-3 text-gray-400">{{ domain.randomSeed }}</td>
                        <td class="px-4 py-3 text-gray-400">{{ domain.graphHeight }}</td>
                        <td class="px-4 py-3 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a href="{{ path('admin_domain_edit', {id: domain.id}) }}" class="text-purple-400 hover:text-purple-300 text-sm">Modifier</a>
                                <form method="post" action="{{ path('admin_domain_delete', {id: domain.id}) }}" onsubmit="return confirm('Supprimer ce domaine ?');" class="inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ domain.id) }}">
                                    <button type="submit" class="text-red-400 hover:text-red-300 text-sm">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="px-4 py-8 text-center text-gray-500">Aucun domaine trouve.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% if totalPages is defined and totalPages > 1 %}
        {% include 'admin/_pagination.html.twig' %}
    {% endif %}
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}{{ 'home.title'|trans }}{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-bold text-white mb-6">{{ 'home.welcome'|trans }}</h1>
    
    {% if app.user %}
        <div class="bg-green-800 bg-opacity-50 border border-green-700 rounded-lg p-4 mb-6">
            <p class="text-green-200 mb-3">{{ 'home.logged_in_as'|trans({'%username%': app.user.username}) }}</p>
            <div class="flex space-x-3">
                <a href="{{ path('app_logout') }}" class="px-3 py-2 bg-red-600 hover:bg-red-700 text-white rounded-md text-sm transition-colors shadow-md">{{ 'home.logout'|trans }}</a>
                <a href="{{ path('app_game') }}" class="px-3 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-md text-sm transition-colors shadow-md">{{ 'home.access_game'|trans }}</a>
            </div>
        </div>
    {% else %}
        <div class="bg-blue-900 bg-opacity-50 border border-blue-800 rounded-lg p-4 mb-6">
            <p class="text-blue-200 mb-3">{{ 'home.not_logged_in'|trans }}</p>
            <div class="flex space-x-3">
                <a href="{{ path('app_login') }}" class="px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md text-sm transition-colors shadow-md">{{ 'home.login'|trans }}</a>
                <a href="{{ path('app_register') }}" class="px-3 py-2 bg-green-600 hover:bg-green-700 text-white rounded-md text-sm transition-colors shadow-md">{{ 'home.register'|trans }}</a>
            </div>
        </div>
    {% endif %}
    
    <div class="mt-8">
        <h2 class="text-2xl font-bold text-purple-400 mb-3">{{ 'home.content.title'|trans }}</h2>
        <p class="text-gray-300">{{ 'home.content.description'|trans }}</p>
    </div>
</div>
{% endblock %} 
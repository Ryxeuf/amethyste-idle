<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1">
        <meta name="theme-color" content="#111827">
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
        <title>{% block title %}{{ 'base.title'|trans }}{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">
        <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
        {% block stylesheets %}
            {# styles/app.css est charge via importmap + assets/app.js (import './styles/app.css') #}
        {% endblock %}
        {% block javascripts %}{% endblock %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    </head>
    <body class="bg-gray-900 text-white min-h-screen antialiased" data-controller="sound"{% if mercure_url is defined and mercure_url %} data-mercure-url="{{ mercure_url }}"{% endif %}>
    {% block site_navbar %}
        <nav class="bg-gray-800 border-b border-purple-900">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between h-14">
                    <div class="flex items-center">
                        <div class="flex-shrink-0">
                            <a href="{{ path('app_home') }}" class="text-purple-500 font-bold text-xl">{{ 'base.site_name'|trans }}</a>
                        </div>
                        <div class="hidden md:block">
                            <div class="ml-10 flex items-baseline space-x-4">
                                <a href="{{ path('app_home') }}" class="text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium">{{ 'base.nav.home'|trans }}</a>
                                {% if app.user %}
                                <a href="{{ path('app_game') }}" class="text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium">{{ 'base.nav.game_area'|trans }}</a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    <div class="hidden md:block">
                        <div class="ml-4 flex items-center md:ml-6">
                            <div class="relative ml-3 group">
                                <button type="button" class="flex items-center max-w-xs text-sm rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-gray-800 focus:ring-white">
                                    {% if app.request.locale == 'fr' %}
                                        <span class="flag-icon flag-icon-fr mr-2"></span>
                                    {% else %}
                                        <span class="flag-icon flag-icon-en mr-2"></span>
                                    {% endif %}
                                    <span>{{ 'base.language.select'|trans }}</span>
                                    <svg class="ml-1 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                                    </svg>
                                </button>
                                <div class="hidden group-hover:block absolute right-0 z-10 mt-2 w-48 origin-top-right rounded-md bg-white py-1 shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none">
                                    <a href="{{ path('app_change_locale', {'locale': 'fr'}) }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                                        <span class="flag-icon flag-icon-fr mr-2"></span>
                                        {{ 'base.language.fr'|trans }}
                                    </a>
                                    <a href="{{ path('app_change_locale', {'locale': 'en'}) }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                                        <span class="flag-icon flag-icon-en mr-2"></span>
                                        {{ 'base.language.en'|trans }}
                                    </a>
                                </div>
                            </div>

                            {% if app.user %}
                                <div class="ml-4 flex items-center">
                                    <span class="text-gray-300 text-sm font-medium mr-3">{{ app.user.username }}</span>
                                    <a href="{{ path('app_logout') }}" class="text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium">{{ 'base.nav.logout'|trans }}</a>
                                </div>
                            {% else %}
                                <div class="ml-4 flex items-center space-x-2">
                                    <a href="{{ path('app_login') }}" class="text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium">{{ 'base.nav.login'|trans }}</a>
                                    <a href="{{ path('app_register') }}" class="bg-purple-600 hover:bg-purple-700 text-white px-3 py-2 rounded-md text-sm font-medium">{{ 'base.nav.register'|trans }}</a>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                    <div class="-mr-2 flex md:hidden">
                        <button type="button" class="mobile-menu-button bg-gray-800 inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-white hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-gray-800 focus:ring-white">
                            <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Mobile menu -->
            <div class="mobile-menu hidden md:hidden">
                <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
                    <a href="{{ path('app_home') }}" class="text-gray-300 hover:bg-gray-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium">{{ 'base.nav.home'|trans }}</a>
                    {% if app.user %}
                    <a href="{{ path('app_game') }}" class="text-gray-300 hover:bg-gray-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium">{{ 'base.nav.game_area'|trans }}</a>
                    {% endif %}
                </div>
                <div class="pt-4 pb-3 border-t border-gray-700">
                    <div class="flex items-center px-5">
                        {% if app.user %}
                            <div class="ml-3">
                                <div class="text-base font-medium leading-none text-white">{{ app.user.username }}</div>
                            </div>
                        {% endif %}
                    </div>
                    <div class="mt-3 px-2 space-y-1">
                        <a href="{{ path('app_change_locale', {'locale': 'fr'}) }}" class="block px-3 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-gray-700">
                            <span class="flag-icon flag-icon-fr mr-2"></span>
                            {{ 'base.language.fr'|trans }}
                        </a>
                        <a href="{{ path('app_change_locale', {'locale': 'en'}) }}" class="block px-3 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-gray-700">
                            <span class="flag-icon flag-icon-en mr-2"></span>
                            {{ 'base.language.en'|trans }}
                        </a>
                        {% if app.user %}
                            <a href="{{ path('app_logout') }}" class="block px-3 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-gray-700">{{ 'base.nav.logout'|trans }}</a>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="block px-3 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-gray-700">{{ 'base.nav.login'|trans }}</a>
                            <a href="{{ path('app_register') }}" class="block px-3 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-gray-700">{{ 'base.nav.register'|trans }}</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </nav>
        {% endblock %}
        {% block body %}{% endblock %}

        <script>
            // Mobile menu toggle
            document.addEventListener('DOMContentLoaded', function() {
                const mobileMenuButton = document.querySelector('.mobile-menu-button');
                const mobileMenu = document.querySelector('.mobile-menu');

                if (mobileMenuButton && mobileMenu) {
                    mobileMenuButton.addEventListener('click', function() {
                        mobileMenu.classList.toggle('hidden');
                    });
                }
            });
        </script>
    </body>
</html>

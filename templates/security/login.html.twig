{% extends 'base.html.twig' %}

{% block title %}{{ 'security.title'|trans }}{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h1 class="h3 mb-3 font-weight-normal">{{ 'security.title'|trans }}</h1>
                </div>
                <div class="card-body">
                    <form method="post">
                        {% if error %}
                            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                        {% endif %}

                        {% if app.user %}
                            <div class="mb-3">
                                {{ 'security.logged_in_as'|trans({'%username%': app.user.userIdentifier}) }}, <a href="{{ path('app_logout') }}">{{ 'security.logout'|trans }}</a>
                            </div>
                        {% endif %}

                        <div class="mb-3">
                            <label for="inputEmail">{{ 'security.email'|trans }}</label>
                            <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" required autofocus>
                        </div>
                        <div class="mb-3">
                            <label for="inputPassword">{{ 'security.password'|trans }}</label>
                            <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" required>
                        </div>

                        <input type="hidden" name="_csrf_token"
                               value="{{ csrf_token('authenticate') }}"
                        >

                        <div class="checkbox mb-3">
                            <label>
                                <input type="checkbox" name="_remember_me"> {{ 'security.remember_me'|trans }}
                            </label>
                        </div>

                        <button class="btn btn-lg btn-primary" type="submit">
                            {{ 'security.login'|trans }}
                        </button>
                    </form>
                </div>
                <div class="card-footer text-center">
                    <p>{{ 'security.no_account'|trans }} <a href="{{ path('app_register') }}">{{ 'security.register_link'|trans }}</a></p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %} 
{% extends 'base.html.twig' %}

{% block title %}{{ 'security.title'|trans }}{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-[calc(100vh-4rem)] px-4 py-12">
    <div class="w-full max-w-md">
        <div class="bg-gray-800 rounded-2xl shadow-2xl border border-gray-700 overflow-hidden">
            <div class="px-8 pt-8 pb-4 text-center">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-purple-600 bg-opacity-20 mb-4">
                    <svg class="w-8 h-8 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                </div>
                <h1 class="text-2xl font-bold text-white">{{ 'security.title'|trans }}</h1>
                <p class="text-gray-400 text-sm mt-1">Entrez vos identifiants pour accéder au jeu</p>
            </div>

            <div class="px-8 pb-8">
                {% if error %}
                    <div class="mb-4 px-4 py-3 rounded-lg bg-red-900 bg-opacity-40 border border-red-700 text-red-300 text-sm flex items-start gap-2">
                        <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                        </svg>
                        <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                    </div>
                {% endif %}

                {% if app.user %}
                    <div class="mb-4 px-4 py-3 rounded-lg bg-purple-900 bg-opacity-30 border border-purple-700 text-purple-300 text-sm">
                        {{ 'security.logged_in_as'|trans({'%username%': app.user.userIdentifier}) }}
                        <a href="{{ path('app_logout') }}" class="text-purple-400 hover:text-purple-300 underline ml-1">{{ 'security.logout'|trans }}</a>
                    </div>
                {% endif %}

                {# Turbo intercepte le POST en fetch() : la session / le 302 de login peuvent échouer sans rechargement complet #}
                <form method="post" class="space-y-5" data-turbo="false">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <div>
                        <label for="inputEmail" class="block text-sm font-medium text-gray-300 mb-1.5">{{ 'security.email'|trans }}</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>
                            </div>
                            <input type="email" value="{{ last_username }}" name="email" id="inputEmail"
                                   class="w-full pl-10 pr-4 py-2.5 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition"
                                   placeholder="votre@email.com" autocomplete="email" required autofocus>
                        </div>
                    </div>

                    <div>
                        <label for="inputPassword" class="block text-sm font-medium text-gray-300 mb-1.5">{{ 'security.password'|trans }}</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                                </svg>
                            </div>
                            <input type="password" name="password" id="inputPassword"
                                   class="w-full pl-10 pr-4 py-2.5 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition"
                                   placeholder="••••••••" autocomplete="current-password" required>
                        </div>
                    </div>

                    <div class="flex items-center">
                        <input type="checkbox" name="_remember_me" id="rememberMe"
                               class="w-4 h-4 rounded bg-gray-700 border-gray-600 text-purple-500 focus:ring-purple-500 focus:ring-offset-gray-800">
                        <label for="rememberMe" class="ml-2 text-sm text-gray-300 cursor-pointer select-none">{{ 'security.remember_me'|trans }}</label>
                    </div>

                    <button type="submit"
                            class="w-full py-2.5 px-4 bg-purple-600 hover:bg-purple-700 active:bg-purple-800 text-white font-semibold rounded-lg shadow-lg shadow-purple-900/30 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 focus:ring-offset-gray-800">
                        {{ 'security.login'|trans }}
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>
{% endblock %} 
<div class="bg-gray-800 border border-gray-700 rounded-lg p-6">
    <p class="text-gray-400 text-sm mb-4">
        Combinez des ingrédients pour tenter de découvrir de nouvelles recettes alchimiques.
        Saisissez les slugs des items que vous souhaitez combiner.
    </p>

    <form id="experiment-form" class="space-y-4">
        <div id="ingredient-slots" class="space-y-2">
            <div class="flex items-center gap-2">
                <input type="text" name="item_slugs[]" placeholder="Slug de l'ingrédient (ex: herb-leaf)"
                       class="flex-1 bg-gray-700 border border-gray-600 text-white rounded-md px-3 py-2 text-sm focus:ring-purple-500 focus:border-purple-500">
                <button type="button" onclick="addIngredientSlot()"
                        class="bg-gray-600 hover:bg-gray-500 text-white px-3 py-2 rounded-md text-sm">
                    +
                </button>
            </div>
        </div>

        <button type="submit"
                class="bg-purple-600 hover:bg-purple-500 text-white px-6 py-2 rounded-md text-sm font-medium transition-colors">
            Expérimenter
        </button>
    </form>

    <div id="experiment-result" class="mt-4 hidden">
        <div class="p-3 rounded-md text-sm"></div>
    </div>
</div>

<script>
    function addIngredientSlot() {
        const container = document.getElementById('ingredient-slots');
        const div = document.createElement('div');
        div.className = 'flex items-center gap-2';
        div.innerHTML = `
            <input type="text" name="item_slugs[]" placeholder="Slug de l'ingrédient"
                   class="flex-1 bg-gray-700 border border-gray-600 text-white rounded-md px-3 py-2 text-sm focus:ring-purple-500 focus:border-purple-500">
            <button type="button" onclick="this.parentElement.remove()"
                    class="bg-red-700 hover:bg-red-600 text-white px-3 py-2 rounded-md text-sm">
                -
            </button>
        `;
        container.appendChild(div);
    }

    document.getElementById('experiment-form').addEventListener('submit', function(e) {
        e.preventDefault();
        const formData = new FormData(this);

        fetch('{{ path('app_game_craft_experiment') }}', {
            method: 'POST',
            headers: {
                'X-Requested-With': 'XMLHttpRequest',
            },
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            const resultDiv = document.getElementById('experiment-result');
            const inner = resultDiv.querySelector('div');
            resultDiv.classList.remove('hidden');

            if (data.success) {
                inner.className = 'p-3 rounded-md text-sm bg-green-900 border border-green-700 text-green-300';
                inner.textContent = data.message;
            } else {
                inner.className = 'p-3 rounded-md text-sm bg-yellow-900 border border-yellow-700 text-yellow-300';
                inner.textContent = data.message || data.error;
            }
        })
        .catch(() => {
            alert('Erreur de connexion.');
        });
    });
</script>

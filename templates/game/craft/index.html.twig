{% extends 'game/game.html.twig' %}

{% block game_content %}
<div class="max-w-7xl mx-auto px-4 py-6">
    <h1 class="text-2xl font-bold text-purple-400 mb-6">Artisanat</h1>

    {# Onglets professions #}
    <div class="flex flex-wrap gap-2 mb-6 border-b border-gray-700 pb-4">
        <a href="{{ path('app_game_craft') }}"
           class="px-4 py-2 rounded-md text-sm font-medium {% if activeProfession is not defined or activeProfession is null %}bg-purple-700 text-white{% else %}bg-gray-700 text-gray-300 hover:bg-gray-600 hover:text-white{% endif %}">
            Toutes
        </a>
        {% for key, label in professions %}
            <a href="{{ path('app_game_craft_profession', {profession: key}) }}"
               class="px-4 py-2 rounded-md text-sm font-medium {% if activeProfession is defined and activeProfession == key %}bg-purple-700 text-white{% else %}bg-gray-700 text-gray-300 hover:bg-gray-600 hover:text-white{% endif %}">
                {{ label }}
            </a>
        {% endfor %}
    </div>

    {# Liste des recettes #}
    {% if activeProfession is defined and activeProfession is not null %}
        {# Affichage par profession spécifique #}
        {% if recipes is defined and recipes|length > 0 %}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {% for recipe in recipes %}
                    {% include 'game/craft/_recipe_card.html.twig' with {
                        recipe: recipe,
                        canCraft: canCraft[recipe.id] ?? false,
                        hasIngredients: hasIngredients[recipe.id] ?? false
                    } %}
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center text-gray-400 py-12">
                <p class="text-lg">Aucune recette disponible pour cette profession.</p>
                <p class="text-sm mt-2">Découvrez de nouvelles recettes en progressant dans le jeu.</p>
            </div>
        {% endif %}
    {% else %}
        {# Affichage toutes professions #}
        {% for key, data in recipesByProfession %}
            {% if data.recipes|length > 0 %}
                <div class="mb-8">
                    <h2 class="text-xl font-semibold text-purple-300 mb-4">{{ data.label }}</h2>
                    {% include 'game/craft/_recipe_list.html.twig' with {
                        recipes: data.recipes,
                        canCraft: data.canCraft
                    } %}
                </div>
            {% endif %}
        {% endfor %}

        {% set hasAnyRecipe = false %}
        {% for key, data in recipesByProfession %}
            {% if data.recipes|length > 0 %}
                {% set hasAnyRecipe = true %}
            {% endif %}
        {% endfor %}

        {% if not hasAnyRecipe %}
            <div class="text-center text-gray-400 py-12">
                <p class="text-lg">Aucune recette disponible.</p>
                <p class="text-sm mt-2">Progressez dans le jeu pour débloquer des recettes d'artisanat.</p>
            </div>
        {% endif %}
    {% endif %}

    {# Section Expérimentation (alchimiste) #}
    <div class="mt-8 border-t border-gray-700 pt-6">
        <h2 class="text-xl font-semibold text-purple-300 mb-4">Expérimentation alchimique</h2>
        {% include 'game/craft/experiment.html.twig' %}
    </div>
</div>
{% endblock %}

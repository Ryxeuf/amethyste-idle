<div class="bg-gray-800 border border-gray-700 rounded-lg p-4 hover:border-purple-600 transition-colors">
    <div class="flex items-start justify-between mb-3">
        <div>
            <h3 class="text-lg font-semibold text-white">{{ recipe.name }}</h3>
            <p class="text-sm text-gray-400 mt-1">{{ recipe.description }}</p>
        </div>
        {% if recipe.requiredLevel > 1 %}
            <span class="text-xs bg-gray-700 text-gray-300 px-2 py-1 rounded-full ml-2 whitespace-nowrap">
                Niv. {{ recipe.requiredLevel }}
            </span>
        {% endif %}
    </div>

    {# Ingrédients #}
    <div class="mb-3">
        <h4 class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Ingrédients</h4>
        <div class="flex flex-wrap gap-2">
            {% for ingredient in recipe.ingredients %}
                <span class="inline-flex items-center px-2 py-1 rounded text-xs
                    {% if canCraft %}bg-green-900 text-green-300 border border-green-700{% else %}bg-red-900 text-red-300 border border-red-700{% endif %}">
                    {{ ingredient.item_slug|replace({'-': ' '})|capitalize }} x{{ ingredient.quantity ?? 1 }}
                </span>
            {% endfor %}
        </div>
    </div>

    {# Résultat #}
    <div class="mb-3">
        <h4 class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Résultat</h4>
        <span class="text-purple-300 font-medium">
            {{ recipe.resultItemSlug|replace({'-': ' '})|capitalize }}
            {% if recipe.resultQuantity > 1 %} x{{ recipe.resultQuantity }}{% endif %}
        </span>
    </div>

    {# Info craft #}
    <div class="flex items-center justify-between text-xs text-gray-500 mb-3">
        <span>Temps : {{ recipe.craftTime }}s</span>
        <span>+{{ recipe.experienceGain }} XP</span>
    </div>

    {# Bouton craft #}
    <button
        data-recipe-id="{{ recipe.id }}"
        class="craft-btn w-full py-2 px-4 rounded-md text-sm font-medium transition-colors
            {% if canCraft %}
                bg-purple-600 hover:bg-purple-500 text-white cursor-pointer
            {% else %}
                bg-gray-700 text-gray-500 cursor-not-allowed
            {% endif %}"
        {% if not canCraft %}disabled{% endif %}
        onclick="executeCraft({{ recipe.id }})">
        {% if canCraft %}
            Fabriquer
        {% else %}
            Conditions non remplies
        {% endif %}
    </button>
</div>

<script>
    function executeCraft(recipeId) {
        fetch('/game/craft/execute/' + recipeId, {
            method: 'POST',
            headers: {
                'X-Requested-With': 'XMLHttpRequest',
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                window.location.reload();
            } else {
                alert(data.error || 'Erreur lors de la fabrication.');
            }
        })
        .catch(() => alert('Erreur de connexion.'));
    }
</script>

{% extends 'game/game.html.twig' %}

{% block title %}Donjons{% endblock %}

{% block game_content %}
<div class="game-page">
    {% for message in app.flashes('success') %}
        <div class="mb-3 rounded-lg p-3 text-sm bg-green-900/50 border border-green-700 text-green-300">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="mb-3 rounded-lg p-3 text-sm bg-red-900/50 border border-red-700 text-red-300">{{ message }}</div>
    {% endfor %}

    {# Active run banner #}
    {% if activeRun %}
        <div class="game-card mb-4">
            <div class="game-card-body">
                <div class="flex items-center justify-between bg-purple-900/30 rounded-lg p-3 border border-purple-700/50">
                    <div>
                        <span class="text-purple-300 text-sm font-medium">Donjon en cours</span>
                        <p class="text-white text-xs mt-0.5">{{ activeRun.dungeon|localized_dungeon_name }} — <span class="{{ activeRun.difficulty.cssClass }}">{{ activeRun.difficulty.label }}</span></p>
                    </div>
                    <a href="{{ path('app_game_map') }}" class="px-3 py-1.5 bg-purple-600 hover:bg-purple-500 text-white text-xs rounded transition-colors">
                        Retourner au donjon
                    </a>
                </div>
            </div>
        </div>
    {% endif %}

    <div class="game-card">
        <div class="game-card-header flex items-center justify-between">
            <div>
                <h2 class="text-base sm:text-lg font-semibold text-white">Donjons</h2>
                <p class="text-gray-400 text-xs mt-0.5">Explorez des donjons instancies pour obtenir du loot rare</p>
            </div>
        </div>

        <div class="game-card-body">
            {% if dungeons is empty %}
                <div class="text-center py-8">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-gray-600 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                    </svg>
                    <p class="text-gray-500 text-sm">Aucun donjon disponible pour le moment</p>
                </div>
            {% else %}
                <div class="space-y-3">
                    {% for dungeon in dungeons %}
                        <a href="{{ path('app_game_dungeon_show', {slug: dungeon.slug}) }}"
                           class="block bg-gray-700/50 rounded-lg p-3 sm:p-4 border border-gray-600 hover:border-purple-600/50 transition-colors">
                            <div class="flex items-start justify-between gap-2">
                                <div class="min-w-0">
                                    <h3 class="text-white font-semibold text-sm sm:text-base">{{ dungeon|localized_dungeon_name }}</h3>
                                    <p class="text-gray-400 text-xs mt-0.5 line-clamp-2">{{ dungeon|localized_dungeon_description }}</p>
                                </div>
                                <div class="flex flex-col items-end gap-1 flex-shrink-0">
                                    <span class="px-1.5 py-0.5 bg-gray-800 border border-gray-700 text-gray-400 text-[10px] rounded">
                                        Niv. {{ dungeon.minLevel }}+
                                    </span>
                                    {% if dungeon.maxPlayers > 1 %}
                                        <span class="px-1.5 py-0.5 bg-blue-900/50 border border-blue-700 text-blue-300 text-[10px] rounded">
                                            {{ dungeon.maxPlayers }} joueurs
                                        </span>
                                    {% endif %}
                                </div>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% endif %}

            {# History #}
            {% if history is not empty %}
                <div class="mt-6 pt-4 border-t border-gray-700">
                    <h3 class="text-sm font-semibold text-gray-300 mb-3">Historique recent</h3>
                    <div class="space-y-1.5">
                        {% for run in history %}
                            <div class="flex items-center justify-between text-xs bg-gray-800/50 rounded px-3 py-2">
                                <div class="flex items-center gap-2">
                                    <span class="text-gray-300">{{ run.dungeon|localized_dungeon_name }}</span>
                                    <span class="{{ run.difficulty.cssClass }} text-[10px]">{{ run.difficulty.label }}</span>
                                </div>
                                <span class="text-gray-500">{{ run.completedAt|date('d/m H:i') }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% extends 'game/game.html.twig' %}

{% block title %}{{ dungeon|localized_dungeon_name }}{% endblock %}

{% block game_content %}
<div class="game-page">
    {% for message in app.flashes('success') %}
        <div class="mb-3 rounded-lg p-3 text-sm bg-green-900/50 border border-green-700 text-green-300">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="mb-3 rounded-lg p-3 text-sm bg-red-900/50 border border-red-700 text-red-300">{{ message }}</div>
    {% endfor %}

    <div class="game-card">
        <div class="game-card-header">
            <div class="flex items-center gap-2 mb-1">
                <a href="{{ path('app_game_dungeon_list') }}" class="text-gray-400 hover:text-gray-300 text-xs">&larr; {{ 'game.dungeon.back_link'|trans }}</a>
            </div>
            <h2 class="text-base sm:text-lg font-semibold text-white">{{ dungeon|localized_dungeon_name }}</h2>
            <p class="text-gray-400 text-xs mt-0.5">{{ dungeon|localized_dungeon_description }}</p>
        </div>

        <div class="game-card-body">
            {# Dungeon info #}
            <div class="flex flex-wrap gap-3 mb-4">
                <div class="bg-gray-700/50 rounded-lg px-3 py-2 border border-gray-600">
                    <span class="text-gray-500 text-[10px] block">{{ 'game.dungeon.info.min_level'|trans }}</span>
                    <span class="text-white text-sm font-medium">{{ dungeon.minLevel }}+</span>
                </div>
                <div class="bg-gray-700/50 rounded-lg px-3 py-2 border border-gray-600">
                    <span class="text-gray-500 text-[10px] block">{{ 'game.dungeon.info.max_players'|trans }}</span>
                    <span class="text-white text-sm font-medium">{{ dungeon.maxPlayers }}</span>
                </div>
            </div>

            {# Level requirement check #}
            {% if not meetsLevel %}
                <div class="mb-4 rounded-lg p-3 bg-red-900/30 border border-red-700/50">
                    <p class="text-red-300 text-xs">{{ 'game.dungeon.requirements.xp_insufficient'|trans({'%xp%': dungeon.minLevel * 100}) }}</p>
                </div>
            {% endif %}

            {# Entry requirements (items) #}
            {% if missingItems is not empty %}
                <div class="mb-4 rounded-lg p-3 bg-amber-900/30 border border-amber-700/50">
                    <p class="text-amber-300 text-xs font-semibold mb-1">{{ 'game.dungeon.requirements.missing_items_heading'|trans }}</p>
                    <ul class="text-amber-200 text-xs list-disc list-inside">
                        {% for itemName in missingItems %}
                            <li>{{ itemName }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

            {# Active run warning #}
            {% if activeRun %}
                <div class="mb-4 rounded-lg p-3 bg-yellow-900/30 border border-yellow-700/50">
                    <p class="text-yellow-300 text-xs">{{ 'game.dungeon.active_run.warning'|trans({'%name%': activeRun.dungeon|localized_dungeon_name}) }}</p>
                </div>
            {% endif %}

            {# Loot preview #}
            {% if dungeon.lootPreview is not null and dungeon.lootPreview is not empty %}
                <div class="mb-4">
                    <h3 class="text-sm font-semibold text-gray-300 mb-2">{{ 'game.dungeon.loot_preview_heading'|trans }}</h3>
                    <div class="flex flex-wrap gap-2">
                        {% for item in dungeon.lootPreview %}
                            <span class="px-2 py-1 bg-gray-800 border border-gray-700 text-gray-300 text-xs rounded">{{ item }}</span>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Difficulty selection #}
            <h3 class="text-sm font-semibold text-gray-300 mb-3">{{ 'game.dungeon.difficulty.heading'|trans }}</h3>
            <div class="space-y-2">
                {% for diff in difficulties %}
                    {% set cd = cooldowns[diff.value] %}
                    {% set canEnter = meetsLevel and activeRun is null and cd == 0 and missingItems is empty %}
                    <div class="bg-gray-700/50 rounded-lg p-3 border border-gray-600 {% if canEnter %}hover:border-purple-600/50{% endif %}">
                        <div class="flex items-center justify-between">
                            <div>
                                <span class="{{ diff.cssClass }} text-sm font-medium">{{ ('game.dungeon.difficulty.' ~ diff.value)|trans }}</span>
                                <div class="flex items-center gap-3 mt-1">
                                    <span class="text-gray-500 text-[10px]">{{ 'game.dungeon.difficulty.stat_multiplier'|trans({'%mult%': diff.statMultiplier}) }}</span>
                                    <span class="text-gray-500 text-[10px]">{{ 'game.dungeon.difficulty.cooldown'|trans({'%hours%': diff.cooldownSeconds // 3600}) }}</span>
                                </div>
                            </div>
                            <div>
                                {% if cd > 0 %}
                                    <span class="px-2 py-1 bg-gray-800 border border-gray-700 text-gray-500 text-xs rounded">
                                        {{ 'game.dungeon.difficulty.cooldown_badge'|trans }}
                                    </span>
                                {% elseif canEnter %}
                                    <form action="{{ path('app_game_dungeon_enter', {slug: dungeon.slug}) }}" method="post">
                                        <input type="hidden" name="difficulty" value="{{ diff.value }}">
                                        <button type="submit" class="px-3 py-1.5 bg-purple-600 hover:bg-purple-500 text-white text-xs rounded transition-colors touch-target">
                                            {{ 'game.dungeon.difficulty.enter'|trans }}
                                        </button>
                                    </form>
                                {% else %}
                                    <span class="px-2 py-1 bg-gray-800 border border-gray-700 text-gray-500 text-xs rounded">
                                        {{ 'game.dungeon.difficulty.unavailable'|trans }}
                                    </span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

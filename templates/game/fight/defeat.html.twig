{% extends 'game/game.html.twig' %}

{% block title %}{{ 'game.fight.defeat'|trans }}{% endblock %}

{% block site_navbar %}
	<header class="bg-gray-800/95 backdrop-blur-sm border-b border-red-900/30 sticky top-0 z-40">
		<div class="flex items-center justify-between h-11 px-3 md:px-6" style="padding-top: var(--safe-top)">
			<a href="{{ path('app_game') }}" class="text-purple-400 font-bold text-base">{{ 'game.title'|trans }}</a>
			<span class="text-sm text-red-400">{{ 'game.fight.defeat'|trans }}</span>
		</div>
	</header>
{% endblock %}

{% block game_content %}
	<div class="game-page min-h-screen bg-gradient-to-b from-gray-900 to-gray-800 flex items-center justify-center">
		<div class="max-w-md w-full mx-4">
			<div class="game-card p-6 sm:p-8 text-center">
				{# Icone de defaite #}
				<div class="inline-block p-4 bg-red-500/20 rounded-full mb-4">
					<svg class="w-16 h-16 text-red-500 mx-auto" fill="currentColor" viewBox="0 0 20 20">
						<path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-2 1-3 .5 1.5 1 2 1 3a3 3 0 01.12 1.62z" clip-rule="evenodd"/>
					</svg>
				</div>

				<h2 class="text-2xl font-bold text-red-400 mb-2">{{ 'game.fight.defeat'|trans }}</h2>
				<p class="text-gray-400 mb-6">{{ 'game.fight.defeat_description'|trans }}</p>

				{# Infos joueur respawn #}
				<div class="bg-gray-700/50 rounded-lg p-4 mb-6">
					<div class="flex items-center justify-between mb-2">
						<span class="text-sm text-gray-400">{{ 'game.fight.hp'|trans }}</span>
						<span class="text-sm font-bold text-white">{{ player.life }}/{{ player.maxLife }}</span>
					</div>
					<div class="w-full bg-gray-600 rounded-full h-2">
						<div class="bg-red-500 h-2 rounded-full" style="width: {{ (player.life / player.maxLife) * 100 }}%"></div>
					</div>
				</div>

				<a href="{{ path('app_game_map') }}" class="inline-block w-full px-6 py-3 bg-gradient-to-r from-purple-600 to-purple-700 text-white rounded-lg hover:from-purple-700 hover:to-purple-800 transition-all font-medium text-sm">
					{{ 'game.fight.return_to_map'|trans }}
				</a>
			</div>
		</div>
	</div>
{% endblock %}

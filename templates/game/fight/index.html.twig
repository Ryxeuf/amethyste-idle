{% extends 'game/game.html.twig' %}

{% block title %}{{ 'game.fight.title'|trans }}{% endblock %}

{% block site_navbar %}
	{# Minimal fight header #}
	<header class="bg-gray-800/95 backdrop-blur-sm border-b border-purple-900/30 sticky top-0 z-40">
		<div class="flex items-center justify-between h-11 px-3 md:px-6" style="padding-top: var(--safe-top)">
			<a href="{{ path('app_game') }}" class="text-purple-400 font-bold text-base">{{ 'game.title'|trans }}</a>
			<div class="flex items-center gap-2">
				<span class="text-xs text-gray-500">{{ 'game.fight.turn'|trans }} {{ fight.step }}</span>
				<span class="text-sm text-gray-400">{{ 'game.fight.title'|trans }}</span>
			</div>
		</div>
	</header>
{% endblock %}

{# Macro pour les badges de statut #}
{% macro status_effect_badges(effectsList) %}
	{% for fse in effectsList %}
		<span class="status-badge
			{% if fse.statusEffect.type == 'poison' %}bg-green-900/50 text-green-300 border-green-700
			{% elseif fse.statusEffect.type == 'burn' %}bg-orange-900/50 text-orange-300 border-orange-700
			{% elseif fse.statusEffect.type == 'freeze' %}bg-cyan-900/50 text-cyan-300 border-cyan-700
			{% elseif fse.statusEffect.type == 'paralysis' %}bg-yellow-900/50 text-yellow-300 border-yellow-700
			{% elseif fse.statusEffect.type == 'silence' %}bg-gray-700/50 text-gray-300 border-gray-600
			{% elseif fse.statusEffect.type == 'regeneration' %}bg-emerald-900/50 text-emerald-300 border-emerald-700
			{% elseif fse.statusEffect.type == 'shield' %}bg-blue-900/50 text-blue-300 border-blue-700
			{% elseif fse.statusEffect.type == 'berserk' %}bg-red-900/50 text-red-300 border-red-700
			{% else %}bg-purple-900/50 text-purple-300 border-purple-700
			{% endif %}
		" title="{{ fse.statusEffect.name }} ({{ fse.remainingTurns }} {{ 'game.fight.turns'|trans|default('tours') }})">
			{% if fse.statusEffect.icon %}
				<span class="mr-0.5">{{ fse.statusEffect.icon }}</span>
			{% endif %}
			{{ fse.statusEffect.name }}
			<span class="ml-0.5 opacity-75">{{ fse.remainingTurns }}t</span>
		</span>
	{% endfor %}
{% endmacro %}

{# Macro pour une icone de type de log #}
{% macro log_icon(type) %}
	{% if type == 'attack' or type == 'spell' %}
		<span class="text-red-400">&#9876;</span>
	{% elseif type == 'damage' %}
		<span class="text-red-500">&#10007;</span>
	{% elseif type == 'heal' or type == 'status_tick' %}
		<span class="text-green-400">&#10010;</span>
	{% elseif type == 'death' %}
		<span class="text-red-600">&#9760;</span>
	{% elseif type == 'miss' %}
		<span class="text-gray-500">&#8709;</span>
	{% elseif type == 'critical' %}
		<span class="text-yellow-400">&#9733;</span>
	{% elseif type == 'shield' %}
		<span class="text-blue-400">&#9711;</span>
	{% elseif type == 'status_apply' %}
		<span class="text-purple-400">&#10070;</span>
	{% elseif type == 'synergy' %}
		<span class="text-cyan-400">&#10024;</span>
	{% elseif type == 'resist' %}
		<span class="text-green-500">&#9650;</span>
	{% elseif type == 'flee' %}
		<span class="text-green-400">&#10132;</span>
	{% elseif type == 'flee_fail' %}
		<span class="text-red-400">&#10132;</span>
	{% elseif type == 'immobilized' %}
		<span class="text-yellow-500">&#9949;</span>
	{% elseif type == 'item' %}
		<span class="text-green-300">&#9753;</span>
	{% elseif type == 'victory' %}
		<span class="text-yellow-400">&#9812;</span>
	{% elseif type == 'defeat' %}
		<span class="text-red-600">&#9760;</span>
	{% elseif type == 'boss_phase' %}
		<span class="text-yellow-400">&#9888;</span>
	{% elseif type == 'fight_start' %}
		<span class="text-purple-400">&#9876;</span>
	{% else %}
		<span class="text-gray-400">&#8226;</span>
	{% endif %}
{% endmacro %}

{% block game_content %}
	<style>
		.selectable-target { cursor: pointer; transition: all 0.2s ease; }
		.selectable-target.selected { border-color: #f59e0b; box-shadow: 0 0 0 2px rgba(245, 158, 11, 0.5); }
		.selectable-target.disabled { opacity: 0.5; cursor: not-allowed; }
		.spell-on-cooldown { opacity: 0.5; pointer-events: none; }
		.spell-btn .cooldown-badge {
			position: absolute; top: -4px; right: -4px;
			background: #ef4444; color: white; border-radius: 50%;
			width: 18px; height: 18px; font-size: 10px;
			display: flex; align-items: center; justify-content: center;
		}
		/* Combat log styles */
		.combat-log-container {
			max-height: 200px;
			overflow-y: auto;
			scroll-behavior: smooth;
			scrollbar-width: thin;
			scrollbar-color: rgba(139, 92, 246, 0.3) transparent;
		}
		.combat-log-container::-webkit-scrollbar { width: 4px; }
		.combat-log-container::-webkit-scrollbar-track { background: transparent; }
		.combat-log-container::-webkit-scrollbar-thumb { background: rgba(139, 92, 246, 0.3); border-radius: 4px; }
		@media (min-width: 1024px) {
			.combat-log-container { max-height: 400px; }
		}
		/* Mobile combatants row */
		.fight-combatants-row {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0.5rem;
		}
		@media (min-width: 1024px) {
			.fight-combatants-row {
				gap: 1rem;
			}
		}
		/* Fight mobile layout */
		.fight-mobile-layout {
			display: flex;
			flex-direction: column;
			gap: 0.5rem;
		}
		@media (min-width: 1024px) {
			.fight-mobile-layout {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1rem;
			}
		}
		/* Tab active state */
		.fight-tab.active { color: #a78bfa; border-bottom-color: #a78bfa; }
		.fight-tab { color: #9ca3af; border-bottom-color: transparent; }
		/* Compact progress bar for mobile */
		.progress-bar-compact { height: 0.25rem; }
		/* Log entry animation */
		.log-entry { animation: logSlideIn 0.15s ease-out; }
		@keyframes logSlideIn {
			from { opacity: 0; transform: translateX(-4px); }
			to { opacity: 1; transform: translateX(0); }
		}
		/* Elemental flash overlay */
		.elemental-flash {
			position: fixed; inset: 0; pointer-events: none; z-index: 9998;
			animation: elementalFlash 0.35s ease-out forwards;
		}
		@keyframes elementalFlash {
			0% { opacity: 0.35; }
			100% { opacity: 0; }
		}
		/* Camera shake on critical */
		@keyframes combatShake {
			0%, 100% { transform: translateX(0) translateY(0); }
			10% { transform: translateX(-4px) translateY(2px); }
			20% { transform: translateX(3px) translateY(-3px); }
			30% { transform: translateX(-3px) translateY(1px); }
			40% { transform: translateX(2px) translateY(-2px); }
			50% { transform: translateX(-2px) translateY(2px); }
			60% { transform: translateX(3px) translateY(-1px); }
			70% { transform: translateX(-1px) translateY(1px); }
			80% { transform: translateX(1px) translateY(-1px); }
			90% { transform: translateX(-1px) translateY(0); }
		}
		.combat-shake { animation: combatShake 0.4s ease-out; }
		/* Target hit shake */
		@keyframes targetHitShake {
			0%, 100% { transform: translateX(0); }
			15% { transform: translateX(-3px); }
			30% { transform: translateX(3px); }
			45% { transform: translateX(-2px); }
			60% { transform: translateX(2px); }
			75% { transform: translateX(-1px); }
			90% { transform: translateX(1px); }
		}
		.target-hit-shake { animation: targetHitShake 0.3s ease-out; }
		/* Death fade */
		@keyframes deathFade {
			0% { opacity: 1; filter: saturate(1); }
			50% { opacity: 0.6; filter: saturate(0.3); }
			100% { opacity: 0.25; filter: saturate(0) brightness(0.7); }
		}
		.death-fade { animation: deathFade 0.8s ease-out forwards; }
	</style>

	<div class="game-page min-h-screen bg-gradient-to-b from-gray-900 to-gray-800"
		{% if isCoop is defined and isCoop %}data-coop="true" data-fight-id="{{ fight.id }}" data-my-turn="{{ isMyTurn ? 'true' : 'false' }}" data-current-turn-key="{{ currentTurnKey }}" data-player-key="player_{{ player.id }}"{% endif %}>

		{# Coop turn indicator #}
		{% if isCoop is defined and isCoop %}
			<div id="coop-turn-banner" class="mb-2 p-2 rounded-lg text-center border
				{% if isMyTurn %}bg-green-900/60 border-green-500 animate-pulse{% else %}bg-yellow-900/40 border-yellow-600{% endif %}">
				{% if isMyTurn %}
					<span class="text-green-200 font-bold text-xs sm:text-sm">C'est votre tour !</span>
				{% else %}
					{% set currentTurnName = '' %}
					{% for fp in fight.players %}
						{% if ('player_' ~ fp.id) == currentTurnKey %}
							{% set currentTurnName = fp.name %}
						{% endif %}
					{% endfor %}
					<span class="text-yellow-200 font-bold text-xs sm:text-sm">
						Tour de {{ currentTurnName }}... En attente.
					</span>
				{% endif %}
			</div>
		{% endif %}

		{# Danger alert #}
		{% if dangerAlert is defined and dangerAlert %}
			<div class="mb-2 p-2 bg-red-900/60 border border-red-500 rounded-lg text-center animate-pulse">
				<span class="text-red-200 font-bold text-xs sm:text-sm">{{ dangerAlert }}</span>
			</div>
		{% endif %}

		{# ===== TIMELINE ===== #}
		{% include 'game/fight/partials/_timeline.html.twig' %}

		{# ===== COMBATANTS ROW: Player(s) vs Monster(s) ===== #}
		<div class="fight-combatants-row mb-2 sm:mb-3">
			{# --- PLAYERS --- #}
			<div class="space-y-2">
				{% for fightPlayer in fight.players %}
					{% set isCurrentPlayer = fightPlayer.id == player.id %}
					{% set effMaxLife = effectiveMaxLifeByPlayer[fightPlayer.id] ?? fightPlayer.maxLife %}
					<div class="selectable-target rounded-lg p-2 sm:p-3 transition-all
						{% if isCurrentPlayer %}bg-gradient-to-br from-purple-900/80 to-purple-800/80 border-2 border-purple-500{% else %}game-card border border-purple-500/20{% endif %}"
						data-player-id="{{ fightPlayer.id }}" data-target-type="player">

						<div class="flex items-center gap-2 mb-1.5">
							<div class="w-8 h-8 sm:w-10 sm:h-10 bg-gradient-to-br from-purple-500 to-purple-700 rounded-lg flex items-center justify-center shadow-lg flex-shrink-0
								{% if isCurrentPlayer %}ring-2 ring-purple-400{% endif %}">
								<svg class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
								</svg>
							</div>
							<div class="min-w-0 flex-1">
								<h2 class="text-xs sm:text-sm font-bold text-white truncate">{{ fightPlayer.name }}</h2>
								<span class="text-[10px] text-purple-300">{{ 'game.fight.level_short'|trans }}{{ fightPlayer.level ?? 0 }}</span>
							</div>
						</div>

						{# HP bar #}
						<div class="mb-1">
							<div class="flex items-center justify-between mb-0.5">
								<span class="text-[10px] text-gray-400">{{ 'game.fight.hp'|trans }}</span>
								<span class="text-[10px] font-bold text-white">{{ fightPlayer.life }}/{{ effMaxLife }}</span>
							</div>
							<div class="progress-bar progress-bar-compact">
								<div class="progress-bar-fill bg-red-500" style="width: {{ (fightPlayer.life / (effMaxLife > 0 ? effMaxLife : 1)) * 100 }}%"></div>
							</div>
						</div>

						{# Energy bar #}
						<div class="mb-1">
							<div class="flex items-center justify-between mb-0.5">
								<span class="text-[10px] text-gray-400">{{ 'game.fight.energy'|trans }}</span>
								<span class="text-[10px] font-bold text-white">{{ fightPlayer.energy }}/{{ fightPlayer.maxEnergy }}</span>
							</div>
							<div class="progress-bar progress-bar-compact">
								<div class="progress-bar-fill bg-blue-500" style="width: {{ (fightPlayer.energy/fightPlayer.maxEnergy)*100 }}%"></div>
							</div>
						</div>

						{# Status effects #}
						{% if statusEffects['player_' ~ fightPlayer.id] is defined and statusEffects['player_' ~ fightPlayer.id]|length > 0 %}
							<div class="flex flex-wrap gap-0.5 mt-1">
								{{ _self.status_effect_badges(statusEffects['player_' ~ fightPlayer.id]) }}
							</div>
						{% endif %}
					</div>
				{% endfor %}
			</div>

			{# --- MONSTERS --- #}
			<div class="space-y-2">
				{% for mob in fight.mobs %}
					<div class="selectable-target game-card p-2 sm:p-3 rounded-lg transition-all"
						data-mob-id="{{ mob.id }}" data-target-type="mob">

						<div class="flex items-center gap-2 mb-1.5">
							<div class="w-8 h-8 sm:w-10 sm:h-10 bg-gradient-to-br from-red-600 to-red-800 rounded-lg flex items-center justify-center shadow-lg flex-shrink-0">
								{% if mob.monster.isBoss %}
									<span class="text-yellow-400 text-sm">&#9813;</span>
								{% else %}
									<svg class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
										<path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-2 1-3 .5 1.5 1 2 1 3a3 3 0 01.12 1.62z" clip-rule="evenodd"/>
									</svg>
								{% endif %}
							</div>
							<div class="min-w-0 flex-1">
								<h2 class="text-xs sm:text-sm font-bold text-white truncate">
									{{ mob.name }}
									{% if mob.monster.isBoss %}
										<span class="text-[9px] text-yellow-400 uppercase">Boss</span>
									{% endif %}
								</h2>
								<div class="flex items-center gap-1 flex-wrap">
									<span class="text-[10px] text-gray-400">{{ 'game.fight.level_short'|trans }}{{ mob.level ?? 0 }}</span>
									<span class="text-[9px]" title="{{ 'game.fight.difficulty'|trans({'%level%': mob.monster.difficulty}) }}">
										{% for i in 1..5 %}
											{% if i <= (mob.monster.difficulty ?? 1) %}
												<span class="text-yellow-400">&#9733;</span>
											{% else %}
												<span class="text-gray-600">&#9733;</span>
											{% endif %}
										{% endfor %}
									</span>
									{% if bossPhases[mob.id] is defined %}
										<span class="inline-flex items-center px-1 py-0.5 rounded text-[8px] sm:text-[9px] bg-yellow-900/40 text-yellow-300 border border-yellow-700/50">
											{{ bossPhases[mob.id].name }}
										</span>
									{% endif %}
								</div>
							</div>
						</div>

						{# HP bar #}
						<div class="mb-1">
							<div class="flex items-center justify-between mb-0.5">
								<span class="text-[10px] text-gray-400">{{ 'game.fight.hp'|trans }}</span>
								<span class="text-[10px] font-bold text-white">{{ mob.life }}/{{ mob.maxLife }}</span>
							</div>
							<div class="progress-bar progress-bar-compact">
								<div class="progress-bar-fill bg-red-500" style="width: {{ (mob.life/mob.maxLife)*100 }}%"></div>
							</div>
						</div>

						{# Elemental resistances (boss only) #}
						{% if mob.monster.isBoss and mob.monster.elementalResistances %}
							<div class="flex flex-wrap gap-0.5 mt-1">
								{% for element, value in mob.monster.elementalResistances %}
									<span class="inline-flex items-center px-1 py-0.5 rounded text-[9px]
										{% if value > 0 %}bg-green-900/30 text-green-400 border border-green-800
										{% else %}bg-red-900/30 text-red-400 border border-red-800{% endif %}"
										title="{{ element }}: {{ value > 0 ? '+' : '' }}{{ (value * 100)|round }}%">
										{{ element|capitalize }} {{ value > 0 ? '+' : '' }}{{ (value * 100)|round }}%
									</span>
								{% endfor %}
							</div>
						{% endif %}

						{# Status effects #}
						{% if statusEffects['mob_' ~ mob.id] is defined and statusEffects['mob_' ~ mob.id]|length > 0 %}
							<div class="flex flex-wrap gap-0.5 mt-1">
								{{ _self.status_effect_badges(statusEffects['mob_' ~ mob.id]) }}
							</div>
						{% endif %}
					</div>
				{% endfor %}
			</div>
		</div>

		{# ===== ACTIONS + LOG (tabbed on mobile, side by side on desktop) ===== #}
		<div class="fight-mobile-layout">
			{# --- LEFT: ACTIONS --- #}
			<div>
				{# Mobile tabs #}
				<div class="flex border-b border-gray-700 mb-2 lg:hidden">
					<button class="fight-tab active flex-1 text-center py-2 text-xs font-semibold border-b-2 transition-colors" data-tab="actions">
						{{ 'game.fight.actions'|trans }}
					</button>
					<button class="fight-tab flex-1 text-center py-2 text-xs font-semibold border-b-2 transition-colors" data-tab="log">
						{{ 'game.fight.log.title'|trans }}
						{% if fightLogs|length > 0 %}
							<span class="ml-1 inline-flex items-center justify-center w-4 h-4 text-[9px] bg-purple-600 text-white rounded-full">{{ fightLogs|length }}</span>
						{% endif %}
					</button>
				</div>

				{# Actions panel #}
				<div id="panel-actions" class="game-card p-2 sm:p-3">
					{% if not fight.terminated %}
						{# Action buttons #}
						<div class="fight-actions-grid w-full mb-2">
							<button id="action-attack"
									class="fight-action bg-gradient-to-r from-red-600 to-red-700 text-white rounded-lg hover:from-red-700 hover:to-red-800 active:from-red-800 active:to-red-900 transition-all font-medium touch-target text-sm"
									data-href="{{ path("app_game_fight_attack") }}"
									data-content="{{ 'game.fight.attacking'|trans }}">
								{{ 'game.fight.action.attack'|trans }}
							</button>

							<button id="fight-spells"
									class="bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg hover:from-blue-700 hover:to-blue-800 active:from-blue-800 active:to-blue-900 transition-all font-medium touch-target text-sm"
									data-href="{{ path("app_game_fight_spell") }}"
									data-target="#fight-action-container">
								{{ 'game.fight.action.spell'|trans }}
							</button>

							<button id="fight-objects"
									class="bg-gradient-to-r from-green-600 to-green-700 text-white rounded-lg hover:from-green-700 hover:to-green-800 active:from-green-800 active:to-green-900 transition-all font-medium touch-target text-sm"
									data-href="{{ path("app_game_fight_item") }}"
									data-target="#fight-action-container">
								{{ 'game.fight.action.object'|trans }}
							</button>

							<button id="action-flee"
									class="fight-action bg-gradient-to-r from-gray-600 to-gray-700 text-white rounded-lg hover:from-gray-700 hover:to-gray-800 active:from-gray-800 active:to-gray-900 transition-all font-medium touch-target text-sm"
									data-href="{{ path("app_game_fight_flee") }}"
									data-content="{{ 'game.fight.fleeing'|trans }}">
								{{ 'game.fight.action.flee'|trans }}
							</button>
						</div>

						{# Materia spells #}
						{% if materiaSpells is defined and materiaSpells|length > 0 %}
							<div class="w-full">
								<h4 class="text-[10px] font-semibold text-purple-300 mb-1.5">{{ 'game.fight.materia_spells'|trans }}</h4>
								<div class="grid grid-cols-2 sm:grid-cols-3 gap-1">
									{% for entry in materiaSpells %}
										{% set spell = entry.spell %}
										{% set elementMatch = entry.elementMatch %}
										{% set isLocked = entry.locked ?? false %}
										{% set cooldown = playerCooldowns[spell.slug] ?? 0 %}
										{% set hasEnergy = player.energy >= spell.energyCost %}
										{% set isAvailable = not isLocked and cooldown == 0 and hasEnergy %}
										{% set isDefensive = (spell.heal is not null and spell.heal > 0) and (spell.damage is null or spell.damage == 0) %}
										<button class="spell-btn fight-action relative px-1.5 py-1.5 rounded-lg text-[11px] font-medium transition-all touch-target
											{% if isLocked %}bg-gray-800 text-gray-600 cursor-not-allowed opacity-50
											{% elseif not isAvailable %}spell-on-cooldown bg-gray-700 text-gray-500 cursor-not-allowed
											{% else %}bg-gradient-to-r from-indigo-600 to-indigo-700 text-white hover:from-indigo-700 hover:to-indigo-800{% endif %}
											{% if not isLocked %}
												{% if elementMatch %} ring-2 ring-yellow-400
												{% elseif spell.element.value == 'fire' %} ring-1 ring-orange-500/50
												{% elseif spell.element.value == 'water' %} ring-1 ring-blue-500/50
												{% elseif spell.element.value == 'earth' %} ring-1 ring-amber-500/50
												{% elseif spell.element.value == 'air' %} ring-1 ring-teal-500/50
												{% elseif spell.element.value == 'light' %} ring-1 ring-yellow-500/50
												{% elseif spell.element.value == 'dark' %} ring-1 ring-purple-500/50
												{% elseif spell.element.value == 'metal' %} ring-1 ring-gray-400/50
												{% elseif spell.element.value == 'beast' %} ring-1 ring-green-500/50
												{% endif %}
											{% endif %}"
											data-href="{{ path("app_game_fight_spell") }}"
											data-spell-slug="{{ spell.slug }}"
											data-spell-type="{{ isDefensive ? 'defensive' : 'offensive' }}"
											{% if not isAvailable %}disabled{% endif %}
											title="{% if isLocked %}{{ 'game.fight.spell_locked'|trans }} — {% endif %}{{ spell.description }}{% if elementMatch %} [{{ 'game.fight.element_match_bonus'|trans }}]{% endif %}{% if spell.energyCost > 0 %} ({{ spell.energyCost }} {{ 'game.fight.energy'|trans|lower }}){% endif %}{% if cooldown > 0 %} - {{ 'game.fight.cooldown_remaining'|trans({'%turns%': cooldown}) }}{% endif %}">
											<span class="block truncate">{{ spell.name }}</span>
											{% if isLocked %}
												<span class="block text-[9px] text-red-400 mt-0.5">{{ 'game.fight.spell_locked'|trans }}</span>
											{% else %}
												<span class="block text-[9px] opacity-75 mt-0.5">
													{% if spell.energyCost > 0 %}{{ spell.energyCost }} EN{% endif %}
													{% if spell.damage %} · {{ spell.damage }} DMG{% endif %}
													{% if spell.heal %} · {{ spell.heal }} HEAL{% endif %}
													{% if elementMatch %} · <span class="text-yellow-400">+25%</span>{% endif %}
												</span>
												{% if cooldown > 0 %}
													<span class="cooldown-badge">{{ cooldown }}</span>
												{% endif %}
												{% if not hasEnergy and cooldown == 0 %}
													<span class="block text-[9px] text-red-400">{{ 'game.fight.energy_insufficient'|trans }}</span>
												{% endif %}
											{% endif %}
										</button>
									{% endfor %}
								</div>
							</div>
						{% endif %}
					{% else %}
						{# Fight ended #}
						<div>
							<h3 class="text-lg sm:text-xl font-bold text-white text-center mb-3">{{ 'game.fight.terminated'|trans }}</h3>
							{% if fight.victory %}
								<form class="space-y-3" action="{{ path("app_game_fight_loot") }}" role="form" method="post">
									<input type="hidden" name="fight" value="{{ fight.id }}">
									<div class="bg-gray-700/50 rounded-lg p-2 sm:p-4">
										<h4 class="text-sm font-semibold text-white mb-2">{{ 'game.fight.loot.items_list'|trans }}</h4>
										<div class="grid grid-cols-1 sm:grid-cols-2 gap-1.5 sm:gap-2">
											{% for item in fight.loot %}
												<div class="flex items-center justify-between p-2 bg-gray-800 rounded-lg border border-purple-500/20">
													<div class="flex items-center gap-2 min-w-0">
														<div class="w-6 h-6 bg-gradient-to-br from-purple-600 to-purple-800 rounded flex items-center justify-center flex-shrink-0">
															<svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
																<path d="M11 17a1 1 0 001.447.894l4-2A1 1 0 0017 15V9.236a1 1 0 00-1.447-.894l-4 2a1 1 0 00-.553.894V17zM15.211 6.276a1 1 0 000-1.788l-4.764-2.382a1 1 0 00-.894 0L4.789 4.488a1 1 0 000 1.788l4.764 2.382a1 1 0 00.894 0l4.764-2.382zM4.447 8.342A1 1 0 003 9.236V15a1 1 0 00.553.894l4 2A1 1 0 009 17v-5.764a1 1 0 00-.553-.894l-4-2z"/>
															</svg>
														</div>
														<span class="text-white text-xs truncate">{{ item.name }}</span>
													</div>
													<input type="checkbox" class="form-checkbox h-4 w-4 text-purple-600 rounded border-gray-600 flex-shrink-0" checked name="items[]" value="{{ item.id }}">
												</div>
											{% endfor %}
										</div>
									</div>
									<button type="submit" class="w-full px-3 py-2.5 bg-gradient-to-r from-purple-600 to-purple-700 text-white rounded-lg hover:from-purple-700 hover:to-purple-800 transition-all font-medium touch-target text-sm">
										{{ 'game.fight.loot.collect'|trans }}
									</button>
								</form>

								{# Butcher buttons #}
								{% for mob in fight.mobs %}
								<div id="butcher-section-{{ mob.id }}" class="mt-2">
									<button type="button"
										class="butcher-btn w-full px-3 py-2.5 bg-gradient-to-r from-amber-600 to-amber-700 text-white rounded-lg hover:from-amber-700 hover:to-amber-800 transition-all font-medium touch-target text-sm"
										data-mob-id="{{ mob.id }}"
										onclick="butcherMob({{ mob.id }}, this)">
										{{ 'game.fight.butcher'|trans({'%name%': mob.monster.name}) }}
									</button>
									<div id="butcher-result-{{ mob.id }}" class="mt-1"></div>
								</div>
								{% endfor %}
							{% else %}
								<div class="text-center py-4">
									<div class="inline-block p-3 bg-red-500/20 rounded-xl">
										<svg class="w-10 h-10 text-red-500 mx-auto" fill="currentColor" viewBox="0 0 20 20">
											<path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-2 1-3 .5 1.5 1 2 1 3a3 3 0 01.12 1.62z" clip-rule="evenodd"/>
										</svg>
										<p class="text-white mt-2 font-medium text-sm">{{ 'game.fight.defeat'|trans }}</p>
									</div>
								</div>
							{% endif %}
						</div>
					{% endif %}
				</div>
			</div>

			{# --- RIGHT: COMBAT LOG --- #}
			<div id="panel-log" class="hidden lg:block">
				<div class="hidden lg:block">
					<h4 class="text-xs font-semibold text-purple-300 mb-1.5">{{ 'game.fight.log.title'|trans }}</h4>
				</div>
				<div class="game-card p-2 sm:p-3">
					<div id="combat-log" class="combat-log-container">
						{% if fightLogs|length == 0 %}
							<p class="text-gray-500 text-xs text-center py-4">{{ 'game.fight.log.empty'|trans }}</p>
						{% else %}
							{% set currentTurn = -1 %}
							{% for log in fightLogs %}
								{% if log.turn != currentTurn %}
									{% set currentTurn = log.turn %}
									<div class="flex items-center gap-2 my-1.5">
										<div class="flex-1 h-px bg-gray-700"></div>
										<span class="text-[9px] text-gray-500 font-semibold uppercase">{{ 'game.fight.turn'|trans }} {{ log.turn }}</span>
										<div class="flex-1 h-px bg-gray-700"></div>
									</div>
								{% endif %}
								<div class="log-entry flex items-start gap-1.5 py-0.5 text-[11px] leading-tight
									{% if log.type == 'death' or log.type == 'defeat' %}text-red-300
									{% elseif log.type == 'victory' %}text-yellow-300
									{% elseif log.type == 'heal' %}text-green-300
									{% elseif log.type == 'critical' %}text-yellow-400
									{% elseif log.type == 'miss' %}text-gray-500
									{% elseif log.type == 'fight_start' %}text-purple-300
									{% elseif log.actorType == 'mob' %}text-red-200
									{% elseif log.actorType == 'player' %}text-blue-200
									{% else %}text-gray-300{% endif %}">
									<span class="flex-shrink-0 w-3 text-center">{{ _self.log_icon(log.type) }}</span>
									<span>{{ log.message }}</span>
								</div>
							{% endfor %}
						{% endif %}
					</div>
				</div>
			</div>
		</div>

		{# Notification component #}
		<div class="mt-2">
			{{ component('FightNotification', {fight: fight}) }}
		</div>
	</div>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script>
		document.addEventListener('DOMContentLoaded', function() {
			// ===== COOP TURN STATE =====
			const gamePage = document.querySelector('.game-page');
			const isCoop = gamePage?.dataset.coop === 'true';
			let isMyTurn = gamePage?.dataset.myTurn === 'true';
			const fightId = gamePage?.dataset.fightId;
			const myKey = gamePage?.dataset.playerKey;

			// ===== MERCURE SSE FOR COOP TURN CHANGES =====
			if (isCoop && fightId) {
				const mercureUrl = document.body.dataset.mercureUrl || document.querySelector('[data-event-notification-mercure-url-value]')?.dataset.eventNotificationMercureUrlValue;
				if (mercureUrl) {
					const topic = 'fight/' + fightId + '/turn';
					const url = new URL(mercureUrl);
					url.searchParams.append('topic', topic);
					const eventSource = new EventSource(url, { withCredentials: true });
					eventSource.onmessage = function(event) {
						try {
							const data = JSON.parse(event.data);
							if (data.type === 'fight_end' || data.type === 'turn_change') {
								// Reload the page to get fresh state
								window.location.reload();
							}
						} catch (e) {
							console.error('[coop] SSE parse error', e);
						}
					};
					eventSource.onerror = function() {
						console.warn('[coop] SSE connection lost, will retry');
					};
				}
			}

			function setCoopActionsEnabled(enabled) {
				if (!isCoop) return;
				const actionsPanel = document.getElementById('panel-actions');
				if (!actionsPanel) return;
				if (enabled) {
					actionsPanel.style.opacity = '1';
					actionsPanel.style.pointerEvents = '';
				} else {
					actionsPanel.style.opacity = '0.5';
					actionsPanel.style.pointerEvents = 'none';
				}
			}

			// Disable actions if not my turn
			if (isCoop && !isMyTurn) {
				setCoopActionsEnabled(false);
			}

			// ===== TAB SWITCHING (mobile) =====
			const tabs = document.querySelectorAll('.fight-tab');
			const panelActions = document.getElementById('panel-actions');
			const panelLog = document.getElementById('panel-log');

			tabs.forEach(tab => {
				tab.addEventListener('click', function() {
					tabs.forEach(t => t.classList.remove('active'));
					this.classList.add('active');
					const target = this.dataset.tab;
					if (target === 'actions') {
						panelActions.classList.remove('hidden');
						if (panelLog) panelLog.classList.add('hidden', 'lg:block');
					} else {
						panelActions.classList.add('hidden');
						if (panelLog) {
							panelLog.classList.remove('hidden', 'lg:block');
							panelLog.classList.add('block');
						}
					}
				});
			});

			// Auto-scroll log to bottom
			const logContainer = document.getElementById('combat-log');
			if (logContainer) {
				logContainer.scrollTop = logContainer.scrollHeight;
			}

			// ===== TARGET SELECTION =====
			let selectedTarget = null;
			const selectableTargets = document.querySelectorAll('.selectable-target');
			const actionButtons = document.querySelectorAll('.fight-action');
			const aliveMobs = document.querySelectorAll('.selectable-target[data-target-type="mob"]');
			const playerTargets = document.querySelectorAll('.selectable-target[data-target-type="player"]');

			if (aliveMobs.length === 1) {
				aliveMobs[0].classList.add('selected');
				selectedTarget = aliveMobs[0];
			}

			selectableTargets.forEach(target => {
				target.addEventListener('click', function() {
					if (this.classList.contains('disabled')) return;
					if (selectedTarget) selectedTarget.classList.remove('selected');
					this.classList.add('selected');
					selectedTarget = this;
					actionButtons.forEach(button => {
						if (!button.disabled) button.classList.remove('spell-on-cooldown');
					});
				});
			});

			function resolveTarget(button) {
				const isFlee = button.dataset.href.includes('/flee');
				if (isFlee) return { resolved: true, target: null };

				const isDefensiveSpell = button.dataset.spellType === 'defensive';

				if (isDefensiveSpell) {
					if (playerTargets.length === 1) {
						return { resolved: true, target: playerTargets[0] };
					}
					if (selectedTarget && selectedTarget.dataset.targetType === 'player') {
						return { resolved: true, target: selectedTarget };
					}
					return { resolved: false };
				}

				if (selectedTarget && selectedTarget.dataset.targetType === 'mob') {
					return { resolved: true, target: selectedTarget };
				}
				if (aliveMobs.length === 1) {
					return { resolved: true, target: aliveMobs[0] };
				}
				if (selectedTarget) {
					return { resolved: true, target: selectedTarget };
				}
				return { resolved: false };
			}

			// ===== COMBAT PARTICLES =====
			const ELEMENT_COLORS = {
				fire: '#ef4444', water: '#3b82f6', earth: '#a16207',
				air: '#67e8f9', light: '#fde68a', dark: '#7c3aed',
				metal: '#94a3b8', beast: '#22c55e', none: '#a855f7'
			};

			function spawnCombatParticles(targetEl, { count = 8, color = '#a855f7', life = 600, spread = 40, size = 4 } = {}) {
				if (!targetEl) return;
				const rect = targetEl.getBoundingClientRect();
				const cx = rect.left + rect.width / 2;
				const cy = rect.top + rect.height / 2;

				for (let i = 0; i < count; i++) {
					const p = document.createElement('div');
					p.style.cssText = `position:fixed;left:${cx}px;top:${cy}px;width:${size}px;height:${size}px;border-radius:50%;background:${color};pointer-events:none;z-index:9999;opacity:0.9;`;
					document.body.appendChild(p);

					const angle = Math.random() * Math.PI * 2;
					const dist = spread * (0.3 + Math.random() * 0.7);
					const dx = Math.cos(angle) * dist;
					const dy = Math.sin(angle) * dist - 20;

					p.animate([
						{ transform: 'translate(0,0) scale(1)', opacity: 0.9 },
						{ transform: `translate(${dx}px,${dy}px) scale(0.2)`, opacity: 0 }
					], { duration: life, easing: 'ease-out', fill: 'forwards' })
					.onfinish = () => p.remove();
				}
			}

			function spawnCriticalParticles(targetEl) {
				spawnCombatParticles(targetEl, { count: 14, color: '#fbbf24', life: 800, spread: 60, size: 5 });
				spawnCombatParticles(targetEl, { count: 6, color: '#ffffff', life: 500, spread: 30, size: 3 });
			}

			// ===== VISUAL EFFECTS =====

			/** Flash coloré plein écran sur dégâts élémentaires */
			function flashElemental(element) {
				const color = ELEMENT_COLORS[element] || ELEMENT_COLORS.none;
				const overlay = document.createElement('div');
				overlay.className = 'elemental-flash';
				overlay.style.backgroundColor = color;
				document.body.appendChild(overlay);
				overlay.addEventListener('animationend', () => overlay.remove());
			}

			/** Shake camera sur coup critique */
			function shakeCombat() {
				const page = document.querySelector('.game-page');
				if (!page) return;
				page.classList.remove('combat-shake');
				void page.offsetWidth; // force reflow
				page.classList.add('combat-shake');
				page.addEventListener('animationend', () => page.classList.remove('combat-shake'), { once: true });
			}

			/** Tremblement du sprite cible quand il reçoit des dégâts */
			function shakeTarget(targetEl) {
				if (!targetEl) return;
				targetEl.classList.remove('target-hit-shake');
				void targetEl.offsetWidth;
				targetEl.classList.add('target-hit-shake');
				targetEl.addEventListener('animationend', () => targetEl.classList.remove('target-hit-shake'), { once: true });
			}

			/** Fondu progressif à la mort d'un mob/joueur */
			function fadeOnDeath(targetEl) {
				if (!targetEl) return;
				targetEl.classList.add('death-fade');
			}

			// ===== ACTION HANDLING =====
			actionButtons.forEach(button => {
				button.addEventListener('click', async function(e) {
					if (this.disabled) return;

					const actionUrl = this.dataset.href;
					const { resolved, target } = resolveTarget(this);

					if (!resolved) {
						alert("{{ 'game.fight.select_target'|trans|e('js') }}");
						return;
					}

					// Disable all buttons during action
					actionButtons.forEach(b => b.disabled = true);

					const targetId = target ? (target.dataset.playerId || target.dataset.mobId) : null;
					const targetType = target ? target.dataset.targetType : null;
					const spellSlug = this.dataset.spellSlug || null;

					try {
						const body = {};
						if (targetId) body.targetId = parseInt(targetId, 10);
						if (targetType) body.targetType = targetType;
						if (spellSlug) body.spellSlug = spellSlug;

						const response = await fetch(actionUrl, {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(body)
						});

						const data = await response.json();

						if (!response.ok || data.error) {
							alert(data.error || "{{ 'game.fight.error_action'|trans|e('js') }}");
							actionButtons.forEach(b => b.disabled = false);
							return;
						}

						// Visual effects on hit
						if (data.hit && target) {
							const element = data.spellElement || 'none';
							const color = ELEMENT_COLORS[element] || ELEMENT_COLORS.none;
							spawnCombatParticles(target, { color });
							shakeTarget(target);

							// Sons de combat
							if (window.SoundManager) {
								if (data.critical) {
									window.SoundManager.play('combat_critical');
								} else if (spellSlug) {
									window.SoundManager.play('combat_spell');
								} else {
									window.SoundManager.play('combat_hit');
								}
							}

							// Flash élémentaire (seulement si élément != none)
							if (element !== 'none') {
								flashElemental(element);
							}

							if (data.critical) {
								spawnCriticalParticles(target);
								shakeCombat();
							}
						} else if (!data.hit && !data.fled && window.SoundManager) {
							window.SoundManager.play('combat_miss');
						}

						// Fondu sur mort de la cible
						if (data.hit && target && data.fight) {
							const isMobTarget = target.dataset.targetType === 'mob';
							const isPlayerTarget = target.dataset.targetType === 'player';
							// Vérifier si le combat est terminé avec un mort
							if (data.fight.terminated || data.messages?.some(m => m.includes('vaincu'))) {
								if (isMobTarget && (data.fight.victory || data.messages?.some(m => m.includes('vaincu')))) {
									fadeOnDeath(target);
								}
								if (isPlayerTarget && !data.fight.victory && data.fight.terminated) {
									fadeOnDeath(target);
								}
								// Son de mort
								if (window.SoundManager) {
									window.SoundManager.play('combat_death');
								}
							}
						}

						// Delay to show visual effects before navigation
						const hasEffects = data.hit && target;
						const hasDeath = hasEffects && data.fight?.terminated;
						const navigate = () => {
							if (data.fight && data.fight.terminated) {
								if (data.fight.victory) {
									if (window.SoundManager) window.SoundManager.play('combat_victory');
									window.location.href = '{{ path("app_game_fight_loot") }}';
								} else {
									if (window.SoundManager) window.SoundManager.play('combat_defeat');
									window.location.href = '{{ path("app_game_fight") }}';
								}
								return;
							}

							if (data.fled) {
								if (window.SoundManager) window.SoundManager.play('combat_flee');
								window.location.href = '{{ path("app_game_map") }}';
								return;
							}

							window.location.reload();
						};

						if (hasDeath) {
							setTimeout(navigate, 900);
						} else if (hasEffects) {
							setTimeout(navigate, 500);
						} else {
							navigate();
						}
					} catch (error) {
						console.error('Error:', error);
						alert("{{ 'game.fight.error_action'|trans|e('js') }}");
						actionButtons.forEach(b => b.disabled = false);
					}
				});
			});
		});

		async function butcherMob(mobId, btn) {
			btn.disabled = true;
			btn.textContent = "{{ 'game.fight.butchering'|trans|e('js') }}";
			const resultDiv = document.getElementById('butcher-result-' + mobId);

			try {
				const resp = await fetch('/game/harvest/butcher/' + mobId, { method: 'POST' });
				const data = await resp.json();

				if (data.error) {
					resultDiv.innerHTML = '<p class="text-red-400 text-xs">' + data.error + '</p>';
					btn.disabled = false;
					btn.textContent = "{{ 'game.fight.butcher_retry'|trans|e('js') }}";
					return;
				}

				btn.style.display = 'none';

				if (data.items && data.items.length > 0) {
					let html = '<div class="bg-amber-900/30 border border-amber-500/30 rounded-lg p-2">';
					html += '<p class="text-amber-400 text-xs font-bold mb-1">{{ "game.fight.butcher_materials"|trans|e("js") }}</p>';
					for (const item of data.items) {
						html += '<p class="text-yellow-300 text-[11px]">+ ' + item.name + '</p>';
					}
					html += '</div>';
					resultDiv.innerHTML = html;
				} else {
					resultDiv.innerHTML = '<p class="text-gray-400 text-xs">{{ "game.fight.butcher_none"|trans|e("js") }}</p>';
				}

				if (data.message && data.message.includes('brise')) {
					resultDiv.innerHTML += '<p class="text-red-400 text-[10px] mt-1 font-bold">{{ "game.fight.butcher_broken"|trans|e("js") }}</p>';
				}
			} catch (err) {
				console.error('[butcher] Error:', err);
				resultDiv.innerHTML = '<p class="text-red-400 text-xs">{{ "game.fight.connection_error"|trans|e("js") }}</p>';
				btn.disabled = false;
				btn.textContent = "{{ 'game.fight.butcher_retry'|trans|e('js') }}";
			}
		}
	</script>
{% endblock %}

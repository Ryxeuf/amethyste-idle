{% extends 'game/game.html.twig' %}

{% block title %}
	{{ 'game.map.title'|trans }}
{% endblock %}


{% block site_navbar %}
	<div class="bg-gray-800 border-b border-purple-900 shadow-md">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="flex items-center justify-between h-12">
				<div
					class="flex items-center">
					<!-- Titre du jeu -->
					<div class="flex-shrink-0 mr-4">
						<a href="{{ path('app_game') }}" class="text-purple-400 font-bold text-xl">{{ 'game.title'|trans }}</a>
					</div>
					<div class="hidden md:block">
						<div class="flex items-baseline space-x-4"></div>
					</div>
				</div>
				<div class="-mr-2 flex md:hidden">
					<button type="button" class="game-mobile-menu-button bg-gray-800 inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-white hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-gray-800 focus:ring-white">
						<svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
						</svg>
					</button>
				</div>
			</div>
		</div>

		<!-- Menu mobile pour le jeu -->
		<div
			class="game-mobile-menu hidden md:hidden">
			<!-- Titre du jeu pour mobile -->
			<div class="px-2 pt-2 pb-1 border-b border-gray-700">
				<a href="{{ path('app_game') }}" class="text-purple-400 font-bold text-lg block">{{ 'game.title'|trans }}</a>
			</div>
			<div class="px-2 pt-2 pb-3 space-y-1 sm:px-3"></div>
			<div class="px-2 pt-2 pb-3 border-t border-gray-700">
				<div
					class="flex flex-col space-y-2 px-3 py-2"><!-- Les informations de currency et energy ont été supprimées ici -->
				</div>
			</div>
		</div>
	</div>

	<script>
		// Menu mobile pour le jeu
document.addEventListener('DOMContentLoaded', function () {
const gameMobileMenuButton = document.querySelector('.game-mobile-menu-button');
const gameMobileMenu = document.querySelector('.game-mobile-menu');

if (gameMobileMenuButton && gameMobileMenu) {
gameMobileMenuButton.addEventListener('click', function () {
gameMobileMenu.classList.toggle('hidden');
});
}
});
	</script>
{% endblock %}


{% block game_content %}
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
		<!-- Données du combat -->
		<div id="fight" data-id="{{ fight.id }}" class="hidden">{{ fight|json_encode|raw }}</div>

		<!-- Timeline du combat -->
		{# <div id="fight-timeline" class="mb-6">
		        <div class="bg-white rounded-lg shadow">
		            <div class="px-4 py-5 sm:p-6">
		                <h3 class="text-lg font-medium text-gray-900 mb-4">{{ "game.fight.timeline"|trans }}</h3>
		                <div class="fight-timeline-content space-y-2">
		                    {% for item in fight.timeline %}
		                        <span class="inline-block px-3 py-1 rounded-md bg-gray-100 text-gray-800 border-l-4 border-purple-500">
		                            {{ item.name }}
		                        </span>
		                    {% endfor %}
		                </div>
		            </div>
		        </div>
		    </div> #}
		{{ component('FightTimeline', {fight: fight}) }}

		<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
			<!-- Container du joueur -->
			<div id="player-container" class="bg-white rounded-lg shadow-lg p-6 transform transition-all duration-300 hover:shadow-xl">
				<div class="space-y-4">
					<div class="flex items-center space-x-4">
						<div class="player-avatar w-16 h-16 bg-purple-100 rounded-lg flex items-center justify-center">
							<i class="fas fa-user text-purple-600 text-2xl"></i>
						</div>
						<div>
							<h2 class="text-2xl font-bold text-gray-800">{{ player.name }}</h2>
							{# <p class="text-gray-600 text-sm">Niveau {{ player.level }}</p> #}
						</div>
					</div>
					
					<div class="space-y-2">
						<div class="flex items-center space-x-2">
							<span class="text-red-500">
								<i class="fas fa-heart"></i>
							</span>
							<span class="text-gray-700">
								<span class="player-life font-semibold">{{ player.life }}</span>
								<span class="text-gray-400">/</span>
								<span class="player-maxlife">{{ player.maxLife }}</span>
							</span>
						</div>
						
						<div class="w-full bg-gray-200 rounded-full h-2.5">
							<div class="bg-red-500 h-2.5 rounded-full transition-all duration-300 player-progress-life" 
								 style="width: {{ (player.life/player.maxLife)*100 }}%;"></div>
						</div>

						<div class="flex items-center space-x-2">
							<span class="text-blue-500">
								<i class="fas fa-bolt"></i>
							</span>
							<span class="text-gray-700">
								<span class="player-energy font-semibold">{{ player.energy }}</span>
								<span class="text-gray-400">/</span>
								<span class="player-maxenergy">{{ player.maxEnergy }}</span>
							</span>
						</div>
						
						<div class="w-full bg-gray-200 rounded-full h-2.5">
							<div class="bg-blue-500 h-2.5 rounded-full transition-all duration-300 player-progress-energy" 
								 style="width: {{ (player.energy/player.maxEnergy)*100 }}%;"></div>
						</div>

						<div class="player-statuses flex flex-wrap gap-2 mt-2"></div>
					</div>
				</div>
			</div>

			<!-- Container du monstre -->
			<div id="mob-container" class="bg-white rounded-lg shadow-lg p-6 transform transition-all duration-300 hover:shadow-xl">
				<div id="mob" data-id="{{ mob.id }}"></div>
				<div class="space-y-4">
					<div class="flex items-center space-x-4">
						<div class="monster w-16 h-16 bg-gray-100 rounded-lg flex items-center justify-center" data-id="{{ mob.id }}"></div>
						<div>
							<h2 class="text-2xl font-bold text-gray-800">{{ mob.name }}</h2>
						</div>
					</div>
					
					<div class="space-y-2">
						<div class="flex items-center space-x-2">
							<span class="text-red-500">
								<i class="fas fa-heart"></i>
							</span>
							<span class="text-gray-700">
								<span class="mob-life font-semibold">{{ mob.life }}</span>
								<span class="text-gray-400">/</span>
								<span class="mob-maxlife">{{ mob.maxLife }}</span>
							</span>
						</div>
						
						<div class="w-full bg-gray-200 rounded-full h-2.5">
							<div class="bg-red-500 h-2.5 rounded-full transition-all duration-300 mob-progress-life" 
								 style="width: {{ mob.life/mob.maxLife*100 }}%;"></div>
						</div>

						<div class="mob-statuses flex flex-wrap gap-2 mt-2"></div>
					</div>
				</div>
			</div>

			{{ component('FightNotification', {fight: fight}) }}

			<!-- Traitement des actions -->
			<div id="fight-action-processing" class="hidden">
				<div class="content"></div>
				<div class="flex justify-center items-center py-8">
					<div class="animate-spin rounded-full h-12 w-12 border-4 border-purple-500 border-t-transparent"></div>
				</div>
			</div>

			<!-- Combat terminé -->
			<div id="fight-terminated" class="{% if not fight.terminated %}hidden{% endif %} bg-white rounded-lg shadow-lg p-6">
				<div class="space-y-6">
					<h3 class="text-2xl font-bold text-gray-800">{{ "game.fight.terminated"|trans }}</h3>
					<div id="fight-terminated-content">
						{% if fight.victory %}
							<form class="space-y-4" action="{{ path("fight_loot") }}" role="form" method="post">
								<input type="hidden" name="fight" value="{{ fight.id }}">
								<div class="bg-gray-50 rounded-lg p-4">
									<h4 class="text-lg font-semibold mb-4">{{ "game.fight.loots.loot_list"|trans }}</h4>
									<div class="space-y-3">
										{% for item in fight.loot %}
											<div class="flex items-center justify-between p-3 bg-white rounded-lg shadow-sm">
												<div class="flex items-center space-x-3">
													<div class="objectlayer objectlayer-list w-8 h-8 bg-gray-100 rounded"></div>
													<span class="text-gray-700">{{ item.name }}</span>
												</div>
												<input type="checkbox" class="form-checkbox h-5 w-5 text-purple-600" checked name="items[]" value="{{ item.id }}">
											</div>
										{% endfor %}
									</div>
								</div>
								<button type="submit" class="w-full px-6 py-3 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors duration-300">
									{{ "game.fight.loots.loot"|trans }}
								</button>
							</form>
						{% else %}
							<div class="text-center py-8">
								<i class="text-gray-600 text-xl">Vous êtes mort...</i>
							</div>
						{% endif %}
					</div>
				</div>
			</div>

			<!-- Actions de combat -->
			{% if not fight.terminated %}
				<div id="fight-actions" class="bg-white rounded-lg shadow-lg p-6">
					<div class="space-y-6">
						<h3 class="text-2xl font-bold text-gray-800">{{ "game.fight.choose_action"|trans }}</h3>
						
						<div id="fight-action-container" class="space-y-4"></div>

						<div class="grid grid-cols-2 gap-4">
							<button id="action-attack" 
									class="fight-action w-full px-6 py-3 bg-purple-600 text-white rounded-lg hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 transition-colors duration-300"
									data-href="{{ path("app_game_fight_attack") }}" 
									data-content="Attaque en cours...">
								{{ "game.fight.action.attack"|trans }}
							</button>

							<button id="fight-spells" 
									class="w-full px-6 py-3 bg-purple-600 text-white rounded-lg hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 transition-colors duration-300"
									data-href="{{ path("app_game_fight_spell") }}" 
									data-target="#fight-action-container">
								{{ "game.fight.action.spell"|trans }}
							</button>

							<button id="fight-objects" 
									class="w-full px-6 py-3 bg-purple-600 text-white rounded-lg hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 transition-colors duration-300"
									data-href="{{ path("app_game_fight_item") }}" 
									data-target="#fight-action-container">
								{{ "game.fight.action.object"|trans }}
							</button>

							<button id="action-flee" 
									class="fight-action w-full px-6 py-3 bg-purple-600 text-white rounded-lg hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 transition-colors duration-300"
									data-href="{{ path("app_game_fight_flee") }}" 
									data-content="Fuite en cours...">
								{{ "game.fight.action.flee"|trans }}
							</button>
						</div>

						<div id="fight-spells-container" class="hidden"></div>
						<div id="fight-items-container" class="hidden"></div>
					</div>
				</div>
			{% endif %}
		</div>
	</div>
{% endblock %}

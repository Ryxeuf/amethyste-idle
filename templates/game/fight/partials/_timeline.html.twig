{# Timeline dynamique de combat — ordre base sur la vitesse #}
{% if timeline is defined and timeline|length > 0 %}
<div class="mb-2">
	<div class="bg-gray-800/80 backdrop-blur-sm rounded-xl border border-purple-500/20 p-3">
		<div class="flex items-center justify-between mb-2">
			<div class="flex items-center space-x-3">
				<h3 class="text-sm font-bold text-white">{{ 'game.fight.timeline.title'|trans|default('Sequence') }}</h3>
				<div class="flex items-center space-x-1.5 px-2 py-0.5 bg-gray-700/50 rounded-lg">
					<span class="text-[10px] text-gray-400">{{ 'game.fight.timeline.round'|trans|default('Round') }}</span>
					<span class="text-xs font-bold text-purple-400">{{ currentRound }}</span>
				</div>
			</div>
		</div>

		{# Sequence des participants #}
		<div class="flex items-center justify-start gap-1 overflow-x-auto pb-1">
			{% set prevRound = 0 %}
			{% for i, entry in timeline %}
				{# Separateur de round #}
				{% if entry.round != prevRound and prevRound != 0 %}
					<div class="flex-shrink-0 w-px h-8 bg-gray-600/50 mx-0.5"></div>
				{% endif %}
				{% set prevRound = entry.round %}

				{% set isCurrent = (i == 0) %}
				<div class="flex-shrink-0 flex flex-col items-center gap-0.5
					{% if isCurrent %}scale-110 transform{% endif %}"
					title="{{ entry.entity.name }} — {{ 'game.fight.timeline.speed'|trans|default('Vitesse') }}: {{ entry.speed }}">
					{# Avatar #}
					<div class="w-8 h-8 rounded-full flex items-center justify-center text-[10px] font-bold text-white border-2 transition-all
						{% if entry.type == 'player' %}
							bg-gradient-to-br from-purple-500 to-purple-700
							{% if isCurrent %}border-purple-300 shadow-lg shadow-purple-500/30{% else %}border-purple-600/50{% endif %}
						{% else %}
							bg-gradient-to-br from-red-600 to-red-800
							{% if isCurrent %}border-red-300 shadow-lg shadow-red-500/30{% else %}border-red-700/50{% endif %}
						{% endif %}">
						{% if entry.type == 'player' %}
							{{ entry.entity.name|first|upper }}
						{% else %}
							{{ entry.entity.name|first|upper }}
						{% endif %}
					</div>
					{# Nom tronque #}
					<span class="text-[8px] max-w-[2.5rem] truncate
						{% if isCurrent %}text-white font-semibold{% else %}text-gray-500{% endif %}">
						{{ entry.entity.name }}
					</span>
					{# Indicateur de vitesse #}
					{% if isCurrent %}
						<span class="text-[7px] text-purple-400">&#9650;</span>
					{% endif %}
				</div>
			{% endfor %}
		</div>
	</div>
</div>
{% endif %}

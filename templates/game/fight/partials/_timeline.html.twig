
<div class="mb-6">
	<div id="timeline" class="mb-8">
		<div class="bg-gray-800/80 backdrop-blur-sm rounded-xl border border-purple-500/20 p-6">
			<div class="flex items-center justify-between mb-4">
				<div class="flex items-center space-x-4">
					<h3 class="text-lg font-bold text-white">Séquence</h3>
					<div class="flex items-center space-x-2 px-3 py-1 bg-gray-700/50 rounded-lg">
						<span class="text-sm text-gray-400">Tour</span>
						<span class="text-sm font-bold text-purple-400" id="current-turn">1</span>
					</div>
				</div>
			</div>

			<div
				class="space-y-4">
				<!-- Barre de progression du tour -->
				<div class="w-full h-1 bg-gray-700 rounded-full overflow-hidden">
					<div class="h-full bg-purple-500 rounded-full timeline-progress transition-all duration-300" style="width: 50%;"></div>
				</div>

				<!-- Séquence des actions -->
				<div class="flex items-center justify-center space-x-2">
					{% for action in [
						{"id": 1, "actor": "J1", "type": "player", "status": "current", "details": {"vie": 100, "énergie": 50}},
						{"id": 2, "actor": "M1", "type": "mob", "status": "pending", "details": {"vie": 80, "dégâts": 15}},
						{"id": 3, "actor": "J2", "type": "player", "status": "pending", "details": {"vie": 90, "énergie": 60}},
						{"id": 4, "actor": "M2", "type": "mob", "status": "pending", "details": {"vie": 70, "dégâts": 20}}
					] %}
						{% if action.status != "completed" %}
							<div class="action-card {% if action.status == 'current' %}bg-purple-900/30 border-purple-500{% else %}bg-gray-700/30 border-gray-600{% endif %} rounded-lg border p-2 transform transition-all duration-300 {% if action.status == 'current' %}scale-105{% endif %} cursor-pointer hover:bg-gray-700/50" 
								 data-action-id="{{ action.id }}"
								 data-details="{{ action.details|json_encode|e('html_attr') }}"
								 onclick="showActionDetails(this)">
								<div class="w-8 h-8 rounded-full {% if action.type == 'player' %}bg-gradient-to-br from-purple-500 to-purple-700{% else %}bg-gradient-to-br from-red-500 to-red-700{% endif %} flex items-center justify-center text-sm text-white">
									{{ action.actor }}
								</div>
							</div>
						{% endif %}
					{% endfor %}
				</div>
			</div>
		</div>
	</div>

	<!-- Modal pour les détails -->
	<div id="action-details-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
		<div class="bg-gray-800 rounded-lg p-6 max-w-md w-full mx-4 relative">
			<button class="absolute top-4 right-4 text-gray-400 hover:text-white transition-colors duration-200" onclick="closeActionModal()">
				<i class="fas fa-times text-xl"></i>
			</button>
			<div class="flex justify-between items-center mb-4">
				<h3 class="text-lg font-bold text-white">Détails</h3>
			</div>
			<div id="action-details-content" class="space-y-4">
				<!-- Les détails seront injectés ici via JavaScript -->
			</div>
		</div>
	</div>

	<script>
		function showActionDetails(element) {
			const details = JSON.parse(element.dataset.details);
			const modal = document.getElementById('action-details-modal');
			const content = document.getElementById('action-details-content');
			
			let detailsHtml = '';
			for (const [key, value] of Object.entries(details)) {
				detailsHtml += `
					<div class="flex justify-between items-center">
						<span class="text-gray-400">${key.charAt(0).toUpperCase() + key.slice(1)}</span>
						<span class="text-white font-medium">${value}</span>
					</div>
				`;
			}
			
			content.innerHTML = detailsHtml;
			modal.classList.remove('hidden');
		}

		function closeActionModal() {
			document.getElementById('action-details-modal').classList.add('hidden');
		}

		// Fermer la modal en cliquant sur le fond
		document.getElementById('action-details-modal').addEventListener('click', function(e) {
			if (e.target === this) {
				closeActionModal();
			}
		});

		// Fermer la modal avec la touche Escape
		document.addEventListener('keydown', function(e) {
			if (e.key === 'Escape') {
				closeActionModal();
			}
		});
	</script>
</div>
{% extends 'game/game.html.twig' %}

{% block title %}Boutique - {{ pnj.name }}{% endblock %}

{% block game_content %}
<div class="game-page">
    <div class="game-card">
        {# Header #}
        <div class="game-card-header flex items-center justify-between">
            <div>
                <h2 class="text-base sm:text-lg font-semibold text-white">{{ pnj.name }}</h2>
                <p class="text-purple-200/70 text-xs">
                    Marchand
                    {% if opensAt is not null and closesAt is not null %}
                        <span class="ml-1">({{ opensAt }}h - {{ closesAt }}h)</span>
                    {% endif %}
                    {% if not isOpen %}
                        <span class="ml-1 text-red-400 font-semibold">— Fermé</span>
                    {% endif %}
                </p>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-yellow-400 font-bold text-sm sm:text-base" id="player-gils">{{ player.gils }} Gils</span>
                <a href="{{ path('app_game_map') }}" class="text-purple-200/70 hover:text-white text-xs sm:text-sm">Retour</a>
            </div>
        </div>
        <div class="game-card-body">

        {% if not isOpen %}
            <div class="bg-red-900/30 border border-red-700/50 rounded-lg p-4 mb-4 text-center">
                <p class="text-red-300 text-sm">La boutique est fermée. Revenez entre {{ opensAt }}h et {{ closesAt }}h.</p>
            </div>
        {% endif %}

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            {# Buy section #}
            <div>
                <h3 class="text-lg font-semibold text-purple-300 mb-3 border-b border-gray-700 pb-2">Acheter</h3>
                {% if shopItems is empty %}
                    <p class="text-gray-500 text-sm">Aucun objet en vente.</p>
                {% else %}
                    <div class="space-y-2">
                        {% for item in shopItems %}
                            <div class="flex items-center justify-between bg-gray-700/50 rounded-lg p-3 hover:bg-gray-700 transition-colors"
                                 data-item-slug="{{ item.slug }}">
                                <div class="flex-1 min-w-0">
                                    <span class="font-medium text-sm {% if item.rarity == 'amethyst' %}text-fuchsia-400{% elseif item.rarity == 'legendary' %}text-yellow-400{% elseif item.rarity == 'epic' %}text-purple-300{% elseif item.rarity == 'rare' %}text-blue-300{% elseif item.rarity == 'uncommon' %}text-green-300{% else %}text-white{% endif %}">{{ item.name }}</span>
                                    {% if item.rarity and item.rarity != 'common' %}
                                        <span class="text-[9px] ml-1 inv-tooltip-rarity inv-tooltip-rarity--{{ item.rarity }}">{{ item.rarity|capitalize }}</span>
                                    {% endif %}
                                    <p class="text-gray-400 text-xs truncate">{{ item.description|slice(0, 60) }}{% if item.description|length > 60 %}...{% endif %}</p>
                                </div>
                                <div class="flex items-center gap-3 ml-3">
                                    <span class="text-yellow-400 text-sm font-mono whitespace-nowrap">{{ item.price }} G</span>
                                    <button onclick="buyItem('{{ item.slug }}', '{{ item.name }}', {{ item.price }}, {{ pnj.id }})"
                                            class="px-3 py-2 bg-purple-600 hover:bg-purple-500 active:bg-purple-700 text-white text-xs rounded-lg transition-colors touch-target{% if player.gils < item.price %} opacity-50 cursor-not-allowed{% endif %}"
                                            {% if player.gils < item.price %}disabled{% endif %}>
                                        Acheter
                                    </button>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {# Sell section #}
            <div>
                <h3 class="text-lg font-semibold text-purple-300 mb-3 border-b border-gray-700 pb-2">Vendre</h3>
                {% set bag = player.inventories|first %}
                {% if bag and bag.items|length > 0 %}
                    <div class="space-y-2 max-h-96 overflow-y-auto">
                        {% for playerItem in bag.items %}
                            <div class="flex items-center justify-between bg-gray-700/50 rounded-lg p-3 hover:bg-gray-700 transition-colors"
                                 id="sell-item-{{ playerItem.id }}">
                                <div class="flex-1 min-w-0">
                                    <span class="font-medium text-sm {% if playerItem.genericItem.rarity == 'amethyst' %}text-fuchsia-400{% elseif playerItem.genericItem.rarity == 'legendary' %}text-yellow-400{% elseif playerItem.genericItem.rarity == 'epic' %}text-purple-300{% elseif playerItem.genericItem.rarity == 'rare' %}text-blue-300{% elseif playerItem.genericItem.rarity == 'uncommon' %}text-green-300{% else %}text-white{% endif %}">{{ playerItem.genericItem.name }}</span>
                                    <span class="text-gray-500 text-xs ml-1">({{ playerItem.genericItem.type }})</span>
                                </div>
                                <div class="flex items-center gap-3 ml-3">
                                    <span class="text-yellow-400 text-sm font-mono whitespace-nowrap">{{ max(1, (playerItem.genericItem.price * 0.3)|round) }} G</span>
                                    <button onclick="sellItem({{ playerItem.id }}, '{{ playerItem.genericItem.name }}', {{ pnj.id }})"
                                            class="px-3 py-2 bg-red-600/80 hover:bg-red-500 active:bg-red-700 text-white text-xs rounded-lg transition-colors touch-target">
                                        Vendre
                                    </button>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="text-gray-500 text-sm">Votre inventaire est vide.</p>
                {% endif %}
            </div>
        </div>

        {# Messages area #}
        <div id="shop-messages" class="mt-4 hidden">
            <div class="bg-green-900/50 border border-green-700 rounded-lg p-3 text-green-300 text-sm" id="shop-message-text"></div>
        </div>
        </div>{# end game-card-body #}
    </div>
</div>

<script>
async function buyItem(slug, name, price, pnjId) {
    try {
        const resp = await fetch(`/game/shop/${pnjId}/buy`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ itemSlug: slug, quantity: 1 }),
        });
        const data = await resp.json();
        if (data.success) {
            showMessage(data.message);
            document.getElementById('player-gils').textContent = data.gils + ' Gils';
            // Reload page to update sell list
            setTimeout(() => location.reload(), 800);
        } else {
            showMessage(data.error || 'Erreur', true);
        }
    } catch (e) {
        showMessage('Erreur de connexion', true);
    }
}

async function sellItem(playerItemId, name, pnjId) {
    try {
        const resp = await fetch(`/game/shop/${pnjId}/sell`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ playerItemId }),
        });
        const data = await resp.json();
        if (data.success) {
            showMessage(data.message);
            document.getElementById('player-gils').textContent = data.gils + ' Gils';
            const el = document.getElementById(`sell-item-${playerItemId}`);
            if (el) el.remove();
        } else {
            showMessage(data.error || 'Erreur', true);
        }
    } catch (e) {
        showMessage('Erreur de connexion', true);
    }
}

function showMessage(msg, isError = false) {
    const container = document.getElementById('shop-messages');
    const text = document.getElementById('shop-message-text');
    container.classList.remove('hidden');
    text.textContent = msg;
    text.className = isError
        ? 'bg-red-900/50 border border-red-700 rounded-lg p-3 text-red-300 text-sm'
        : 'bg-green-900/50 border border-green-700 rounded-lg p-3 text-green-300 text-sm';
    setTimeout(() => container.classList.add('hidden'), 3000);
}
</script>
{% endblock %}

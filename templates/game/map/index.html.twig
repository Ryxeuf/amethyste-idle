{% extends 'game/game.html.twig' %}

{% block title %}{{ 'game.map.title'|trans }}{% endblock %}

{% block game_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-purple-400 mb-4">{{ 'game.map.title'|trans }}</h1>
        <p class="text-gray-300">{{ 'game.map.description'|trans }}</p>
    </div>
    
    <!-- Carte du monde -->
    <div class="bg-gray-800 rounded-lg shadow-lg p-6 mb-8">
        <div class="flex flex-col md:flex-row">
            <!-- Carte interactive -->
            <div class="w-full md:w-3/4 mb-6 md:mb-0 md:pr-6">
                <div class="bg-gray-700 rounded-lg p-4 h-96 relative overflow-hidden" id="world-map">
                    <!-- Fond de carte stylisé -->
                    <div class="absolute inset-0 bg-gray-900 opacity-50 z-0"></div>
                    
                    <!-- Régions de la carte (à remplacer par une vraie carte interactive) -->
                    <div class="relative z-10 h-full">
                        <!-- Région 1: Forêt -->
                        <div class="absolute top-1/4 left-1/4 transform -translate-x-1/2 -translate-y-1/2">
                            <div class="w-24 h-24 bg-green-800 rounded-full opacity-70 hover:opacity-90 transition cursor-pointer flex items-center justify-center region-marker" data-region="forest">
                                <div class="text-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mx-auto text-green-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                                    </svg>
                                    <span class="text-xs font-bold text-white">{{ 'game.map.regions.forest'|trans }}</span>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Région 2: Montagnes -->
                        <div class="absolute top-1/3 right-1/4 transform -translate-x-1/2 -translate-y-1/2">
                            <div class="w-24 h-24 bg-gray-600 rounded-full opacity-70 hover:opacity-90 transition cursor-pointer flex items-center justify-center region-marker" data-region="mountains">
                                <div class="text-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mx-auto text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                                    </svg>
                                    <span class="text-xs font-bold text-white">{{ 'game.map.regions.mountains'|trans }}</span>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Région 3: Désert -->
                        <div class="absolute bottom-1/4 right-1/3 transform -translate-x-1/2 -translate-y-1/2">
                            <div class="w-24 h-24 bg-yellow-800 rounded-full opacity-70 hover:opacity-90 transition cursor-pointer flex items-center justify-center region-marker" data-region="desert">
                                <div class="text-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mx-auto text-yellow-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
                                    </svg>
                                    <span class="text-xs font-bold text-white">{{ 'game.map.regions.desert'|trans }}</span>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Région 4: Marais -->
                        <div class="absolute bottom-1/3 left-1/3 transform -translate-x-1/2 -translate-y-1/2">
                            <div class="w-24 h-24 bg-purple-900 rounded-full opacity-70 hover:opacity-90 transition cursor-pointer flex items-center justify-center region-marker" data-region="swamp">
                                <div class="text-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mx-auto text-purple-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                    </svg>
                                    <span class="text-xs font-bold text-white">{{ 'game.map.regions.swamp'|trans }}</span>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Région 5: Capitale -->
                        <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
                            <div class="w-32 h-32 bg-blue-900 rounded-full opacity-80 hover:opacity-100 transition cursor-pointer flex items-center justify-center region-marker" data-region="capital">
                                <div class="text-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mx-auto text-blue-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                                    </svg>
                                    <span class="text-sm font-bold text-white">{{ 'game.map.regions.capital'|trans }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Informations sur la région sélectionnée -->
            <div class="w-full md:w-1/4">
                <div class="bg-gray-700 rounded-lg p-4 h-full" id="region-info">
                    <h2 class="text-xl font-semibold text-purple-400 mb-4">{{ 'game.map.select_region'|trans }}</h2>
                    <div id="region-details" class="hidden">
                        <h3 class="text-lg font-medium text-white mb-2" id="region-name"></h3>
                        <p class="text-gray-300 mb-4" id="region-description"></p>
                        
                        <div class="mb-4">
                            <h4 class="text-sm font-medium text-gray-400 mb-1">{{ 'game.map.difficulty'|trans }}</h4>
                            <div class="flex" id="region-difficulty">
                                <!-- Les étoiles seront ajoutées dynamiquement -->
                            </div>
                        </div>
                        
                        <div class="mb-4">
                            <h4 class="text-sm font-medium text-gray-400 mb-1">{{ 'game.map.resources'|trans }}</h4>
                            <ul class="list-disc list-inside text-gray-300" id="region-resources">
                                <!-- Les ressources seront ajoutées dynamiquement -->
                            </ul>
                        </div>
                        
                        <div class="mb-4">
                            <h4 class="text-sm font-medium text-gray-400 mb-1">{{ 'game.map.enemies'|trans }}</h4>
                            <ul class="list-disc list-inside text-gray-300" id="region-enemies">
                                <!-- Les ennemis seront ajoutés dynamiquement -->
                            </ul>
                        </div>
                        
                        <button id="explore-btn" class="w-full bg-purple-600 hover:bg-purple-700 text-white font-medium py-2 px-4 rounded focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-opacity-50 transition">
                            {{ 'game.map.explore'|trans }}
                        </button>
                    </div>
                    <div id="region-placeholder" class="text-gray-400 text-center py-8">
                        {{ 'game.map.click_region'|trans }}
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Quêtes disponibles dans la région -->
    <div class="bg-gray-800 rounded-lg shadow-lg p-6 mb-8 hidden" id="region-quests">
        <h2 class="text-xl font-semibold text-purple-400 mb-4">{{ 'game.map.available_quests'|trans }}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="quests-list">
            <!-- Les quêtes seront ajoutées dynamiquement -->
            <div class="bg-gray-700 rounded-lg p-4 flex flex-col hover:bg-gray-600 transition cursor-pointer">
                <div class="flex items-center mb-3">
                    <div class="w-10 h-10 bg-red-900 rounded-md flex items-center justify-center mr-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                        </svg>
                    </div>
                    <div class="flex-1">
                        <h3 class="text-white font-medium">{{ 'game.map.quest_example.title'|trans }}</h3>
                        <div class="flex items-center">
                            <span class="text-xs text-gray-400 mr-2">{{ 'game.map.difficulty'|trans }}:</span>
                            <div class="flex">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                            </div>
                        </div>
                    </div>
                    <div class="text-sm font-semibold text-white bg-gray-800 px-2 py-1 rounded">
                        <span class="text-yellow-400">+150</span> XP
                    </div>
                </div>
                <p class="text-sm text-gray-300 mt-1">{{ 'game.map.quest_example.description'|trans }}</p>
                <div class="mt-4 flex justify-between items-center">
                    <div class="text-xs text-gray-400">
                        {{ 'game.map.energy_cost'|trans }}: <span class="text-purple-400 font-medium">25</span>
                    </div>
                    <button class="bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium py-1 px-3 rounded focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-opacity-50 transition">
                        {{ 'game.map.start_quest'|trans }}
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Points d'intérêt découverts -->
    <div class="bg-gray-800 rounded-lg shadow-lg p-6">
        <h2 class="text-xl font-semibold text-purple-400 mb-4">{{ 'game.map.discovered_locations'|trans }}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="locations-list">
            <!-- Exemple de point d'intérêt -->
            <div class="bg-gray-700 rounded-lg p-4 flex flex-col hover:bg-gray-600 transition cursor-pointer">
                <div class="flex items-center mb-3">
                    <div class="w-10 h-10 bg-blue-900 rounded-md flex items-center justify-center mr-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-white font-medium">{{ 'game.map.location_example.title'|trans }}</h3>
                        <p class="text-xs text-gray-400">{{ 'game.map.regions.capital'|trans }}</p>
                    </div>
                </div>
                <p class="text-sm text-gray-300 mt-1">{{ 'game.map.location_example.description'|trans }}</p>
                <div class="mt-4 text-right">
                    <button class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-1 px-3 rounded focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-opacity-50 transition">
                        {{ 'game.map.fast_travel'|trans }}
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Sélection des éléments
    const regionMarkers = document.querySelectorAll('.region-marker');
    const regionDetails = document.getElementById('region-details');
    const regionPlaceholder = document.getElementById('region-placeholder');
    const regionName = document.getElementById('region-name');
    const regionDescription = document.getElementById('region-description');
    const regionDifficulty = document.getElementById('region-difficulty');
    const regionResources = document.getElementById('region-resources');
    const regionEnemies = document.getElementById('region-enemies');
    const regionQuests = document.getElementById('region-quests');
    
    // Données des régions (à remplacer par des données dynamiques)
    const regions = {
        'forest': {
            name: '{{ "game.map.regions.forest"|trans }}',
            description: '{{ "game.map.region_descriptions.forest"|trans }}',
            difficulty: 2,
            resources: [
                '{{ "game.map.resources.wood"|trans }}',
                '{{ "game.map.resources.herbs"|trans }}',
                '{{ "game.map.resources.fruits"|trans }}'
            ],
            enemies: [
                '{{ "game.map.enemies.wolf"|trans }}',
                '{{ "game.map.enemies.bandit"|trans }}',
                '{{ "game.map.enemies.spider"|trans }}'
            ]
        },
        'mountains': {
            name: '{{ "game.map.regions.mountains"|trans }}',
            description: '{{ "game.map.region_descriptions.mountains"|trans }}',
            difficulty: 4,
            resources: [
                '{{ "game.map.resources.stone"|trans }}',
                '{{ "game.map.resources.ore"|trans }}',
                '{{ "game.map.resources.crystal"|trans }}'
            ],
            enemies: [
                '{{ "game.map.enemies.troll"|trans }}',
                '{{ "game.map.enemies.golem"|trans }}',
                '{{ "game.map.enemies.dragon"|trans }}'
            ]
        },
        'desert': {
            name: '{{ "game.map.regions.desert"|trans }}',
            description: '{{ "game.map.region_descriptions.desert"|trans }}',
            difficulty: 3,
            resources: [
                '{{ "game.map.resources.sand"|trans }}',
                '{{ "game.map.resources.cactus"|trans }}',
                '{{ "game.map.resources.fossil"|trans }}'
            ],
            enemies: [
                '{{ "game.map.enemies.scorpion"|trans }}',
                '{{ "game.map.enemies.mummy"|trans }}',
                '{{ "game.map.enemies.sandworm"|trans }}'
            ]
        },
        'swamp': {
            name: '{{ "game.map.regions.swamp"|trans }}',
            description: '{{ "game.map.region_descriptions.swamp"|trans }}',
            difficulty: 3,
            resources: [
                '{{ "game.map.resources.mushroom"|trans }}',
                '{{ "game.map.resources.poison"|trans }}',
                '{{ "game.map.resources.moss"|trans }}'
            ],
            enemies: [
                '{{ "game.map.enemies.frog"|trans }}',
                '{{ "game.map.enemies.witch"|trans }}',
                '{{ "game.map.enemies.slime"|trans }}'
            ]
        },
        'capital': {
            name: '{{ "game.map.regions.capital"|trans }}',
            description: '{{ "game.map.region_descriptions.capital"|trans }}',
            difficulty: 1,
            resources: [
                '{{ "game.map.resources.gold"|trans }}',
                '{{ "game.map.resources.food"|trans }}',
                '{{ "game.map.resources.knowledge"|trans }}'
            ],
            enemies: [
                '{{ "game.map.enemies.thief"|trans }}',
                '{{ "game.map.enemies.guard"|trans }}',
                '{{ "game.map.enemies.noble"|trans }}'
            ]
        }
    };
    
    // Gestion des clics sur les régions
    regionMarkers.forEach(marker => {
        marker.addEventListener('click', function() {
            const regionId = this.dataset.region;
            const region = regions[regionId];
            
            // Afficher les détails de la région
            regionName.textContent = region.name;
            regionDescription.textContent = region.description;
            
            // Afficher la difficulté
            regionDifficulty.innerHTML = '';
            for (let i = 0; i < 5; i++) {
                const star = document.createElement('svg');
                star.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
                star.setAttribute('class', 'h-5 w-5 ' + (i < region.difficulty ? 'text-yellow-400' : 'text-gray-600'));
                star.setAttribute('viewBox', '0 0 20 20');
                star.setAttribute('fill', 'currentColor');
                star.innerHTML = '<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />';
                regionDifficulty.appendChild(star);
            }
            
            // Afficher les ressources
            regionResources.innerHTML = '';
            region.resources.forEach(resource => {
                const li = document.createElement('li');
                li.textContent = resource;
                regionResources.appendChild(li);
            });
            
            // Afficher les ennemis
            regionEnemies.innerHTML = '';
            region.enemies.forEach(enemy => {
                const li = document.createElement('li');
                li.textContent = enemy;
                regionEnemies.appendChild(li);
            });
            
            // Afficher les détails et masquer le placeholder
            regionDetails.classList.remove('hidden');
            regionPlaceholder.classList.add('hidden');
            
            // Afficher les quêtes de la région
            regionQuests.classList.remove('hidden');
        });
    });
    
    // Gestion du bouton d'exploration
    document.getElementById('explore-btn').addEventListener('click', function() {
        alert('{{ "game.map.exploration_message"|trans }}');
    });
});
</script>
{% endblock %} 
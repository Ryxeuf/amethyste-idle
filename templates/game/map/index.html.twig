{% extends 'game/game.html.twig' %}

{% block title %}{{ 'game.map.title'|trans }}{% endblock %}

{% block game_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 sm:py-8">
    <div class="bg-gray-800 rounded-lg shadow-lg p-2 sm:p-6 mb-4 sm:mb-8">
        <h2 class="text-xl font-semibold text-purple-400 mb-2 sm:mb-4 hidden sm:block">{{ 'game.map.live_map'|trans }}</h2>
        <div class="relative flex justify-center items-center"
             role="application"
             aria-label="{{ 'game.map.aria_label'|trans({}, 'messages')|default('Carte du monde interactive') }}">
            {# Map canvas container — landscape-aware aspect ratio #}
            <div class="bg-gray-700 rounded-lg p-0 sm:p-4 flex justify-center items-center"
                 {{ stimulus_controller('map_pixi', {
                     mercureUrl: (mercure_url is defined and mercure_url starts with 'http') ? mercure_url : (app.request.schemeAndHttpHost ~ '/.well-known/mercure'),
                     playerId: playerId,
                     mapId: mapId,
                     playerX: playerX,
                     playerY: playerY,
                     stepDelay: 120,
                 }) }}
                 data-action="dialog:closed->map_pixi#onDialogClosed"
                 style="width: 100%; max-width: 672px; aspect-ratio: 1; touch-action: none;">
            </div>

            {# Virtual joystick (mobile only) #}
            <div {{ stimulus_controller('joystick') }}
                 data-action="joystick:move->map_pixi#onJoystickMove"
                 class="absolute inset-0 pointer-events-none sm:hidden"
                 aria-hidden="true">
            </div>

            {# Harvest overlay #}
            <div {{ stimulus_controller('harvest') }}
                 data-action="map_pixi:harvestSpot->harvest#open harvest:startFishing->fishing#open"
                 class="absolute inset-0 pointer-events-none flex items-start justify-center p-2 sm:p-4"
                 aria-label="Panneau de récolte">
                <div data-harvest-target="panel"
                     class="hidden pointer-events-auto w-full max-w-sm bg-gray-900/95 border border-amber-500 rounded-lg shadow-2xl p-4 backdrop-blur-sm mt-2">
                    <div class="flex items-center justify-between mb-2">
                        <span data-harvest-target="spotName"
                              class="text-amber-400 font-bold text-sm"></span>
                        <button data-action="click->harvest#close"
                                class="text-gray-500 hover:text-white text-xs px-2 py-1">&#x2715;</button>
                    </div>
                    <p data-harvest-target="toolType" class="text-gray-400 text-xs mb-2"></p>
                    <button data-harvest-target="harvestBtn"
                            data-action="click->harvest#harvest"
                            class="w-full px-4 py-2 bg-amber-700 hover:bg-amber-600 text-white rounded text-sm transition-colors mb-2">
                        Récolter
                    </button>
                    <div class="h-1 bg-gray-700 rounded-full overflow-hidden mb-2">
                        <div data-harvest-target="cooldownBar"
                             class="h-full bg-amber-500 transition-all duration-1000"
                             style="width: 100%"></div>
                    </div>
                    <p data-harvest-target="message" class="text-sm mt-1"></p>
                    <div data-harvest-target="resultList"></div>
                </div>
            </div>

            {# Fishing mini-game overlay #}
            <div {{ stimulus_controller('fishing') }}
                 class="absolute inset-0 pointer-events-none flex items-center justify-center p-2 sm:p-4"
                 aria-label="Mini-jeu de pêche">
                <div data-fishing-target="panel"
                     class="hidden pointer-events-auto w-full max-w-sm bg-gray-900/95 border border-blue-500 rounded-lg shadow-2xl p-4 backdrop-blur-sm">
                    <div class="flex items-center justify-between mb-2">
                        <span data-fishing-target="spotName"
                              class="text-blue-400 font-bold text-sm"></span>
                        <button data-action="click->fishing#close"
                                class="text-gray-500 hover:text-white text-xs px-2 py-1">&#x2715;</button>
                    </div>
                    {# Tension bar #}
                    <div data-fishing-target="bar"
                         class="relative w-full h-6 bg-gray-700 rounded-full overflow-hidden my-3">
                        {# Success zone (30-70%) #}
                        <div class="absolute h-full bg-green-700/50" style="left: 30%; width: 40%"></div>
                        {# Danger zones #}
                        <div class="absolute h-full bg-red-800/30" style="left: 0; width: 30%"></div>
                        <div class="absolute h-full bg-red-800/30" style="left: 70%; width: 30%"></div>
                        {# Moving indicator #}
                        <div data-fishing-target="indicator"
                             class="absolute top-0 h-full w-1.5 bg-white rounded"
                             style="left: 50%"></div>
                    </div>
                    <button data-fishing-target="catchBtn"
                            data-action="click->fishing#catch"
                            class="w-full px-4 py-2 bg-blue-700 hover:bg-blue-600 text-white rounded text-sm transition-colors font-bold">
                        Ferrer !
                    </button>
                    <p data-fishing-target="message" class="text-gray-300 text-xs mt-2 text-center"></p>
                </div>
            </div>

            {# Dialog overlay #}
            <div {{ stimulus_controller('dialog') }}
                 data-action="map_pixi:pnjDialog->dialog#open"
                 class="absolute inset-0 pointer-events-none flex items-end justify-center p-2 sm:p-4"
                 role="dialog"
                 aria-label="{{ 'game.map.dialog_aria'|trans({}, 'messages')|default('Dialogue PNJ') }}">
                <div data-dialog-target="box"
                     class="hidden pointer-events-auto w-full max-w-lg bg-gray-900/95 border border-purple-500 rounded-lg shadow-2xl p-4 backdrop-blur-sm">
                    {# PNJ name #}
                    <div class="flex items-center justify-between mb-2">
                        <span data-dialog-target="name"
                              class="text-purple-400 font-bold text-sm"></span>
                        <button data-action="click->dialog#close"
                                class="text-gray-500 hover:text-white text-xs px-2 py-1"
                                aria-label="{{ 'game.map.close_dialog'|trans({}, 'messages')|default('Fermer le dialogue') }}">&#x2715;</button>
                    </div>
                    {# Dialog text #}
                    <p data-dialog-target="text"
                       class="text-gray-200 text-sm leading-relaxed mb-3 min-h-[3rem]"
                       aria-live="polite"></p>
                    {# Choices #}
                    <div data-dialog-target="choices"
                         class="hidden flex flex-wrap gap-2 mb-2"
                         role="group"
                         aria-label="{{ 'game.map.dialog_choices'|trans({}, 'messages')|default('Choix de dialogue') }}"></div>
                    {# Next button #}
                    <button data-dialog-target="nextBtn"
                            data-action="click->dialog#next"
                            class="w-full text-center text-purple-400 hover:text-purple-300 text-xs py-1 transition-colors">
                        ▼ {{ 'game.map.dialog_next'|trans({}, 'messages')|default('Continuer') }}
                    </button>
                    {# Keyboard hint (desktop) #}
                    <p class="hidden sm:block text-gray-600 text-[10px] text-center mt-1">
                        Espace/Entrée: suivant · Échap: fermer
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

{# Landscape orientation hint for mobile #}
<style>
@media (max-height: 500px) and (orientation: landscape) {
    .max-w-7xl { padding-top: 0.25rem !important; padding-bottom: 0.25rem !important; }
    .bg-gray-800 { padding: 0.25rem !important; margin-bottom: 0.25rem !important; }
    h2.hidden { display: none !important; }
}
</style>
{% endblock %}

{% extends 'game/game.html.twig' %}

{% block title %}{{ 'game.map.title'|trans }}{% endblock %}

{% block game_content %}
<div class="map-fullscreen-mobile">
    <div class="bg-gray-800 sm:rounded-lg sm:shadow-lg p-0 sm:p-4 lg:p-6">
        <h2 class="text-lg font-semibold text-purple-400 mb-3 px-4 pt-3 sm:px-0 sm:pt-0 hidden sm:block">{{ 'game.map.live_map'|trans }}</h2>
        <div class="relative flex justify-center items-center"
             role="application"
             aria-label="{{ 'game.map.aria_label'|trans({}, 'messages')|default('Carte du monde interactive') }}">
            {# Map canvas — takes full width on mobile, capped on desktop #}
            <div class="bg-gray-700 sm:rounded-lg flex justify-center items-center map-canvas-container"
                 {{ stimulus_controller('map_pixi', {
                     mercureUrl: (mercure_url is defined and mercure_url starts with 'http') ? mercure_url : (app.request.schemeAndHttpHost ~ '/.well-known/mercure'),
                     playerId: playerId,
                     mapId: mapId,
                     playerX: playerX,
                     playerY: playerY,
                     stepDelay: stepDelay,
                 }) }}
                 data-action="dialog:closed@document->map-pixi#onDialogClosed harvest:harvestSuccess@document->map-pixi#onHarvestSuccess">
            </div>

            {# Harvest overlay #}
            <div {{ stimulus_controller('harvest') }}
                 data-action="map-pixi:harvestSpot@document->harvest#open map-pixi:playerMoveStart@document->harvest#onPlayerMove"
                 class="absolute inset-0 pointer-events-none flex items-start justify-center p-2 sm:p-4"
                 aria-label="Panneau de recolte">
                <div data-harvest-target="panel"
                     class="hidden pointer-events-auto w-full max-w-sm bg-gray-900/95 border border-amber-500/60 rounded-2xl shadow-2xl backdrop-blur-sm mt-2 overflow-hidden">

                    {# Header with spot name, domain badge, close button #}
                    <div class="flex items-center justify-between px-4 pt-3 pb-2 border-b border-gray-700/50">
                        <div class="flex items-center gap-2 min-w-0">
                            <span data-harvest-target="spotIcon" class="text-lg shrink-0">🌿</span>
                            <div class="min-w-0">
                                <span data-harvest-target="spotName"
                                      class="text-amber-400 font-bold text-sm block truncate"></span>
                                <span data-harvest-target="domainBadge"
                                      class="hidden text-[10px] text-emerald-400/80 font-medium"></span>
                            </div>
                        </div>
                        <button data-action="click->harvest#close keydown.escape@document->harvest#close"
                                class="text-gray-500 hover:text-white text-xs p-2 touch-target shrink-0 -mr-1"
                                aria-label="Fermer">&#x2715;</button>
                    </div>

                    <div class="px-4 py-3 space-y-3">
                        {# Loading skeleton #}
                        <div data-harvest-target="loading" class="hidden">
                            <div class="flex flex-col gap-2 animate-pulse">
                                <div class="h-3 bg-gray-700 rounded w-3/4"></div>
                                <div class="h-8 bg-gray-700 rounded"></div>
                                <div class="h-3 bg-gray-700 rounded w-1/2"></div>
                            </div>
                        </div>

                        {# Content (hidden while loading) #}
                        <div data-harvest-target="content" class="space-y-3">

                            {# Tool info bar #}
                            <div data-harvest-target="toolInfo" class="hidden">
                                <div class="flex items-center justify-between text-xs mb-1">
                                    <span class="text-gray-400 flex items-center gap-1">
                                        <span data-harvest-target="toolIcon" class="text-sm">⛏️</span>
                                        <span data-harvest-target="toolName" class="text-gray-300"></span>
                                    </span>
                                    <span data-harvest-target="toolDurabilityText" class="text-gray-500 tabular-nums"></span>
                                </div>
                                <div class="h-1.5 bg-gray-700/80 rounded-full overflow-hidden">
                                    <div data-harvest-target="toolDurabilityBar"
                                         class="h-full rounded-full transition-all duration-500"
                                         style="width: 100%"></div>
                                </div>
                            </div>

                            {# No tool warning #}
                            <div data-harvest-target="noToolWarning" class="hidden">
                                <div class="flex items-center gap-2 text-xs text-yellow-500 bg-yellow-500/10 rounded-lg px-3 py-2 border border-yellow-500/20">
                                    <span>⚠️</span>
                                    <span data-harvest-target="toolType">Outil requis</span>
                                </div>
                            </div>

                            {# Possible items grid #}
                            <div data-harvest-target="itemsSection" class="hidden">
                                <p class="text-[10px] text-gray-500 uppercase tracking-wider font-semibold mb-1.5">Ressources possibles</p>
                                <div data-harvest-target="itemList"
                                     class="grid grid-cols-2 gap-1.5"></div>
                            </div>

                            {# Harvest button #}
                            <button data-harvest-target="harvestBtn"
                                    data-action="click->harvest#harvest"
                                    class="w-full relative px-4 py-3 bg-gradient-to-r from-amber-700 to-amber-600 hover:from-amber-600 hover:to-amber-500 active:from-amber-800 active:to-amber-700 text-white rounded-xl text-sm font-semibold transition-all shadow-lg shadow-amber-900/30 touch-target overflow-hidden disabled:opacity-50 disabled:cursor-not-allowed">
                                <span data-harvest-target="harvestBtnText">Récolter</span>
                                {# Progress bar inside button #}
                                <div data-harvest-target="progressBar"
                                     class="absolute inset-0 bg-amber-400/20 origin-left transition-transform duration-[1500ms] ease-linear"
                                     style="transform: scaleX(0)"></div>
                            </button>

                            {# Keyboard hint #}
                            <p class="hidden sm:block text-gray-600 text-[10px] text-center">
                                Espace: récolter · Échap: fermer
                            </p>

                            {# Cooldown bar #}
                            <div data-harvest-target="cooldownSection" class="hidden">
                                <div class="flex items-center justify-between text-[10px] text-gray-500 mb-1">
                                    <span>Respawn</span>
                                    <span data-harvest-target="cooldownText" class="tabular-nums"></span>
                                </div>
                                <div class="h-1.5 bg-gray-700/80 rounded-full overflow-hidden">
                                    <div data-harvest-target="cooldownBar"
                                         class="h-full bg-amber-500/70 rounded-full transition-all duration-1000"
                                         style="width: 0%"></div>
                                </div>
                            </div>

                            {# Results section #}
                            <div data-harvest-target="resultSection" class="hidden">
                                <div class="border-t border-gray-700/50 pt-2">
                                    <p data-harvest-target="message" class="text-sm font-medium mb-1.5"></p>
                                    <div data-harvest-target="resultList" class="space-y-1"></div>
                                    <div data-harvest-target="xpGain"
                                         class="hidden mt-2 text-xs text-emerald-400 font-semibold flex items-center gap-1">
                                        <span>✦</span>
                                        <span data-harvest-target="xpGainText"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {# Fishing mini-game overlay #}
            <div {{ stimulus_controller('fishing') }}
                 data-action="harvest:startFishing@document->fishing#open map-pixi:playerMoveStart@document->fishing#onPlayerMove"
                 class="absolute inset-0 pointer-events-none flex items-center justify-center p-3 sm:p-4"
                 aria-label="Mini-jeu de peche">
                <div data-fishing-target="panel"
                     class="hidden pointer-events-auto w-full max-w-sm bg-gray-900/95 border border-blue-500 rounded-xl shadow-2xl p-4 backdrop-blur-sm">
                    <div class="flex items-center justify-between mb-2">
                        <span data-fishing-target="spotName"
                              class="text-blue-400 font-bold text-sm"></span>
                        <button data-action="click->fishing#close"
                                class="text-gray-500 hover:text-white text-xs p-2 touch-target">&#x2715;</button>
                    </div>
                    {# Tension bar #}
                    <div data-fishing-target="bar"
                         class="relative w-full h-8 bg-gray-700 rounded-full overflow-hidden my-3">
                        <div class="absolute h-full bg-green-700/50" style="left: 30%; width: 40%"></div>
                        <div class="absolute h-full bg-red-800/30" style="left: 0; width: 30%"></div>
                        <div class="absolute h-full bg-red-800/30" style="left: 70%; width: 30%"></div>
                        <div data-fishing-target="indicator"
                             class="absolute top-0 h-full w-2 bg-white rounded"
                             style="left: 50%"></div>
                    </div>
                    <button data-fishing-target="catchBtn"
                            data-action="click->fishing#catch"
                            class="w-full px-4 py-3 bg-blue-700 hover:bg-blue-600 active:bg-blue-800 text-white rounded-lg text-sm transition-colors font-bold touch-target">
                        Ferrer !
                    </button>
                    <p data-fishing-target="message" class="text-gray-300 text-xs mt-2 text-center"></p>
                </div>
            </div>

            {# Dialog overlay #}
            <div {{ stimulus_controller('dialog') }}
                 data-action="map-pixi:pnjDialog@document->dialog#open"
                 class="absolute inset-0 pointer-events-none flex items-end justify-center p-2 sm:p-4"
                 role="dialog"
                 aria-label="{{ 'game.map.dialog_aria'|trans({}, 'messages')|default('Dialogue PNJ') }}">
                <div data-dialog-target="box"
                     class="hidden pointer-events-auto w-full max-w-lg bg-gray-900/95 border border-purple-500 rounded-xl shadow-2xl p-4 backdrop-blur-sm mb-1 sm:mb-0">
                    {# PNJ portrait + name #}
                    <div class="flex items-center justify-between mb-2">
                        <div class="flex items-center gap-2">
                            <div data-dialog-target="portrait" class="hidden shrink-0"></div>
                            <span data-dialog-target="name"
                                  class="text-purple-400 font-bold text-sm"></span>
                        </div>
                        <button data-action="click->dialog#close"
                                class="text-gray-500 hover:text-white text-xs p-2 touch-target"
                                aria-label="{{ 'game.map.close_dialog'|trans({}, 'messages')|default('Fermer le dialogue') }}">&#x2715;</button>
                    </div>
                    {# Dialog text #}
                    <p data-dialog-target="text"
                       class="text-gray-200 text-sm leading-relaxed mb-3 min-h-[3rem]"
                       aria-live="polite"></p>
                    {# Choices #}
                    <div data-dialog-target="choices"
                         class="hidden flex flex-wrap gap-2 mb-2"
                         role="group"
                         aria-label="{{ 'game.map.dialog_choices'|trans({}, 'messages')|default('Choix de dialogue') }}"></div>
                    {# Next button #}
                    <button data-dialog-target="nextBtn"
                            data-action="click->dialog#next"
                            class="w-full text-center text-purple-400 hover:text-purple-300 text-sm py-2 transition-colors touch-target">
                        ▼ {{ 'game.map.dialog_next'|trans({}, 'messages')|default('Continuer') }}
                    </button>
                    {# Keyboard hint (desktop) #}
                    <p class="hidden sm:block text-gray-600 text-[10px] text-center mt-1">
                        Espace/Entree: suivant · Echap: fermer
                    </p>
                </div>
            </div>
            {# Mobile tap info banner (replaces hover tooltip on touch devices) #}
            <div id="mobile-tap-banner"
                 class="absolute bottom-14 left-0 right-0 pointer-events-none flex justify-center px-2 z-20 sm:hidden"
                 style="display: none;">
                <div class="bg-gray-900/95 border border-amber-500/50 rounded-lg px-3 py-1.5 backdrop-blur-sm shadow-lg flex items-center gap-2 max-w-xs">
                    <span id="mobile-tap-icon" class="text-sm"></span>
                    <div class="flex flex-col min-w-0">
                        <span id="mobile-tap-name" class="text-xs font-bold text-amber-400 truncate"></span>
                        <span id="mobile-tap-detail" class="text-[10px] text-gray-400 truncate"></span>
                    </div>
                </div>
            </div>

            {# Quick action bar #}
            <div {{ stimulus_controller('quickbar') }}
                 class="absolute bottom-0 left-0 right-0 pointer-events-auto flex justify-center p-1 sm:p-2"
                 aria-label="Barre d'action rapide">
                <div class="flex gap-1 sm:gap-1.5 bg-gray-900/90 backdrop-blur-sm rounded-lg px-2 py-1.5 border border-gray-700/50">
                    {% for i in 0..5 %}
                        <button data-quickbar-target="slot"
                                data-slot-index="{{ i }}"
                                data-action="click->quickbar#slotClick contextmenu->quickbar#slotRightClick"
                                class="relative w-11 h-11 sm:w-12 sm:h-12 rounded-lg bg-gray-800/80 border border-gray-700/50 flex flex-col items-center justify-center cursor-pointer hover:border-purple-500/50 hover:bg-gray-700/50 transition-all group"
                                title="Slot {{ i + 1 }} — Clic: utiliser, Clic droit: retirer">
                            <span data-key class="absolute top-0.5 left-1 text-[9px] text-gray-600 group-hover:text-gray-400 font-mono">{{ i + 1 }}</span>
                            <span data-name class="text-[9px] sm:text-[10px] text-gray-300 truncate max-w-[2.5rem] leading-tight mt-1"></span>
                            <span data-qty class="text-[8px] text-purple-400/70"></span>
                        </button>
                    {% endfor %}
                </div>

                {# Item picker modal #}
                <div data-quickbar-target="picker"
                     class="hidden absolute bottom-14 sm:bottom-16 left-1/2 -translate-x-1/2 w-64 max-h-56 bg-gray-900/95 border border-purple-500/40 rounded-xl shadow-2xl backdrop-blur-sm overflow-hidden z-10">
                    <div class="flex items-center justify-between px-3 py-2 border-b border-gray-700/50">
                        <span class="text-xs text-purple-400 font-semibold">Assigner un objet</span>
                        <button data-action="click->quickbar#closePicker"
                                class="text-gray-500 hover:text-white text-xs p-1">&#x2715;</button>
                    </div>
                    <div data-quickbar-target="pickerList"
                         class="overflow-y-auto max-h-44 p-1.5"></div>
                </div>
            </div>
        </div>
    </div>
</div>

{# Landscape compact mode #}
<style>
@media (max-height: 500px) and (orientation: landscape) {
    .map-fullscreen-mobile { padding: 0 !important; }
    .bg-gray-800 { padding: 0.125rem !important; margin-bottom: 0 !important; }
    h2.hidden { display: none !important; }
}
</style>
{% endblock %}

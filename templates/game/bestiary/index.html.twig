{% extends 'game/game.html.twig' %}

{% block title %}{{ 'game.bestiary.title'|trans }}{% endblock %}

{% block game_content %}
<div class="game-page">
    <div class="game-card">
        <div class="game-card-header flex items-center justify-between">
            <div>
                <h2 class="text-base sm:text-lg font-semibold text-white">{{ 'game.bestiary.title'|trans }}</h2>
                <p class="text-gray-400 text-xs mt-0.5">{{ 'game.bestiary.subtitle'|trans }}</p>
            </div>
        </div>

        <div class="game-card-body">
            {# Stats summary #}
            <div class="flex gap-4 mb-4 text-xs">
                <div class="bg-gray-700/50 rounded-lg px-3 py-2 border border-gray-600">
                    <span class="text-gray-400">{{ 'game.bestiary.discovered'|trans({'%count%': discoveredCount, '%total%': totalMonsters}) }}</span>
                </div>
                <div class="bg-gray-700/50 rounded-lg px-3 py-2 border border-gray-600">
                    <span class="text-gray-400">{{ 'game.bestiary.total_kills'|trans({'%count%': totalKills}) }}</span>
                </div>
            </div>

            {% if entries is empty %}
                <div class="text-center py-8">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-gray-600 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                    </svg>
                    <p class="text-gray-500 text-sm">{{ 'game.bestiary.empty'|trans }}</p>
                    <p class="text-gray-600 text-xs mt-1">{{ 'game.bestiary.empty_hint'|trans }}</p>
                </div>
            {% else %}
                <div class="space-y-2 sm:space-y-3">
                    {% for entry in entries %}
                        {% set monster = entry.monster %}
                        {% set nextTier = entry.nextTierThreshold %}
                        <div class="bg-gray-700/50 rounded-lg p-3 sm:p-4 border border-gray-600">
                            {# Header: name + level + badges #}
                            <div class="flex items-start justify-between gap-2 mb-2">
                                <div class="min-w-0">
                                    <div class="flex items-center gap-2">
                                        <h3 class="text-white font-semibold text-sm sm:text-base">{{ monster.name }}</h3>
                                        {% if monster.boss %}
                                            <span class="px-1.5 py-0.5 bg-red-900/60 border border-red-700 text-red-300 text-[10px] rounded">{{ 'game.bestiary.boss'|trans }}</span>
                                        {% endif %}
                                    </div>
                                    <p class="text-gray-400 text-xs mt-0.5">{{ 'game.bestiary.level'|trans({'%level%': monster.level}) }}</p>
                                </div>
                                <div class="flex items-center gap-1.5 flex-shrink-0">
                                    <span class="text-purple-400 text-xs font-mono">{{ 'game.bestiary.kills'|trans({'%count%': entry.killCount}) }}</span>
                                </div>
                            </div>

                            {# Tier badges #}
                            <div class="flex gap-1.5 mb-2">
                                <span class="px-1.5 py-0.5 rounded text-[10px] {% if entry.weaknessesRevealed %}bg-blue-900/60 border border-blue-700 text-blue-300{% else %}bg-gray-800 border border-gray-700 text-gray-500{% endif %}">
                                    {{ 'game.bestiary.tier_weaknesses'|trans }}
                                </span>
                                <span class="px-1.5 py-0.5 rounded text-[10px] {% if entry.lootTableRevealed %}bg-yellow-900/60 border border-yellow-700 text-yellow-300{% else %}bg-gray-800 border border-gray-700 text-gray-500{% endif %}">
                                    {{ 'game.bestiary.tier_loot'|trans }}
                                </span>
                                <span class="px-1.5 py-0.5 rounded text-[10px] {% if entry.hunterTitle %}bg-purple-900/60 border border-purple-700 text-purple-300{% else %}bg-gray-800 border border-gray-700 text-gray-500{% endif %}">
                                    {{ 'game.bestiary.tier_title'|trans({'%monster%': monster.name}) }}
                                </span>
                            </div>

                            {# Progress bar to next tier #}
                            {% if nextTier is not null %}
                                <div class="mt-2">
                                    <div class="flex justify-between text-[10px] text-gray-400 mb-1">
                                        <span>{{ 'game.bestiary.next_tier'|trans({'%kills%': entry.killCount, '%required%': nextTier}) }}</span>
                                        <span>{{ ((entry.killCount / nextTier) * 100)|round }}%</span>
                                    </div>
                                    <div class="progress-bar">
                                        <div class="progress-bar-fill bg-purple-500" style="width: {{ ((entry.killCount / nextTier) * 100)|round }}%"></div>
                                    </div>
                                </div>
                            {% endif %}

                            {# Weaknesses (tier 1) #}
                            {% if entry.weaknessesRevealed and monster.elementalResistances is not null %}
                                <div class="mt-2 pt-2 border-t border-gray-600">
                                    <span class="text-[10px] text-gray-500">{{ 'game.bestiary.weaknesses'|trans }} :</span>
                                    <div class="flex flex-wrap gap-2 mt-1">
                                        {% for element, value in monster.elementalResistances %}
                                            <span class="text-xs {% if value < 0 %}text-red-400{% elseif value > 0 %}text-green-400{% else %}text-gray-400{% endif %}">
                                                {{ element }} : {{ value > 0 ? '+' : '' }}{{ (value * 100)|round }}%
                                            </span>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}

                            {# Loot table (tier 2) #}
                            {% if entry.lootTableRevealed and monster.monsterItems is not empty %}
                                <div class="mt-2 pt-2 border-t border-gray-600">
                                    <span class="text-[10px] text-gray-500">{{ 'game.bestiary.loot_table'|trans }} :</span>
                                    <div class="space-y-0.5 mt-1">
                                        {% for monsterItem in monster.monsterItems %}
                                            <div class="flex items-center justify-between text-xs">
                                                <span class="text-gray-300">{{ monsterItem.item.name }}</span>
                                                <span class="text-gray-400">{{ 'game.bestiary.loot_probability'|trans({'%percent%': monsterItem.probability}) }}</span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}

                            {# Hunter title (tier 3) #}
                            {% if entry.hunterTitle %}
                                <div class="mt-2 pt-2 border-t border-gray-600">
                                    <span class="text-purple-300 text-xs font-medium">{{ 'game.bestiary.tier_title'|trans({'%monster%': monster.name}) }}</span>
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

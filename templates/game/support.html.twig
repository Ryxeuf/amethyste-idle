{% extends 'game/game.html.twig' %}

{% block title %}Soutenir le projet{% endblock %}

{% block game_content %}
<div class="game-page">
    <div class="max-w-2xl mx-auto space-y-6">

        {# Header #}
        <div class="game-card">
            <div class="game-card-header">
                <h1 class="text-base sm:text-xl font-bold text-white">Soutenir Amethyste</h1>
                <p class="text-purple-200/70 text-xs sm:text-sm mt-0.5">Aidez-nous a faire vivre le projet</p>
            </div>
            <div class="p-4 sm:p-6 space-y-4">
                <p class="text-gray-300 text-sm leading-relaxed">
                    Amethyste est un jeu <strong class="text-purple-400">100% gratuit</strong> et sans pay-to-win.
                    Pas de publicite, pas de loot boxes, pas d'avantage payant en combat.
                    Si le projet vous plait, vous pouvez nous soutenir pour financer les serveurs
                    et le developpement de nouvelles fonctionnalites.
                </p>
                <div class="flex items-center gap-2 text-xs text-gray-500 bg-gray-800/50 rounded-lg px-3 py-2 border border-gray-700/50">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                    <span>Votre soutien ne donne <strong class="text-gray-300">aucun avantage en jeu</strong>. C'est un don, pas un achat.</span>
                </div>
            </div>
        </div>

        {# Donation options #}
        <div class="game-card">
            <div class="p-4 sm:p-6">
                <h2 class="text-sm font-semibold text-purple-400 uppercase tracking-wider mb-4">Faire un don</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    {# Ko-fi #}
                    <a href="https://ko-fi.com/amethyste" target="_blank" rel="noopener noreferrer"
                       class="flex items-center gap-3 p-4 rounded-xl border border-gray-700/50 bg-gray-800/50 hover:bg-gray-700/50 hover:border-amber-500/30 transition-all group">
                        <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-amber-500/10 flex items-center justify-center">
                            <span class="text-xl">☕</span>
                        </div>
                        <div class="min-w-0">
                            <span class="text-sm font-medium text-white group-hover:text-amber-400 transition-colors">Ko-fi</span>
                            <p class="text-xs text-gray-400">Don ponctuel ou recurrent</p>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-600 group-hover:text-gray-400 ml-auto flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                    </a>

                    {# GitHub Sponsors #}
                    <a href="https://github.com/sponsors/ryxeuf" target="_blank" rel="noopener noreferrer"
                       class="flex items-center gap-3 p-4 rounded-xl border border-gray-700/50 bg-gray-800/50 hover:bg-gray-700/50 hover:border-pink-500/30 transition-all group">
                        <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-pink-500/10 flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-pink-400" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
                            </svg>
                        </div>
                        <div class="min-w-0">
                            <span class="text-sm font-medium text-white group-hover:text-pink-400 transition-colors">GitHub Sponsors</span>
                            <p class="text-xs text-gray-400">Sponsoring mensuel</p>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-600 group-hover:text-gray-400 ml-auto flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                    </a>
                </div>
            </div>
        </div>

        {# Community #}
        <div class="game-card">
            <div class="p-4 sm:p-6">
                <h2 class="text-sm font-semibold text-purple-400 uppercase tracking-wider mb-4">Rejoindre la communaute</h2>
                <a href="https://discord.gg/pe8Pw5Wsg" target="_blank" rel="noopener noreferrer"
                   class="flex items-center gap-3 p-4 rounded-xl border border-gray-700/50 bg-gray-800/50 hover:bg-gray-700/50 hover:border-indigo-500/30 transition-all group">
                    <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-indigo-500/10 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-400" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M20.317 4.369a19.791 19.791 0 0 0-4.885-1.515a.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0a12.64 12.64 0 0 0-.617-1.25a.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.369a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.056a19.9 19.9 0 0 0 5.993 3.03a.078.078 0 0 0 .084-.028a14.09 14.09 0 0 0 1.226-1.994a.076.076 0 0 0-.041-.106a13.107 13.107 0 0 1-1.872-.892a.077.077 0 0 1-.008-.128a10.2 10.2 0 0 0 .372-.292a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.099.246.197.373.292a.077.077 0 0 1-.006.128a12.299 12.299 0 0 1-1.873.891a.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.994a.076.076 0 0 0 .084.028a19.839 19.839 0 0 0 6.002-3.03a.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.331c-1.183 0-2.157-1.086-2.157-2.419c0-1.333.955-2.419 2.157-2.419c1.211 0 2.176 1.095 2.157 2.419c0 1.333-.955 2.419-2.157 2.419zm7.975 0c-1.183 0-2.157-1.086-2.157-2.419c0-1.333.955-2.419 2.157-2.419c1.211 0 2.176 1.095 2.157 2.419c0 1.333-.946 2.419-2.157 2.419z" />
                        </svg>
                    </div>
                    <div class="min-w-0">
                        <span class="text-sm font-medium text-white group-hover:text-indigo-400 transition-colors">Discord</span>
                        <p class="text-xs text-gray-400">Discuter, s'entraider, suivre l'actualite</p>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-600 group-hover:text-gray-400 ml-auto flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                </a>
            </div>
        </div>

        {# What your donation pays for #}
        <div class="game-card">
            <div class="p-4 sm:p-6">
                <h2 class="text-sm font-semibold text-purple-400 uppercase tracking-wider mb-4">A quoi servent les dons ?</h2>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                    <div class="text-center p-3 rounded-lg bg-gray-800/30">
                        <div class="text-2xl mb-1">🖥️</div>
                        <span class="text-xs font-medium text-gray-300">Serveurs</span>
                        <p class="text-[10px] text-gray-500 mt-0.5">Hebergement et infrastructure</p>
                    </div>
                    <div class="text-center p-3 rounded-lg bg-gray-800/30">
                        <div class="text-2xl mb-1">🎨</div>
                        <span class="text-xs font-medium text-gray-300">Contenu</span>
                        <p class="text-[10px] text-gray-500 mt-0.5">Nouvelles zones, quetes, monstres</p>
                    </div>
                    <div class="text-center p-3 rounded-lg bg-gray-800/30">
                        <div class="text-2xl mb-1">🛡️</div>
                        <span class="text-xs font-medium text-gray-300">Perennite</span>
                        <p class="text-[10px] text-gray-500 mt-0.5">Garder le jeu en ligne et gratuit</p>
                    </div>
                </div>
            </div>
        </div>

        {# Transparency #}
        <div class="text-center text-xs text-gray-500 pb-4">
            <p>Amethyste est un projet independant. Merci pour votre soutien !</p>
            <p class="mt-1">
                <a href="{{ path('app_game') }}" class="text-purple-400 hover:text-purple-300 transition-colors">← Retour au jeu</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}

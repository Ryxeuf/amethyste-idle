{% extends 'game/game.html.twig' %}

{% block title %}Ameliorations de region{% endblock %}

{% block game_content %}
<div class="game-page">
    <div class="mb-3 flex items-center justify-between">
        <a href="{{ path('app_game_guild') }}" class="text-xs text-gray-400 hover:text-white transition-colors">
            &larr; Retour guilde
        </a>
        <span class="text-xs text-gray-500">Tresor : <span class="text-amber-400" id="treasury-display">{{ guild.gilsTreasury|number_format(0, ',', ' ') }}</span> Gils</span>
    </div>

    <div id="upgrade-messages" class="mb-3 hidden">
        <div class="rounded-lg p-3 text-sm" id="upgrade-message-text"></div>
    </div>

    <div class="game-card mb-4">
        <div class="game-card-header">
            <h2 class="text-base font-semibold text-white">Ameliorations de region</h2>
            <p class="text-gray-500 text-[10px] mt-1">Investissez le tresor de guilde pour ameliorer les regions que vous controlez.</p>
        </div>
    </div>

    {% for data in regionData %}
        <div class="game-card mb-4">
            <div class="game-card-header flex items-center justify-between">
                <div>
                    <h3 class="text-sm font-semibold text-white">{{ data.region.name }}</h3>
                    {% if data.controllingGuild %}
                        <p class="text-[10px] mt-0.5 {% if data.isOurs %}text-green-400{% else %}text-gray-500{% endif %}">
                            Controlee par : {{ data.controllingGuild.name }} [{{ data.controllingGuild.tag }}]
                        </p>
                    {% else %}
                        <p class="text-[10px] text-gray-600 mt-0.5">Region libre</p>
                    {% endif %}
                </div>
                {% if data.isOurs %}
                    <span class="px-2 py-0.5 bg-green-700/50 text-green-300 text-[10px] rounded">Votre guilde</span>
                {% endif %}
            </div>

            {% if data.isOurs and data.upgrades is not empty %}
                <div class="game-card-body">
                    <div class="space-y-3">
                        {% for upgrade in data.upgrades %}
                            <div class="bg-gray-700/30 rounded-lg p-3 border border-gray-700">
                                <div class="flex items-start justify-between mb-1.5">
                                    <div>
                                        <span class="text-white text-sm font-medium">{{ upgrade.label }}</span>
                                        <p class="text-gray-500 text-[10px]">{{ upgrade.description }}</p>
                                    </div>
                                    <span class="text-xs text-gray-400 shrink-0 ml-2">Niv. {{ upgrade.currentLevel }}/{{ upgrade.maxLevel }}</span>
                                </div>

                                {# Level progress bar #}
                                <div class="flex gap-0.5 mb-2">
                                    {% for i in 1..upgrade.maxLevel %}
                                        <div class="h-1.5 flex-1 rounded-full {{ i <= upgrade.currentLevel ? 'bg-amber-500' : 'bg-gray-600' }}"></div>
                                    {% endfor %}
                                </div>

                                {% if upgrade.effect %}
                                    <p class="text-[10px] text-amber-400 mb-1.5">Actuel : {{ upgrade.effect }}</p>
                                {% endif %}

                                {% if upgrade.nextCost is not null %}
                                    <div class="flex items-center justify-between">
                                        <span class="text-[10px] text-gray-400">
                                            Prochain : <span class="text-green-400">{{ upgrade.nextEffect }}</span>
                                        </span>
                                        {% if canManage %}
                                            <button onclick="purchaseUpgrade('{{ data.region.slug }}', '{{ upgrade.slug }}', {{ upgrade.nextCost }})"
                                                    class="px-2.5 py-1 bg-amber-700/50 hover:bg-amber-600 text-amber-300 text-[10px] rounded transition-colors touch-target {% if guild.gilsTreasury < upgrade.nextCost %}opacity-50 cursor-not-allowed{% endif %}"
                                                    {% if guild.gilsTreasury < upgrade.nextCost %}disabled{% endif %}>
                                                {{ upgrade.nextCost|number_format(0, ',', ' ') }} Gils
                                            </button>
                                        {% else %}
                                            <span class="text-[10px] text-gray-500">{{ upgrade.nextCost|number_format(0, ',', ' ') }} Gils</span>
                                        {% endif %}
                                    </div>
                                {% else %}
                                    <p class="text-[10px] text-amber-400">Niveau maximum atteint</p>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% elseif not data.isOurs %}
                <div class="game-card-body">
                    <p class="text-gray-500 text-xs text-center py-2">Votre guilde doit controler cette region pour y investir.</p>
                </div>
            {% endif %}
        </div>
    {% endfor %}

    {% if regionData is empty %}
        <div class="game-card">
            <div class="game-card-body text-center py-4">
                <p class="text-gray-500 text-sm">Aucune region contestable disponible.</p>
            </div>
        </div>
    {% endif %}
</div>

<script>
async function purchaseUpgrade(regionSlug, upgradeSlug, cost) {
    if (!confirm(`Investir ${cost.toLocaleString('fr-FR')} Gils du tresor dans cette amelioration ?`)) return;

    try {
        const resp = await fetch(`/game/guild/upgrade/${regionSlug}/${upgradeSlug}`, { method: 'POST' });
        const data = await resp.json();
        if (data.success) {
            showUpgradeMessage(data.message);
            setTimeout(() => location.reload(), 800);
        } else {
            showUpgradeMessage(data.error || 'Erreur', true);
        }
    } catch (e) {
        showUpgradeMessage('Erreur de connexion', true);
    }
}

function showUpgradeMessage(msg, isError = false) {
    const container = document.getElementById('upgrade-messages');
    const text = document.getElementById('upgrade-message-text');
    container.classList.remove('hidden');
    text.textContent = msg;
    text.className = isError
        ? 'bg-red-900/50 border border-red-700 rounded-lg p-3 text-red-300 text-sm'
        : 'bg-green-900/50 border border-green-700 rounded-lg p-3 text-green-300 text-sm';
    setTimeout(() => container.classList.add('hidden'), 3000);
}
</script>
{% endblock %}

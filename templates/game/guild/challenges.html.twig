{% extends 'game/game.html.twig' %}

{% block title %}Defis hebdomadaires{% endblock %}

{% block game_content %}
<div class="game-page">
    <div class="game-card mb-4">
        <div class="game-card-header flex items-center justify-between">
            <h2 class="text-base font-semibold text-white">
                Defis de la semaine
            </h2>
            <a href="{{ path('app_game_guild') }}" class="px-2.5 py-1.5 bg-gray-600 hover:bg-gray-500 text-white text-xs rounded transition-colors">
                Retour guilde
            </a>
        </div>
        <div class="game-card-body">
            <p class="text-gray-500 text-xs mb-4">
                Defis collectifs de saison. Chaque defi complete rapporte des points d'influence bonus a la guilde.
                {% if season %}
                    <span class="text-amber-400">Saison : {{ season.name }}</span>
                {% endif %}
            </p>

            {% if activeChallenges is empty %}
                <p class="text-gray-500 text-sm text-center py-4">Aucun defi actif cette semaine.</p>
            {% else %}
                <div class="space-y-3">
                    {% for entry in activeChallenges %}
                        {% set challenge = entry.challenge %}
                        <div class="bg-gray-700/30 rounded-lg p-3 border border-gray-700">
                            <div class="flex items-start justify-between mb-2">
                                <div>
                                    <span class="text-purple-400 text-xs font-medium uppercase">{{ challenge.activityType.label }}</span>
                                    <h3 class="text-white text-sm font-medium mt-0.5">{{ challenge|localized_challenge_title }}</h3>
                                    <p class="text-gray-400 text-xs mt-0.5">{{ challenge|localized_challenge_description }}</p>
                                </div>
                                <div class="text-right flex-shrink-0 ml-2">
                                    <div class="text-amber-400 text-xs">+{{ challenge.bonusPoints }} pts influence</div>
                                    <div class="text-gray-500 text-[10px]">Semaine {{ challenge.weekNumber }}</div>
                                </div>
                            </div>

                            {# Progress bar #}
                            <div class="mb-1.5">
                                <div class="flex justify-between text-[10px] text-gray-400 mb-1">
                                    <span>{{ entry.current }}/{{ entry.target }}</span>
                                    <span>{{ entry.percentage|number_format(0) }}%</span>
                                </div>
                                <div class="w-full bg-gray-800 rounded-full h-2">
                                    <div class="h-2 rounded-full transition-all duration-300 {% if entry.percentage >= 100 %}bg-green-500{% elseif entry.percentage >= 50 %}bg-amber-500{% else %}bg-purple-500{% endif %}"
                                         style="width: {{ entry.percentage }}%"></div>
                                </div>
                            </div>

                            <div class="text-[10px] text-gray-500">
                                Expire {{ challenge.endsAt|date('d/m/Y H:i') }}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>

    {# Completed challenges #}
    {% if completedChallenges is not empty %}
        <div class="game-card">
            <div class="game-card-header">
                <h2 class="text-base font-semibold text-white">Defis termines</h2>
            </div>
            <div class="game-card-body">
                <div class="space-y-2">
                    {% for entry in completedChallenges %}
                        {% set challenge = entry.challenge %}
                        <div class="bg-gray-700/20 rounded-lg p-2.5 border border-gray-700/50 opacity-75">
                            <div class="flex items-center justify-between">
                                <div>
                                    <span class="text-purple-400/70 text-[10px] font-medium uppercase">{{ challenge.activityType.label }}</span>
                                    <span class="text-gray-300 text-xs ml-1">{{ challenge|localized_challenge_title }}</span>
                                </div>
                                <div class="text-right flex-shrink-0 ml-2">
                                    {% if entry.completed %}
                                        <span class="text-green-400 text-[10px]">Complete</span>
                                        <span class="text-amber-400/70 text-[10px] ml-1">+{{ challenge.bonusPoints }} pts</span>
                                    {% else %}
                                        <span class="text-red-400/70 text-[10px]">Expire ({{ entry.current }}/{{ entry.target }})</span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}

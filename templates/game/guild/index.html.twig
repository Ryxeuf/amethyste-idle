{% extends 'game/game.html.twig' %}

{% block title %}{{ 'game.guild.title'|trans }}{% endblock %}

{% block game_content %}
<div class="game-page">
    {# Flash messages #}
    {% for type in ['success', 'error'] %}
        {% for message in app.flashes(type) %}
            <div class="mb-3 px-4 py-2 rounded text-sm {{ type == 'success' ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400' }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# Pending invitations #}
    {% if pendingInvitations is not empty %}
        <div class="game-card mb-4">
            <div class="game-card-header">
                <h2 class="text-base sm:text-lg font-semibold text-white">
                    {{ 'game.guild.pending_invitations'|trans }}
                    <span class="text-xs text-yellow-400 ml-1">({{ pendingInvitations|length }})</span>
                </h2>
            </div>
            <div class="game-card-body">
                <div class="space-y-2">
                    {% for invitation in pendingInvitations %}
                        <div class="flex items-center justify-between bg-gray-700/50 rounded-lg p-3 border border-yellow-500/30">
                            <div class="min-w-0">
                                <span class="text-white text-sm font-medium">{{ invitation.guild.name }}</span>
                                <span class="text-gray-400 text-xs ml-1">[{{ invitation.guild.tag }}]</span>
                                <span class="text-gray-500 text-xs block">{{ 'game.guild.invited_by'|trans({'%name%': invitation.invitedBy.name}) }}</span>
                            </div>
                            <div class="flex gap-2 flex-shrink-0">
                                <form action="{{ path('app_game_guild_accept', {id: invitation.id}) }}" method="post">
                                    <button type="submit" class="px-3 py-1 bg-green-600 hover:bg-green-500 text-white text-xs rounded transition-colors">
                                        {{ 'game.guild.accept'|trans }}
                                    </button>
                                </form>
                                <form action="{{ path('app_game_guild_decline', {id: invitation.id}) }}" method="post">
                                    <button type="submit" class="px-3 py-1 bg-gray-600 hover:bg-gray-500 text-white text-xs rounded transition-colors">
                                        {{ 'game.guild.decline'|trans }}
                                    </button>
                                </form>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}

    {# Create guild form #}
    <div class="game-card">
        <div class="game-card-header">
            <h2 class="text-base sm:text-lg font-semibold text-white">{{ 'game.guild.create_title'|trans }}</h2>
        </div>
        <div class="game-card-body">
            <p class="text-gray-400 text-sm mb-4">{{ 'game.guild.create_desc'|trans({'%cost%': 5000}) }}</p>

            <form action="{{ path('app_game_guild_create') }}" method="post" class="space-y-3">
                <div>
                    <label for="guild-name" class="block text-sm text-gray-300 mb-1">{{ 'game.guild.name'|trans }}</label>
                    <input type="text" id="guild-name" name="name" required minlength="3" maxlength="50"
                           class="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-white text-sm focus:outline-none focus:border-purple-500"
                           placeholder="{{ 'game.guild.name_placeholder'|trans }}">
                </div>
                <div>
                    <label for="guild-tag" class="block text-sm text-gray-300 mb-1">{{ 'game.guild.tag'|trans }}</label>
                    <input type="text" id="guild-tag" name="tag" required minlength="2" maxlength="5" pattern="[A-Za-z0-9]+"
                           class="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-white text-sm uppercase focus:outline-none focus:border-purple-500"
                           placeholder="{{ 'game.guild.tag_placeholder'|trans }}">
                </div>
                <div>
                    <label for="guild-desc" class="block text-sm text-gray-300 mb-1">{{ 'game.guild.description'|trans }}</label>
                    <textarea id="guild-desc" name="description" rows="3" maxlength="500"
                              class="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-white text-sm focus:outline-none focus:border-purple-500"
                              placeholder="{{ 'game.guild.desc_placeholder'|trans }}"></textarea>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-yellow-400 text-sm">{{ 'game.guild.cost'|trans({'%amount%': 5000}) }}</span>
                    <button type="submit" class="px-4 py-2 bg-purple-600 hover:bg-purple-500 text-white text-sm rounded transition-colors"
                            {{ player.gils < 5000 ? 'disabled' : '' }}>
                        {{ 'game.guild.create_button'|trans }}
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

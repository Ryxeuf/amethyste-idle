{% extends 'game/game.html.twig' %}

{% block title %}Guilde{% endblock %}

{% block game_content %}
<div class="game-page">
    {# Navigation #}
    <div class="mb-3 text-right flex justify-end gap-3">
        <a href="{{ path('app_game_guild_influence') }}" class="text-xs text-amber-400 hover:text-amber-300 transition-colors">
            Influence
        </a>
        <a href="{{ path('app_game_guild_ranking') }}" class="text-xs text-amber-400 hover:text-amber-300 transition-colors">
            Classement des guildes
        </a>
    </div>

    {# Messages area #}
    <div id="guild-messages" class="mb-3 hidden">
        <div class="rounded-lg p-3 text-sm" id="guild-message-text"></div>
    </div>

    {# Pending invitations #}
    {% if invitations is not empty %}
        <div class="game-card mb-4">
            <div class="game-card-header">
                <h2 class="text-base font-semibold text-white">Invitations en attente</h2>
            </div>
            <div class="game-card-body">
                <div class="space-y-2">
                    {% for invitation in invitations %}
                        <div class="flex items-center justify-between bg-gray-700/50 rounded-lg p-3 border border-amber-700/30" id="invitation-{{ invitation.id }}">
                            <div>
                                <span class="text-white text-sm font-medium">{{ invitation.guild.name }}</span>
                                <span class="text-gray-400 text-xs ml-1">[{{ invitation.guild.tag }}]</span>
                                <p class="text-gray-500 text-[10px]">Invite par {{ invitation.invitedBy.name }}</p>
                            </div>
                            <div class="flex gap-1.5">
                                <button onclick="acceptInvitation({{ invitation.id }})"
                                        class="px-2.5 py-1.5 bg-green-600 hover:bg-green-500 text-white text-xs rounded transition-colors touch-target">
                                    Accepter
                                </button>
                                <button onclick="declineInvitation({{ invitation.id }})"
                                        class="px-2.5 py-1.5 bg-red-600/60 hover:bg-red-500 text-white text-xs rounded transition-colors touch-target">
                                    Decliner
                                </button>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}

    {% if guild %}
        {# Guild info #}
        <div class="game-card">
            <div class="game-card-header flex items-center justify-between">
                <div>
                    <h2 class="text-base sm:text-lg font-semibold text-white">
                        {{ guild.name }}
                        <span class="text-purple-400 text-sm ml-1">[{{ guild.tag }}]</span>
                    </h2>
                </div>
                {% if membership.rank.value != 'leader' %}
                    <button onclick="leaveGuild()"
                            class="px-2.5 py-1.5 bg-red-600/60 hover:bg-red-500 text-white text-xs rounded transition-colors touch-target">
                        Quitter
                    </button>
                {% endif %}
            </div>
            <div class="game-card-body">
                {% if guild.description %}
                    <p class="text-gray-400 text-sm mb-4">{{ guild.description }}</p>
                {% endif %}

                <div class="flex flex-wrap gap-4 mb-4 text-xs text-gray-400">
                    <span>Chef : <span class="text-yellow-400">{{ guild.leader.name }}</span></span>
                    <span>Membres : <span class="text-white">{{ guild.memberCount }}</span></span>
                    <span>Votre rang : <span class="{{ membership.rank.cssClass }}">{{ membership.rank.label }}</span></span>
                </div>

                <div class="flex flex-wrap gap-2 mb-4">
                    <a href="{{ path('app_game_guild_vault') }}"
                       class="inline-block px-3 py-1.5 bg-amber-700/50 hover:bg-amber-600 text-amber-300 text-xs rounded transition-colors touch-target">
                        Coffre de guilde
                    </a>
                    <a href="{{ path('app_game_guild_quests') }}"
                       class="inline-block px-3 py-1.5 bg-purple-700/50 hover:bg-purple-600 text-purple-300 text-xs rounded transition-colors touch-target">
                        Quetes de guilde
                    </a>
                </div>

                {# Invite form (officer+) #}
                {% if membership.rank.canInvite %}
                    <div class="mb-4 p-3 bg-gray-700/30 rounded-lg border border-gray-600">
                        <h3 class="text-white text-sm font-medium mb-2">Inviter un joueur</h3>
                        <div class="flex gap-2">
                            <input type="text" id="invite-player-name" placeholder="Nom du joueur"
                                   class="flex-1 px-3 py-1.5 bg-gray-800 border border-gray-600 rounded text-white text-sm placeholder-gray-500 focus:border-purple-500 focus:outline-none">
                            <button onclick="invitePlayer()"
                                    class="px-3 py-1.5 bg-purple-600 hover:bg-purple-500 text-white text-xs rounded transition-colors touch-target">
                                Inviter
                            </button>
                        </div>
                    </div>
                {% endif %}

                {# Members list #}
                <h3 class="text-white text-sm font-medium mb-2">Membres</h3>
                <div class="space-y-1.5">
                    {% for guildMember in guild.members %}
                        <div class="flex items-center justify-between bg-gray-700/30 rounded-lg p-2.5 border border-gray-700">
                            <div class="flex items-center gap-2.5">
                                <div class="w-7 h-7 rounded-full bg-gray-600 flex items-center justify-center text-xs text-white font-bold">
                                    {{ guildMember.player.name|first|upper }}
                                </div>
                                <div>
                                    <a href="{{ path('app_game_profile', {name: guildMember.player.name}) }}" class="text-white text-sm hover:text-purple-400 transition-colors">
                                        {{ guildMember.player.name }}
                                    </a>
                                    <span class="{{ guildMember.rank.cssClass }} text-[10px] ml-1">{{ guildMember.rank.label }}</span>
                                </div>
                            </div>
                            {% if membership.rank.canPromote and guildMember.id != membership.id %}
                                <div class="flex gap-1">
                                    {% if guildMember.rank.value in ['recruit', 'member'] %}
                                        <button onclick="promoteMember({{ guildMember.id }})"
                                                class="px-2 py-1 bg-green-700/50 hover:bg-green-600 text-green-300 text-[10px] rounded transition-colors"
                                                title="Promouvoir">Promouvoir</button>
                                    {% endif %}
                                    {% if guildMember.rank.value in ['officer', 'member'] %}
                                        <button onclick="demoteMember({{ guildMember.id }})"
                                                class="px-2 py-1 bg-orange-700/50 hover:bg-orange-600 text-orange-300 text-[10px] rounded transition-colors"
                                                title="Retrograder">Retrograder</button>
                                    {% endif %}
                                    {% if guildMember.rank.value != 'leader' %}
                                        <button onclick="kickMember({{ guildMember.id }}, '{{ guildMember.player.name|e('js') }}')"
                                                class="px-2 py-1 bg-red-700/50 hover:bg-red-600 text-red-300 text-[10px] rounded transition-colors"
                                                title="Expulser">Expulser</button>
                                    {% endif %}
                                </div>
                            {% elseif membership.rank.canKick and membership.rank.isHigherThan(guildMember.rank) and guildMember.id != membership.id %}
                                <button onclick="kickMember({{ guildMember.id }}, '{{ guildMember.player.name|e('js') }}')"
                                        class="px-2 py-1 bg-red-700/50 hover:bg-red-600 text-red-300 text-[10px] rounded transition-colors"
                                        title="Expulser">Expulser</button>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% else %}
        {# No guild — create form #}
        <div class="game-card">
            <div class="game-card-header">
                <h2 class="text-base sm:text-lg font-semibold text-white">Guilde</h2>
            </div>
            <div class="game-card-body">
                <div class="text-center py-4 mb-4">
                    <p class="text-gray-400 text-sm">Vous n'appartenez a aucune guilde.</p>
                    <p class="text-gray-500 text-xs mt-1">Creez la votre ou attendez une invitation.</p>
                </div>

                <div class="p-4 bg-gray-700/30 rounded-lg border border-gray-600">
                    <h3 class="text-white text-sm font-medium mb-3">Creer une guilde</h3>
                    <p class="text-gray-500 text-[10px] mb-3">Cout : {{ creationCost|number_format(0, ',', ' ') }} Gils — Vous avez {{ player.gils|number_format(0, ',', ' ') }} Gils</p>
                    <div class="space-y-2">
                        <input type="text" id="guild-name" placeholder="Nom de la guilde (3-50 car.)"
                               class="w-full px-3 py-1.5 bg-gray-800 border border-gray-600 rounded text-white text-sm placeholder-gray-500 focus:border-purple-500 focus:outline-none">
                        <input type="text" id="guild-tag" placeholder="Tag (3-5 lettres/chiffres)" maxlength="5"
                               class="w-full px-3 py-1.5 bg-gray-800 border border-gray-600 rounded text-white text-sm placeholder-gray-500 focus:border-purple-500 focus:outline-none uppercase">
                        <textarea id="guild-description" placeholder="Description (optionnel)" rows="2"
                                  class="w-full px-3 py-1.5 bg-gray-800 border border-gray-600 rounded text-white text-sm placeholder-gray-500 focus:border-purple-500 focus:outline-none resize-none"></textarea>
                        <button onclick="createGuild()"
                                class="w-full px-3 py-2 bg-purple-600 hover:bg-purple-500 text-white text-sm rounded transition-colors touch-target {% if player.gils < creationCost %}opacity-50 cursor-not-allowed{% endif %}"
                                {% if player.gils < creationCost %}disabled{% endif %}>
                            Creer ({{ creationCost|number_format(0, ',', ' ') }} Gils)
                        </button>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>

<script>
async function guildAction(url, method = 'POST', body = null) {
    try {
        const opts = { method };
        if (body) {
            opts.headers = { 'Content-Type': 'application/json' };
            opts.body = JSON.stringify(body);
        }
        const resp = await fetch(url, opts);
        const data = await resp.json();
        if (data.success) {
            showGuildMessage(data.message);
            setTimeout(() => location.reload(), 800);
        } else {
            showGuildMessage(data.error || 'Erreur', true);
        }
    } catch (e) {
        showGuildMessage('Erreur de connexion', true);
    }
}

function createGuild() {
    const name = document.getElementById('guild-name').value.trim();
    const tag = document.getElementById('guild-tag').value.trim();
    const description = document.getElementById('guild-description').value.trim();
    if (!name || !tag) { showGuildMessage('Nom et tag requis.', true); return; }
    guildAction('/game/guild/create', 'POST', { name, tag, description });
}

function invitePlayer() {
    const nameInput = document.getElementById('invite-player-name');
    const name = nameInput.value.trim();
    if (!name) { showGuildMessage('Entrez un nom de joueur.', true); return; }
    fetch(`/game/chat/players/search?q=${encodeURIComponent(name)}`)
        .then(r => r.json())
        .then(data => {
            const exact = (data.players || []).find(p => p.name.toLowerCase() === name.toLowerCase());
            if (exact) {
                guildAction(`/game/guild/invite/${exact.id}`);
            } else if (data.players && data.players.length > 0) {
                guildAction(`/game/guild/invite/${data.players[0].id}`);
            } else {
                showGuildMessage('Joueur introuvable.', true);
            }
        })
        .catch(() => showGuildMessage('Erreur de recherche.', true));
}

function acceptInvitation(id) { guildAction(`/game/guild/invitation/${id}/accept`); }
function declineInvitation(id) { guildAction(`/game/guild/invitation/${id}/decline`); }
function leaveGuild() { if (confirm('Quitter la guilde ?')) guildAction('/game/guild/leave'); }
function kickMember(id, name) { if (confirm(`Expulser ${name} ?`)) guildAction(`/game/guild/kick/${id}`); }
function promoteMember(id) { guildAction(`/game/guild/promote/${id}`); }
function demoteMember(id) { guildAction(`/game/guild/demote/${id}`); }

function showGuildMessage(msg, isError = false) {
    const container = document.getElementById('guild-messages');
    const text = document.getElementById('guild-message-text');
    container.classList.remove('hidden');
    text.textContent = msg;
    text.className = isError
        ? 'bg-red-900/50 border border-red-700 rounded-lg p-3 text-red-300 text-sm'
        : 'bg-green-900/50 border border-green-700 rounded-lg p-3 text-green-300 text-sm';
    setTimeout(() => container.classList.add('hidden'), 3000);
}
</script>
{% endblock %}

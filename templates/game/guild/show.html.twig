{% extends 'game/game.html.twig' %}

{% block title %}{{ guild.name }} — {{ 'game.guild.title'|trans }}{% endblock %}

{% block game_content %}
<div class="game-page">
    {# Flash messages #}
    {% for type in ['success', 'error'] %}
        {% for message in app.flashes(type) %}
            <div class="mb-3 px-4 py-2 rounded text-sm {{ type == 'success' ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400' }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# Guild header #}
    <div class="game-card mb-4">
        <div class="game-card-header">
            <div class="flex items-center justify-between">
                <div>
                    <h2 class="text-base sm:text-lg font-semibold text-white">
                        {{ guild.name }}
                        <span class="text-purple-400 text-sm ml-1">[{{ guild.tag }}]</span>
                    </h2>
                    <p class="text-gray-400 text-xs mt-1">{{ 'game.guild.leader'|trans }}: {{ guild.leader.name }}</p>
                </div>
                <div class="text-right">
                    <span class="inline-block px-2 py-1 rounded text-xs {{ membership.rank.cssClass }}">
                        {{ membership.rank.label }}
                    </span>
                </div>
            </div>
        </div>
        {% if guild.description %}
            <div class="game-card-body border-b border-gray-700">
                <p class="text-gray-300 text-sm">{{ guild.description }}</p>
            </div>
        {% endif %}
    </div>

    {# Members list #}
    <div class="game-card mb-4">
        <div class="game-card-header">
            <h2 class="text-base sm:text-lg font-semibold text-white">
                {{ 'game.guild.members'|trans }}
                <span class="text-xs text-gray-400 ml-1">({{ guild.members|length }})</span>
            </h2>
        </div>
        <div class="game-card-body">
            <div class="space-y-2">
                {% for guildMember in guild.members %}
                    <div class="flex items-center justify-between bg-gray-700/50 rounded-lg p-3 border border-gray-600">
                        <div class="flex items-center gap-3 min-w-0">
                            <div class="w-8 h-8 rounded-full bg-purple-500/20 flex items-center justify-center text-purple-400 text-sm font-bold flex-shrink-0">
                                {{ guildMember.player.name|first|upper }}
                            </div>
                            <div class="min-w-0">
                                <a href="{{ path('app_game_player_profile', {id: guildMember.player.id}) }}" class="text-white text-sm font-medium hover:text-purple-400 truncate block">
                                    {{ guildMember.player.name }}
                                </a>
                                <span class="inline-block px-1.5 py-0.5 rounded text-[10px] {{ guildMember.rank.cssClass }}">
                                    {{ guildMember.rank.label }}
                                </span>
                            </div>
                        </div>
                        {% if membership.rank.canPromote and guildMember.player.id != player.id %}
                            <div class="flex gap-1 flex-shrink-0">
                                {% if guildMember.rank.value != 'officer' %}
                                    <form action="{{ path('app_game_guild_promote', {id: guildMember.player.id}) }}" method="post">
                                        <input type="hidden" name="rank" value="officer">
                                        <button type="submit" class="px-2 py-1 bg-blue-600/50 hover:bg-blue-500/50 text-blue-300 text-xs rounded transition-colors" title="{{ 'game.guild.promote_officer'|trans }}">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
                                            </svg>
                                        </button>
                                    </form>
                                {% endif %}
                                {% if guildMember.rank.value != 'recruit' and guildMember.rank.value != 'master' %}
                                    <form action="{{ path('app_game_guild_promote', {id: guildMember.player.id}) }}" method="post">
                                        <input type="hidden" name="rank" value="member">
                                        <button type="submit" class="px-2 py-1 bg-gray-600/50 hover:bg-gray-500/50 text-gray-300 text-xs rounded transition-colors" title="{{ 'game.guild.demote_member'|trans }}">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                            </svg>
                                        </button>
                                    </form>
                                {% endif %}
                                <form action="{{ path('app_game_guild_kick', {id: guildMember.player.id}) }}" method="post">
                                    <button type="submit" class="px-2 py-1 text-gray-400 hover:text-red-400 text-xs transition-colors" title="{{ 'game.guild.kick'|trans }}">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        {% elseif membership.rank.canKick and guildMember.player.id != player.id and guildMember.rank.value != 'master' and guildMember.rank.value != 'officer' %}
                            <form action="{{ path('app_game_guild_kick', {id: guildMember.player.id}) }}" method="post">
                                <button type="submit" class="px-2 py-1 text-gray-400 hover:text-red-400 text-xs transition-colors" title="{{ 'game.guild.kick'|trans }}">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                                    </svg>
                                </button>
                            </form>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Invite player (officer+) #}
    {% if membership.rank.canInvite %}
        <div class="game-card mb-4">
            <div class="game-card-header">
                <h2 class="text-base sm:text-lg font-semibold text-white">{{ 'game.guild.invite_title'|trans }}</h2>
            </div>
            <div class="game-card-body">
                <p class="text-gray-400 text-xs mb-2">{{ 'game.guild.invite_desc'|trans }}</p>
            </div>
        </div>
    {% endif %}

    {# Actions #}
    <div class="game-card">
        <div class="game-card-body">
            <div class="flex gap-2">
                {% if membership.rank.value == 'master' %}
                    <form action="{{ path('app_game_guild_disband') }}" method="post" onsubmit="return confirm('{{ 'game.guild.disband_confirm'|trans }}')">
                        <button type="submit" class="px-3 py-1.5 bg-red-600/50 hover:bg-red-500/50 text-red-300 text-xs rounded transition-colors">
                            {{ 'game.guild.disband'|trans }}
                        </button>
                    </form>
                {% else %}
                    <form action="{{ path('app_game_guild_leave') }}" method="post" onsubmit="return confirm('{{ 'game.guild.leave_confirm'|trans }}')">
                        <button type="submit" class="px-3 py-1.5 bg-red-600/50 hover:bg-red-500/50 text-red-300 text-xs rounded transition-colors">
                            {{ 'game.guild.leave'|trans }}
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

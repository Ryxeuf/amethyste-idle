{% extends 'game/game.html.twig' %}

{% block title %}{{ 'game.settings.title'|trans }}{% endblock %}

{% block game_content %}
<div class="game-page">
    <div class="game-card">
        <div class="game-card-header">
            <h1 class="text-base sm:text-xl font-bold text-white">{{ 'game.settings.title'|trans }}</h1>
            <p class="text-purple-200/70 text-xs sm:text-sm mt-0.5">{{ 'game.settings.subtitle'|trans }}</p>
        </div>

        <div class="p-3 sm:p-6">
            {# Scrollable tab navigation #}
            <div class="border-b border-gray-700 mb-4 sm:mb-6 -mx-3 px-3 sm:mx-0 sm:px-0">
                <nav class="scroll-tabs">
                    <a href="#" class="settings-tab active whitespace-nowrap py-3 px-3 sm:px-4 border-b-2 border-purple-500 font-medium text-sm text-purple-400 touch-target" data-target="general">
                        {{ 'game.settings.tabs.general'|trans }}
                    </a>
                    <a href="#" class="settings-tab whitespace-nowrap py-3 px-3 sm:px-4 border-b-2 border-transparent font-medium text-sm text-gray-400 hover:text-gray-300 touch-target" data-target="appearance">
                        {{ 'game.settings.tabs.appearance'|trans }}
                    </a>
                    <a href="#" class="settings-tab whitespace-nowrap py-3 px-3 sm:px-4 border-b-2 border-transparent font-medium text-sm text-gray-400 hover:text-gray-300 touch-target" data-target="notifications">
                        {{ 'game.settings.tabs.notifications'|trans }}
                    </a>
                    <a href="#" class="settings-tab whitespace-nowrap py-3 px-3 sm:px-4 border-b-2 border-transparent font-medium text-sm text-gray-400 hover:text-gray-300 touch-target" data-target="account">
                        {{ 'game.settings.tabs.account'|trans }}
                    </a>
                </nav>
            </div>

            {# General #}
            <div class="settings-content" id="general-content">
                <div class="space-y-5">
                    <div>
                        <h3 class="text-base font-medium text-white">{{ 'game.settings.general.game_settings'|trans }}</h3>
                        <p class="mt-0.5 text-xs sm:text-sm text-gray-400">{{ 'game.settings.general.game_settings_desc'|trans }}</p>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label for="language" class="block text-sm font-medium text-gray-300 mb-1">{{ 'game.settings.general.language'|trans }}</label>
                            <select id="language" name="language" class="bg-gray-700 text-white shadow-sm focus:ring-purple-500 focus:border-purple-500 block w-full text-sm border-gray-600 rounded-lg py-2.5 px-3">
                                <option value="fr">Francais</option>
                                <option value="en">English</option>
                                <option value="es">Espanol</option>
                            </select>
                        </div>
                        <div>
                            <label for="difficulty" class="block text-sm font-medium text-gray-300 mb-1">{{ 'game.settings.general.difficulty'|trans }}</label>
                            <select id="difficulty" name="difficulty" class="bg-gray-700 text-white shadow-sm focus:ring-purple-500 focus:border-purple-500 block w-full text-sm border-gray-600 rounded-lg py-2.5 px-3">
                                <option value="easy">{{ 'game.settings.general.difficulty_easy'|trans }}</option>
                                <option value="normal">{{ 'game.settings.general.difficulty_normal'|trans }}</option>
                                <option value="hard">{{ 'game.settings.general.difficulty_hard'|trans }}</option>
                            </select>
                        </div>
                    </div>

                    <div class="space-y-3">
                        <label class="flex items-start gap-3 cursor-pointer">
                            <input id="tutorial" name="tutorial" type="checkbox" class="mt-0.5 focus:ring-purple-500 h-4 w-4 text-purple-600 border-gray-600 rounded bg-gray-700">
                            <div>
                                <span class="text-sm font-medium text-gray-300">{{ 'game.settings.general.show_tutorial'|trans }}</span>
                                <p class="text-xs text-gray-400 mt-0.5">{{ 'game.settings.general.show_tutorial_desc'|trans }}</p>
                            </div>
                        </label>
                        <label class="flex items-start gap-3 cursor-pointer">
                            <input id="sound" name="sound" type="checkbox" class="mt-0.5 focus:ring-purple-500 h-4 w-4 text-purple-600 border-gray-600 rounded bg-gray-700" checked>
                            <div>
                                <span class="text-sm font-medium text-gray-300">{{ 'game.settings.general.enable_sound'|trans }}</span>
                                <p class="text-xs text-gray-400 mt-0.5">{{ 'game.settings.general.enable_sound_desc'|trans }}</p>
                            </div>
                        </label>
                        <div id="sound-volume-group" class="ml-7">
                            <label for="sound-volume" class="block text-sm font-medium text-gray-300 mb-2">{{ 'game.settings.general.sound_volume'|trans }}</label>
                            <div class="flex items-center gap-3">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072M12 6l-4 4H4v4h4l4 4V6z" />
                                </svg>
                                <input type="range" id="sound-volume" name="sound-volume" min="0" max="100" value="60" class="w-full h-2 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-purple-500">
                                <span id="sound-volume-label" class="text-xs text-gray-400 w-8 text-right">60%</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {# Appearance #}
            <div class="settings-content hidden" id="appearance-content">
                <div class="space-y-5">
                    <div>
                        <h3 class="text-base font-medium text-white">{{ 'game.settings.appearance.title'|trans }}</h3>
                        <p class="mt-0.5 text-xs sm:text-sm text-gray-400">{{ 'game.settings.appearance.desc'|trans }}</p>
                    </div>

                    <fieldset>
                        <legend class="text-sm font-medium text-gray-300 mb-3">{{ 'game.settings.appearance.theme'|trans }}</legend>
                        <div class="space-y-3">
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input id="theme-system" name="theme" type="radio" class="focus:ring-purple-500 h-4 w-4 text-purple-600 border-gray-600 bg-gray-700" checked>
                                <span class="text-sm text-gray-300">{{ 'game.settings.appearance.theme_system'|trans }}</span>
                            </label>
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input id="theme-light" name="theme" type="radio" class="focus:ring-purple-500 h-4 w-4 text-purple-600 border-gray-600 bg-gray-700">
                                <span class="text-sm text-gray-300">{{ 'game.settings.appearance.theme_light'|trans }}</span>
                            </label>
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input id="theme-dark" name="theme" type="radio" class="focus:ring-purple-500 h-4 w-4 text-purple-600 border-gray-600 bg-gray-700">
                                <span class="text-sm text-gray-300">{{ 'game.settings.appearance.theme_dark'|trans }}</span>
                            </label>
                        </div>
                    </fieldset>

                    <div>
                        <label for="font-size" class="block text-sm font-medium text-gray-300 mb-2">{{ 'game.settings.appearance.font_size'|trans }}</label>
                        <input type="range" id="font-size" name="font-size" min="80" max="120" value="100" class="w-full h-2 bg-gray-700 rounded-lg appearance-none cursor-pointer">
                        <div class="flex justify-between text-xs text-gray-400 px-1 mt-1">
                            <span>{{ 'game.settings.appearance.small'|trans }}</span>
                            <span>{{ 'game.settings.appearance.normal'|trans }}</span>
                            <span>{{ 'game.settings.appearance.large'|trans }}</span>
                        </div>
                    </div>
                </div>
            </div>

            {# Notifications #}
            <div class="settings-content hidden" id="notifications-content">
                <div class="space-y-5">
                    <div>
                        <h3 class="text-base font-medium text-white">{{ 'game.settings.notifications.title'|trans }}</h3>
                        <p class="mt-0.5 text-xs sm:text-sm text-gray-400">{{ 'game.settings.notifications.desc'|trans }}</p>
                    </div>

                    <div class="space-y-3">
                        <label class="flex items-start gap-3 cursor-pointer">
                            <input id="quest-notifications" name="quest-notifications" type="checkbox" class="mt-0.5 focus:ring-purple-500 h-4 w-4 text-purple-600 border-gray-600 rounded bg-gray-700" checked>
                            <div>
                                <span class="text-sm font-medium text-gray-300">{{ 'game.settings.notifications.quests'|trans }}</span>
                                <p class="text-xs text-gray-400 mt-0.5">{{ 'game.settings.notifications.quests_desc'|trans }}</p>
                            </div>
                        </label>
                        <label class="flex items-start gap-3 cursor-pointer">
                            <input id="energy-notifications" name="energy-notifications" type="checkbox" class="mt-0.5 focus:ring-purple-500 h-4 w-4 text-purple-600 border-gray-600 rounded bg-gray-700" checked>
                            <div>
                                <span class="text-sm font-medium text-gray-300">{{ 'game.settings.notifications.energy'|trans }}</span>
                                <p class="text-xs text-gray-400 mt-0.5">{{ 'game.settings.notifications.energy_desc'|trans }}</p>
                            </div>
                        </label>
                        <label class="flex items-start gap-3 cursor-pointer">
                            <input id="event-notifications" name="event-notifications" type="checkbox" class="mt-0.5 focus:ring-purple-500 h-4 w-4 text-purple-600 border-gray-600 rounded bg-gray-700" checked>
                            <div>
                                <span class="text-sm font-medium text-gray-300">{{ 'game.settings.notifications.events'|trans }}</span>
                                <p class="text-xs text-gray-400 mt-0.5">{{ 'game.settings.notifications.events_desc'|trans }}</p>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            {# Account #}
            <div class="settings-content hidden" id="account-content">
                <div class="space-y-5">
                    <div>
                        <h3 class="text-base font-medium text-white">{{ 'game.settings.account.title'|trans }}</h3>
                        <p class="mt-0.5 text-xs sm:text-sm text-gray-400">{{ 'game.settings.account.desc'|trans }}</p>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label for="username" class="block text-sm font-medium text-gray-300 mb-1">{{ 'game.settings.account.username'|trans }}</label>
                            <input type="text" name="username" id="username" value="{{ app.user.username|default('') }}" class="bg-gray-700 text-white shadow-sm focus:ring-purple-500 focus:border-purple-500 block w-full text-sm border-gray-600 rounded-lg py-2.5 px-3">
                        </div>
                        <div>
                            <label for="email" class="block text-sm font-medium text-gray-300 mb-1">{{ 'game.settings.account.email'|trans }}</label>
                            <input type="email" name="email" id="email" value="{{ app.user.email|default('') }}" class="bg-gray-700 text-white shadow-sm focus:ring-purple-500 focus:border-purple-500 block w-full text-sm border-gray-600 rounded-lg py-2.5 px-3">
                        </div>
                    </div>

                    <div>
                        <label for="current-password" class="block text-sm font-medium text-gray-300 mb-1">{{ 'game.settings.account.current_password'|trans }}</label>
                        <input type="password" name="current-password" id="current-password" class="bg-gray-700 text-white shadow-sm focus:ring-purple-500 focus:border-purple-500 block w-full text-sm border-gray-600 rounded-lg py-2.5 px-3">
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label for="new-password" class="block text-sm font-medium text-gray-300 mb-1">{{ 'game.settings.account.new_password'|trans }}</label>
                            <input type="password" name="new-password" id="new-password" class="bg-gray-700 text-white shadow-sm focus:ring-purple-500 focus:border-purple-500 block w-full text-sm border-gray-600 rounded-lg py-2.5 px-3">
                        </div>
                        <div>
                            <label for="confirm-password" class="block text-sm font-medium text-gray-300 mb-1">{{ 'game.settings.account.confirm_password'|trans }}</label>
                            <input type="password" name="confirm-password" id="confirm-password" class="bg-gray-700 text-white shadow-sm focus:ring-purple-500 focus:border-purple-500 block w-full text-sm border-gray-600 rounded-lg py-2.5 px-3">
                        </div>
                    </div>

                    <div class="pt-4 border-t border-gray-700">
                        <h3 class="text-base font-medium text-red-400">{{ 'game.settings.account.danger_zone'|trans }}</h3>
                        <p class="mt-0.5 text-xs text-gray-400">{{ 'game.settings.account.danger_zone_desc'|trans }}</p>
                        <div class="mt-3">
                            <button type="button" class="px-4 py-2.5 text-sm font-medium rounded-lg text-white bg-red-600 hover:bg-red-700 active:bg-red-800 transition-colors touch-target">
                                {{ 'game.settings.account.delete_account'|trans }}
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Save/Cancel footer #}
        <div class="px-3 sm:px-6 py-3 sm:py-4 bg-gray-900/50 border-t border-gray-700 flex justify-end gap-2">
            <button type="button" class="px-4 py-2.5 border border-gray-600 text-sm font-medium rounded-lg text-gray-300 bg-gray-800 hover:bg-gray-700 transition-colors touch-target">
                {{ 'game.settings.cancel'|trans }}
            </button>
            <button type="submit" class="px-4 py-2.5 text-sm font-medium rounded-lg text-white bg-purple-600 hover:bg-purple-700 transition-colors touch-target">
                {{ 'game.settings.save'|trans }}
            </button>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const tabs = document.querySelectorAll('.settings-tab');
        const contents = document.querySelectorAll('.settings-content');

        tabs.forEach(tab => {
            tab.addEventListener('click', function(e) {
                e.preventDefault();
                tabs.forEach(t => {
                    t.classList.remove('active', 'border-purple-500', 'text-purple-400');
                    t.classList.add('border-transparent', 'text-gray-400');
                });
                this.classList.add('active', 'border-purple-500', 'text-purple-400');
                this.classList.remove('border-transparent', 'text-gray-400');
                contents.forEach(content => content.classList.add('hidden'));
                const target = this.getAttribute('data-target');
                document.getElementById(`${target}-content`).classList.remove('hidden');
            });
        });

        // ===== Sound settings =====
        const soundCheckbox = document.getElementById('sound');
        const volumeSlider = document.getElementById('sound-volume');
        const volumeLabel = document.getElementById('sound-volume-label');
        const volumeGroup = document.getElementById('sound-volume-group');

        if (soundCheckbox && window.SoundManager) {
            // Init from SoundManager state
            soundCheckbox.checked = !window.SoundManager.isMuted();
            if (volumeSlider) {
                volumeSlider.value = Math.round(window.SoundManager.getVolume() * 100);
                volumeLabel.textContent = volumeSlider.value + '%';
            }
            if (volumeGroup) {
                volumeGroup.style.opacity = soundCheckbox.checked ? '1' : '0.4';
                volumeGroup.style.pointerEvents = soundCheckbox.checked ? '' : 'none';
            }

            soundCheckbox.addEventListener('change', function() {
                window.SoundManager.setMuted(!this.checked);
                if (volumeGroup) {
                    volumeGroup.style.opacity = this.checked ? '1' : '0.4';
                    volumeGroup.style.pointerEvents = this.checked ? '' : 'none';
                }
                if (this.checked) {
                    window.SoundManager.play('ui_click');
                }
            });

            if (volumeSlider) {
                volumeSlider.addEventListener('input', function() {
                    const val = parseInt(this.value, 10);
                    volumeLabel.textContent = val + '%';
                    window.SoundManager.setVolume(val / 100);
                });
                volumeSlider.addEventListener('change', function() {
                    window.SoundManager.play('ui_click');
                });
            }
        }
    });
</script>
{% endblock %}

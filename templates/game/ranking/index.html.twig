{% extends 'game/game.html.twig' %}

{% block title %}{{ 'game.ranking.title'|trans }}{% endblock %}

{% block game_content %}
{% set valueKey = tab == 'quests' ? 'totalQuests' : (tab == 'xp' ? 'totalXp' : 'totalKills') %}
{% set colLabel = tab == 'quests' ? 'game.ranking.col.quests'|trans : (tab == 'xp' ? 'game.ranking.col.xp'|trans : 'game.ranking.col.kills'|trans) %}
<div class="game-page">
    <div class="game-card">
        <div class="game-card-header flex items-center justify-between">
            <div>
                <h2 class="text-base sm:text-lg font-semibold text-white">{{ 'game.ranking.title'|trans }}</h2>
                <p class="text-gray-400 text-xs mt-0.5">{{ 'game.ranking.subtitle'|trans }}</p>
            </div>
        </div>

        <div class="game-card-body">
            <div class="flex gap-2 mb-4 border-b border-gray-700">
                <a href="{{ path('app_game_rankings', {tab: 'kills'}) }}"
                   class="px-3 py-2 text-xs font-medium {% if tab == 'kills' %}text-white border-b-2 border-purple-500 -mb-px{% else %}text-gray-400 hover:text-gray-200{% endif %}">
                    {{ 'game.ranking.tab.kills'|trans }}
                </a>
                <a href="{{ path('app_game_rankings', {tab: 'quests'}) }}"
                   class="px-3 py-2 text-xs font-medium {% if tab == 'quests' %}text-white border-b-2 border-purple-500 -mb-px{% else %}text-gray-400 hover:text-gray-200{% endif %}">
                    {{ 'game.ranking.tab.quests'|trans }}
                </a>
                <a href="{{ path('app_game_rankings', {tab: 'xp'}) }}"
                   class="px-3 py-2 text-xs font-medium {% if tab == 'xp' %}text-white border-b-2 border-purple-500 -mb-px{% else %}text-gray-400 hover:text-gray-200{% endif %}">
                    {{ 'game.ranking.tab.xp'|trans }}
                </a>
            </div>

            {# Titres saisonniers du joueur #}
            {% if playerTitles is defined and playerTitles|length > 0 %}
                <div class="mb-4">
                    <h3 class="text-xs font-semibold text-gray-300 uppercase tracking-wide mb-2">
                        {{ 'game.ranking.titles.heading'|trans }}
                    </h3>
                    <div class="flex flex-wrap gap-2">
                        {% for title in playerTitles %}
                            {% set rankColor = title.rank == 1 ? 'text-yellow-300 border-yellow-500/50 bg-yellow-900/20'
                                : (title.rank == 2 ? 'text-gray-200 border-gray-400/50 bg-gray-700/40'
                                : 'text-orange-300 border-orange-500/50 bg-orange-900/20') %}
                            <span class="inline-flex items-center gap-1 rounded-full border px-2 py-0.5 text-[11px] font-medium {{ rankColor }}"
                                  title="{{ 'game.ranking.titles.season_tooltip'|trans({'%season%': title.season.name, '%tab%': ('game.ranking.tab.' ~ title.tab.value)|trans}) }}">
                                <span aria-hidden="true">&#9733;</span>{{ title.titleLabel }}
                            </span>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Resume du rang du joueur #}
            <div class="flex flex-wrap gap-3 mb-4 text-xs">
                <div class="bg-gray-700/50 rounded-lg px-3 py-2 border border-gray-600">
                    <span class="text-gray-400">
                        {% if playerRank is null %}
                            {{ 'game.ranking.your_rank_none'|trans }}
                        {% else %}
                            {{ 'game.ranking.your_rank'|trans({'%rank%': playerRank}) }}
                        {% endif %}
                    </span>
                </div>
                <div class="bg-gray-700/50 rounded-lg px-3 py-2 border border-gray-600">
                    <span class="text-gray-400">
                        {% if tab == 'quests' %}
                            {{ 'game.ranking.your_quests'|trans({'%count%': playerTotal}) }}
                        {% elseif tab == 'xp' %}
                            {{ 'game.ranking.your_xp'|trans({'%count%': playerTotal}) }}
                        {% else %}
                            {{ 'game.ranking.your_kills'|trans({'%count%': playerTotal}) }}
                        {% endif %}
                    </span>
                </div>
            </div>

            {% if topEntries is empty %}
                <div class="text-center py-8">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-gray-600 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <p class="text-gray-500 text-sm">{{ 'game.ranking.empty'|trans }}</p>
                </div>
            {% else %}
                <div class="overflow-x-auto">
                    <table class="w-full text-xs sm:text-sm">
                        <thead>
                            <tr class="text-gray-400 border-b border-gray-700">
                                <th class="text-left py-2 px-2 font-medium">{{ 'game.ranking.col.rank'|trans }}</th>
                                <th class="text-left py-2 px-2 font-medium">{{ 'game.ranking.col.player'|trans }}</th>
                                <th class="text-right py-2 px-2 font-medium">{{ colLabel }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for entry in topEntries %}
                                {% set isCurrentPlayer = entry.player.id == player.id %}
                                <tr class="border-b border-gray-800 {% if isCurrentPlayer %}bg-purple-900/30{% else %}hover:bg-gray-800/40{% endif %}">
                                    <td class="py-2 px-2 font-mono">
                                        {% if loop.index == 1 %}
                                            <span class="text-yellow-400" title="1er">&#9733; {{ loop.index }}</span>
                                        {% elseif loop.index == 2 %}
                                            <span class="text-gray-300" title="2eme">&#9733; {{ loop.index }}</span>
                                        {% elseif loop.index == 3 %}
                                            <span class="text-orange-400" title="3eme">&#9733; {{ loop.index }}</span>
                                        {% else %}
                                            <span class="text-gray-500">{{ loop.index }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="py-2 px-2 {% if isCurrentPlayer %}text-purple-200 font-semibold{% else %}text-gray-200{% endif %}">
                                        {{ entry.player.name }}
                                        {% if isCurrentPlayer %}
                                            <span class="ml-1 text-[10px] text-purple-400">({{ 'game.ranking.you'|trans }})</span>
                                        {% endif %}
                                    </td>
                                    <td class="py-2 px-2 text-right text-purple-400 font-mono">{{ attribute(entry, valueKey) }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <p class="text-gray-500 text-[10px] mt-3 text-center">
                    {{ 'game.ranking.top_limit_note'|trans({'%limit%': topLimit}) }}
                </p>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}
{% from 'game/character/create.html.twig' import avatar_choice_group %}

{% block title %}{{ 'game.character.customize.title'|trans }}{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-[calc(100vh-4rem)] px-4 py-12">
    <div class="w-full max-w-2xl">
        <div class="bg-gray-800 rounded-2xl shadow-2xl border border-gray-700 overflow-hidden">
            <div class="px-8 pt-8 pb-4 text-center">
                <h1 class="text-2xl font-bold text-white">{{ 'game.character.customize.title'|trans }}</h1>
                <p class="text-gray-400 text-sm mt-1">{{ 'game.character.customize.subtitle'|trans({'%name%': player.name}) }}</p>
            </div>

            <div class="px-8 pb-8">
                {% for message in app.flashes('success') %}
                    <div class="mb-4 px-4 py-3 rounded-lg bg-emerald-900 bg-opacity-40 border border-emerald-700 text-emerald-300 text-sm">
                        {{ message }}
                    </div>
                {% endfor %}

                {{ form_start(form, { attr: { 'class': 'space-y-6', 'data-turbo': 'false' } }) }}
                    {{ avatar_choice_group(form.body, 'game.character.customize.body'|trans, true) }}
                    {{ avatar_choice_group(form.hair, 'game.character.customize.hair'|trans, false) }}

                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">{{ 'game.character.customize.hair_color'|trans }}</label>
                        <div class="flex flex-wrap gap-2">
                            {% for child in form.hairColor %}
                                <label for="{{ child.vars.id }}" class="relative cursor-pointer">
                                    <input type="radio" id="{{ child.vars.id }}" name="{{ child.vars.full_name }}" value="{{ child.vars.value }}" class="sr-only peer" {{ child.vars.checked ? 'checked' : '' }}>
                                    <div class="w-9 h-9 rounded-full border-2 border-gray-600 transition-all hover:border-gray-400 peer-checked:border-purple-400 peer-checked:scale-110"
                                         style="background-color: {{ child.vars.value }};"
                                         title="{{ child.vars.label }}"></div>
                                </label>
                            {% endfor %}
                        </div>
                    </div>

                    <button type="submit" class="w-full py-3 px-4 bg-purple-600 hover:bg-purple-700 text-white font-semibold rounded-lg shadow-lg shadow-purple-900/30 transition-all focus:outline-none focus:ring-2 focus:ring-purple-500">
                        {{ 'game.character.customize.submit'|trans }}
                    </button>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}

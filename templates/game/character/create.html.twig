{% extends 'base.html.twig' %}

{% block title %}Créer un personnage{% endblock %}

{% macro avatar_choice_group(field, label, required) %}
    <div>
        <label class="block text-sm font-medium text-gray-300 mb-2">
            {{ label }}{% if required %} <span class="text-red-400">*</span>{% endif %}
        </label>
        {% if field|length > 0 %}
            <div class="grid grid-cols-3 sm:grid-cols-4 gap-2">
                {% for child in field %}
                    <label for="{{ child.vars.id }}" class="relative cursor-pointer group">
                        <input type="radio"
                               id="{{ child.vars.id }}"
                               name="{{ child.vars.full_name }}"
                               value="{{ child.vars.value }}"
                               class="sr-only peer"
                               {{ child.vars.checked ? 'checked' : '' }}>
                        <div class="p-1.5 rounded-lg border-2 border-gray-600 bg-gray-900 bg-opacity-50 transition-all duration-200
                                    hover:border-gray-500 peer-checked:border-purple-500 peer-checked:bg-purple-900 peer-checked:bg-opacity-30">
                            {% set sheet = child.vars.attr['data-sheet'] ?? null %}
                            <div class="w-full aspect-square rounded bg-gray-950 overflow-hidden flex items-center justify-center">
                                {% if sheet %}
                                    <img src="{{ sheet }}"
                                         alt="{{ child.vars.value }}"
                                         class="w-12 h-12 object-none object-left-top"
                                         style="image-rendering: pixelated; object-position: -128px -320px;">
                                {% else %}
                                    <span class="text-gray-600 text-xs">—</span>
                                {% endif %}
                            </div>
                            <div class="mt-1 text-center text-[11px] text-gray-400 truncate">{{ child.vars.value }}</div>
                        </div>
                    </label>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-sm text-gray-500 italic">Aucun choix disponible.</p>
        {% endif %}
        {% if field.vars.errors|length > 0 %}
            <p class="mt-2 text-sm text-red-400">{{ field.vars.errors[0].message }}</p>
        {% endif %}
    </div>
{% endmacro %}

{% block body %}
<div class="flex items-center justify-center min-h-[calc(100vh-4rem)] px-4 py-12">
    <div class="w-full max-w-2xl">
        <div class="bg-gray-800 rounded-2xl shadow-2xl border border-gray-700 overflow-hidden">
            <div class="px-8 pt-8 pb-4 text-center">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-purple-600 bg-opacity-20 mb-4">
                    <svg class="w-8 h-8 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                    </svg>
                </div>
                <h1 class="text-2xl font-bold text-white">Créer un personnage</h1>
                <p class="text-gray-400 text-sm mt-1">Choisissez un nom et une race pour commencer l'aventure</p>
            </div>

            <div class="px-8 pb-8">
                {% for message in app.flashes('error') %}
                    <div class="mb-4 px-4 py-3 rounded-lg bg-red-900 bg-opacity-40 border border-red-700 text-red-300 text-sm flex items-start gap-2">
                        <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                        </svg>
                        <span>{{ message }}</span>
                    </div>
                {% endfor %}

                {{ form_start(form, { attr: { 'class': 'space-y-6', 'data-turbo': 'false', 'data-controller': 'character-creator' } }) }}

                    {# Preview avatar (AVT-24) — compose body/outfit/hair+tint dans un canvas 64x64 #}
                    <div class="flex items-center justify-center">
                        <div class="p-3 rounded-xl border-2 border-gray-700 bg-gray-900 bg-opacity-60">
                            <canvas data-character-creator-target="canvas"
                                    width="64" height="64"
                                    class="w-32 h-32 block"
                                    style="image-rendering: pixelated;"
                                    aria-label="Apercu de l'apparence selectionnee"></canvas>
                            <p class="mt-1 text-center text-[11px] text-gray-500 uppercase tracking-wider">Apercu</p>
                        </div>
                    </div>


                    {# Nom du personnage #}
                    <div>
                        <label for="{{ form.name.vars.id }}" class="block text-sm font-medium text-gray-300 mb-1.5">
                            Nom du personnage
                        </label>
                        <input type="text"
                               id="{{ form.name.vars.id }}"
                               name="{{ form.name.vars.full_name }}"
                               value="{{ form.name.vars.value }}"
                               class="w-full px-4 py-2.5 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition"
                               placeholder="Ex: Aldric, Elara, Thorin..."
                               maxlength="16"
                               minlength="3"
                               autocomplete="off"
                               required>
                        {% if form.name.vars.errors|length > 0 %}
                            <p class="mt-1 text-sm text-red-400">{{ form.name.vars.errors[0].message }}</p>
                        {% endif %}
                    </div>

                    {# Apparence #}
                    <div class="space-y-5 pt-2">
                        <h2 class="text-lg font-semibold text-gray-200">Apparence</h2>

                        {{ _self.avatar_choice_group(form.body, 'Corps', true) }}
                        {{ _self.avatar_choice_group(form.hair, 'Coiffure', false) }}

                        {# Couleur de cheveux #}
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">Couleur de cheveux</label>
                            <div class="flex flex-wrap gap-2">
                                {% for child in form.hairColor %}
                                    <label for="{{ child.vars.id }}" class="relative cursor-pointer">
                                        <input type="radio"
                                               id="{{ child.vars.id }}"
                                               name="{{ child.vars.full_name }}"
                                               value="{{ child.vars.value }}"
                                               class="sr-only peer"
                                               {{ child.vars.checked ? 'checked' : '' }}>
                                        <span class="block w-8 h-8 rounded-full border-2 border-gray-600 transition
                                                     peer-checked:border-purple-400 peer-checked:ring-2 peer-checked:ring-purple-500 peer-checked:ring-offset-2 peer-checked:ring-offset-gray-800"
                                              style="background-color: {{ child.vars.value }};"
                                              title="{{ child.vars.label }}"></span>
                                    </label>
                                {% endfor %}
                            </div>
                            {% if form.hairColor.vars.errors|length > 0 %}
                                <p class="mt-2 text-sm text-red-400">{{ form.hairColor.vars.errors[0].message }}</p>
                            {% endif %}
                        </div>

                        {{ _self.avatar_choice_group(form.outfit, 'Tenue de depart', false) }}
                    </div>

                    {# Choix de la race #}
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-3">Choisissez une race</label>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            {% for child in form.race %}
                                {% set race = child.vars.data %}
                                <label for="{{ child.vars.id }}"
                                       class="relative cursor-pointer group">
                                    <input type="radio"
                                           id="{{ child.vars.id }}"
                                           name="{{ child.vars.full_name }}"
                                           value="{{ child.vars.value }}"
                                           class="sr-only peer"
                                           {{ child.vars.checked ? 'checked' : '' }}>
                                    <div class="p-4 rounded-xl border-2 border-gray-600 bg-gray-750 bg-opacity-50 transition-all duration-200
                                                hover:border-gray-500 hover:bg-gray-700
                                                peer-checked:border-purple-500 peer-checked:bg-purple-900 peer-checked:bg-opacity-30 peer-checked:shadow-lg peer-checked:shadow-purple-900/20">
                                        <div class="flex items-start gap-3">
                                            {# Sprite preview #}
                                            {% if race.spriteSheet %}
                                                <div class="w-16 h-16 flex-shrink-0 rounded-lg bg-gray-900 border border-gray-700 flex items-center justify-center overflow-hidden">
                                                    <img src="{{ asset('styles/images/sprites/' ~ race.spriteSheet) }}"
                                                         alt="{{ race.name }}"
                                                         class="w-12 h-16 object-cover object-top"
                                                         style="image-rendering: pixelated;">
                                                </div>
                                            {% else %}
                                                <div class="w-16 h-16 flex-shrink-0 rounded-lg bg-gray-900 border border-gray-700 flex items-center justify-center">
                                                    <svg class="w-8 h-8 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                                    </svg>
                                                </div>
                                            {% endif %}

                                            <div class="flex-1 min-w-0">
                                                <h3 class="text-white font-semibold text-sm">{{ race.name }}</h3>
                                                <p class="text-gray-400 text-xs mt-0.5 line-clamp-2">{{ race.description }}</p>

                                                {# Stat modifiers #}
                                                {% set modifiers = race.statModifiers %}
                                                <div class="flex flex-wrap gap-1.5 mt-2">
                                                    {% set stat_labels = { 'life': 'Vie', 'energy': 'Energie', 'speed': 'Vitesse', 'hit': 'Precision' } %}
                                                    {% for stat, value in modifiers %}
                                                        {% if value != 0 %}
                                                            <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium
                                                                {{ value > 0 ? 'bg-green-900 bg-opacity-50 text-green-400' : 'bg-red-900 bg-opacity-50 text-red-400' }}">
                                                                {{ value > 0 ? '+' : '' }}{{ value }} {{ stat_labels[stat] ?? stat }}
                                                            </span>
                                                        {% endif %}
                                                    {% endfor %}
                                                    {% set has_modifiers = false %}
                                                    {% for stat, value in modifiers %}
                                                        {% if value != 0 %}{% set has_modifiers = true %}{% endif %}
                                                    {% endfor %}
                                                    {% if not has_modifiers %}
                                                        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-gray-700 text-gray-400">
                                                            Equilibre
                                                        </span>
                                                    {% endif %}
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </label>
                            {% endfor %}
                        </div>
                        {% if form.race.vars.errors|length > 0 %}
                            <p class="mt-2 text-sm text-red-400">{{ form.race.vars.errors[0].message }}</p>
                        {% endif %}
                    </div>

                    <button type="submit"
                            class="w-full py-3 px-4 bg-purple-600 hover:bg-purple-700 active:bg-purple-800 text-white font-semibold rounded-lg shadow-lg shadow-purple-900/30 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 focus:ring-offset-gray-800">
                        Commencer l'aventure
                    </button>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}

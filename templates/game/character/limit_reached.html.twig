{% extends 'base.html.twig' %}

{% block title %}{{ 'game.character.limit_reached.title_full'|trans }}{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-[calc(100vh-4rem)] px-4 py-12">
    <div class="w-full max-w-md">
        <div class="bg-gray-800 rounded-2xl shadow-2xl border border-gray-700 overflow-hidden">
            <div class="px-8 py-8 text-center">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-yellow-600 bg-opacity-20 mb-4">
                    <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                    </svg>
                </div>
                <h1 class="text-xl font-bold text-white mb-2">{{ 'game.character.limit_reached.title_short'|trans }}</h1>
                <p class="text-gray-400 text-sm">
                    {{ 'game.character.limit_reached.body'|trans({'%count%': maxPlayers, '%plural%': maxPlayers > 1 ? 's' : ''}) }}
                </p>
                <a href="{{ path('app_game') }}"
                   class="inline-block mt-6 py-2.5 px-6 bg-purple-600 hover:bg-purple-700 text-white font-semibold rounded-lg shadow-lg shadow-purple-900/30 transition-all duration-200">
                    {{ 'game.character.limit_reached.back'|trans }}
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% extends 'game/game.html.twig' %}

{% block title %}Echanges{% endblock %}

{% block game_content %}
<div class="game-page">
    <div class="game-card">
        {# Header #}
        <div class="game-card-header flex items-center justify-between">
            <div>
                <h2 class="text-base sm:text-lg font-semibold text-white">Echanges</h2>
                <p class="text-purple-200/70 text-xs">Echange securise entre joueurs</p>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-yellow-400 font-bold text-sm sm:text-base" id="player-gils">{{ player.gils }} Gils</span>
                <a href="{{ path('app_game_map') }}" class="text-purple-200/70 hover:text-white text-xs sm:text-sm">Retour</a>
            </div>
        </div>

        <div class="game-card-body">
            {# Tabs #}
            <div class="flex gap-2 mb-4 border-b border-gray-700 pb-2">
                <button onclick="switchTab('received')" id="tab-received" class="px-3 py-1.5 text-sm rounded-lg bg-purple-600 text-white transition-colors">
                    Recu{{ receivedTrades|length > 0 ? ' (' ~ receivedTrades|length ~ ')' : '' }}
                </button>
                <button onclick="switchTab('sent')" id="tab-sent" class="px-3 py-1.5 text-sm rounded-lg text-gray-400 hover:text-white hover:bg-gray-700 transition-colors">
                    Envoye{{ sentTrades|length > 0 ? ' (' ~ sentTrades|length ~ ')' : '' }}
                </button>
                <button onclick="switchTab('new')" id="tab-new" class="px-3 py-1.5 text-sm rounded-lg text-gray-400 hover:text-white hover:bg-gray-700 transition-colors">Nouvel echange</button>
            </div>

            {# === Received Trades Tab === #}
            <div id="panel-received">
                {% if receivedTrades is empty %}
                    <p class="text-gray-500 text-sm text-center py-8">Aucun echange en attente.</p>
                {% else %}
                    <div class="space-y-3">
                        {% for trade in receivedTrades %}
                            <div class="bg-gray-700/50 rounded-lg p-4" id="trade-{{ trade.id }}">
                                <div class="flex items-center justify-between mb-2">
                                    <span class="text-white font-medium text-sm">Proposition de {{ trade.initiator.name }}</span>
                                    <span class="text-xs text-gray-400">{{ trade.createdAt|date('d/m H:i') }}</span>
                                </div>

                                <div class="grid grid-cols-2 gap-4 mb-3">
                                    {# What initiator offers #}
                                    <div>
                                        <p class="text-xs text-purple-300 mb-1">{{ trade.initiator.name }} propose :</p>
                                        {% if trade.initiatorGils > 0 %}
                                            <span class="text-yellow-400 text-sm">{{ trade.initiatorGils }} Gils</span>
                                        {% endif %}
                                        {% if trade.initiatorItems|length > 0 %}
                                            <div class="text-xs text-gray-300 mt-1">{{ trade.initiatorItems|length }} objet(s)</div>
                                        {% endif %}
                                        {% if trade.initiatorItems is empty and trade.initiatorGils == 0 %}
                                            <span class="text-gray-500 text-xs">Rien</span>
                                        {% endif %}
                                    </div>

                                    {# What you offer #}
                                    <div>
                                        <p class="text-xs text-purple-300 mb-1">Vous proposez :</p>
                                        {% if trade.receiverGils > 0 %}
                                            <span class="text-yellow-400 text-sm">{{ trade.receiverGils }} Gils</span>
                                        {% endif %}
                                        {% if trade.receiverItems|length > 0 %}
                                            <div class="text-xs text-gray-300 mt-1">{{ trade.receiverItems|length }} objet(s)</div>
                                        {% endif %}
                                        {% if trade.receiverItems is empty and trade.receiverGils == 0 %}
                                            <span class="text-gray-500 text-xs">Rien (ajoutez votre offre)</span>
                                        {% endif %}
                                    </div>
                                </div>

                                <div class="flex items-center gap-2">
                                    <span class="text-xs {% if trade.initiatorConfirmed %}text-green-400{% else %}text-gray-500{% endif %}">
                                        {{ trade.initiator.name }}: {% if trade.initiatorConfirmed %}Confirme{% else %}En attente{% endif %}
                                    </span>
                                    <span class="text-gray-600">|</span>
                                    <span class="text-xs {% if trade.receiverConfirmed %}text-green-400{% else %}text-gray-500{% endif %}">
                                        Vous: {% if trade.receiverConfirmed %}Confirme{% else %}En attente{% endif %}
                                    </span>
                                </div>

                                <div class="flex gap-2 mt-3">
                                    <button onclick="confirmTrade({{ trade.id }})"
                                            class="px-3 py-1.5 bg-green-600 hover:bg-green-500 text-white text-xs rounded-lg transition-colors">
                                        Confirmer
                                    </button>
                                    <button onclick="declineTrade({{ trade.id }})"
                                            class="px-3 py-1.5 bg-red-600/80 hover:bg-red-500 text-white text-xs rounded-lg transition-colors">
                                        Refuser
                                    </button>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {# === Sent Trades Tab === #}
            <div id="panel-sent" class="hidden">
                {% if sentTrades is empty %}
                    <p class="text-gray-500 text-sm text-center py-8">Aucun echange envoye.</p>
                {% else %}
                    <div class="space-y-3">
                        {% for trade in sentTrades %}
                            <div class="bg-gray-700/50 rounded-lg p-4" id="trade-{{ trade.id }}">
                                <div class="flex items-center justify-between mb-2">
                                    <span class="text-white font-medium text-sm">Vers {{ trade.receiver.name }}</span>
                                    <span class="text-xs text-gray-400">{{ trade.createdAt|date('d/m H:i') }}</span>
                                </div>

                                <div class="flex items-center gap-2 mb-2">
                                    <span class="text-xs {% if trade.initiatorConfirmed %}text-green-400{% else %}text-gray-500{% endif %}">
                                        Vous: {% if trade.initiatorConfirmed %}Confirme{% else %}En attente{% endif %}
                                    </span>
                                    <span class="text-gray-600">|</span>
                                    <span class="text-xs {% if trade.receiverConfirmed %}text-green-400{% else %}text-gray-500{% endif %}">
                                        {{ trade.receiver.name }}: {% if trade.receiverConfirmed %}Confirme{% else %}En attente{% endif %}
                                    </span>
                                </div>

                                <div class="flex gap-2">
                                    <button onclick="confirmTrade({{ trade.id }})"
                                            class="px-3 py-1.5 bg-green-600 hover:bg-green-500 text-white text-xs rounded-lg transition-colors">
                                        Confirmer
                                    </button>
                                    <button onclick="declineTrade({{ trade.id }})"
                                            class="px-3 py-1.5 bg-red-600/80 hover:bg-red-500 text-white text-xs rounded-lg transition-colors">
                                        Annuler
                                    </button>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {# === New Trade Tab === #}
            <div id="panel-new" class="hidden">
                <h3 class="text-lg font-semibold text-purple-300 mb-3">Proposer un echange</h3>

                {# Player selection #}
                <div class="mb-4">
                    <label class="text-sm text-gray-300 block mb-1">Choisir un joueur a proximite :</label>
                    {% if nearbyPlayers is empty %}
                        <p class="text-gray-500 text-sm">Aucun joueur a proximite.</p>
                    {% else %}
                        <select id="trade-receiver" class="w-full px-3 py-2 bg-gray-700/50 border border-gray-600 rounded-lg text-sm text-white">
                            <option value="">-- Choisir un joueur --</option>
                            {% for p in nearbyPlayers %}
                                <option value="{{ p.id }}">{{ p.name }}</option>
                            {% endfor %}
                        </select>
                    {% endif %}
                </div>

                {# Items to offer #}
                <div class="mb-4">
                    <label class="text-sm text-gray-300 block mb-1">Objets a proposer :</label>
                    {% set bag = player.inventories|first %}
                    {% if bag and bag.items|length > 0 %}
                        <div class="space-y-1 max-h-48 overflow-y-auto">
                            {% for playerItem in bag.items %}
                                {% if playerItem.gear == 0 %}
                                <label class="flex items-center gap-2 bg-gray-700/30 rounded p-2 cursor-pointer hover:bg-gray-700/50">
                                    <input type="checkbox" class="trade-item-checkbox" value="{{ playerItem.id }}">
                                    <span class="text-white text-sm">{{ playerItem.genericItem.name }}</span>
                                    <span class="text-gray-500 text-xs">({{ playerItem.genericItem.type }})</span>
                                </label>
                                {% endif %}
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-gray-500 text-sm">Inventaire vide.</p>
                    {% endif %}
                </div>

                {# Gils to offer #}
                <div class="mb-4">
                    <label class="text-sm text-gray-300 block mb-1">Gils a proposer :</label>
                    <input type="number" id="trade-gils" min="0" max="{{ player.gils }}" value="0"
                           class="w-32 px-3 py-2 bg-gray-700/50 border border-gray-600 rounded-lg text-sm text-white">
                    <span class="text-xs text-gray-400 ml-2">(max: {{ player.gils }})</span>
                </div>

                <button onclick="createTrade()"
                        class="px-4 py-2 bg-purple-600 hover:bg-purple-500 text-white text-sm rounded-lg transition-colors">
                    Envoyer la proposition
                </button>
            </div>

            {# Messages area #}
            <div id="trade-messages" class="mt-4 hidden">
                <div class="bg-green-900/50 border border-green-700 rounded-lg p-3 text-green-300 text-sm" id="trade-message-text"></div>
            </div>
        </div>
    </div>
</div>

<script>
function switchTab(tab) {
    ['received', 'sent', 'new'].forEach(t => {
        const panel = document.getElementById(`panel-${t}`);
        const btn = document.getElementById(`tab-${t}`);
        if (t === tab) {
            panel.classList.remove('hidden');
            btn.className = 'px-3 py-1.5 text-sm rounded-lg bg-purple-600 text-white transition-colors';
        } else {
            panel.classList.add('hidden');
            btn.className = 'px-3 py-1.5 text-sm rounded-lg text-gray-400 hover:text-white hover:bg-gray-700 transition-colors';
        }
    });
}

async function createTrade() {
    const receiverId = document.getElementById('trade-receiver')?.value;
    if (!receiverId) { showMessage('Selectionnez un joueur', true); return; }

    const itemIds = [...document.querySelectorAll('.trade-item-checkbox:checked')].map(cb => parseInt(cb.value));
    const gils = parseInt(document.getElementById('trade-gils').value) || 0;

    if (itemIds.length === 0 && gils === 0) {
        showMessage('Proposez au moins un objet ou des Gils', true);
        return;
    }

    try {
        const resp = await fetch('/game/trade/create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ receiverId: parseInt(receiverId), itemIds, gils }),
        });
        const data = await resp.json();
        if (data.success) {
            showMessage(data.message);
            setTimeout(() => location.reload(), 1000);
        } else {
            showMessage(data.error || 'Erreur', true);
        }
    } catch (e) {
        showMessage('Erreur de connexion', true);
    }
}

async function confirmTrade(tradeId) {
    try {
        const resp = await fetch(`/game/trade/${tradeId}/confirm`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
        });
        const data = await resp.json();
        if (data.success) {
            showMessage(data.message);
            if (data.completed) {
                document.getElementById('player-gils').textContent = data.gils + ' Gils';
                const el = document.getElementById(`trade-${tradeId}`);
                if (el) el.remove();
            } else {
                setTimeout(() => location.reload(), 800);
            }
        } else {
            showMessage(data.error || 'Erreur', true);
        }
    } catch (e) {
        showMessage('Erreur de connexion', true);
    }
}

async function declineTrade(tradeId) {
    if (!confirm('Etes-vous sur ?')) return;
    try {
        const resp = await fetch(`/game/trade/${tradeId}/decline`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
        });
        const data = await resp.json();
        if (data.success) {
            showMessage(data.message);
            const el = document.getElementById(`trade-${tradeId}`);
            if (el) el.remove();
        } else {
            showMessage(data.error || 'Erreur', true);
        }
    } catch (e) {
        showMessage('Erreur de connexion', true);
    }
}

function showMessage(msg, isError = false) {
    const container = document.getElementById('trade-messages');
    const text = document.getElementById('trade-message-text');
    container.classList.remove('hidden');
    text.textContent = msg;
    text.className = isError
        ? 'bg-red-900/50 border border-red-700 rounded-lg p-3 text-red-300 text-sm'
        : 'bg-green-900/50 border border-green-700 rounded-lg p-3 text-green-300 text-sm';
    setTimeout(() => container.classList.add('hidden'), 3000);
}
</script>
{% endblock %}

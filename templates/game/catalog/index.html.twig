{% extends 'game/game.html.twig' %}

{% block title %}{{ 'game.catalog.title'|trans }}{% endblock %}

{% block game_content %}
<div class="game-page">
    <div class="game-card">
        <div class="game-card-header flex items-center justify-between">
            <div>
                <h2 class="text-base sm:text-lg font-semibold text-white">{{ 'game.catalog.title'|trans }}</h2>
                <p class="text-gray-400 text-xs mt-0.5">{{ 'game.catalog.subtitle'|trans }}</p>
            </div>
        </div>

        <div class="game-card-body">
            {# Stats summary #}
            <div class="flex gap-4 mb-4 text-xs">
                <div class="bg-gray-700/50 rounded-lg px-3 py-2 border border-gray-600">
                    <span class="text-gray-400">{{ 'game.catalog.discovered'|trans({'%count%': discoveredCount, '%total%': totalResources}) }}</span>
                </div>
                <div class="bg-gray-700/50 rounded-lg px-3 py-2 border border-gray-600">
                    <span class="text-gray-400">{{ 'game.catalog.total_collected'|trans({'%count%': totalCollected}) }}</span>
                </div>
            </div>

            {% if entries is empty %}
                <div class="text-center py-8">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-gray-600 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.005 9.005 0 003 12a9 9 0 0017.354 3.354z" />
                    </svg>
                    <p class="text-gray-500 text-sm">{{ 'game.catalog.empty'|trans }}</p>
                    <p class="text-gray-600 text-xs mt-1">{{ 'game.catalog.empty_hint'|trans }}</p>
                </div>
            {% else %}
                <div class="space-y-2 sm:space-y-3">
                    {% for entry in entries %}
                        {% set item = entry.item %}
                        {% set nextTier = entry.nextTierThreshold %}
                        <div class="bg-gray-700/50 rounded-lg p-3 sm:p-4 border border-gray-600">
                            {# Header: name + type + count #}
                            <div class="flex items-start justify-between gap-2 mb-2">
                                <div class="min-w-0">
                                    <div class="flex items-center gap-2">
                                        <h3 class="text-white font-semibold text-sm sm:text-base">{{ item.name }}</h3>
                                        <span class="px-1.5 py-0.5 rounded text-[10px]
                                            {% if item.type == 'herb' %}bg-green-900/60 border border-green-700 text-green-300
                                            {% elseif item.type == 'ore' %}bg-amber-900/60 border border-amber-700 text-amber-300
                                            {% elseif item.type == 'plant' %}bg-emerald-900/60 border border-emerald-700 text-emerald-300
                                            {% else %}bg-gray-800 border border-gray-700 text-gray-400{% endif %}">
                                            {{ ('game.catalog.type_' ~ item.type)|trans }}
                                        </span>
                                        {% if item.rarityEnum is not null and item.rarityEnum.value != 'common' %}
                                            <span class="px-1.5 py-0.5 rounded text-[10px]
                                                {% if item.rarityEnum.value == 'uncommon' %}bg-blue-900/60 border border-blue-700 text-blue-300
                                                {% elseif item.rarityEnum.value == 'rare' %}bg-purple-900/60 border border-purple-700 text-purple-300
                                                {% elseif item.rarityEnum.value == 'epic' %}bg-yellow-900/60 border border-yellow-700 text-yellow-300
                                                {% endif %}">
                                                {{ item.rarityEnum.value|capitalize }}
                                            </span>
                                        {% endif %}
                                    </div>
                                    <p class="text-gray-400 text-xs mt-0.5">{{ item|localized_description }}</p>
                                </div>
                                <div class="flex items-center gap-1.5 flex-shrink-0">
                                    <span class="text-emerald-400 text-xs font-mono">{{ 'game.catalog.collected'|trans({'%count%': entry.collectCount}) }}</span>
                                </div>
                            </div>

                            {# Tier badges #}
                            <div class="flex gap-1.5 mb-2">
                                <span class="px-1.5 py-0.5 rounded text-[10px] {% if entry.locationsRevealed %}bg-blue-900/60 border border-blue-700 text-blue-300{% else %}bg-gray-800 border border-gray-700 text-gray-500{% endif %}">
                                    {{ 'game.catalog.tier_locations'|trans }}
                                </span>
                                <span class="px-1.5 py-0.5 rounded text-[10px] {% if entry.recipesRevealed %}bg-yellow-900/60 border border-yellow-700 text-yellow-300{% else %}bg-gray-800 border border-gray-700 text-gray-500{% endif %}">
                                    {{ 'game.catalog.tier_recipes'|trans }}
                                </span>
                                <span class="px-1.5 py-0.5 rounded text-[10px] {% if entry.specialistTitle %}bg-emerald-900/60 border border-emerald-700 text-emerald-300{% else %}bg-gray-800 border border-gray-700 text-gray-500{% endif %}">
                                    {{ 'game.catalog.tier_specialist'|trans({'%resource%': item.name}) }}
                                </span>
                            </div>

                            {# Progress bar to next tier #}
                            {% if nextTier is not null %}
                                <div class="mt-2">
                                    <div class="flex justify-between text-[10px] text-gray-400 mb-1">
                                        <span>{{ 'game.catalog.next_tier'|trans({'%count%': entry.collectCount, '%required%': nextTier}) }}</span>
                                        <span>{{ ((entry.collectCount / nextTier) * 100)|round }}%</span>
                                    </div>
                                    <div class="progress-bar">
                                        <div class="progress-bar-fill bg-emerald-500" style="width: {{ ((entry.collectCount / nextTier) * 100)|round }}%"></div>
                                    </div>
                                </div>
                            {% endif %}

                            {# Locations info (tier 1) #}
                            {% if entry.locationsRevealed %}
                                <div class="mt-2 pt-2 border-t border-gray-600">
                                    <span class="text-[10px] text-gray-500">{{ 'game.catalog.info_element'|trans }} :</span>
                                    <div class="flex flex-wrap gap-2 mt-1">
                                        {% if item.element.value != 'none' %}
                                            <span class="text-xs text-blue-300">{{ item.element.value|capitalize }}</span>
                                        {% endif %}
                                        <span class="text-xs text-gray-400">{{ 'game.catalog.value'|trans({'%price%': item.price ?? 0}) }}</span>
                                    </div>
                                </div>
                            {% endif %}

                            {# Specialist title (tier 3) #}
                            {% if entry.specialistTitle %}
                                <div class="mt-2 pt-2 border-t border-gray-600">
                                    <span class="text-emerald-300 text-xs font-medium">{{ 'game.catalog.tier_specialist'|trans({'%resource%': item.name}) }}</span>
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% extends 'game/game.html.twig' %}

{% block title %}Journal de quetes{% endblock %}

{% block game_content %}
<div class="game-page">
    <div class="game-card">
        <div class="game-card-header flex items-center justify-between">
            <h2 class="text-base sm:text-lg font-semibold text-white">Journal de quetes</h2>
        </div>

        <div class="game-card-body">
            {# Messages area #}
            <div id="quest-messages" class="mb-3 hidden">
                <div class="rounded-lg p-3 text-sm" id="quest-message-text"></div>
            </div>

            {# Tabs #}
            <div class="flex border-b border-gray-700 mb-4 -mx-4 px-4 sm:mx-0 sm:px-0">
                <button onclick="showTab('active')" id="tab-active"
                        class="px-4 py-2.5 text-sm font-medium border-b-2 border-purple-500 text-purple-400 touch-target">
                    En cours ({{ activeQuests|length }})
                </button>
                <button onclick="showTab('available')" id="tab-available"
                        class="px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-400 hover:text-gray-300 touch-target">
                    Disponibles ({{ availableQuests|length }})
                </button>
                <button onclick="showTab('completed')" id="tab-completed"
                        class="px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-400 hover:text-gray-300 touch-target">
                    Terminees ({{ completedQuests|length }})
                </button>
            </div>

            {# Active quests #}
            <div id="panel-active">
                {% if activeQuests is empty %}
                    <div class="text-center py-8">
                        <p class="text-gray-500 text-sm">Aucune quete en cours.</p>
                        <p class="text-gray-600 text-xs mt-1">Parlez aux PNJ sur la carte pour obtenir des quetes.</p>
                    </div>
                {% else %}
                    <div class="space-y-2 sm:space-y-3">
                        {% for playerQuest in activeQuests %}
                            {% set quest = playerQuest.quest %}
                            {% set progress = questProgress[playerQuest.id] %}
                            <div class="bg-gray-700/50 rounded-lg p-3 sm:p-4 border border-gray-600" id="quest-{{ playerQuest.id }}">
                                <div class="flex items-start justify-between gap-2 mb-2">
                                    <div class="min-w-0">
                                        <h3 class="text-white font-semibold text-sm sm:text-base">{{ quest.name }}</h3>
                                        <p class="text-gray-400 text-xs sm:text-sm mt-0.5">{{ quest.description }}</p>
                                    </div>
                                    <div class="flex gap-1.5 flex-shrink-0">
                                        {% if progress >= 100 %}
                                            <button onclick="completeQuest({{ playerQuest.id }})"
                                                    class="px-2.5 py-1.5 bg-green-600 hover:bg-green-500 active:bg-green-700 text-white text-xs rounded transition-colors touch-target">
                                                Rendre
                                            </button>
                                        {% endif %}
                                        <button onclick="abandonQuest({{ playerQuest.id }})"
                                                class="px-2.5 py-1.5 bg-red-600/60 hover:bg-red-500 active:bg-red-700 text-white text-xs rounded transition-colors touch-target">
                                            Abandonner
                                        </button>
                                    </div>
                                </div>

                                {# Progress bar #}
                                <div class="mt-2">
                                    <div class="flex justify-between text-[10px] sm:text-xs text-gray-400 mb-1">
                                        <span>Progression</span>
                                        <span>{{ progress }}%</span>
                                    </div>
                                    <div class="progress-bar">
                                        <div class="progress-bar-fill {% if progress >= 100 %}bg-green-500{% else %}bg-purple-500{% endif %}"
                                             style="width: {{ progress }}%"></div>
                                    </div>
                                </div>

                                {# Tracking details #}
                                {% set tracking = playerQuest.tracking %}
                                {% if tracking.monsters is defined and tracking.monsters is not empty %}
                                    <div class="mt-2 space-y-0.5">
                                        {% for monster in tracking.monsters %}
                                            <div class="flex items-center justify-between text-xs">
                                                <span class="text-gray-300">Tuer {{ monster.name }}</span>
                                                <span class="{% if monster.count >= monster.necessary %}text-green-400{% else %}text-gray-400{% endif %}">
                                                    {{ monster.count }}/{{ monster.necessary }}
                                                </span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}

                                {# Rewards #}
                                {% set rewards = quest.rewards %}
                                {% if rewards is not empty %}
                                    <div class="mt-2 pt-2 border-t border-gray-600">
                                        <span class="text-[10px] text-gray-500">Recompenses :</span>
                                        <div class="flex flex-wrap gap-3 mt-0.5">
                                            {% if rewards.gils is defined %}
                                                <span class="text-yellow-400 text-xs">{{ rewards.gils }} Gils</span>
                                            {% elseif rewards.gold is defined %}
                                                <span class="text-yellow-400 text-xs">{{ rewards.gold }} Gils</span>
                                            {% endif %}
                                            {% if rewards.xp is defined %}
                                                <span class="text-blue-400 text-xs">{{ rewards.xp }} XP</span>
                                            {% endif %}
                                            {% if rewards.items is defined %}
                                                {% for itemData in rewards.items %}
                                                    {% if itemData is iterable and itemData.genericItemSlug is defined %}
                                                        <span class="text-green-400 text-xs">{{ itemData.count|default(1) }}x {{ itemData.genericItemSlug|replace({'_': ' ', '-': ' '})|capitalize }}</span>
                                                    {% endif %}
                                                {% endfor %}
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {# Available quests #}
            <div id="panel-available" class="hidden">
                {% if availableQuests is empty %}
                    <div class="text-center py-8">
                        <p class="text-gray-500 text-sm">Aucune nouvelle quete disponible.</p>
                        <p class="text-gray-600 text-xs mt-1">Completez des quetes pour en debloquer de nouvelles.</p>
                    </div>
                {% else %}
                    <div class="space-y-2 sm:space-y-3">
                        {% for quest in availableQuests %}
                            <div class="bg-gray-700/50 rounded-lg p-3 sm:p-4 border border-gray-600" id="available-quest-{{ quest.id }}">
                                <div class="flex items-start justify-between gap-2 mb-2">
                                    <div class="min-w-0">
                                        <h3 class="text-white font-semibold text-sm sm:text-base">{{ quest.name }}</h3>
                                        <p class="text-gray-400 text-xs sm:text-sm mt-0.5">{{ quest.description }}</p>
                                    </div>
                                </div>

                                {# Requirements preview #}
                                {% set requirements = quest.requirements %}
                                {% if requirements.monsters is defined and requirements.monsters is not empty %}
                                    <div class="mt-2 space-y-0.5">
                                        {% for monster in requirements.monsters %}
                                            <div class="flex items-center justify-between text-xs">
                                                <span class="text-gray-300">Tuer {{ monster.name }}</span>
                                                <span class="text-gray-400">0/{{ monster.count }}</span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}

                                {# Rewards #}
                                {% set rewards = quest.rewards %}
                                {% if rewards is not empty %}
                                    <div class="mt-2 pt-2 border-t border-gray-600">
                                        <span class="text-[10px] text-gray-500">Recompenses :</span>
                                        <div class="flex flex-wrap gap-3 mt-0.5">
                                            {% if rewards.gils is defined %}
                                                <span class="text-yellow-400 text-xs">{{ rewards.gils }} Gils</span>
                                            {% elseif rewards.gold is defined %}
                                                <span class="text-yellow-400 text-xs">{{ rewards.gold }} Gils</span>
                                            {% endif %}
                                            {% if rewards.xp is defined %}
                                                <span class="text-blue-400 text-xs">{{ rewards.xp }} XP</span>
                                            {% endif %}
                                            {% if rewards.items is defined %}
                                                {% for itemData in rewards.items %}
                                                    {% if itemData is iterable and itemData.genericItemSlug is defined %}
                                                        <span class="text-green-400 text-xs">{{ itemData.count|default(1) }}x {{ itemData.genericItemSlug|replace({'_': ' ', '-': ' '})|capitalize }}</span>
                                                    {% endif %}
                                                {% endfor %}
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {# Completed quests #}
            <div id="panel-completed" class="hidden">
                {% if completedQuests is empty %}
                    <div class="text-center py-8">
                        <p class="text-gray-500 text-sm">Aucune quete terminee.</p>
                    </div>
                {% else %}
                    <div class="space-y-1.5 sm:space-y-2">
                        {% for pqc in completedQuests %}
                            {% set quest = pqc.quest %}
                            <div class="bg-gray-700/30 rounded-lg p-3 border border-gray-700 opacity-75">
                                <div class="flex items-center justify-between">
                                    <div class="min-w-0">
                                        <h3 class="text-gray-300 font-medium text-sm truncate">{{ quest.name }}</h3>
                                        <p class="text-gray-500 text-xs">{{ quest.description|slice(0, 80) }}{% if quest.description|length > 80 %}...{% endif %}</p>
                                    </div>
                                    <span class="text-green-500 text-xs font-mono flex-shrink-0 ml-2">Terminee</span>
                                </div>
                                {% set rewards = quest.rewards %}
                                {% if rewards is not empty %}
                                    <div class="mt-1.5 flex flex-wrap gap-2">
                                        {% if rewards.gils is defined %}
                                            <span class="text-yellow-400/60 text-[10px]">{{ rewards.gils }} Gils</span>
                                        {% elseif rewards.gold is defined %}
                                            <span class="text-yellow-400/60 text-[10px]">{{ rewards.gold }} Gils</span>
                                        {% endif %}
                                        {% if rewards.xp is defined %}
                                            <span class="text-blue-400/60 text-[10px]">{{ rewards.xp }} XP</span>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<script>
function showTab(tab) {
    const tabs = ['active', 'available', 'completed'];
    tabs.forEach(t => {
        document.getElementById('panel-' + t).classList.toggle('hidden', tab !== t);
        document.getElementById('tab-' + t).className = tab === t
            ? 'px-4 py-2.5 text-sm font-medium border-b-2 border-purple-500 text-purple-400 touch-target'
            : 'px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-400 hover:text-gray-300 touch-target';
    });
}

async function completeQuest(id) {
    try {
        const resp = await fetch(`/game/quests/complete/${id}`, { method: 'POST' });
        const data = await resp.json();
        if (data.success) {
            showMessage(data.messages.join(' '));
            setTimeout(() => location.reload(), 1000);
        } else {
            showMessage(data.error || 'Erreur', true);
        }
    } catch (e) {
        showMessage('Erreur de connexion', true);
    }
}

async function abandonQuest(id) {
    if (!confirm('Abandonner cette quete ?')) return;
    try {
        const resp = await fetch(`/game/quests/abandon/${id}`, { method: 'POST' });
        const data = await resp.json();
        if (data.success) {
            showMessage(data.message);
            const el = document.getElementById(`quest-${id}`);
            if (el) el.remove();
        } else {
            showMessage(data.error || 'Erreur', true);
        }
    } catch (e) {
        showMessage('Erreur de connexion', true);
    }
}

function showMessage(msg, isError = false) {
    const container = document.getElementById('quest-messages');
    const text = document.getElementById('quest-message-text');
    container.classList.remove('hidden');
    text.textContent = msg;
    text.className = isError
        ? 'bg-red-900/50 border border-red-700 rounded-lg p-3 text-red-300 text-sm'
        : 'bg-green-900/50 border border-green-700 rounded-lg p-3 text-green-300 text-sm';
    setTimeout(() => container.classList.add('hidden'), 3000);
}
</script>
{% endblock %}

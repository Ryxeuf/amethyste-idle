{% extends 'game/game.html.twig' %}

{% block title %}Journal de quetes{% endblock %}

{% block game_content %}
<div class="game-page">
    <div class="game-card">
        <div class="game-card-header flex items-center justify-between">
            <h2 class="text-base sm:text-lg font-semibold text-white">Journal de quetes</h2>
        </div>

        <div class="game-card-body">
            {# Messages area #}
            <div id="quest-messages" class="mb-3 hidden">
                <div class="rounded-lg p-3 text-sm" id="quest-message-text"></div>
            </div>

            {# Tabs #}
            <div class="flex border-b border-gray-700 mb-4 -mx-4 px-4 sm:mx-0 sm:px-0 overflow-x-auto">
                <button onclick="showTab('active')" id="tab-active"
                        class="px-4 py-2.5 text-sm font-medium border-b-2 border-purple-500 text-purple-400 touch-target whitespace-nowrap">
                    En cours ({{ activeQuests|length }})
                </button>
                <button onclick="showTab('daily')" id="tab-daily"
                        class="px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-400 hover:text-gray-300 touch-target whitespace-nowrap">
                    Quotidiennes ({{ activeDailyQuests|length + availableDailyQuests|length }})
                </button>
                <button onclick="showTab('available')" id="tab-available"
                        class="px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-400 hover:text-gray-300 touch-target whitespace-nowrap">
                    Disponibles ({{ availableQuests|length }})
                </button>
                <button onclick="showTab('completed')" id="tab-completed"
                        class="px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-400 hover:text-gray-300 touch-target whitespace-nowrap">
                    Terminees ({{ completedQuests|length }})
                </button>
            </div>

            {# Active quests #}
            <div id="panel-active">
                {% if activeQuests is empty %}
                    <div class="text-center py-8">
                        <p class="text-gray-500 text-sm">Aucune quete en cours.</p>
                        <p class="text-gray-600 text-xs mt-1">Parlez aux PNJ sur la carte pour obtenir des quetes.</p>
                    </div>
                {% else %}
                    <div class="space-y-2 sm:space-y-3">
                        {% for playerQuest in activeQuests %}
                            {% set quest = playerQuest.quest %}
                            {% set progress = questProgress[playerQuest.id] %}
                            {% set chainInfo = questChains[quest.id] ?? null %}
                            {% set questType = questTypes[quest.id] ?? 'other' %}
                            {% set giver = questGivers[quest.id] ?? null %}
                            <div class="bg-gray-700/50 rounded-lg p-3 sm:p-4 border border-gray-600" id="quest-{{ playerQuest.id }}">
                                <div class="flex items-start justify-between gap-2 mb-2">
                                    <div class="min-w-0">
                                        <div class="flex items-center gap-2 flex-wrap">
                                            <h3 class="text-white font-semibold text-sm sm:text-base">{{ quest.name }}</h3>
                                            {% if chainInfo %}
                                                <span class="text-[10px] px-1.5 py-0.5 rounded bg-purple-900/50 text-purple-300 border border-purple-700/50">
                                                    Quete {{ chainInfo.position }}/{{ chainInfo.total }}
                                                </span>
                                            {% endif %}
                                            <span class="text-[10px] px-1.5 py-0.5 rounded {{ questType == 'kill' ? 'bg-red-900/50 text-red-300 border border-red-700/50' : (questType == 'collect' ? 'bg-green-900/50 text-green-300 border border-green-700/50' : (questType == 'talk_to' ? 'bg-cyan-900/50 text-cyan-300 border border-cyan-700/50' : (questType == 'boss_challenge' ? 'bg-orange-900/50 text-orange-300 border border-orange-700/50' : (questType == 'defend' ? 'bg-yellow-900/50 text-yellow-300 border border-yellow-700/50' : (questType == 'escort' ? 'bg-teal-900/50 text-teal-300 border border-teal-700/50' : (questType == 'puzzle' ? 'bg-purple-900/50 text-purple-300 border border-purple-700/50' : 'bg-gray-800/50 text-gray-300 border border-gray-600/50')))))) }}">
                                                {{ questType == 'kill' ? 'Combat' : (questType == 'collect' ? 'Recolte' : (questType == 'deliver' ? 'Livraison' : (questType == 'explore' ? 'Exploration' : (questType == 'talk_to' ? 'Enquete' : (questType == 'boss_challenge' ? 'Defi Boss' : (questType == 'defend' ? 'Defense' : (questType == 'escort' ? 'Escorte' : (questType == 'puzzle' ? 'Enigme' : 'Divers')))))))) }}
                                            </span>
                                            {% if quest.hidden %}
                                                <span class="text-[10px] px-1.5 py-0.5 rounded bg-amber-900/50 text-amber-300 border border-amber-700/50">
                                                    Decouverte
                                                </span>
                                            {% endif %}
                                        </div>
                                        <p class="text-gray-400 text-xs sm:text-sm mt-0.5">{{ quest.description }}</p>
                                        {% if giver %}
                                            <p class="text-gray-500 text-[10px] mt-1">
                                                Donnee par <span class="text-amber-400/80">{{ giver.name }}</span>
                                                {% if giver.map %}
                                                    — <a href="{{ path('app_game_map') }}" class="text-purple-400/80 hover:text-purple-300 underline">{{ giver.map.name ?? 'Carte' }}</a>
                                                {% endif %}
                                            </p>
                                        {% endif %}
                                    </div>
                                    <div class="flex gap-1.5 flex-shrink-0">
                                        {% if progress >= 100 %}
                                            {% if quest.choiceOutcome is not empty %}
                                                <button onclick="showChoiceModal({{ playerQuest.id }}, {{ quest.choiceOutcome|json_encode|e('html_attr') }})"
                                                        class="px-2.5 py-1.5 bg-green-600 hover:bg-green-500 active:bg-green-700 text-white text-xs rounded transition-colors touch-target">
                                                    Choisir & Rendre
                                                </button>
                                            {% else %}
                                                <button onclick="completeQuest({{ playerQuest.id }})"
                                                        class="px-2.5 py-1.5 bg-green-600 hover:bg-green-500 active:bg-green-700 text-white text-xs rounded transition-colors touch-target">
                                                    Rendre
                                                </button>
                                            {% endif %}
                                        {% endif %}
                                        <button onclick="abandonQuest({{ playerQuest.id }})"
                                                class="px-2.5 py-1.5 bg-red-600/60 hover:bg-red-500 active:bg-red-700 text-white text-xs rounded transition-colors touch-target">
                                            Abandonner
                                        </button>
                                    </div>
                                </div>

                                {# Progress bar #}
                                <div class="mt-2">
                                    <div class="flex justify-between text-[10px] sm:text-xs text-gray-400 mb-1">
                                        <span>Progression</span>
                                        <span>{{ progress }}%</span>
                                    </div>
                                    <div class="progress-bar">
                                        <div class="progress-bar-fill {% if progress >= 100 %}bg-green-500{% else %}bg-purple-500{% endif %}"
                                             style="width: {{ progress }}%"></div>
                                    </div>
                                </div>

                                {# Tracking details #}
                                {% set tracking = playerQuest.tracking %}
                                {% if tracking.monsters is defined and tracking.monsters is not empty %}
                                    <div class="mt-2 space-y-0.5">
                                        {% for monster in tracking.monsters %}
                                            <div class="flex items-center justify-between text-xs">
                                                <span class="text-gray-300">Tuer {{ monster.name }}</span>
                                                <span class="{% if monster.count >= monster.necessary %}text-green-400{% else %}text-gray-400{% endif %}">
                                                    {{ monster.count }}/{{ monster.necessary }}
                                                </span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {% if tracking.collect is defined and tracking.collect is not empty %}
                                    <div class="mt-2 space-y-0.5">
                                        {% for item in tracking.collect %}
                                            <div class="flex items-center justify-between text-xs">
                                                <span class="text-gray-300">Recolter {{ item.slug|replace({'_': ' ', '-': ' '})|capitalize }}</span>
                                                <span class="{% if item.count >= item.necessary %}text-green-400{% else %}text-gray-400{% endif %}">
                                                    {{ item.count }}/{{ item.necessary }}
                                                </span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {% if tracking.craft is defined and tracking.craft is not empty %}
                                    <div class="mt-2 space-y-0.5">
                                        {% for item in tracking.craft %}
                                            <div class="flex items-center justify-between text-xs">
                                                <span class="text-gray-300">Fabriquer {{ item.slug|replace({'_': ' ', '-': ' '})|capitalize }}</span>
                                                <span class="{% if item.count >= item.necessary %}text-green-400{% else %}text-gray-400{% endif %}">
                                                    {{ item.count }}/{{ item.necessary }}
                                                </span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {% if tracking.deliver is defined and tracking.deliver is not empty %}
                                    <div class="mt-2 space-y-0.5">
                                        {% for entry in tracking.deliver %}
                                            <div class="flex items-center justify-between text-xs">
                                                <span class="text-gray-300">Livrer {{ entry.name|default(entry.item_slug)|replace({'_': ' ', '-': ' '})|capitalize }}</span>
                                                <span class="{% if entry.count >= entry.necessary %}text-green-400{% else %}text-gray-400{% endif %}">
                                                    {{ entry.count }}/{{ entry.necessary }}
                                                </span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {% if tracking.explore is defined and tracking.explore is not empty %}
                                    <div class="mt-2 space-y-0.5">
                                        {% for entry in tracking.explore %}
                                            <div class="flex items-center justify-between text-xs">
                                                <span class="text-gray-300">Explorer {{ entry.name|default('Zone inconnue') }}</span>
                                                <span class="{% if entry.count >= entry.necessary %}text-green-400{% else %}text-gray-400{% endif %}">
                                                    {{ entry.count >= entry.necessary ? 'Decouvert' : 'Non decouvert' }}
                                                </span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {% if tracking.talk_to is defined and tracking.talk_to is not empty %}
                                    <div class="mt-2 space-y-0.5">
                                        {% for entry in tracking.talk_to %}
                                            <div class="flex items-center justify-between text-xs">
                                                <span class="text-gray-300">Parler a {{ entry.name|default('PNJ inconnu') }}</span>
                                                <span class="{% if entry.count >= entry.necessary %}text-green-400{% else %}text-gray-400{% endif %}">
                                                    {{ entry.count >= entry.necessary ? 'Fait' : 'A faire' }}
                                                </span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {% if tracking.boss_challenge is defined and tracking.boss_challenge is not empty %}
                                    <div class="mt-2 space-y-0.5">
                                        {% for entry in tracking.boss_challenge %}
                                            <div class="flex items-center justify-between text-xs">
                                                <span class="text-gray-300">Vaincre {{ entry.name|default('Boss') }}</span>
                                                <span class="{% if entry.count >= entry.necessary %}text-green-400{% else %}text-gray-400{% endif %}">
                                                    {{ entry.count >= entry.necessary ? 'Vaincu' : 'Non vaincu' }}
                                                </span>
                                            </div>
                                            {% if entry.conditions is defined and entry.conditions is not empty %}
                                                <div class="ml-3 text-[10px] text-gray-500">
                                                    {% if entry.conditions.no_heal is defined and entry.conditions.no_heal %}
                                                        <span class="inline-block mr-2">Sans soin</span>
                                                    {% endif %}
                                                    {% if entry.conditions.solo is defined and entry.conditions.solo %}
                                                        <span class="inline-block mr-2">Solo</span>
                                                    {% endif %}
                                                    {% if entry.conditions.time_limit is defined %}
                                                        <span class="inline-block">< {{ (entry.conditions.time_limit / 60)|round }}min</span>
                                                    {% endif %}
                                                </div>
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {% if tracking.defend is defined and tracking.defend is not empty %}
                                    <div class="mt-2 space-y-0.5">
                                        {% for entry in tracking.defend %}
                                            <div class="flex items-center justify-between text-xs">
                                                <span class="text-gray-300">Defendre {{ entry.zone_name|default('Zone') }} — Tuer {{ entry.name }}</span>
                                                <span class="{% if entry.count >= entry.necessary %}text-green-400{% else %}text-gray-400{% endif %}">
                                                    {{ entry.count }}/{{ entry.necessary }}
                                                </span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {% if tracking.escort is defined and tracking.escort is not empty %}
                                    <div class="mt-2 space-y-0.5">
                                        {% for entry in tracking.escort %}
                                            <div class="flex items-center justify-between text-xs">
                                                <span class="text-gray-300">{{ entry.name|default('Escorter') }}</span>
                                                <span class="{% if entry.count >= entry.necessary %}text-green-400{% else %}text-gray-400{% endif %}">
                                                    {{ entry.count >= entry.necessary ? 'Arrive a destination' : 'En route...' }}
                                                </span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {% if tracking.puzzle is defined and tracking.puzzle is not empty %}
                                    <div class="mt-2 space-y-0.5">
                                        {% for entry in tracking.puzzle %}
                                            <div class="flex items-center justify-between text-xs">
                                                <span class="text-gray-300">{{ entry.name|default('Enigme') }}</span>
                                                <span class="{% if entry.count >= entry.necessary %}text-green-400{% else %}text-gray-400{% endif %}">
                                                    {{ entry.count >= entry.necessary ? 'Resolue' : 'Non resolue' }}
                                                </span>
                                            </div>
                                            {% if entry.count < entry.necessary %}
                                                <div class="mt-1 flex gap-1">
                                                    <input type="text" id="puzzle-answer-{{ entry.pnj_id }}" placeholder="Votre reponse..."
                                                           class="flex-1 px-2 py-0.5 text-xs bg-gray-900 border border-gray-600 rounded text-white placeholder-gray-500 focus:border-purple-500 focus:outline-none">
                                                    <button onclick="submitPuzzleAnswer({{ entry.pnj_id }})"
                                                            class="px-2 py-0.5 text-xs bg-purple-700 hover:bg-purple-600 text-white rounded transition-colors">
                                                        Repondre
                                                    </button>
                                                </div>
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                {% endif %}

                                {# Rewards #}
                                {% set rewards = quest.rewards %}
                                {% if rewards is not empty %}
                                    <div class="mt-2 pt-2 border-t border-gray-600">
                                        <span class="text-[10px] text-gray-500">Recompenses :</span>
                                        <div class="flex flex-wrap gap-3 mt-0.5">
                                            {% if rewards.gils is defined %}
                                                <span class="text-yellow-400 text-xs">{{ rewards.gils }} Gils</span>
                                            {% elseif rewards.gold is defined %}
                                                <span class="text-yellow-400 text-xs">{{ rewards.gold }} Gils</span>
                                            {% endif %}
                                            {% if rewards.xp is defined %}
                                                <span class="text-blue-400 text-xs">{{ rewards.xp }} XP</span>
                                            {% endif %}
                                            {% if rewards.items is defined %}
                                                {% for itemData in rewards.items %}
                                                    {% if itemData is iterable and itemData.genericItemSlug is defined %}
                                                        <span class="text-green-400 text-xs">{{ itemData.count|default(1) }}x {{ itemData.genericItemSlug|replace({'_': ' ', '-': ' '})|capitalize }}</span>
                                                    {% endif %}
                                                {% endfor %}
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {# Daily quests #}
            <div id="panel-daily" class="hidden">
                {# Timer de reset quotidien #}
                <div class="mb-4 flex items-center justify-end gap-2 text-xs text-gray-400"
                     data-controller="daily-reset-timer">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span>Prochain reset : <span data-daily-reset-timer-target="display" class="text-amber-400 font-mono">--h--m--s</span></span>
                </div>

                {% if activeDailyQuests is empty and availableDailyQuests is empty %}
                    <div class="text-center py-8">
                        <p class="text-gray-500 text-sm">Aucune quete quotidienne disponible aujourd'hui.</p>
                        <p class="text-gray-600 text-xs mt-1">Les quetes quotidiennes changent chaque jour a minuit.</p>
                    </div>
                {% else %}
                    {# Active daily quests #}
                    {% if activeDailyQuests is not empty %}
                        <div class="space-y-2 sm:space-y-3 mb-4">
                            {% for dailyQuest in activeDailyQuests %}
                                {% set quest = dailyQuest.quest %}
                                {% set progress = dailyQuestProgress[dailyQuest.id] %}
                                <div class="bg-gray-700/50 rounded-lg p-3 sm:p-4 border border-amber-600/50" id="daily-quest-{{ dailyQuest.id }}">
                                    <div class="flex items-start justify-between gap-2 mb-2">
                                        <div class="min-w-0">
                                            <div class="flex items-center gap-2 flex-wrap">
                                                <h3 class="text-white font-semibold text-sm sm:text-base">{{ quest.name }}</h3>
                                                <span class="text-[10px] px-1.5 py-0.5 rounded bg-amber-900/50 text-amber-300 border border-amber-700/50">
                                                    Quotidienne
                                                </span>
                                                {% if quest.dailyPool %}
                                                    <span class="text-[10px] px-1.5 py-0.5 rounded bg-gray-800/50 text-gray-300 border border-gray-600/50">
                                                        {{ quest.dailyPool|capitalize }}
                                                    </span>
                                                {% endif %}
                                            </div>
                                            <p class="text-gray-400 text-xs sm:text-sm mt-0.5">{{ quest.description }}</p>
                                        </div>
                                        <div class="flex gap-1.5 flex-shrink-0">
                                            {% if progress >= 100 %}
                                                <button onclick="completeDailyQuest({{ dailyQuest.id }})"
                                                        class="px-2.5 py-1.5 bg-green-600 hover:bg-green-500 active:bg-green-700 text-white text-xs rounded transition-colors touch-target">
                                                    Rendre
                                                </button>
                                            {% endif %}
                                            <button onclick="abandonDailyQuest({{ dailyQuest.id }})"
                                                    class="px-2.5 py-1.5 bg-red-600/60 hover:bg-red-500 active:bg-red-700 text-white text-xs rounded transition-colors touch-target">
                                                Abandonner
                                            </button>
                                        </div>
                                    </div>

                                    {# Progress bar #}
                                    <div class="mt-2">
                                        <div class="flex justify-between text-[10px] sm:text-xs text-gray-400 mb-1">
                                            <span>Progression</span>
                                            <span>{{ progress }}%</span>
                                        </div>
                                        <div class="progress-bar">
                                            <div class="progress-bar-fill {% if progress >= 100 %}bg-green-500{% else %}bg-amber-500{% endif %}"
                                                 style="width: {{ progress }}%"></div>
                                        </div>
                                    </div>

                                    {# Tracking details #}
                                    {% set tracking = dailyQuest.tracking %}
                                    {% if tracking.monsters is defined and tracking.monsters is not empty %}
                                        <div class="mt-2 space-y-0.5">
                                            {% for monster in tracking.monsters %}
                                                <div class="flex items-center justify-between text-xs">
                                                    <span class="text-gray-300">Tuer {{ monster.name }}</span>
                                                    <span class="{% if monster.count >= monster.necessary %}text-green-400{% else %}text-gray-400{% endif %}">
                                                        {{ monster.count }}/{{ monster.necessary }}
                                                    </span>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                    {% if tracking.collect is defined and tracking.collect is not empty %}
                                        <div class="mt-2 space-y-0.5">
                                            {% for item in tracking.collect %}
                                                <div class="flex items-center justify-between text-xs">
                                                    <span class="text-gray-300">Recolter {{ item.slug|replace({'_': ' ', '-': ' '})|capitalize }}</span>
                                                    <span class="{% if item.count >= item.necessary %}text-green-400{% else %}text-gray-400{% endif %}">
                                                        {{ item.count }}/{{ item.necessary }}
                                                    </span>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    {% endif %}

                                    {# Rewards #}
                                    {% set rewards = quest.rewards %}
                                    {% if rewards is not empty %}
                                        <div class="mt-2 pt-2 border-t border-gray-600">
                                            <span class="text-[10px] text-gray-500">Recompenses :</span>
                                            <div class="flex flex-wrap gap-3 mt-0.5">
                                                {% if rewards.gils is defined %}
                                                    <span class="text-yellow-400 text-xs">{{ rewards.gils }} Gils</span>
                                                {% elseif rewards.gold is defined %}
                                                    <span class="text-yellow-400 text-xs">{{ rewards.gold }} Gils</span>
                                                {% endif %}
                                                {% if rewards.xp is defined %}
                                                    <span class="text-blue-400 text-xs">{{ rewards.xp }} XP</span>
                                                {% endif %}
                                                {% if rewards.items is defined %}
                                                    {% for itemData in rewards.items %}
                                                        {% if itemData is iterable and itemData.genericItemSlug is defined %}
                                                            <span class="text-green-400 text-xs">{{ itemData.count|default(1) }}x {{ itemData.genericItemSlug|replace({'_': ' ', '-': ' '})|capitalize }}</span>
                                                        {% endif %}
                                                    {% endfor %}
                                                {% endif %}
                                            </div>
                                        </div>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}

                    {# Completed daily quests #}
                    {% if completedDailyQuests is not empty %}
                        <div class="mb-4">
                            <h4 class="text-xs text-gray-500 uppercase tracking-wider mb-2">Completees aujourd'hui</h4>
                            <div class="space-y-1.5">
                                {% for dq in completedDailyQuests %}
                                    <div class="bg-gray-700/30 rounded-lg p-3 border border-gray-700 opacity-75">
                                        <div class="flex items-center justify-between">
                                            <h3 class="text-gray-300 font-medium text-sm">{{ dq.quest.name }}</h3>
                                            <span class="text-green-500 text-xs font-mono flex-shrink-0 ml-2">Terminee</span>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}

                    {# Available daily quests #}
                    {% if availableDailyQuests is not empty %}
                        <div>
                            <h4 class="text-xs text-gray-500 uppercase tracking-wider mb-2">Disponibles</h4>
                            <div class="space-y-2 sm:space-y-3">
                                {% for quest in availableDailyQuests %}
                                    <div class="bg-gray-700/50 rounded-lg p-3 sm:p-4 border border-gray-600" id="daily-available-{{ quest.id }}">
                                        <div class="flex items-start justify-between gap-2 mb-2">
                                            <div class="min-w-0">
                                                <div class="flex items-center gap-2 flex-wrap">
                                                    <h3 class="text-white font-semibold text-sm sm:text-base">{{ quest.name }}</h3>
                                                    <span class="text-[10px] px-1.5 py-0.5 rounded bg-amber-900/50 text-amber-300 border border-amber-700/50">
                                                        Quotidienne
                                                    </span>
                                                </div>
                                                <p class="text-gray-400 text-xs sm:text-sm mt-0.5">{{ quest.description }}</p>
                                            </div>
                                            <button onclick="acceptDailyQuest({{ quest.id }})"
                                                    class="px-2.5 py-1.5 bg-amber-600 hover:bg-amber-500 active:bg-amber-700 text-white text-xs rounded transition-colors touch-target flex-shrink-0">
                                                Accepter
                                            </button>
                                        </div>

                                        {# Requirements preview #}
                                        {% set requirements = quest.requirements %}
                                        {% if requirements.monsters is defined and requirements.monsters is not empty %}
                                            <div class="mt-2 space-y-0.5">
                                                {% for monster in requirements.monsters %}
                                                    <div class="flex items-center justify-between text-xs">
                                                        <span class="text-gray-300">Tuer {{ monster.name }}</span>
                                                        <span class="text-gray-400">0/{{ monster.count }}</span>
                                                    </div>
                                                {% endfor %}
                                            </div>
                                        {% endif %}
                                        {% if requirements.collect is defined and requirements.collect is not empty %}
                                            <div class="mt-2 space-y-0.5">
                                                {% for itemSlug, count in requirements.collect %}
                                                    <div class="flex items-center justify-between text-xs">
                                                        <span class="text-gray-300">Recolter {{ itemSlug|replace({'_': ' ', '-': ' '})|capitalize }}</span>
                                                        <span class="text-gray-400">0/{{ count }}</span>
                                                    </div>
                                                {% endfor %}
                                            </div>
                                        {% endif %}

                                        {# Rewards #}
                                        {% set rewards = quest.rewards %}
                                        {% if rewards is not empty %}
                                            <div class="mt-2 pt-2 border-t border-gray-600">
                                                <span class="text-[10px] text-gray-500">Recompenses :</span>
                                                <div class="flex flex-wrap gap-3 mt-0.5">
                                                    {% if rewards.gils is defined %}
                                                        <span class="text-yellow-400 text-xs">{{ rewards.gils }} Gils</span>
                                                    {% elseif rewards.gold is defined %}
                                                        <span class="text-yellow-400 text-xs">{{ rewards.gold }} Gils</span>
                                                    {% endif %}
                                                    {% if rewards.xp is defined %}
                                                        <span class="text-blue-400 text-xs">{{ rewards.xp }} XP</span>
                                                    {% endif %}
                                                    {% if rewards.items is defined %}
                                                        {% for itemData in rewards.items %}
                                                            {% if itemData is iterable and itemData.genericItemSlug is defined %}
                                                                <span class="text-green-400 text-xs">{{ itemData.count|default(1) }}x {{ itemData.genericItemSlug|replace({'_': ' ', '-': ' '})|capitalize }}</span>
                                                            {% endif %}
                                                        {% endfor %}
                                                    {% endif %}
                                                </div>
                                            </div>
                                        {% endif %}
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                {% endif %}
            </div>

            {# Available quests #}
            <div id="panel-available" class="hidden">
                {% if availableQuests is not empty %}
                    {# Type filter #}
                    <div class="flex flex-wrap gap-2 mb-3">
                        <button onclick="filterQuests('all')" id="filter-all"
                                class="px-2.5 py-1 text-[11px] rounded border border-purple-600 bg-purple-900/50 text-purple-300 transition-colors">
                            Toutes
                        </button>
                        <button onclick="filterQuests('kill')" id="filter-kill"
                                class="px-2.5 py-1 text-[11px] rounded border border-gray-600 bg-gray-800/50 text-gray-400 hover:text-gray-300 transition-colors">
                            Combat
                        </button>
                        <button onclick="filterQuests('collect')" id="filter-collect"
                                class="px-2.5 py-1 text-[11px] rounded border border-gray-600 bg-gray-800/50 text-gray-400 hover:text-gray-300 transition-colors">
                            Recolte
                        </button>
                        <button onclick="filterQuests('deliver')" id="filter-deliver"
                                class="px-2.5 py-1 text-[11px] rounded border border-gray-600 bg-gray-800/50 text-gray-400 hover:text-gray-300 transition-colors">
                            Livraison
                        </button>
                        <button onclick="filterQuests('explore')" id="filter-explore"
                                class="px-2.5 py-1 text-[11px] rounded border border-gray-600 bg-gray-800/50 text-gray-400 hover:text-gray-300 transition-colors">
                            Exploration
                        </button>
                        <button onclick="filterQuests('defend')" id="filter-defend"
                                class="px-2.5 py-1 text-[11px] rounded border border-gray-600 bg-gray-800/50 text-gray-400 hover:text-gray-300 transition-colors">
                            Defense
                        </button>
                        <button onclick="filterQuests('escort')" id="filter-escort"
                                class="px-2.5 py-1 text-[11px] rounded border border-gray-600 bg-gray-800/50 text-gray-400 hover:text-gray-300 transition-colors">
                            Escorte
                        </button>
                        <button onclick="filterQuests('puzzle')" id="filter-puzzle"
                                class="px-2.5 py-1 text-[11px] rounded border border-gray-600 bg-gray-800/50 text-gray-400 hover:text-gray-300 transition-colors">
                            Enigme
                        </button>
                    </div>
                {% endif %}

                {% if availableQuests is empty %}
                    <div class="text-center py-8">
                        <p class="text-gray-500 text-sm">Aucune nouvelle quete disponible.</p>
                        <p class="text-gray-600 text-xs mt-1">Completez des quetes pour en debloquer de nouvelles.</p>
                    </div>
                {% else %}
                    <div class="space-y-2 sm:space-y-3" id="available-quests-list">
                        {% for quest in availableQuests %}
                            {% set chainInfo = questChains[quest.id] ?? null %}
                            {% set questType = questTypes[quest.id] ?? 'other' %}
                            {% set giver = questGivers[quest.id] ?? null %}
                            <div class="bg-gray-700/50 rounded-lg p-3 sm:p-4 border border-gray-600" id="available-quest-{{ quest.id }}" data-quest-type="{{ questType }}">
                                <div class="flex items-start justify-between gap-2 mb-2">
                                    <div class="min-w-0">
                                        <div class="flex items-center gap-2 flex-wrap">
                                            <h3 class="text-white font-semibold text-sm sm:text-base">{{ quest.name }}</h3>
                                            {% if chainInfo %}
                                                <span class="text-[10px] px-1.5 py-0.5 rounded bg-purple-900/50 text-purple-300 border border-purple-700/50">
                                                    Quete {{ chainInfo.position }}/{{ chainInfo.total }}
                                                </span>
                                            {% endif %}
                                            <span class="text-[10px] px-1.5 py-0.5 rounded {{ questType == 'kill' ? 'bg-red-900/50 text-red-300 border border-red-700/50' : (questType == 'collect' ? 'bg-green-900/50 text-green-300 border border-green-700/50' : (questType == 'talk_to' ? 'bg-cyan-900/50 text-cyan-300 border border-cyan-700/50' : (questType == 'boss_challenge' ? 'bg-orange-900/50 text-orange-300 border border-orange-700/50' : (questType == 'defend' ? 'bg-yellow-900/50 text-yellow-300 border border-yellow-700/50' : (questType == 'escort' ? 'bg-teal-900/50 text-teal-300 border border-teal-700/50' : (questType == 'puzzle' ? 'bg-purple-900/50 text-purple-300 border border-purple-700/50' : 'bg-gray-800/50 text-gray-300 border border-gray-600/50')))))) }}">
                                                {{ questType == 'kill' ? 'Combat' : (questType == 'collect' ? 'Recolte' : (questType == 'deliver' ? 'Livraison' : (questType == 'explore' ? 'Exploration' : (questType == 'talk_to' ? 'Enquete' : (questType == 'boss_challenge' ? 'Defi Boss' : (questType == 'defend' ? 'Defense' : (questType == 'escort' ? 'Escorte' : (questType == 'puzzle' ? 'Enigme' : 'Divers')))))))) }}
                                            </span>
                                            {% if quest.hasRenownRequirement %}
                                                {% set requiredTier = quest.requiredRenownTier %}
                                                <span class="text-[10px] px-1.5 py-0.5 rounded bg-amber-900/50 border border-amber-700/50 {{ requiredTier.cssClass }}"
                                                      title="Renommée {{ quest.minRenownScore }} requise ({{ requiredTier.label }})">
                                                    Renommée : {{ requiredTier.label }}
                                                </span>
                                            {% endif %}
                                        </div>
                                        <p class="text-gray-400 text-xs sm:text-sm mt-0.5">{{ quest.description }}</p>
                                        {% if giver %}
                                            <p class="text-gray-500 text-[10px] mt-1">
                                                Donnee par <span class="text-amber-400/80">{{ giver.name }}</span>
                                                {% if giver.map %}
                                                    — <a href="{{ path('app_game_map') }}" class="text-purple-400/80 hover:text-purple-300 underline">{{ giver.map.name ?? 'Carte' }}</a>
                                                {% endif %}
                                            </p>
                                        {% endif %}
                                    </div>
                                    <button onclick="acceptQuest({{ quest.id }})"
                                            class="px-2.5 py-1.5 bg-purple-600 hover:bg-purple-500 active:bg-purple-700 text-white text-xs rounded transition-colors touch-target flex-shrink-0">
                                        Accepter
                                    </button>
                                </div>

                                {# Requirements preview #}
                                {% set requirements = quest.requirements %}
                                {% if requirements.monsters is defined and requirements.monsters is not empty %}
                                    <div class="mt-2 space-y-0.5">
                                        {% for monster in requirements.monsters %}
                                            <div class="flex items-center justify-between text-xs">
                                                <span class="text-gray-300">Tuer {{ monster.name }}</span>
                                                <span class="text-gray-400">0/{{ monster.count }}</span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {% if requirements.collect is defined and requirements.collect is not empty %}
                                    <div class="mt-2 space-y-0.5">
                                        {% for itemSlug, count in requirements.collect %}
                                            <div class="flex items-center justify-between text-xs">
                                                {% if count is iterable %}
                                                    <span class="text-gray-300">Recolter {{ count.name|default(count.slug|replace({'_': ' ', '-': ' '})|capitalize) }}</span>
                                                    <span class="text-gray-400">0/{{ count.count }}</span>
                                                {% else %}
                                                    <span class="text-gray-300">Recolter {{ itemSlug|replace({'_': ' ', '-': ' '})|capitalize }}</span>
                                                    <span class="text-gray-400">0/{{ count }}</span>
                                                {% endif %}
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {% if requirements.deliver is defined and requirements.deliver is not empty %}
                                    <div class="mt-2 space-y-0.5">
                                        {% for entry in requirements.deliver %}
                                            <div class="flex items-center justify-between text-xs">
                                                <span class="text-gray-300">Livrer {{ entry.name|default(entry.item_slug)|replace({'_': ' ', '-': ' '})|capitalize }}</span>
                                                <span class="text-gray-400">0/{{ entry.quantity|default(1) }}</span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {% if requirements.explore is defined and requirements.explore is not empty %}
                                    <div class="mt-2 space-y-0.5">
                                        {% for entry in requirements.explore %}
                                            <div class="flex items-center justify-between text-xs">
                                                <span class="text-gray-300">Explorer {{ entry.name|default('Zone inconnue') }}</span>
                                                <span class="text-gray-400">Non decouvert</span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}

                                {# Rewards #}
                                {% set rewards = quest.rewards %}
                                {% if rewards is not empty %}
                                    <div class="mt-2 pt-2 border-t border-gray-600">
                                        <span class="text-[10px] text-gray-500">Recompenses :</span>
                                        <div class="flex flex-wrap gap-3 mt-0.5">
                                            {% if rewards.gils is defined %}
                                                <span class="text-yellow-400 text-xs">{{ rewards.gils }} Gils</span>
                                            {% elseif rewards.gold is defined %}
                                                <span class="text-yellow-400 text-xs">{{ rewards.gold }} Gils</span>
                                            {% endif %}
                                            {% if rewards.xp is defined %}
                                                <span class="text-blue-400 text-xs">{{ rewards.xp }} XP</span>
                                            {% endif %}
                                            {% if rewards.items is defined %}
                                                {% for itemData in rewards.items %}
                                                    {% if itemData is iterable and itemData.genericItemSlug is defined %}
                                                        <span class="text-green-400 text-xs">{{ itemData.count|default(1) }}x {{ itemData.genericItemSlug|replace({'_': ' ', '-': ' '})|capitalize }}</span>
                                                    {% endif %}
                                                {% endfor %}
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {# Completed quests #}
            <div id="panel-completed" class="hidden">
                {% if completedQuests is empty %}
                    <div class="text-center py-8">
                        <p class="text-gray-500 text-sm">Aucune quete terminee.</p>
                    </div>
                {% else %}
                    <div class="space-y-1.5 sm:space-y-2">
                        {% for pqc in completedQuests %}
                            {% set quest = pqc.quest %}
                            <div class="bg-gray-700/30 rounded-lg p-3 border border-gray-700 opacity-75">
                                <div class="flex items-center justify-between">
                                    <div class="min-w-0">
                                        <h3 class="text-gray-300 font-medium text-sm truncate">{{ quest.name }}</h3>
                                        <p class="text-gray-500 text-xs">{{ quest.description|slice(0, 80) }}{% if quest.description|length > 80 %}...{% endif %}</p>
                                        {% if pqc.choiceMade %}
                                            {% set choiceLabel = pqc.choiceMade %}
                                            {% for outcome in quest.choiceOutcome ?? [] %}
                                                {% if outcome.key == pqc.choiceMade %}
                                                    {% set choiceLabel = outcome.label %}
                                                {% endif %}
                                            {% endfor %}
                                            <p class="text-purple-400/70 text-[10px] mt-0.5">Choix : {{ choiceLabel }}</p>
                                        {% endif %}
                                    </div>
                                    <span class="text-green-500 text-xs font-mono flex-shrink-0 ml-2">Terminee</span>
                                </div>
                                {% set rewards = quest.rewards %}
                                {% if rewards is not empty %}
                                    <div class="mt-1.5 flex flex-wrap gap-2">
                                        {% if rewards.gils is defined %}
                                            <span class="text-yellow-400/60 text-[10px]">{{ rewards.gils }} Gils</span>
                                        {% elseif rewards.gold is defined %}
                                            <span class="text-yellow-400/60 text-[10px]">{{ rewards.gold }} Gils</span>
                                        {% endif %}
                                        {% if rewards.xp is defined %}
                                            <span class="text-blue-400/60 text-[10px]">{{ rewards.xp }} XP</span>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{# Choice modal #}
<div id="choice-modal" class="fixed inset-0 bg-black/70 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-gray-800 border border-purple-600 rounded-xl p-5 max-w-sm w-full">
        <h3 class="text-white font-semibold text-sm mb-3">Faites votre choix</h3>
        <div id="choice-modal-buttons" class="space-y-2"></div>
        <button onclick="closeChoiceModal()" class="mt-3 w-full px-3 py-1.5 bg-gray-700 hover:bg-gray-600 text-gray-300 text-xs rounded transition-colors">
            Annuler
        </button>
    </div>
</div>

<script>
function showTab(tab) {
    const tabs = ['active', 'daily', 'available', 'completed'];
    tabs.forEach(t => {
        document.getElementById('panel-' + t).classList.toggle('hidden', tab !== t);
        document.getElementById('tab-' + t).className = tab === t
            ? 'px-4 py-2.5 text-sm font-medium border-b-2 border-purple-500 text-purple-400 touch-target whitespace-nowrap'
            : 'px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-400 hover:text-gray-300 touch-target whitespace-nowrap';
    });
}

function filterQuests(type) {
    const filters = ['all', 'kill', 'collect', 'deliver', 'explore', 'defend', 'escort', 'puzzle'];
    filters.forEach(f => {
        const btn = document.getElementById('filter-' + f);
        if (btn) {
            btn.className = f === type
                ? 'px-2.5 py-1 text-[11px] rounded border border-purple-600 bg-purple-900/50 text-purple-300 transition-colors'
                : 'px-2.5 py-1 text-[11px] rounded border border-gray-600 bg-gray-800/50 text-gray-400 hover:text-gray-300 transition-colors';
        }
    });

    const list = document.getElementById('available-quests-list');
    if (!list) return;

    list.querySelectorAll('[data-quest-type]').forEach(el => {
        if (type === 'all' || el.dataset.questType === type) {
            el.classList.remove('hidden');
        } else {
            el.classList.add('hidden');
        }
    });
}

async function acceptQuest(id) {
    try {
        const resp = await fetch(`/game/quests/accept/${id}`, { method: 'POST' });
        const data = await resp.json();
        if (data.success) {
            showMessage(data.message);
            setTimeout(() => location.reload(), 800);
        } else {
            showMessage(data.error || 'Erreur', true);
        }
    } catch (e) {
        showMessage('Erreur de connexion', true);
    }
}

async function completeQuest(id, choice = null) {
    try {
        const body = choice ? JSON.stringify({ choice }) : '{}';
        const resp = await fetch(`/game/quests/complete/${id}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: body
        });
        const data = await resp.json();
        if (data.success) {
            closeChoiceModal();
            showMessage(data.messages.join(' '));
            setTimeout(() => location.reload(), 1000);
        } else {
            showMessage(data.error || 'Erreur', true);
        }
    } catch (e) {
        showMessage('Erreur de connexion', true);
    }
}

let currentChoiceQuestId = null;

function showChoiceModal(playerQuestId, choices) {
    currentChoiceQuestId = playerQuestId;
    const container = document.getElementById('choice-modal-buttons');
    container.innerHTML = '';
    choices.forEach(c => {
        const btn = document.createElement('button');
        btn.textContent = c.label;
        btn.className = 'w-full px-3 py-2 bg-purple-700 hover:bg-purple-600 active:bg-purple-800 text-white text-sm rounded transition-colors';
        btn.onclick = () => completeQuest(playerQuestId, c.key);
        container.appendChild(btn);
    });
    document.getElementById('choice-modal').classList.remove('hidden');
}

function closeChoiceModal() {
    document.getElementById('choice-modal').classList.add('hidden');
    currentChoiceQuestId = null;
}

async function abandonQuest(id) {
    if (!confirm('Abandonner cette quete ?')) return;
    try {
        const resp = await fetch(`/game/quests/abandon/${id}`, { method: 'POST' });
        const data = await resp.json();
        if (data.success) {
            showMessage(data.message);
            const el = document.getElementById(`quest-${id}`);
            if (el) el.remove();
        } else {
            showMessage(data.error || 'Erreur', true);
        }
    } catch (e) {
        showMessage('Erreur de connexion', true);
    }
}

async function submitPuzzleAnswer(pnjId) {
    const input = document.getElementById(`puzzle-answer-${pnjId}`);
    if (!input || !input.value.trim()) {
        showMessage('Entrez une reponse.', true);
        return;
    }
    try {
        const resp = await fetch(`/game/quests/puzzle-answer/${pnjId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ answer: input.value.trim() })
        });
        const data = await resp.json();
        showMessage(data.message, !data.success);
        if (data.success) {
            setTimeout(() => location.reload(), 800);
        }
    } catch (e) {
        showMessage('Erreur de connexion', true);
    }
}

async function acceptDailyQuest(id) {
    try {
        const resp = await fetch(`/game/quests/daily/accept/${id}`, { method: 'POST' });
        const data = await resp.json();
        if (data.success) {
            showMessage(data.message);
            setTimeout(() => location.reload(), 800);
        } else {
            showMessage(data.error || 'Erreur', true);
        }
    } catch (e) {
        showMessage('Erreur de connexion', true);
    }
}

async function completeDailyQuest(id) {
    try {
        const resp = await fetch(`/game/quests/daily/complete/${id}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: '{}'
        });
        const data = await resp.json();
        if (data.success) {
            showMessage(data.messages.join(' '));
            setTimeout(() => location.reload(), 1000);
        } else {
            showMessage(data.error || 'Erreur', true);
        }
    } catch (e) {
        showMessage('Erreur de connexion', true);
    }
}

async function abandonDailyQuest(id) {
    if (!confirm('Abandonner cette quete quotidienne ?')) return;
    try {
        const resp = await fetch(`/game/quests/daily/abandon/${id}`, { method: 'POST' });
        const data = await resp.json();
        if (data.success) {
            showMessage(data.message);
            const el = document.getElementById(`daily-quest-${id}`);
            if (el) el.remove();
        } else {
            showMessage(data.error || 'Erreur', true);
        }
    } catch (e) {
        showMessage('Erreur de connexion', true);
    }
}

function showMessage(msg, isError = false) {
    const container = document.getElementById('quest-messages');
    const text = document.getElementById('quest-message-text');
    container.classList.remove('hidden');
    text.textContent = msg;
    text.className = isError
        ? 'bg-red-900/50 border border-red-700 rounded-lg p-3 text-red-300 text-sm'
        : 'bg-green-900/50 border border-green-700 rounded-lg p-3 text-green-300 text-sm';
    setTimeout(() => container.classList.add('hidden'), 3000);
}
</script>
{% endblock %}

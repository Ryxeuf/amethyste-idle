{% extends 'game/game.html.twig' %}

{% block title %}Journal de quêtes{% endblock %}

{% block game_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 sm:py-8">
    <div class="bg-gray-800 rounded-lg shadow-lg p-4 sm:p-6 mb-4">
        <h2 class="text-xl font-semibold text-purple-400 mb-4">Journal de quêtes</h2>

        {# Messages area #}
        <div id="quest-messages" class="mb-4 hidden">
            <div class="rounded-lg p-3 text-sm" id="quest-message-text"></div>
        </div>

        {# Tabs #}
        <div class="flex border-b border-gray-700 mb-4">
            <button onclick="showTab('active')" id="tab-active"
                    class="px-4 py-2 text-sm font-medium border-b-2 border-purple-500 text-purple-400">
                En cours ({{ activeQuests|length }})
            </button>
            <button onclick="showTab('completed')" id="tab-completed"
                    class="px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-400 hover:text-gray-300">
                Terminées ({{ completedQuests|length }})
            </button>
        </div>

        {# Active quests #}
        <div id="panel-active">
            {% if activeQuests is empty %}
                <div class="text-center py-8">
                    <p class="text-gray-500">Aucune quête en cours.</p>
                    <p class="text-gray-600 text-sm mt-2">Parlez aux PNJ sur la carte pour obtenir des quêtes.</p>
                </div>
            {% else %}
                <div class="space-y-3">
                    {% for playerQuest in activeQuests %}
                        {% set quest = playerQuest.quest %}
                        {% set progress = questProgress[playerQuest.id] %}
                        <div class="bg-gray-700/50 rounded-lg p-4 border border-gray-600" id="quest-{{ playerQuest.id }}">
                            <div class="flex items-start justify-between mb-2">
                                <div>
                                    <h3 class="text-white font-semibold">{{ quest.name }}</h3>
                                    <p class="text-gray-400 text-sm mt-1">{{ quest.description }}</p>
                                </div>
                                <div class="flex gap-2 ml-3 flex-shrink-0">
                                    {% if progress >= 100 %}
                                        <button onclick="completeQuest({{ playerQuest.id }})"
                                                class="px-3 py-1 bg-green-600 hover:bg-green-500 text-white text-xs rounded transition-colors">
                                            Rendre
                                        </button>
                                    {% endif %}
                                    <button onclick="abandonQuest({{ playerQuest.id }})"
                                            class="px-3 py-1 bg-red-600/60 hover:bg-red-500 text-white text-xs rounded transition-colors">
                                        Abandonner
                                    </button>
                                </div>
                            </div>

                            {# Progress bar #}
                            <div class="mt-3">
                                <div class="flex justify-between text-xs text-gray-400 mb-1">
                                    <span>Progression</span>
                                    <span>{{ progress }}%</span>
                                </div>
                                <div class="w-full bg-gray-600 rounded-full h-2">
                                    <div class="h-2 rounded-full transition-all duration-300 {% if progress >= 100 %}bg-green-500{% else %}bg-purple-500{% endif %}"
                                         style="width: {{ progress }}%"></div>
                                </div>
                            </div>

                            {# Tracking details #}
                            {% set tracking = playerQuest.tracking %}
                            {% if tracking.monsters is defined and tracking.monsters is not empty %}
                                <div class="mt-3 space-y-1">
                                    {% for monster in tracking.monsters %}
                                        <div class="flex items-center justify-between text-xs">
                                            <span class="text-gray-300">Tuer {{ monster.name }}</span>
                                            <span class="{% if monster.count >= monster.necessary %}text-green-400{% else %}text-gray-400{% endif %}">
                                                {{ monster.count }}/{{ monster.necessary }}
                                            </span>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}

                            {# Rewards preview #}
                            {% set rewards = quest.rewards %}
                            {% if rewards is not empty %}
                                <div class="mt-3 pt-2 border-t border-gray-600">
                                    <span class="text-xs text-gray-500">Récompenses :</span>
                                    <div class="flex gap-3 mt-1">
                                        {% if rewards.gils is defined %}
                                            <span class="text-yellow-400 text-xs">{{ rewards.gils }} Gils</span>
                                        {% endif %}
                                        {% if rewards.xp is defined %}
                                            <span class="text-blue-400 text-xs">{{ rewards.xp }} XP</span>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        {# Completed quests #}
        <div id="panel-completed" class="hidden">
            {% if completedQuests is empty %}
                <div class="text-center py-8">
                    <p class="text-gray-500">Aucune quête terminée.</p>
                </div>
            {% else %}
                <div class="space-y-2">
                    {% for pqc in completedQuests %}
                        {% set quest = pqc.quest %}
                        <div class="bg-gray-700/30 rounded-lg p-3 border border-gray-700 opacity-75">
                            <div class="flex items-center justify-between">
                                <div>
                                    <h3 class="text-gray-300 font-medium text-sm">{{ quest.name }}</h3>
                                    <p class="text-gray-500 text-xs">{{ quest.description|slice(0, 80) }}{% if quest.description|length > 80 %}...{% endif %}</p>
                                </div>
                                <span class="text-green-500 text-xs font-mono">Terminée</span>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
</div>

<script>
function showTab(tab) {
    document.getElementById('panel-active').classList.toggle('hidden', tab !== 'active');
    document.getElementById('panel-completed').classList.toggle('hidden', tab !== 'completed');

    document.getElementById('tab-active').className = tab === 'active'
        ? 'px-4 py-2 text-sm font-medium border-b-2 border-purple-500 text-purple-400'
        : 'px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-400 hover:text-gray-300';
    document.getElementById('tab-completed').className = tab === 'completed'
        ? 'px-4 py-2 text-sm font-medium border-b-2 border-purple-500 text-purple-400'
        : 'px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-400 hover:text-gray-300';
}

async function completeQuest(id) {
    try {
        const resp = await fetch(`/game/quests/complete/${id}`, { method: 'POST' });
        const data = await resp.json();
        if (data.success) {
            showMessage(data.messages.join(' '));
            setTimeout(() => location.reload(), 1000);
        } else {
            showMessage(data.error || 'Erreur', true);
        }
    } catch (e) {
        showMessage('Erreur de connexion', true);
    }
}

async function abandonQuest(id) {
    if (!confirm('Abandonner cette quête ?')) return;
    try {
        const resp = await fetch(`/game/quests/abandon/${id}`, { method: 'POST' });
        const data = await resp.json();
        if (data.success) {
            showMessage(data.message);
            const el = document.getElementById(`quest-${id}`);
            if (el) el.remove();
        } else {
            showMessage(data.error || 'Erreur', true);
        }
    } catch (e) {
        showMessage('Erreur de connexion', true);
    }
}

function showMessage(msg, isError = false) {
    const container = document.getElementById('quest-messages');
    const text = document.getElementById('quest-message-text');
    container.classList.remove('hidden');
    text.textContent = msg;
    text.className = isError
        ? 'bg-red-900/50 border border-red-700 rounded-lg p-3 text-red-300 text-sm'
        : 'bg-green-900/50 border border-green-700 rounded-lg p-3 text-green-300 text-sm';
    setTimeout(() => container.classList.add('hidden'), 3000);
}
</script>
{% endblock %}

{% extends 'turbo_stream.html.twig' %}

{% block turbo_stream_content %}
<turbo-frame id="inventory-content">
    <div class="bg-gray-800/50 rounded-xl p-4">
        <h2 class="text-sm font-semibold text-purple-400 mb-3 uppercase tracking-wide">{{ 'game.inventory.materials'|trans }}</h2>
        {% if materials is empty %}
            <div class="text-center text-gray-500 py-8 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mx-auto mb-2 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                Aucune ressource disponible
            </div>
        {% else %}
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
                {% for item in materials %}
                    {% set gi = item.genericItem %}
                    <div class="bg-gray-700/60 rounded-lg p-3 border border-gray-600/30">
                        <div class="flex items-center gap-2 mb-1.5">
                            <div class="w-8 h-8 rounded-md flex items-center justify-center shrink-0
                                {% if gi.rarity == 'legendary' %}bg-yellow-700/40 text-yellow-400
                                {% elseif gi.rarity == 'epic' %}bg-purple-700/40 text-purple-400
                                {% elseif gi.rarity == 'rare' %}bg-blue-700/40 text-blue-400
                                {% elseif gi.rarity == 'uncommon' %}bg-green-700/40 text-green-400
                                {% else %}bg-gray-600/50 text-gray-400{% endif %}">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                            </div>
                            {% if gi.rarity %}
                                <span class="text-[10px] px-1.5 py-0.5 rounded
                                    {% if gi.rarity == 'legendary' %}bg-yellow-900/40 text-yellow-400
                                    {% elseif gi.rarity == 'epic' %}bg-purple-900/40 text-purple-400
                                    {% elseif gi.rarity == 'rare' %}bg-blue-900/40 text-blue-400
                                    {% elseif gi.rarity == 'uncommon' %}bg-green-900/40 text-green-400
                                    {% else %}bg-gray-800 text-gray-500{% endif %}">{{ gi.rarity|capitalize }}</span>
                            {% endif %}
                        </div>
                        <div class="text-sm text-white font-medium truncate">{{ gi.name }}</div>
                        <div class="text-xs text-gray-500 mt-0.5 line-clamp-2">{{ gi.description }}</div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</turbo-frame>
{% endblock %}

{% extends 'game/game.html.twig' %}

{% block title %}{{ 'game.inventory.title'|trans }}{% endblock %}

{% block game_content %}
<div class="game-page">
    {# Header #}
    <div class="mb-4 sm:mb-6">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-xl sm:text-3xl font-bold text-purple-400">{{ 'game.inventory.title'|trans }}</h1>
                <p class="text-gray-400 text-sm mt-0.5 hidden sm:block">{{ 'game.inventory.description'|trans }}</p>
            </div>
            {# Currency display #}
            <div class="flex items-center gap-4">
                <span class="text-yellow-400 flex items-center text-sm sm:text-base">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 sm:h-5 sm:w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z" />
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd" />
                    </svg>
                    <span class="font-bold">{{ inventory.gold|default(0) }}</span>
                </span>
            </div>
        </div>
    </div>

    {# Scrollable tabs #}
    <div class="border-b border-gray-700 mb-4 sm:mb-6 -mx-3 px-3 sm:mx-0 sm:px-0">
        <nav class="scroll-tabs">
            <a href="{{ path('app_game_inventory_equipment_list') }}"
               data-turbo-frame="inventory-content"
               class="tab-btn whitespace-nowrap py-3 px-4 border-b-2 border-purple-500 font-medium text-sm text-purple-400 focus:outline-none touch-target">
                {{ 'game.inventory.tab.equipment'|trans }}
            </a>
            <a href="{{ path('app_game_inventory_items_list') }}"
               data-turbo-frame="inventory-content"
               class="tab-btn whitespace-nowrap py-3 px-4 border-b-2 border-transparent font-medium text-sm text-gray-400 hover:text-gray-300 focus:outline-none touch-target">
                {{ 'game.inventory.tab.items'|trans }}
            </a>
            <a href="{{ path('app_game_inventory_materials_list') }}"
               data-turbo-frame="inventory-content"
               class="tab-btn whitespace-nowrap py-3 px-4 border-b-2 border-transparent font-medium text-sm text-gray-400 hover:text-gray-300 focus:outline-none touch-target">
                {{ 'game.inventory.tab.materials'|trans }}
            </a>
            <a href="{{ path('app_game_inventory_bank_list') }}"
               data-turbo-frame="inventory-content"
               class="tab-btn whitespace-nowrap py-3 px-4 border-b-2 border-transparent font-medium text-sm text-gray-400 hover:text-gray-300 focus:outline-none touch-target">
                {{ 'game.inventory.tab.bank'|trans }}
            </a>
            <a href="{{ path('app_game_inventory_materia_list') }}"
               data-turbo-frame="inventory-content"
               class="tab-btn whitespace-nowrap py-3 px-4 border-b-2 border-transparent font-medium text-sm text-gray-400 hover:text-gray-300 focus:outline-none touch-target">
                {{ 'game.inventory.tab.materia'|trans }}
            </a>
        </nav>
    </div>

    {# Content via turbo-frame #}
    <turbo-frame id="inventory-content" src="{{ path('app_game_inventory_equipment_list') }}">
        <div class="animate-pulse">
            <div class="h-64 sm:h-96 bg-gray-800 rounded-lg"></div>
        </div>
    </turbo-frame>

    {# Item details modal - bottom sheet style on mobile #}
    <div id="item-details-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden" style="padding-bottom: var(--safe-bottom)">
        <div class="flex items-end sm:items-center justify-center min-h-full p-0 sm:p-4">
            <div class="bg-gray-800 w-full sm:max-w-md sm:rounded-xl rounded-t-2xl shadow-2xl">
                <div class="p-4 sm:p-6">
                    <div class="flex justify-between items-start mb-3">
                        <h3 class="text-lg font-bold text-purple-400" id="modal-item-name">{{ 'game.inventory.item_details.placeholder'|trans }}</h3>
                        <button id="close-modal-btn" class="text-gray-400 hover:text-white p-1 touch-target">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                    <div id="modal-item-details"></div>
                    <div class="mt-4 flex gap-2">
                        <button id="modal-action-btn" class="flex-1 px-4 py-3 bg-purple-600 text-white rounded-lg hover:bg-purple-700 font-medium touch-target">
                            {{ 'game.inventory.actions.action'|trans }}
                        </button>
                        <button id="modal-cancel-btn" class="px-4 py-3 bg-gray-700 text-gray-300 rounded-lg hover:bg-gray-600 font-medium touch-target">
                            {{ 'common.cancel'|trans }}
                        </button>
                    </div>
                </div>
                {# Drag handle indicator on mobile #}
                <div class="sm:hidden w-10 h-1 bg-gray-600 rounded-full mx-auto mb-2 mt-0 absolute top-2 left-1/2 -translate-x-1/2"></div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    window.i18nInventory = {
        equip: "{{ 'game.inventory.actions.equip'|trans|e('js') }}",
        use: "{{ 'game.inventory.actions.use'|trans|e('js') }}",
        socket: "{{ 'game.inventory.actions.socket'|trans|e('js') }}",
        details: "{{ 'game.inventory.actions.details'|trans|e('js') }}",
        type_label: "{{ 'game.inventory.item_details.type'|trans|e('js') }}",
        slot_label: "{{ 'game.inventory.item_details.slot'|trans|e('js') }}",
        level_label: "{{ 'game.inventory.item_details.level'|trans|e('js') }}",
        stats_label: "{{ 'game.inventory.stats'|trans|e('js') }}"
    };
    document.addEventListener('DOMContentLoaded', function() {
        const tabButtons = document.querySelectorAll('.tab-btn');

        tabButtons.forEach(button => {
            button.addEventListener('click', () => {
                tabButtons.forEach(btn => {
                    btn.classList.remove('border-purple-500', 'text-purple-400');
                    btn.classList.add('border-transparent', 'text-gray-400');
                });
                button.classList.remove('border-transparent', 'text-gray-400');
                button.classList.add('border-purple-500', 'text-purple-400');
            });
        });

        const modal = document.getElementById('item-details-modal');
        const closeModalBtn = document.getElementById('close-modal-btn');
        const modalCancelBtn = document.getElementById('modal-cancel-btn');
        const modalActionBtn = document.getElementById('modal-action-btn');
        let currentItemId = null;
        let currentItemType = null;

        // Close modal on backdrop click
        modal.addEventListener('click', function(e) {
            if (e.target === this) modal.classList.add('hidden');
        });

        closeModalBtn.addEventListener('click', () => modal.classList.add('hidden'));
        modalCancelBtn.addEventListener('click', () => modal.classList.add('hidden'));

        modalActionBtn.addEventListener('click', function() {
            if (!currentItemId) return;
            const action = modalActionBtn.getAttribute('data-action');

            if (action === 'equip') {
                const url = '/game/inventory/equipment/equip/' + currentItemId;
                fetch(url, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/json',
                        'Accept': 'text/vnd.turbo-stream.html'
                    }
                })
                .then(response => response.text())
                .then(html => {
                    modal.classList.add('hidden');
                    Turbo.renderStreamMessage(html);
                })
                .catch(error => {
                    console.error('Erreur lors de l\'equipement de l\'item:', error);
                });
            } else {
                console.log('Action:', action, 'pour item', currentItemId);
                modal.classList.add('hidden');
            }
        });

        document.addEventListener('click', function(event) {
            const itemCard = event.target.closest('.item-card');
            if (!itemCard) return;

            const itemId = itemCard.getAttribute('data-item-id');
            const itemName = itemCard.querySelector('h3').textContent;
            const itemDescription = itemCard.querySelector('p:last-child').textContent;
            const itemType = itemCard.querySelector('p:first-of-type').textContent;
            const itemSlotType = itemCard.getAttribute('data-slot-type') || '';

            currentItemId = itemId;
            currentItemType = itemType;

            let itemQuantityOrLevel = '';
            const quantityElement = itemCard.querySelector('.bg-gray-800');
            if (quantityElement) itemQuantityOrLevel = quantityElement.textContent;

            document.getElementById('modal-item-name').textContent = itemName;

            const i18n = window.i18nInventory || {};
            let detailsHtml = `<div class="mb-3"><p class="text-gray-300 text-sm">${itemDescription}</p></div><div class="grid grid-cols-2 gap-3">`;
            detailsHtml += `<div><p class="text-xs text-gray-400">${i18n.type_label || 'Type'}</p><p class="text-white text-sm">${itemType}</p></div>`;

            if (itemSlotType) {
                detailsHtml += `<div><p class="text-xs text-gray-400">${i18n.slot_label || 'Emplacement'}</p><p class="text-white text-sm">${itemSlotType}</p></div>`;
            }
            if (quantityElement) {
                detailsHtml += `<div><p class="text-xs text-gray-400">${i18n.level_label || 'Niveau'}</p><p class="text-white text-sm">${itemQuantityOrLevel}</p></div>`;
            }
            detailsHtml += `</div>`;

            const statsContainer = itemCard.querySelector('.grid.grid-cols-2.gap-2');
            if (statsContainer) {
                detailsHtml += `<div class="mt-3 pt-3 border-t border-gray-600"><p class="text-xs text-gray-400 mb-2">${i18n.stats_label || 'Statistiques'}</p><div class="grid grid-cols-2 gap-2">${statsContainer.innerHTML}</div></div>`;
            }

            document.getElementById('modal-item-details').innerHTML = detailsHtml;

            const isEquipment = itemCard.getAttribute('data-is-gear') === 'true';
            const isMateria = itemCard.getAttribute('data-is-materia') === 'true';

            if (isEquipment) {
                modalActionBtn.textContent = i18n.equip || 'Equiper';
                modalActionBtn.setAttribute('data-action', 'equip');
            } else if (isMateria) {
                modalActionBtn.textContent = i18n.socket || 'Sertir';
                modalActionBtn.setAttribute('data-action', 'socket');
            } else if (itemType.includes('Consommable')) {
                modalActionBtn.textContent = i18n.use || 'Utiliser';
                modalActionBtn.setAttribute('data-action', 'use');
            } else {
                modalActionBtn.textContent = i18n.details || 'Examiner';
                modalActionBtn.setAttribute('data-action', 'details');
            }

            modal.classList.remove('hidden');
        });
    });
</script>
{% endblock %}

{% extends 'game/game.html.twig' %}

{% block title %}{{ 'game.inventory.title'|trans }}{% endblock %}

{% block game_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-purple-400 mb-4">{{ 'game.inventory.title'|trans }}</h1>
        <p class="text-gray-300">{{ 'game.inventory.description'|trans }}</p>
    </div>
    
    <!-- Onglets d'inventaire et informations de currency/energy -->
    <div class="mb-6">
        <div class="border-b border-gray-700">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between">
                <!-- Onglets -->
                <nav class="flex flex-wrap space-x-4 md:space-x-8">
                    <button id="tab-equipment-btn" class="tab-btn whitespace-nowrap py-4 px-1 border-b-2 border-purple-500 font-medium text-purple-400 focus:outline-none">
                        {{ 'game.inventory.tab.equipment'|trans }}
                    </button>
                    <button id="tab-items-btn" class="tab-btn whitespace-nowrap py-4 px-1 border-b-2 border-transparent font-medium text-gray-400 hover:text-gray-300 hover:border-gray-400 focus:outline-none">
                        {{ 'game.inventory.tab.items'|trans }}
                    </button>
                    <button id="tab-materials-btn" class="tab-btn whitespace-nowrap py-4 px-1 border-b-2 border-transparent font-medium text-gray-400 hover:text-gray-300 hover:border-gray-400 focus:outline-none">
                        {{ 'game.inventory.tab.materials'|trans }}
                    </button>
                    <button id="tab-bank-btn" class="tab-btn whitespace-nowrap py-4 px-1 border-b-2 border-transparent font-medium text-gray-400 hover:text-gray-300 hover:border-gray-400 focus:outline-none">
                        {{ 'game.inventory.tab.bank'|trans }}
                    </button>
                    <button id="tab-materia-btn" class="tab-btn whitespace-nowrap py-4 px-1 border-b-2 border-transparent font-medium text-gray-400 hover:text-gray-300 hover:border-gray-400 focus:outline-none">
                        {{ 'game.inventory.tab.materia'|trans }}
                    </button>
                </nav>
                
                <!-- Informations de currency et energy -->
                <div class="flex items-center space-x-6 py-2 md:py-4 mt-2 md:mt-0 border-t md:border-none border-gray-700 pt-2 md:pt-0">
                    <span class="text-yellow-400 flex items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z" />
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd" />
                        </svg>
                        <span class="font-medium">{{ app.user.gold|default(0) }}</span>
                    </span>
                    {# <span class="text-purple-400 flex items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
                        </svg>
                        <span class="font-medium">{{ app.user.energy|default(100) }}/100</span>
                    </span> #}
                </div>
            </div>
        </div>
    </div>
    
    <!-- Contenu des onglets -->
    <div id="tab-equipment" class="tab-content">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Équipement du personnage -->
            <div class="bg-gray-800 rounded-lg shadow-lg p-6 col-span-1">
                <h2 class="text-xl font-semibold text-purple-400 mb-4">{{ 'game.inventory.equipped'|trans }}</h2>
                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-gray-700 rounded p-3 flex items-center">
                        <div class="w-12 h-12 bg-gray-600 rounded-md flex items-center justify-center mr-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
                            </svg>
                        </div>
                        <div>
                            <div class="text-sm text-gray-400">{{ 'game.inventory.slot.head'|trans }}</div>
                            <div class="text-white" id="equipped-head">-</div>
                        </div>
                    </div>
                    <div class="bg-gray-700 rounded p-3 flex items-center">
                        <div class="w-12 h-12 bg-gray-600 rounded-md flex items-center justify-center mr-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                            </svg>
                        </div>
                        <div>
                            <div class="text-sm text-gray-400">{{ 'game.inventory.slot.shoulder'|trans }}</div>
                            <div class="text-white" id="equipped-shoulder">-</div>
                        </div>
                    </div>
                    <div class="bg-gray-700 rounded p-3 flex items-center">
                        <div class="w-12 h-12 bg-gray-600 rounded-md flex items-center justify-center mr-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                        </div>
                        <div>
                            <div class="text-sm text-gray-400">{{ 'game.inventory.slot.neck'|trans }}</div>
                            <div class="text-white" id="equipped-neck">-</div>
                        </div>
                    </div>
                    <div class="bg-gray-700 rounded p-3 flex items-center">
                        <div class="w-12 h-12 bg-gray-600 rounded-md flex items-center justify-center mr-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </div>
                        <div>
                            <div class="text-sm text-gray-400">{{ 'game.inventory.slot.chest'|trans }}</div>
                            <div class="text-white" id="equipped-chest">-</div>
                        </div>
                    </div>
                    <div class="bg-gray-700 rounded p-3 flex items-center">
                        <div class="w-12 h-12 bg-gray-600 rounded-md flex items-center justify-center mr-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11" />
                            </svg>
                        </div>
                        <div>
                            <div class="text-sm text-gray-400">{{ 'game.inventory.slot.hand'|trans }}</div>
                            <div class="text-white" id="equipped-hand">-</div>
                        </div>
                    </div>
                    <div class="bg-gray-700 rounded p-3 flex items-center">
                        <div class="w-12 h-12 bg-gray-600 rounded-md flex items-center justify-center mr-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                            </svg>
                        </div>
                        <div>
                            <div class="text-sm text-gray-400">{{ 'game.inventory.slot.main_weapon'|trans }}</div>
                            <div class="text-white" id="equipped-main-weapon">-</div>
                        </div>
                    </div>
                    <div class="bg-gray-700 rounded p-3 flex items-center">
                        <div class="w-12 h-12 bg-gray-600 rounded-md flex items-center justify-center mr-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 12H6" />
                            </svg>
                        </div>
                        <div>
                            <div class="text-sm text-gray-400">{{ 'game.inventory.slot.side_weapon'|trans }}</div>
                            <div class="text-white" id="equipped-side-weapon">-</div>
                        </div>
                    </div>
                    <div class="bg-gray-700 rounded p-3 flex items-center">
                        <div class="w-12 h-12 bg-gray-600 rounded-md flex items-center justify-center mr-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                            </svg>
                        </div>
                        <div>
                            <div class="text-sm text-gray-400">{{ 'game.inventory.slot.belt'|trans }}</div>
                            <div class="text-white" id="equipped-belt">-</div>
                        </div>
                    </div>
                    <div class="bg-gray-700 rounded p-3 flex items-center">
                        <div class="w-12 h-12 bg-gray-600 rounded-md flex items-center justify-center mr-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2" />
                            </svg>
                        </div>
                        <div>
                            <div class="text-sm text-gray-400">{{ 'game.inventory.slot.leg'|trans }}</div>
                            <div class="text-white" id="equipped-leg">-</div>
                        </div>
                    </div>
                    <div class="bg-gray-700 rounded p-3 flex items-center">
                        <div class="w-12 h-12 bg-gray-600 rounded-md flex items-center justify-center mr-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                            </svg>
                        </div>
                        <div>
                            <div class="text-sm text-gray-400">{{ 'game.inventory.slot.foot'|trans }}</div>
                            <div class="text-white" id="equipped-foot">-</div>
                        </div>
                    </div>
                    <div class="bg-gray-700 rounded p-3 flex items-center">
                        <div class="w-12 h-12 bg-gray-600 rounded-md flex items-center justify-center mr-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                            </svg>
                        </div>
                        <div>
                            <div class="text-sm text-gray-400">{{ 'game.inventory.slot.ring_1'|trans }}</div>
                            <div class="text-white" id="equipped-ring-1">-</div>
                        </div>
                    </div>
                    <div class="bg-gray-700 rounded p-3 flex items-center">
                        <div class="w-12 h-12 bg-gray-600 rounded-md flex items-center justify-center mr-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                            </svg>
                        </div>
                        <div>
                            <div class="text-sm text-gray-400">{{ 'game.inventory.slot.ring_2'|trans }}</div>
                            <div class="text-white" id="equipped-ring-2">-</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Statistiques du personnage -->
            <div class="bg-gray-800 rounded-lg shadow-lg p-6 col-span-1 md:col-span-2 lg:col-span-2">
                <h2 class="text-xl font-semibold text-purple-400 mb-4">{{ 'game.inventory.stats'|trans }}</h2>
                <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                    <div class="bg-gray-700 rounded p-4">
                        <div class="text-sm text-gray-400">{{ 'game.stats.attack'|trans }}</div>
                        <div class="text-2xl font-bold text-white" id="stat-attack">0</div>
                    </div>
                    <div class="bg-gray-700 rounded p-4">
                        <div class="text-sm text-gray-400">{{ 'game.stats.defense'|trans }}</div>
                        <div class="text-2xl font-bold text-white" id="stat-defense">0</div>
                    </div>
                    <div class="bg-gray-700 rounded p-4">
                        <div class="text-sm text-gray-400">{{ 'game.stats.magic'|trans }}</div>
                        <div class="text-2xl font-bold text-white" id="stat-magic">0</div>
                    </div>
                    <div class="bg-gray-700 rounded p-4">
                        <div class="text-sm text-gray-400">{{ 'game.stats.speed'|trans }}</div>
                        <div class="text-2xl font-bold text-white" id="stat-speed">0</div>
                    </div>
                    <div class="bg-gray-700 rounded p-4">
                        <div class="text-sm text-gray-400">{{ 'game.stats.health'|trans }}</div>
                        <div class="text-2xl font-bold text-white" id="stat-health">0</div>
                    </div>
                    <div class="bg-gray-700 rounded p-4">
                        <div class="text-sm text-gray-400">{{ 'game.stats.mana'|trans }}</div>
                        <div class="text-2xl font-bold text-white" id="stat-mana">0</div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Liste des équipements disponibles -->
        <div class="mt-8 bg-gray-800 rounded-lg shadow-lg p-6">
            <h2 class="text-xl font-semibold text-purple-400 mb-4">{{ 'game.inventory.available_equipment'|trans }}</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="equipment-list">
                <!-- Les équipements seront chargés dynamiquement ici -->
                <div class="animate-pulse">
                    <div class="h-24 bg-gray-700 rounded"></div>
                </div>
                <div class="animate-pulse">
                    <div class="h-24 bg-gray-700 rounded"></div>
                </div>
                <div class="animate-pulse">
                    <div class="h-24 bg-gray-700 rounded"></div>
                </div>
            </div>
        </div>
    </div>
    
    <div id="tab-items" class="tab-content hidden">
        <div class="bg-gray-800 rounded-lg shadow-lg p-6">

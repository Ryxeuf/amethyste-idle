{% extends 'game/game.html.twig' %}

{% block title %}{{ 'game.inventory.title'|trans }}{% endblock %}

{% block game_content %}
<div class="game-page" data-controller="inventory">
    {# ===== HEADER ===== #}
    <div class="mb-3 sm:mb-4">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
                <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-purple-900/40 flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5 sm:h-5 sm:w-5 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                    </svg>
                </div>
                <div>
                    <h1 class="text-base sm:text-xl font-bold text-white leading-tight">{{ 'game.inventory.title'|trans }}</h1>
                    <div class="flex items-center gap-1.5 mt-0.5">
                        <div class="w-14 sm:w-20 h-1.5 bg-gray-700/60 rounded-full overflow-hidden">
                            <div class="h-full bg-purple-500/80 rounded-full transition-all" style="width: {{ bagSize > 0 ? (bagUsed / bagSize * 100)|round : 0 }}%"></div>
                        </div>
                        <span class="text-[10px] text-gray-500">{{ bagUsed }}/{{ bagSize }}</span>
                    </div>
                </div>
            </div>
            <div class="flex items-center gap-1.5 bg-yellow-900/20 border border-yellow-700/30 rounded-lg px-2 py-1 sm:px-2.5 sm:py-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 sm:h-4 sm:w-4 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z" />
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd" />
                </svg>
                <span class="text-xs sm:text-sm font-semibold text-yellow-400">{{ gils }}</span>
            </div>
        </div>
    </div>

    {# ===== ONGLETS PILLS ===== #}
    <div class="inv-tabs-wrapper" id="inv-tabs-wrapper">
        <nav class="inv-tabs" id="inventory-tabs">
            <a href="{{ path('app_game_inventory_equipment_list') }}"
               data-turbo-frame="inventory-content"
               class="inv-tab inv-tab--active">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                <span class="inv-tab-label">{{ 'game.inventory.tab.equipment'|trans }}</span>
            </a>
            <a href="{{ path('app_game_inventory_items_list') }}"
               data-turbo-frame="inventory-content"
               class="inv-tab">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
                <span class="inv-tab-label">{{ 'game.inventory.tab.items'|trans }}</span>
            </a>
            <a href="{{ path('app_game_inventory_materia_list') }}"
               data-turbo-frame="inventory-content"
               class="inv-tab">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
                <span class="inv-tab-label">{{ 'game.inventory.tab.materia'|trans }}</span>
            </a>
            <a href="{{ path('app_game_inventory_materials_list') }}"
               data-turbo-frame="inventory-content"
               class="inv-tab">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                <span class="inv-tab-label">{{ 'game.inventory.tab.materials'|trans }}</span>
            </a>
            <a href="{{ path('app_game_inventory_bank_list') }}"
               data-turbo-frame="inventory-content"
               class="inv-tab">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
                <span class="inv-tab-label">{{ 'game.inventory.tab.bank'|trans }}</span>
            </a>
        </nav>
    </div>

    {# Contenu via turbo-frame #}
    <turbo-frame id="inventory-content" src="{{ path('app_game_inventory_equipment_list') }}">
        <div class="animate-pulse">
            <div class="h-48 bg-gray-800/50 rounded-xl"></div>
        </div>
    </turbo-frame>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Tab switching
    const tabsNav = document.getElementById('inventory-tabs');
    tabsNav.addEventListener('click', function(e) {
        const tab = e.target.closest('.inv-tab');
        if (!tab) return;
        this.querySelectorAll('.inv-tab').forEach(function(t) {
            t.classList.remove('inv-tab--active');
        });
        tab.classList.add('inv-tab--active');
    });

    // Scroll fade indicators
    const wrapper = document.getElementById('inv-tabs-wrapper');
    const scroller = tabsNav;
    function updateFades() {
        const sl = scroller.scrollLeft;
        const maxScroll = scroller.scrollWidth - scroller.clientWidth;
        wrapper.classList.toggle('scroll-left', sl > 8);
        wrapper.classList.toggle('scroll-right', sl < maxScroll - 8);
    }
    scroller.addEventListener('scroll', updateFades, { passive: true });
    // Initial check after a tick (fonts loaded etc.)
    setTimeout(updateFades, 100);
    window.addEventListener('resize', updateFades);
});
</script>
{% endblock %}

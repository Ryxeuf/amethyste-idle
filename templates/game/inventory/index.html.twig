{% extends 'game/game.html.twig' %}

{% block title %}{{ 'game.inventory.title'|trans }}{% endblock %}

{% block game_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-purple-400 mb-4">{{ 'game.inventory.title'|trans }}</h1>
        <p class="text-gray-300">{{ 'game.inventory.description'|trans }}</p>
    </div>
    
    <!-- Onglets d'inventaire et informations de currency/energy -->
    <div class="mb-6">
        <div class="border-b border-gray-700">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between">
                <!-- Onglets -->
                <nav class="flex flex-wrap space-x-4 md:space-x-8">
                    <a href="{{ path('app_game_inventory_equipment_list') }}" 
                       data-turbo-frame="inventory-content"
                       class="tab-btn whitespace-nowrap py-4 px-1 border-b-2 border-purple-500 font-medium text-purple-400 focus:outline-none">
                        {{ 'game.inventory.tab.equipment'|trans }}
                    </a>
                    <a href="{{ path('app_game_inventory_items_list') }}" 
                       data-turbo-frame="inventory-content"
                       class="tab-btn whitespace-nowrap py-4 px-1 border-b-2 border-transparent font-medium text-gray-400 hover:text-gray-300 hover:border-gray-400 focus:outline-none">
                        {{ 'game.inventory.tab.items'|trans }}
                    </a>
                    <a href="{{ path('app_game_inventory_materials_list') }}" 
                       data-turbo-frame="inventory-content"
                       class="tab-btn whitespace-nowrap py-4 px-1 border-b-2 border-transparent font-medium text-gray-400 hover:text-gray-300 hover:border-gray-400 focus:outline-none">
                        {{ 'game.inventory.tab.materials'|trans }}
                    </a>
                    <a href="{{ path('app_game_inventory_bank_list') }}" 
                       data-turbo-frame="inventory-content"
                       class="tab-btn whitespace-nowrap py-4 px-1 border-b-2 border-transparent font-medium text-gray-400 hover:text-gray-300 hover:border-gray-400 focus:outline-none">
                        {{ 'game.inventory.tab.bank'|trans }}
                    </a>
                    <a href="{{ path('app_game_inventory_materia_list') }}" 
                       data-turbo-frame="inventory-content"
                       class="tab-btn whitespace-nowrap py-4 px-1 border-b-2 border-transparent font-medium text-gray-400 hover:text-gray-300 hover:border-gray-400 focus:outline-none">
                        {{ 'game.inventory.tab.materia'|trans }}
                    </a>
                </nav>
                
                <!-- Informations de currency et energy -->
                <div class="flex items-center space-x-6 py-2 md:py-4 mt-2 md:mt-0 border-t md:border-none border-gray-700 pt-2 md:pt-0">
                    <span class="text-yellow-400 flex items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z" />
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd" />
                        </svg>
                        <span class="font-medium">{{ inventory.gold|default(0) }}</span>
                    </span>
                    {# <span class="text-purple-400 flex items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
                        </svg>
                        <span class="font-medium">{{ app.user.energy|default(100) }}/100</span>
                    </span> #}
                </div>
            </div>
        </div>
    </div>
    
    <!-- Contenu des onglets avec turbo-frame -->
    <turbo-frame id="inventory-content" src="{{ path('app_game_inventory_equipment_list') }}">
        <div class="animate-pulse">
            <div class="h-96 bg-gray-800 rounded-lg"></div>
        </div>
    </turbo-frame>
    
    <!-- Modal pour les détails d'un objet -->
    <div id="item-details-modal" class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center hidden">
        <div class="bg-gray-800 rounded-lg shadow-xl max-w-md w-full mx-4">
            <div class="p-6">
                <div class="flex justify-between items-start">
                    <h3 class="text-xl font-bold text-purple-400" id="modal-item-name">{{ 'game.inventory.item_details.placeholder'|trans }}</h3>
                    <button id="close-modal-btn" class="text-gray-400 hover:text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
                <div class="mt-4" id="modal-item-details">
                    <!-- Détails de l'objet -->
                </div>
                <div class="mt-6 flex justify-end space-x-3">
                    <button id="modal-action-btn" class="px-4 py-2 bg-purple-600 text-white rounded hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 focus:ring-offset-gray-800">
                        {{ 'game.inventory.actions.action'|trans }}
                    </button>
                    <button id="modal-cancel-btn" class="px-4 py-2 bg-gray-600 text-white rounded hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 focus:ring-offset-gray-800">
                        {{ 'common.cancel'|trans }}
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    window.i18nInventory = {
        equip: "{{ 'game.inventory.actions.equip'|trans|e('js') }}",
        use: "{{ 'game.inventory.actions.use'|trans|e('js') }}",
        socket: "{{ 'game.inventory.actions.socket'|trans|e('js') }}",
        details: "{{ 'game.inventory.actions.details'|trans|e('js') }}",
        type_label: "{{ 'game.inventory.item_details.type'|trans|e('js') }}",
        slot_label: "{{ 'game.inventory.item_details.slot'|trans|e('js') }}",
        level_label: "{{ 'game.inventory.item_details.level'|trans|e('js') }}",
        stats_label: "{{ 'game.inventory.stats'|trans|e('js') }}"
    };
    document.addEventListener('DOMContentLoaded', function() {
        // Gestion des onglets
        const tabButtons = document.querySelectorAll('.tab-btn');
        
        tabButtons.forEach(button => {
            button.addEventListener('click', () => {
                // Réinitialiser tous les onglets
                tabButtons.forEach(btn => {
                    btn.classList.remove('border-purple-500', 'text-purple-400');
                    btn.classList.add('border-transparent', 'text-gray-400');
                });
                
                // Activer l'onglet cliqué
                button.classList.remove('border-transparent', 'text-gray-400');
                button.classList.add('border-purple-500', 'text-purple-400');
            });
        });
        
        // Gestion du modal
        const modal = document.getElementById('item-details-modal');
        const closeModalBtn = document.getElementById('close-modal-btn');
        const modalCancelBtn = document.getElementById('modal-cancel-btn');
        const modalActionBtn = document.getElementById('modal-action-btn');
        let currentItemId = null;
        let currentItemType = null;
        
        closeModalBtn.addEventListener('click', () => {
            modal.classList.add('hidden');
        });
        
        modalCancelBtn.addEventListener('click', () => {
            modal.classList.add('hidden');
        });
        
        // Gestion de l'action du bouton (Équiper, Utiliser, etc.)
        modalActionBtn.addEventListener('click', function() {
            if (!currentItemId) return;
            const action = modalActionBtn.getAttribute('data-action');
            
            if (action === 'equip') {
                // Appel AJAX pour équiper l'item
                const url = '/game/inventory/equipment/equip/' + currentItemId;
                
                fetch(url, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/json',
                        'Accept': 'text/vnd.turbo-stream.html'
                    }
                })
                .then(response => response.text())
                .then(html => {
                    // Fermer la modal
                    modal.classList.add('hidden');
                    
                    // Mettre à jour le contenu
                    Turbo.renderStreamMessage(html);
                })
                .catch(error => {
                    console.error('Erreur lors de l\'équipement de l\'item:', error);
                });
            } else if (action === 'use') {
                // Logique pour utiliser un objet
                console.log('Utilisation de l\'objet', currentItemId);
                modal.classList.add('hidden');
            } else if (action === 'socket') {
                // Logique pour sertir une materia
                console.log('Sertissage de la materia', currentItemId);
                modal.classList.add('hidden');
            } else {
                // Action par défaut
                console.log('Action par défaut pour', currentItemId);
                modal.classList.add('hidden');
            }
        });
        
        // Délégation d'événements pour les cartes d'objets ajoutées dynamiquement
        document.addEventListener('click', function(event) {
            // Trouver la carte d'objet la plus proche
            const itemCard = event.target.closest('.item-card');
            
            if (itemCard) {
                const itemId = itemCard.getAttribute('data-item-id');
                const itemName = itemCard.querySelector('h3').textContent;
                const itemDescription = itemCard.querySelector('p:last-child').textContent;
                const itemType = itemCard.querySelector('p:first-of-type').textContent;
                const itemSlotType = itemCard.getAttribute('data-slot-type') || '';
                
                // Stocker l'ID et le type de l'item courant
                currentItemId = itemId;
                currentItemType = itemType;
                
                // Récupérer la quantité ou le niveau (cela dépend de la structure HTML)
                let itemQuantityOrLevel = '';
                const quantityElement = itemCard.querySelector('.bg-gray-800');
                if (quantityElement) {
                    itemQuantityOrLevel = quantityElement.textContent;
                }
                
                // Mettre à jour le modal avec les détails de l'objet
                document.getElementById('modal-item-name').textContent = itemName;
                
                const i18n = window.i18nInventory || {};
                let detailsHtml = `
                    <div class="mb-4">
                        <p class="text-gray-300">${itemDescription}</p>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <p class="text-sm text-gray-400">${i18n.type_label || 'Type'}</p>
                            <p class="text-white">${itemType}</p>
                        </div>
                    `;
                
                if (itemSlotType) {
                    detailsHtml += `
                        <div>
                            <p class="text-sm text-gray-400">${i18n.slot_label || 'Emplacement'}</p>
                            <p class="text-white">${itemSlotType}</p>
                        </div>
                    `;
                }
                
                if (quantityElement) {
                    detailsHtml += `
                        <div>
                            <p class="text-sm text-gray-400">${i18n.level_label || 'Niveau'}</p>
                            <p class="text-white">${itemQuantityOrLevel}</p>
                        </div>
                    `;
                }
                
                detailsHtml += `</div>`;
                
                // Ajouter les statistiques si elles existent
                const statsContainer = itemCard.querySelector('.grid.grid-cols-2.gap-2');
                if (statsContainer) {
                    detailsHtml += `
                        <div class="mt-4 pt-4 border-t border-gray-600">
                            <p class="text-sm text-gray-400 mb-2">${i18n.stats_label || 'Statistiques'}</p>
                            <div class="grid grid-cols-2 gap-2">
                                ${statsContainer.innerHTML}
                            </div>
                        </div>
                    `;
                }
                
                document.getElementById('modal-item-details').innerHTML = detailsHtml;
                
                // Définir l'action du bouton en fonction du type d'objet
                const isEquipment = itemCard.hasAttribute('data-is-gear') && itemCard.getAttribute('data-is-gear') === 'true';
                const isMateria = itemCard.hasAttribute('data-is-materia') && itemCard.getAttribute('data-is-materia') === 'true';
                
                if (isEquipment) {
                    modalActionBtn.textContent = i18n.equip || 'Équiper';
                    modalActionBtn.setAttribute('data-action', 'equip');
                } else if (isMateria) {
                    modalActionBtn.textContent = i18n.socket || 'Sertir';
                    modalActionBtn.setAttribute('data-action', 'socket');
                } else if (itemType.includes('Consommable')) {
                    modalActionBtn.textContent = i18n.use || 'Utiliser';
                    modalActionBtn.setAttribute('data-action', 'use');
                } else {
                    modalActionBtn.textContent = i18n.details || 'Examiner';
                    modalActionBtn.setAttribute('data-action', 'details');
                }
                
                // Afficher le modal
                modal.classList.remove('hidden');
            }
        });
    });
</script>
{% endblock %} 
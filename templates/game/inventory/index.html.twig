{% extends 'game/game.html.twig' %}

{% block title %}{{ 'game.inventory.title'|trans }}{% endblock %}

{% block game_content %}
<div class="game-page">
    {# Header compact #}
    <div class="mb-3 sm:mb-5">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-lg sm:text-2xl font-bold text-purple-400">{{ 'game.inventory.title'|trans }}</h1>
                <p class="text-gray-500 text-xs mt-0.5 hidden sm:block">{{ bagUsed }}/{{ bagSize }} emplacements</p>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-yellow-400 flex items-center text-sm font-medium">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z" />
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd" />
                    </svg>
                    {{ gils }}
                </span>
            </div>
        </div>
    </div>

    {# Tabs horizontaux scrollables #}
    <div class="border-b border-gray-700/50 mb-4 -mx-3 px-3 sm:mx-0 sm:px-0">
        <nav class="scroll-tabs" id="inventory-tabs">
            <a href="{{ path('app_game_inventory_equipment_list') }}"
               data-turbo-frame="inventory-content"
               class="inventory-tab whitespace-nowrap py-2.5 px-3 border-b-2 border-purple-500 font-medium text-xs text-purple-400 uppercase tracking-wide focus:outline-none">
                {{ 'game.inventory.tab.equipment'|trans }}
            </a>
            <a href="{{ path('app_game_inventory_items_list') }}"
               data-turbo-frame="inventory-content"
               class="inventory-tab whitespace-nowrap py-2.5 px-3 border-b-2 border-transparent font-medium text-xs text-gray-500 hover:text-gray-300 uppercase tracking-wide focus:outline-none">
                {{ 'game.inventory.tab.items'|trans }}
            </a>
            <a href="{{ path('app_game_inventory_materials_list') }}"
               data-turbo-frame="inventory-content"
               class="inventory-tab whitespace-nowrap py-2.5 px-3 border-b-2 border-transparent font-medium text-xs text-gray-500 hover:text-gray-300 uppercase tracking-wide focus:outline-none">
                {{ 'game.inventory.tab.materials'|trans }}
            </a>
            <a href="{{ path('app_game_inventory_bank_list') }}"
               data-turbo-frame="inventory-content"
               class="inventory-tab whitespace-nowrap py-2.5 px-3 border-b-2 border-transparent font-medium text-xs text-gray-500 hover:text-gray-300 uppercase tracking-wide focus:outline-none">
                {{ 'game.inventory.tab.bank'|trans }}
            </a>
            <a href="{{ path('app_game_inventory_materia_list') }}"
               data-turbo-frame="inventory-content"
               class="inventory-tab whitespace-nowrap py-2.5 px-3 border-b-2 border-transparent font-medium text-xs text-gray-500 hover:text-gray-300 uppercase tracking-wide focus:outline-none">
                {{ 'game.inventory.tab.materia'|trans }}
            </a>
        </nav>
    </div>

    {# Contenu via turbo-frame #}
    <turbo-frame id="inventory-content" src="{{ path('app_game_inventory_equipment_list') }}">
        <div class="animate-pulse">
            <div class="h-48 bg-gray-800/50 rounded-xl"></div>
        </div>
    </turbo-frame>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('inventory-tabs').addEventListener('click', function(e) {
        const tab = e.target.closest('.inventory-tab');
        if (!tab) return;
        this.querySelectorAll('.inventory-tab').forEach(function(t) {
            t.classList.remove('border-purple-500', 'text-purple-400');
            t.classList.add('border-transparent', 'text-gray-500');
        });
        tab.classList.remove('border-transparent', 'text-gray-500');
        tab.classList.add('border-purple-500', 'text-purple-400');
    });
});
</script>
{% endblock %}

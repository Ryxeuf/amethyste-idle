{% extends 'turbo_stream.html.twig' %}

{% block turbo_stream_content %}
<turbo-frame id="inventory-content">
    <div class="bg-gray-800/50 rounded-xl p-4">
        <h2 class="text-sm font-semibold text-purple-400 mb-3 uppercase tracking-wide">{{ 'game.inventory.items.title'|trans }}</h2>
        {% if items is empty %}
            <div class="text-center text-gray-500 py-8 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mx-auto mb-2 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                Aucun objet disponible
            </div>
        {% else %}
            <div class="space-y-2">
                {% for item in items %}
                    <div class="bg-gray-700/60 rounded-lg p-3 flex items-center gap-3 border border-gray-600/30 hover:border-gray-500/50 transition-colors item-card"
                         data-item-id="{{ item.id }}">
                        <div class="w-9 h-9 rounded-md bg-purple-900/40 flex items-center justify-center text-purple-400 shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="text-sm text-white font-medium truncate">{{ item.name }}</div>
                            <div class="text-xs text-gray-500">{{ item.description|default('Consommable') }}</div>
                        </div>
                        <span class="text-xs bg-gray-800 text-gray-400 px-2 py-1 rounded shrink-0">x{{ item.quantity|default(1) }}</span>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</turbo-frame>
{% endblock %}

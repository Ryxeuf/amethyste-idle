{% extends 'turbo_stream.html.twig' %}

{% block turbo_stream_content %}
<turbo-frame id="inventory-content">
    <div class="bg-gray-800/50 rounded-xl p-3 sm:p-4 border border-gray-700/30">
        <div class="flex items-center justify-between mb-3">
            <h2 class="text-xs sm:text-sm font-semibold text-purple-400 uppercase tracking-wide flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
                {{ 'game.inventory.items.title'|trans }}
            </h2>
            {% set totalItems = 0 %}
            {% for item in items %}
                {% set totalItems = totalItems + item.quantity %}
            {% endfor %}
            {% if totalItems > 0 %}
                <span class="text-[10px] bg-gray-700 text-gray-400 px-2 py-0.5 rounded-full">{{ totalItems }}</span>
            {% endif %}
        </div>

        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-3 px-3 py-2 rounded-lg text-xs sm:text-sm {% if type == 'success' %}bg-green-900/40 border border-green-700/30 text-green-400{% elseif type == 'error' %}bg-red-900/40 border border-red-700/30 text-red-400{% endif %}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% if items is empty %}
            <div class="text-center text-gray-600 py-8 sm:py-10">
                <div class="w-14 h-14 sm:w-16 sm:h-16 mx-auto mb-3 rounded-full bg-gray-800/50 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 sm:h-8 sm:w-8 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
                </div>
                <p class="text-xs sm:text-sm">Aucun objet disponible</p>
                <p class="text-[10px] sm:text-xs text-gray-700 mt-1">Les objets consommables apparaîtront ici</p>
            </div>
        {% else %}
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {% for item in items %}
                    <div class="inv-item-card flex items-center gap-3"
                         data-inventory-target="item"
                         data-item-name="{{ item.name }}"
                         data-item-desc="{{ item.description|default('Consommable') }}"
                         data-item-id="{{ item.id }}">
                        <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-purple-900/30 flex items-center justify-center text-purple-400 shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 sm:h-5 sm:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="text-xs sm:text-sm text-white font-medium truncate flex items-center gap-1">
                                {{ item.name }}
                                {% if item.bound|default(false) %}
                                    <span class="text-yellow-500" title="Lié au personnage">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
                                    </span>
                                {% endif %}
                            </div>
                            <div class="text-[10px] sm:text-xs text-gray-500 truncate">{{ item.description|default('Consommable') }}</div>
                        </div>
                        <span class="text-[10px] sm:text-xs bg-purple-900/30 text-purple-400 font-medium px-1.5 sm:px-2 py-0.5 sm:py-1 rounded-lg shrink-0">x{{ item.quantity|default(1) }}</span>
                        {% if item.usable|default(false) %}
                            <form method="post" action="{{ path('app_game_inventory_items_use', {id: item.id}) }}" data-turbo-frame="inventory-content" class="shrink-0">
                                <button type="submit" class="w-8 h-8 rounded-lg bg-green-600/80 hover:bg-green-500 text-white flex items-center justify-center transition-all" title="Utiliser">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                </button>
                            </form>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</turbo-frame>
{% endblock %}

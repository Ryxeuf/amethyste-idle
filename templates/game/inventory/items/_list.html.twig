{% extends 'turbo_stream.html.twig' %}

{% block turbo_stream_content %}
<turbo-frame id="inventory-content">
    <div class="bg-gray-800 rounded-lg shadow-lg p-6">
        <h2 class="text-xl font-semibold text-purple-400 mb-4">{{ 'game.inventory.items'|trans }}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            {% if items is empty %}
                <div class="col-span-full text-center text-gray-400 py-8">Aucun objet disponible</div>
            {% else %}
                {% for item in items %}
                    <div class="bg-gray-700 rounded-lg p-4 flex flex-col hover:bg-gray-600 transition cursor-pointer item-card" data-item-id="{{ item.id }}">
                        <div class="flex items-center mb-3">
                            <div class="w-10 h-10 bg-purple-900 rounded-md flex items-center justify-center mr-3">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-purple-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                                </svg>
                            </div>
                            <div class="flex-1">
                                <h3 class="text-white font-medium">{{ item.name }}</h3>
                                <p class="text-xs text-gray-400">{{ item.type|default('Consommable') }}</p>
                            </div>
                            <div class="text-sm font-semibold text-white bg-gray-800 px-2 py-1 rounded">x{{ item.quantity|default(1) }}</div>
                        </div>
                        <p class="text-sm text-gray-300 mt-1">{{ item.description|default('Aucune description') }}</p>
                    </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</turbo-frame>
{% endblock %} 
{% extends 'turbo_stream.html.twig' %}

{% block turbo_stream_content %}
<turbo-frame id="inventory-content">
    {# ===== STATS DU PERSONNAGE ===== #}
    <div class="bg-gray-800/50 rounded-xl p-4 mb-4">
        <div class="grid grid-cols-4 gap-2 text-center">
            <div>
                <div class="text-xs text-gray-500 uppercase tracking-wide">PV</div>
                <div class="text-sm font-bold text-red-400">{{ stats.life }}/{{ stats.maxLife }}</div>
            </div>
            <div>
                <div class="text-xs text-gray-500 uppercase tracking-wide">{{ 'game.stats.attack'|trans }}</div>
                <div class="text-sm font-bold text-orange-400">{{ stats.hit }}</div>
            </div>
            <div>
                <div class="text-xs text-gray-500 uppercase tracking-wide">{{ 'game.stats.defense'|trans }}</div>
                <div class="text-sm font-bold text-blue-400">{{ stats.protection }}</div>
            </div>
            <div>
                <div class="text-xs text-gray-500 uppercase tracking-wide">{{ 'game.stats.speed'|trans }}</div>
                <div class="text-sm font-bold text-green-400">{{ stats.speed }}</div>
            </div>
        </div>
        <div class="mt-2 grid grid-cols-2 gap-2">
            <div class="bg-red-900/30 rounded-lg h-2 overflow-hidden">
                <div class="bg-red-500 h-full rounded-lg transition-all" style="width: {{ (stats.life / stats.maxLife * 100)|round }}%"></div>
            </div>
            <div class="bg-blue-900/30 rounded-lg h-2 overflow-hidden">
                <div class="bg-blue-500 h-full rounded-lg transition-all" style="width: {{ (stats.energy / stats.maxEnergy * 100)|round }}%"></div>
            </div>
        </div>
        <div class="grid grid-cols-2 gap-2 mt-1">
            <div class="text-[10px] text-gray-500 text-center">PV {{ stats.life }}/{{ stats.maxLife }}</div>
            <div class="text-[10px] text-gray-500 text-center">EN {{ stats.energy }}/{{ stats.maxEnergy }}</div>
        </div>
    </div>

    {# ===== GRILLE D'EQUIPEMENT (Character Sheet RPG) ===== #}
    <div class="bg-gray-800/50 rounded-xl p-4 mb-4">
        <h2 class="text-sm font-semibold text-purple-400 mb-3 uppercase tracking-wide">{{ 'game.inventory.equipped'|trans }}</h2>

        {# Layout: gauche (tête, épaules, torse, mains, ceinture) | droite (cou, armes, jambes, pieds, anneaux) #}
        <div class="grid grid-cols-2 gap-2">
            {% for slotKey, playerItem in equipped %}
                {% set slotLabel = ('game.inventory.slot.' ~ slotKey)|trans %}
                {% if playerItem is not null %}
                    <div class="equipment-slot group relative bg-gray-700/80 rounded-lg p-2.5 flex items-center gap-2.5 border border-gray-600/50 hover:border-purple-500/50 transition-colors">
                        <div class="w-9 h-9 rounded-md flex items-center justify-center shrink-0
                            {% if playerItem.genericItem.rarity == 'legendary' %}bg-yellow-700/40 text-yellow-400 ring-1 ring-yellow-600/50
                            {% elseif playerItem.genericItem.rarity == 'epic' %}bg-purple-700/40 text-purple-400 ring-1 ring-purple-600/50
                            {% elseif playerItem.genericItem.rarity == 'rare' %}bg-blue-700/40 text-blue-400 ring-1 ring-blue-600/50
                            {% elseif playerItem.genericItem.rarity == 'uncommon' %}bg-green-700/40 text-green-400 ring-1 ring-green-600/50
                            {% else %}bg-gray-600/50 text-gray-300{% endif %}">
                            {{ _self.slot_icon(slotKey) }}
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="text-xs text-gray-500 leading-none">{{ slotLabel }}</div>
                            <div class="text-sm text-white font-medium truncate">{{ playerItem.genericItem.name }}</div>
                            {% if playerItem.genericItem.protection > 0 %}
                                <div class="text-[10px] text-blue-400">+{{ playerItem.genericItem.protection }} DEF</div>
                            {% endif %}
                        </div>
                        <form method="post" action="{{ path('app_game_inventory_equipment_unequip', {id: playerItem.id}) }}" data-turbo-frame="inventory-content" class="shrink-0">
                            <button type="submit" class="w-7 h-7 rounded-md bg-red-900/40 text-red-400 hover:bg-red-800/60 flex items-center justify-center transition-colors" title="{{ 'game.inventory.actions.unequip'|trans }}">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                            </button>
                        </form>
                    </div>
                {% else %}
                    <div class="equipment-slot bg-gray-800/60 rounded-lg p-2.5 flex items-center gap-2.5 border border-dashed border-gray-700/50">
                        <div class="w-9 h-9 rounded-md bg-gray-700/30 flex items-center justify-center text-gray-600 shrink-0">
                            {{ _self.slot_icon(slotKey) }}
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="text-xs text-gray-600 leading-none">{{ slotLabel }}</div>
                            <div class="text-xs text-gray-600 italic">{{ ('game.inventory.slot.empty')|trans }}</div>
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    </div>

    {# ===== EQUIPEMENT DISPONIBLE ===== #}
    <div class="bg-gray-800/50 rounded-xl p-4">
        <h2 class="text-sm font-semibold text-purple-400 mb-3 uppercase tracking-wide">{{ 'game.inventory.available_equipment'|trans }}</h2>

        {% if availableGear is empty %}
            <div class="text-center text-gray-500 py-8 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mx-auto mb-2 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                Aucun équipement disponible
            </div>
        {% else %}
            <div class="space-y-2">
                {% for item in availableGear %}
                    {% set gi = item.genericItem %}
                    <div class="bg-gray-700/60 rounded-lg p-3 flex items-center gap-3 border border-gray-600/30 hover:border-gray-500/50 transition-colors">
                        {# Icon avec rareté #}
                        <div class="w-10 h-10 rounded-md flex items-center justify-center shrink-0
                            {% if gi.rarity == 'legendary' %}bg-yellow-700/40 text-yellow-400 ring-1 ring-yellow-600/50
                            {% elseif gi.rarity == 'epic' %}bg-purple-700/40 text-purple-400 ring-1 ring-purple-600/50
                            {% elseif gi.rarity == 'rare' %}bg-blue-700/40 text-blue-400 ring-1 ring-blue-600/50
                            {% elseif gi.rarity == 'uncommon' %}bg-green-700/40 text-green-400 ring-1 ring-green-600/50
                            {% else %}bg-gray-600/50 text-gray-300{% endif %}">
                            {{ _self.slot_icon(gi.gearLocation) }}
                        </div>

                        {# Infos #}
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2">
                                <span class="text-sm text-white font-medium truncate">{{ gi.name }}</span>
                                {% if gi.level %}
                                    <span class="text-[10px] bg-gray-800 text-gray-400 px-1.5 py-0.5 rounded shrink-0">Niv.{{ gi.level }}</span>
                                {% endif %}
                            </div>
                            <div class="flex items-center gap-2 mt-0.5">
                                <span class="text-xs text-gray-500">{{ _self.slot_name(gi.gearLocation) }}</span>
                                {% if gi.protection > 0 %}
                                    <span class="text-[10px] text-blue-400">+{{ gi.protection }} DEF</span>
                                {% endif %}
                                {% if gi.rarity %}
                                    <span class="text-[10px] px-1.5 py-0.5 rounded
                                        {% if gi.rarity == 'legendary' %}bg-yellow-900/40 text-yellow-400
                                        {% elseif gi.rarity == 'epic' %}bg-purple-900/40 text-purple-400
                                        {% elseif gi.rarity == 'rare' %}bg-blue-900/40 text-blue-400
                                        {% elseif gi.rarity == 'uncommon' %}bg-green-900/40 text-green-400
                                        {% else %}bg-gray-800 text-gray-500{% endif %}">{{ gi.rarity|capitalize }}</span>
                                {% endif %}
                            </div>
                        </div>

                        {# Bouton équiper #}
                        <form method="post" action="{{ path('app_game_inventory_equipment_equip', {id: item.id}) }}" data-turbo-frame="inventory-content" class="shrink-0">
                            <button type="submit" class="px-3 py-1.5 bg-purple-600 hover:bg-purple-500 text-white text-xs font-medium rounded-md transition-colors">
                                {{ 'game.inventory.actions.equip'|trans }}
                            </button>
                        </form>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</turbo-frame>

{# ===== MACRO: Icône par emplacement ===== #}
{% macro slot_icon(slot) %}
{% if slot == 'head' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a7 7 0 0 0-7 7c0 2.38 1.19 4.47 3 5.74V17a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2v-2.26c1.81-1.27 3-3.36 3-5.74a7 7 0 0 0-7-7z"/><path d="M9 21h6"/></svg>
{% elseif slot == 'neck' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4M2 12h4m12 0h4"/></svg>
{% elseif slot == 'chest' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2l3 5h6l3-5"/><rect x="4" y="7" width="16" height="13" rx="2"/><path d="M12 7v6"/></svg>
{% elseif slot == 'shoulder' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 10c0-3 2-5 8-5s8 2 8 5"/><rect x="6" y="10" width="12" height="6" rx="2"/></svg>
{% elseif slot == 'hand' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 1 1 3 0m-3 6a1.5 1.5 0 0 0-3 0v2a7.5 7.5 0 0 0 15 0v-5a1.5 1.5 0 0 0-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 0 1 3 0v1m0 0V11m0-5.5a1.5 1.5 0 0 1 3 0v3m0 0V11"/></svg>
{% elseif slot == 'main_weapon' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.5 2l6 6-9 9-6-6 9-9z"/><path d="M5.5 16.5L2 22l5.5-3.5"/></svg>
{% elseif slot == 'side_weapon' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
{% elseif slot == 'belt' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="9" width="20" height="6" rx="1"/><rect x="9" y="8" width="6" height="8" rx="1"/></svg>
{% elseif slot == 'leg' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2h4v14l-2 6H6V2zm8 0h4v20h-2l-2-6V2z"/></svg>
{% elseif slot == 'foot' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 16s1-4 4-4 4 4 8 4 4-4 4-4v5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-5z"/></svg>
{% elseif slot == 'ring_1' or slot == 'ring_2' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="14" r="5"/><path d="M12 9V2l3 3-3 3"/></svg>
{% else %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
{% endif %}
{% endmacro %}

{# ===== MACRO: Nom d'emplacement ===== #}
{% macro slot_name(slot) %}
{% apply spaceless %}
{% if slot == 'head' %}Tête
{% elseif slot == 'neck' %}Cou
{% elseif slot == 'chest' %}Torse
{% elseif slot == 'shoulder' %}Épaules
{% elseif slot == 'hand' %}Mains
{% elseif slot == 'main_weapon' %}Arme principale
{% elseif slot == 'side_weapon' %}Arme secondaire
{% elseif slot == 'belt' %}Ceinture
{% elseif slot == 'leg' %}Jambes
{% elseif slot == 'foot' %}Pieds
{% elseif slot == 'ring_1' %}Anneau 1
{% elseif slot == 'ring_2' %}Anneau 2
{% else %}Équipement{% endif %}
{% endapply %}
{% endmacro %}
{% endblock %}

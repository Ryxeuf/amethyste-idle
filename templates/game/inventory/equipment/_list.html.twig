{% extends 'turbo_stream.html.twig' %}

{% block turbo_stream_content %}
<turbo-frame id="inventory-content">
    {% include 'game/inventory/_frame_flashes.html.twig' %}
    {# ===== CHARACTER SHEET ===== #}
    <div class="bg-gray-800/50 rounded-xl p-3 sm:p-4 mb-4 border border-gray-700/30">
        {# Stats bar #}
        <div class="flex items-center justify-between mb-3 pb-2.5 border-b border-gray-700/30">
            <h2 class="text-xs sm:text-sm font-semibold text-purple-400 uppercase tracking-wide flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                {{ 'game.inventory.equipped'|trans }}
            </h2>
            <div class="flex flex-wrap items-center gap-2 sm:gap-3 text-xs">
                <span class="equip-stat-pill equip-stat-pill--atk" title="{{ 'game.stats.attack'|trans }}">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.5 2l6 6-9 9-6-6 9-9z"/><path d="M5.5 16.5L2 22l5.5-3.5"/></svg>
                    <span class="font-semibold tabular-nums text-orange-200">{{ stats.hit }}</span>
                    {% if stats.hitBonus > 0 %}
                        <span class="text-[9px] font-medium text-cyan-300/95">(+{{ stats.hitBonus }})</span>
                    {% endif %}
                </span>
                <span class="equip-stat-pill equip-stat-pill--def" title="{{ 'game.stats.defense'|trans }}">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                    <span class="font-semibold tabular-nums text-sky-200">{{ stats.protection }}</span>
                </span>
                <span class="equip-stat-pill equip-stat-pill--spd" title="{{ 'game.stats.speed'|trans }}">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    <span class="font-semibold tabular-nums text-emerald-200">{{ stats.speed }}</span>
                </span>
            </div>
        </div>

        {# PV / EN bars #}
        <div class="grid grid-cols-2 gap-2 sm:gap-3 mb-3 sm:mb-4">
            <div>
                <div class="flex items-center justify-between mb-1">
                    <span class="text-[10px] text-red-400 font-medium uppercase">PV</span>
                    <span class="text-[10px] text-gray-400 tabular-nums">
                        <span class="text-white font-medium">{{ stats.life }}</span>/<span class="text-gray-200">{{ stats.maxLife }}</span>
                        {% if stats.maxLifeBonus > 0 %}
                            <span class="text-cyan-400/95 font-medium ml-0.5" title="{{ 'game.inventory.effective_pv_bonus'|trans }}">(+{{ stats.maxLifeBonus }})</span>
                        {% endif %}
                    </span>
                </div>
                <div class="h-1.5 sm:h-2 bg-gray-900/60 rounded-full overflow-hidden ring-1 ring-red-500/15">
                    <div class="h-full bg-gradient-to-r from-red-600 to-rose-400 rounded-full transition-all shadow-[0_0_8px_rgba(248,113,113,0.35)]" style="width: {{ stats.maxLife > 0 ? (stats.life / stats.maxLife * 100)|round : 0 }}%"></div>
                </div>
            </div>
            <div>
                <div class="flex items-center justify-between mb-1">
                    <span class="text-[10px] text-blue-400 font-medium uppercase">EN</span>
                    <span class="text-[10px] text-gray-500">{{ stats.energy }}/{{ stats.maxEnergy }}</span>
                </div>
                <div class="h-1.5 sm:h-2 bg-gray-900/60 rounded-full overflow-hidden">
                    <div class="h-full bg-gradient-to-r from-blue-600 to-blue-400 rounded-full transition-all" style="width: {{ (stats.energy / stats.maxEnergy * 100)|round }}%"></div>
                </div>
            </div>
        </div>

        {# ===== PAPERDOLL ===== #}
        {# Mobile: 2-col grid (no silhouette). Tablet+: 3-col with silhouette. #}
        <div class="equip-paperdoll">
            {# Left column (desktop only grouping) #}
            <div class="equip-col-left">
                {{ _self.gear_slot('head', equipped.head, 'Tête') }}
                {{ _self.gear_slot('shoulder', equipped.shoulder, 'Épaules') }}
                {{ _self.gear_slot('chest', equipped.chest, 'Torse') }}
                {{ _self.gear_slot('hand', equipped.hand, 'Mains') }}
                {{ _self.gear_slot('belt', equipped.belt, 'Ceinture') }}
                {{ _self.gear_slot('leg', equipped.leg, 'Jambes') }}
            </div>

            {# Center: silhouette (hidden on mobile via CSS) #}
            <div class="equip-center">
                <div class="equip-silhouette">
                    <svg viewBox="0 0 120 200" class="w-full h-full text-purple-500/20" fill="currentColor">
                        <circle cx="60" cy="28" r="18"/>
                        <rect x="54" y="46" width="12" height="8" rx="2"/>
                        <path d="M25 58 C25 54, 35 50, 60 50 C85 50, 95 54, 95 58 L95 105 C95 108, 92 110, 88 110 L32 110 C28 110, 25 108, 25 105 Z"/>
                        <rect x="28" y="108" width="64" height="8" rx="2" class="text-purple-600/15"/>
                        <path d="M30 116 L32 160 C32 163, 35 165, 38 165 L52 165 C55 165, 56 163, 55 160 L52 116 Z"/>
                        <path d="M68 116 L65 160 C64 163, 65 165, 68 165 L82 165 C85 165, 88 163, 88 160 L90 116 Z"/>
                        <path d="M30 163 L22 173 C20 176, 22 180, 26 180 L52 180 C56 180, 58 176, 56 173 L52 163 Z"/>
                        <path d="M68 163 L64 173 C62 176, 64 180, 68 180 L94 180 C98 180, 100 176, 98 173 L90 163 Z"/>
                        <path d="M25 58 L12 85 C10 90, 12 95, 16 95 L22 95 L28 70 Z" class="text-purple-500/15"/>
                        <path d="M95 58 L108 85 C110 90, 108 95, 104 95 L98 95 L92 70 Z" class="text-purple-500/15"/>
                        <circle cx="14" cy="98" r="7" class="text-purple-500/15"/>
                        <circle cx="106" cy="98" r="7" class="text-purple-500/15"/>
                    </svg>
                </div>
            </div>

            {# Right column #}
            <div class="equip-col-right">
                {{ _self.gear_slot('neck', equipped.neck, 'Cou') }}
                {{ _self.gear_slot('main_weapon', equipped.main_weapon, 'Arme') }}
                {{ _self.gear_slot('side_weapon', equipped.side_weapon, 'Bouclier') }}
                {{ _self.gear_slot('ring_1', equipped.ring_1, 'Anneau') }}
                {{ _self.gear_slot('ring_2', equipped.ring_2, 'Anneau') }}
                {{ _self.gear_slot('foot', equipped.foot, 'Pieds') }}
            </div>
        </div>
    </div>

    {# ===== EQUIPMENT SETS ===== #}
    {% if activeSets is defined and activeSets is not empty %}
    <div class="bg-gray-800/50 rounded-xl p-3 sm:p-4 mb-4 border border-gray-700/30">
        <h2 class="text-xs sm:text-sm font-semibold text-purple-400 uppercase tracking-wide flex items-center gap-1.5 mb-3 pb-2.5 border-b border-gray-700/30">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
            Sets d'équipement
        </h2>
        <div class="space-y-2.5">
            {% for slug, data in activeSets %}
                <div class="bg-gray-900/40 rounded-lg p-2.5 border border-gray-700/20">
                    <div class="flex items-center justify-between mb-1.5">
                        <span class="text-xs sm:text-sm font-medium text-yellow-400">{{ data.set.name }}</span>
                        <span class="text-[10px] text-gray-500">{{ data.equippedCount }}/{{ data.totalPieces }} pièces</span>
                    </div>
                    <div class="space-y-0.5">
                        {% for bonus in data.activeBonuses %}
                            <div class="flex items-center gap-1.5 text-[10px] sm:text-xs text-green-400">
                                <span class="w-1.5 h-1.5 rounded-full bg-green-500 shrink-0"></span>
                                <span>({{ bonus.requiredPieces }}) +{{ bonus.bonusValue }} {{ _self.bonus_type_label(bonus.bonusType) }}</span>
                            </div>
                        {% endfor %}
                        {% for bonus in data.inactiveBonuses %}
                            <div class="flex items-center gap-1.5 text-[10px] sm:text-xs text-gray-600">
                                <span class="w-1.5 h-1.5 rounded-full bg-gray-700 shrink-0"></span>
                                <span>({{ bonus.requiredPieces }}) +{{ bonus.bonusValue }} {{ _self.bonus_type_label(bonus.bonusType) }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {# ===== AVAILABLE GEAR ===== #}
    <div class="bg-gray-800/50 rounded-xl p-3 sm:p-4 border border-gray-700/30">
        <div class="flex items-center justify-between mb-3">
            <h2 class="text-xs sm:text-sm font-semibold text-purple-400 uppercase tracking-wide flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
                {{ 'game.inventory.available_equipment'|trans }}
            </h2>
            {% if availableGear is not empty %}
                <span class="text-[10px] bg-gray-700 text-gray-400 px-2 py-0.5 rounded-full">{{ availableGear|length }}</span>
            {% endif %}
        </div>

        {% if availableGear is empty %}
            <div class="text-center text-gray-600 py-6 sm:py-8">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 sm:h-12 sm:w-12 mx-auto mb-2 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                <p class="text-xs sm:text-sm">Aucun équipement disponible</p>
            </div>
        {% else %}
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {% for item in availableGear %}
                    {% set gi = item.genericItem %}
                    <div class="equip-available-item group {{ _self.rarity_border_class(gi.rarity) }}"
                         data-inventory-target="item"
                         data-item-name="{{ gi.name }}"
                         data-item-desc="{{ gi.description }}"
                         data-item-rarity="{{ gi.rarity }}"
                         data-item-protection="{{ gi.protection }}"
                         data-item-level="{{ gi.level }}"
                         data-item-element="{{ gi.element.value }}"
                         data-item-slot="{{ gi.gearLocation }}"
                         data-item-materia-total="{{ gi.materiaSlots }}"
                         data-item-materia-filled="0">
                        <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg flex items-center justify-center shrink-0 {{ _self.rarity_bg_class(gi.rarity) }}">
                            {{ _self.slot_icon(gi.gearLocation) }}
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="text-xs sm:text-sm font-medium truncate {{ _self.rarity_text_class(gi.rarity) }}">{{ gi.name }}</div>
                            <div class="flex items-center gap-1.5 mt-0.5">
                                <span class="text-[10px] text-gray-500">{{ _self.slot_name(gi.gearLocation) }}</span>
                                {% if gi.protection > 0 %}
                                    <span class="text-[10px] text-blue-400 font-medium">+{{ gi.protection }} DEF</span>
                                {% endif %}
                                {% if gi.materiaSlots > 0 %}
                                    <span class="text-[10px] text-purple-400/80 flex items-center gap-0.5">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-2 w-2" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10" opacity=".3"/><circle cx="12" cy="12" r="5"/></svg>
                                        {{ gi.materiaSlots }} slot{{ gi.materiaSlots > 1 ? 's' : '' }}
                                    </span>
                                {% endif %}
                                {% if gi.equipmentSet is not null %}
                                    <span class="text-[10px] text-yellow-500/70">{{ gi.equipmentSet.name }}</span>
                                {% endif %}
                            </div>
                        </div>
                        <form method="post" action="{{ path('app_game_inventory_equipment_equip', {id: item.id}) }}" data-turbo-frame="inventory-content" class="shrink-0">
                            <button type="submit" class="w-8 h-8 rounded-lg bg-purple-600/80 hover:bg-purple-500 text-white flex items-center justify-center transition-all" title="{{ 'game.inventory.actions.equip'|trans }}">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                            </button>
                        </form>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</turbo-frame>

{# ===== MACRO: Equipment slot (with data-attributes for tooltip) ===== #}
{% macro gear_slot(slotKey, playerItem, label) %}
{% if playerItem is not null %}
    {% set gi = playerItem.genericItem %}
    {% if playerItem.slots|length > 0 %}
    <div class="equip-slot equip-slot--filled equip-slot--with-materia group {{ _self.rarity_slot_class(gi.rarity) }} flex flex-col gap-1.5 w-full">
        <div class="flex items-center gap-2 w-full min-w-0">
            <a href="{{ path('app_game_inventory_equipment_modify', {id: playerItem.id}) }}"
               data-turbo-frame="inventory-content"
               data-turbo-action="advance"
               class="equip-slot-link flex flex-1 items-center gap-2 min-w-0 rounded-md py-0.5 -my-0.5 px-0.5 -mx-0.5 transition-colors hover:bg-white/5 border border-transparent hover:border-violet-500/25">
                <div class="equip-slot-icon {{ _self.rarity_bg_class(gi.rarity) }}">
                    {{ _self.slot_icon(slotKey) }}
                </div>
                <div class="equip-slot-info">
                    <span class="equip-slot-label">{{ label }}</span>
                    <span class="equip-slot-name {{ _self.rarity_text_class(gi.rarity) }}">{{ gi.name }}</span>
                    {% if gi.protection > 0 %}
                        <span class="equip-slot-stat">+{{ gi.protection }} DEF</span>
                    {% endif %}
                    {% if gi.equipmentSet is not null %}
                        <span class="text-[9px] text-yellow-500/80 font-medium">{{ gi.equipmentSet.name }}</span>
                    {% endif %}
                </div>
            </a>
            <form method="post" action="{{ path('app_game_inventory_equipment_unequip', {id: playerItem.id}) }}" data-turbo-frame="inventory-content" class="equip-slot-action">
                <button type="submit" class="equip-unequip-btn" title="{{ 'game.inventory.actions.unequip'|trans }}">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                </button>
            </form>
        </div>
        {% include 'game/inventory/equipment/_materia_track.html.twig' with { playerItem: playerItem, materiaTrackContext: 'list' } only %}
    </div>
    {% else %}
    <div class="equip-slot equip-slot--filled group {{ _self.rarity_slot_class(gi.rarity) }} flex items-center gap-2">
        <a href="{{ path('app_game_inventory_equipment_modify', {id: playerItem.id}) }}"
           data-turbo-frame="inventory-content"
           data-turbo-action="advance"
           class="equip-slot-link flex flex-1 items-center gap-2 min-w-0 rounded-md py-0.5 -my-0.5 px-0.5 -mx-0.5 transition-colors hover:bg-white/5 border border-transparent hover:border-violet-500/25">
            <div class="equip-slot-icon {{ _self.rarity_bg_class(gi.rarity) }}">
                {{ _self.slot_icon(slotKey) }}
            </div>
            <div class="equip-slot-info">
                <span class="equip-slot-label">{{ label }}</span>
                <span class="equip-slot-name {{ _self.rarity_text_class(gi.rarity) }}">{{ gi.name }}</span>
                {% if gi.protection > 0 %}
                    <span class="equip-slot-stat">+{{ gi.protection }} DEF</span>
                {% endif %}
                {% if gi.equipmentSet is not null %}
                    <span class="text-[9px] text-yellow-500/80 font-medium">{{ gi.equipmentSet.name }}</span>
                {% endif %}
            </div>
        </a>
        <form method="post" action="{{ path('app_game_inventory_equipment_unequip', {id: playerItem.id}) }}" data-turbo-frame="inventory-content" class="equip-slot-action">
            <button type="submit" class="equip-unequip-btn" title="{{ 'game.inventory.actions.unequip'|trans }}">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </button>
        </form>
    </div>
    {% endif %}
{% else %}
    <div class="equip-slot equip-slot--empty">
        <div class="equip-slot-icon equip-slot-icon--empty">
            {{ _self.slot_icon(slotKey) }}
        </div>
        <div class="equip-slot-info">
            <span class="equip-slot-label">{{ label }}</span>
            <span class="equip-slot-empty-text">—</span>
        </div>
    </div>
{% endif %}
{% endmacro %}

{# ===== MACROS: Rarity helpers ===== #}
{% macro rarity_bg_class(rarity) %}
{% apply spaceless %}
{% if rarity == 'amethyst' %}bg-fuchsia-900/50 text-fuchsia-400
{% elseif rarity == 'legendary' %}bg-yellow-900/50 text-yellow-400
{% elseif rarity == 'epic' %}bg-purple-900/50 text-purple-400
{% elseif rarity == 'rare' %}bg-blue-900/50 text-blue-400
{% elseif rarity == 'uncommon' %}bg-green-900/50 text-green-400
{% else %}bg-gray-700/50 text-gray-400{% endif %}
{% endapply %}
{% endmacro %}

{% macro rarity_text_class(rarity) %}
{% apply spaceless %}
{% if rarity == 'amethyst' %}text-fuchsia-400
{% elseif rarity == 'legendary' %}text-yellow-400
{% elseif rarity == 'epic' %}text-purple-300
{% elseif rarity == 'rare' %}text-blue-300
{% elseif rarity == 'uncommon' %}text-green-300
{% else %}text-white{% endif %}
{% endapply %}
{% endmacro %}

{% macro rarity_border_class(rarity) %}
{% apply spaceless %}
{% if rarity == 'amethyst' %}equip-rarity-amethyst
{% elseif rarity == 'legendary' %}equip-rarity-legendary
{% elseif rarity == 'epic' %}equip-rarity-epic
{% elseif rarity == 'rare' %}equip-rarity-rare
{% elseif rarity == 'uncommon' %}equip-rarity-uncommon
{% else %}equip-rarity-common{% endif %}
{% endapply %}
{% endmacro %}

{% macro rarity_slot_class(rarity) %}
{% apply spaceless %}
{% if rarity == 'amethyst' %}equip-slot-amethyst
{% elseif rarity == 'legendary' %}equip-slot-legendary
{% elseif rarity == 'epic' %}equip-slot-epic
{% elseif rarity == 'rare' %}equip-slot-rare
{% elseif rarity == 'uncommon' %}equip-slot-uncommon
{% else %}{% endif %}
{% endapply %}
{% endmacro %}

{# ===== MACRO: Slot icon ===== #}
{% macro slot_icon(slot) %}
{% if slot == 'head' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a7 7 0 0 0-7 7c0 2.38 1.19 4.47 3 5.74V17a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2v-2.26c1.81-1.27 3-3.36 3-5.74a7 7 0 0 0-7-7z"/><path d="M9 21h6"/></svg>
{% elseif slot == 'neck' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4M2 12h4m12 0h4"/></svg>
{% elseif slot == 'chest' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2l3 5h6l3-5"/><rect x="4" y="7" width="16" height="13" rx="2"/><path d="M12 7v6"/></svg>
{% elseif slot == 'shoulder' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 10c0-3 2-5 8-5s8 2 8 5"/><rect x="6" y="10" width="12" height="6" rx="2"/></svg>
{% elseif slot == 'hand' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 1 1 3 0m-3 6a1.5 1.5 0 0 0-3 0v2a7.5 7.5 0 0 0 15 0v-5a1.5 1.5 0 0 0-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 0 1 3 0v1m0 0V11m0-5.5a1.5 1.5 0 0 1 3 0v3m0 0V11"/></svg>
{% elseif slot == 'main_weapon' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.5 2l6 6-9 9-6-6 9-9z"/><path d="M5.5 16.5L2 22l5.5-3.5"/></svg>
{% elseif slot == 'side_weapon' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
{% elseif slot == 'belt' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="9" width="20" height="6" rx="1"/><rect x="9" y="8" width="6" height="8" rx="1"/></svg>
{% elseif slot == 'leg' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2h4v14l-2 6H6V2zm8 0h4v20h-2l-2-6V2z"/></svg>
{% elseif slot == 'foot' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 16s1-4 4-4 4 4 8 4 4-4 4-4v5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-5z"/></svg>
{% elseif slot == 'ring_1' or slot == 'ring_2' %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="14" r="5"/><path d="M12 9V2l3 3-3 3"/></svg>
{% else %}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
{% endif %}
{% endmacro %}

{# ===== MACRO: Slot name ===== #}
{% macro slot_name(slot) %}
{% apply spaceless %}
{% if slot == 'head' %}Tête
{% elseif slot == 'neck' %}Cou
{% elseif slot == 'chest' %}Torse
{% elseif slot == 'shoulder' %}Épaules
{% elseif slot == 'hand' %}Mains
{% elseif slot == 'main_weapon' %}Arme principale
{% elseif slot == 'side_weapon' %}Arme secondaire
{% elseif slot == 'belt' %}Ceinture
{% elseif slot == 'leg' %}Jambes
{% elseif slot == 'foot' %}Pieds
{% elseif slot == 'ring_1' %}Anneau 1
{% elseif slot == 'ring_2' %}Anneau 2
{% else %}Équipement{% endif %}
{% endapply %}
{% endmacro %}

{# Libellé emplacement comme sur le paperdoll (liste + page modification) #}
{% macro paperdoll_slot_label(key) %}
{% apply spaceless %}
{% if key == 'main_weapon' %}Arme
{% elseif key == 'side_weapon' %}Bouclier
{% elseif key == 'ring_1' or key == 'ring_2' %}Anneau
{% else %}{{ _self.slot_name(key) }}{% endif %}
{% endapply %}
{% endmacro %}

{# ===== MACRO: Element dot color ===== #}
{% macro element_dot_class(element) %}
{% apply spaceless %}
{% if element.value == 'fire' %}bg-orange-500
{% elseif element.value == 'water' %}bg-blue-500
{% elseif element.value == 'earth' %}bg-amber-600
{% elseif element.value == 'air' %}bg-teal-400
{% elseif element.value == 'light' %}bg-yellow-400
{% elseif element.value == 'dark' %}bg-purple-500
{% elseif element.value == 'metal' %}bg-gray-400
{% elseif element.value == 'beast' %}bg-green-500
{% else %}bg-gray-500{% endif %}
{% endapply %}
{% endmacro %}
{# ===== MACRO: Bonus type label ===== #}
{% macro bonus_type_label(type) %}
{% apply spaceless %}
{% if type == 'damage' %}Dégâts
{% elseif type == 'heal' %}Soin
{% elseif type == 'hit' %}Précision
{% elseif type == 'critical' %}Critique
{% elseif type == 'life' %}PV
{% elseif type == 'protection' %}Défense
{% else %}{{ type }}{% endif %}
{% endapply %}
{% endmacro %}
{% endblock %}

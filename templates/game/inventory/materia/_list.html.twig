{% extends 'turbo_stream.html.twig' %}

{% block turbo_stream_content %}
<turbo-frame id="inventory-content">
    <div class="bg-gray-800 rounded-lg shadow-lg p-6">
        <h2 class="text-xl font-semibold text-purple-400 mb-4">{{ 'game.inventory.materia'|trans }}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            {% if materias is empty %}
                <div class="col-span-full text-center text-gray-400 py-8">Aucune materia disponible</div>
            {% else %}
                {% for item in materias %}
                    <div class="bg-gray-700 rounded-lg p-4 flex flex-col hover:bg-gray-600 transition cursor-pointer item-card" 
                         data-item-id="{{ item.id }}"
                         data-is-materia="true">
                        <div class="flex items-center mb-3">
                            <div class="w-10 h-10 
                                {% if item.rarity == 'common' %}bg-gray-600 text-gray-300
                                {% elseif item.rarity == 'uncommon' %}bg-green-800 text-green-300
                                {% elseif item.rarity == 'rare' %}bg-blue-800 text-blue-300
                                {% elseif item.rarity == 'epic' %}bg-purple-800 text-purple-300
                                {% elseif item.rarity == 'legendary' %}bg-yellow-700 text-yellow-300
                                {% else %}bg-gray-600 text-gray-300
                                {% endif %} rounded-md flex items-center justify-center mr-3">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                                </svg>
                            </div>
                            <div class="flex-1">
                                <h3 class="text-white font-medium">{{ item.name }}</h3>
                                <p class="text-xs text-gray-400">Materia</p>
                            </div>
                            <div class="text-sm font-semibold text-white bg-gray-800 px-2 py-1 rounded">Niv. {{ item.level|default(1) }}</div>
                        </div>
                        <p class="text-sm text-gray-300 mt-1">{{ item.description|default('Aucune description') }}</p>
                        {% if item.effects is defined and item.effects is not empty %}
                            <div class="mt-2 pt-2 border-t border-gray-600">
                                <div class="text-xs text-gray-400">Effets:</div>
                                <div class="text-sm text-white">{{ item.effects }}</div>
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</turbo-frame>
{% endblock %} 
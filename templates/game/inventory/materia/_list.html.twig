{% extends 'turbo_stream.html.twig' %}

{% block turbo_stream_content %}
<turbo-frame id="inventory-content">
    <div class="bg-gray-800/50 rounded-xl p-4">
        <h2 class="text-sm font-semibold text-purple-400 mb-3 uppercase tracking-wide">{{ 'game.inventory.materia'|trans }}</h2>
        {% if materias is empty %}
            <div class="text-center text-gray-500 py-8 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mx-auto mb-2 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
                Aucune materia disponible
            </div>
        {% else %}
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
                {% for item in materias %}
                    <div class="bg-gray-700/60 rounded-lg p-3 border border-gray-600/30 hover:border-gray-500/50 transition-colors"
                         data-item-id="{{ item.id }}">
                        <div class="flex items-center gap-2 mb-1.5">
                            <div class="w-8 h-8 rounded-md flex items-center justify-center shrink-0
                                {% if item.element == 'fire' %}bg-red-900/40 text-red-400
                                {% elseif item.element == 'water' %}bg-blue-900/40 text-blue-400
                                {% elseif item.element == 'earth' %}bg-amber-900/40 text-amber-400
                                {% elseif item.element == 'air' %}bg-cyan-900/40 text-cyan-400
                                {% elseif item.element == 'light' %}bg-yellow-900/40 text-yellow-300
                                {% elseif item.element == 'dark' %}bg-violet-900/40 text-violet-400
                                {% else %}bg-green-900/40 text-green-400{% endif %}">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
                            </div>
                            <span class="text-[10px] bg-gray-800 text-gray-400 px-1.5 py-0.5 rounded">Niv.{{ item.level }}</span>
                        </div>
                        <div class="text-sm text-white font-medium truncate">{{ item.name }}</div>
                        <div class="text-xs text-gray-500 mt-0.5">{{ item.description }}</div>
                        {% if item.effects %}
                            <div class="mt-1.5 text-[10px] text-purple-400 bg-purple-900/20 rounded px-1.5 py-1">{{ item.effects }}</div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</turbo-frame>
{% endblock %}

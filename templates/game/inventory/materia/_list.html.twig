{% extends 'turbo_stream.html.twig' %}

{% block turbo_stream_content %}
<turbo-frame id="inventory-content">
    <div class="bg-gray-800/50 rounded-xl p-3 sm:p-4 border border-gray-700/30">
        <div class="flex items-center justify-between mb-3">
            <h2 class="text-sm font-semibold text-purple-400 uppercase tracking-wide flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
                {{ 'game.inventory.materia'|trans }}
            </h2>
            {% if materias is not empty %}
                <span class="text-[10px] bg-gray-700 text-gray-400 px-2 py-0.5 rounded-full">{{ materias|length }}</span>
            {% endif %}
        </div>

        {% if materias is empty %}
            <div class="text-center text-gray-600 py-10">
                <div class="w-16 h-16 mx-auto mb-3 rounded-full bg-gray-800/50 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
                </div>
                <p class="text-sm">Aucune materia disponible</p>
                <p class="text-xs text-gray-700 mt-1">Les materia s'obtiennent en combat et via les quêtes</p>
            </div>
        {% else %}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
                {% for item in materias %}
                    <div class="inv-item-card flex items-center gap-3" data-item-id="{{ item.id }}">
                        {# Orbe de materia avec effet visuel #}
                        <div class="materia-orb materia-orb-{{ item.element }}">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white/90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
                        </div>

                        {# Infos materia #}
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-1.5">
                                <span class="text-sm text-white font-medium truncate">{{ item.name }}</span>
                                <span class="text-[10px] bg-gray-700/60 text-gray-400 px-1.5 py-0.5 rounded shrink-0">Niv.{{ item.level }}</span>
                            </div>
                            <div class="text-xs text-gray-500 mt-0.5 truncate">{{ item.description }}</div>
                            {% if item.effects %}
                                <div class="mt-1 text-[10px] text-purple-400 bg-purple-900/20 rounded px-1.5 py-0.5 truncate">{{ item.effects }}</div>
                            {% endif %}
                        </div>

                        {# Badge élément #}
                        <span class="text-[9px] font-medium uppercase px-1.5 py-0.5 rounded shrink-0
                            {% if item.element == 'fire' %}bg-red-900/30 text-red-400
                            {% elseif item.element == 'water' %}bg-blue-900/30 text-blue-400
                            {% elseif item.element == 'earth' %}bg-amber-900/30 text-amber-400
                            {% elseif item.element == 'air' %}bg-cyan-900/30 text-cyan-400
                            {% elseif item.element == 'light' %}bg-yellow-900/30 text-yellow-300
                            {% elseif item.element == 'dark' %}bg-violet-900/30 text-violet-400
                            {% else %}bg-green-900/30 text-green-400{% endif %}">
                            {{ item.element }}
                        </span>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</turbo-frame>
{% endblock %}

{% extends 'turbo_stream.html.twig' %}

{% block turbo_stream_content %}
<turbo-frame id="inventory-content">
    {% include 'game/inventory/_frame_flashes.html.twig' %}
    <div class="bg-gray-800/50 rounded-xl p-3 sm:p-4 border border-gray-700/30">
        <div class="flex items-center justify-between mb-3">
            <h2 class="text-xs sm:text-sm font-semibold text-purple-400 uppercase tracking-wide flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
                {{ 'game.inventory.materia'|trans }}
            </h2>
            {% set totalMaterias = 0 %}
            {% for item in materias %}
                {% set totalMaterias = totalMaterias + item.quantity %}
            {% endfor %}
            {% if totalMaterias > 0 %}
                <span class="text-[10px] bg-gray-700 text-gray-400 px-2 py-0.5 rounded-full">{{ totalMaterias }}</span>
            {% endif %}
        </div>

        {% if materias is empty %}
            <div class="text-center text-gray-600 py-8 sm:py-10">
                <div class="w-14 h-14 sm:w-16 sm:h-16 mx-auto mb-3 rounded-full bg-gray-800/50 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 sm:h-8 sm:w-8 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
                </div>
                <p class="text-xs sm:text-sm">Aucune materia disponible</p>
                <p class="text-[10px] sm:text-xs text-gray-700 mt-1">Les materia s'obtiennent en combat et via les quêtes</p>
            </div>
        {% else %}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
                {% for item in materias %}
                    <div class="inv-item-card flex items-center gap-3"
                         data-inventory-target="item"
                         data-item-name="{{ item.name }}"
                         data-item-desc="{{ item.description }}"
                         data-item-rarity="{{ item.rarity }}"
                         data-item-level="{{ item.level }}"
                         data-item-element="{{ item.element }}"
                         data-item-effects="{{ item.effects }}"
                         data-item-id="{{ item.id }}">
                        <div class="materia-orb materia-orb-{{ item.element }}"></div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-1.5">
                                <span class="text-xs sm:text-sm text-white font-medium truncate">{{ item.name }}</span>
                                <span class="text-[10px] bg-gray-700/60 text-gray-400 px-1.5 py-0.5 rounded shrink-0">Niv.{{ item.level }}</span>
                            </div>
                            <div class="text-[10px] sm:text-xs text-gray-500 mt-0.5 truncate">{{ item.description }}</div>
                        </div>
                        {% if item.quantity > 1 %}
                            <span class="text-[10px] sm:text-xs bg-purple-900/30 text-purple-400 font-medium px-1.5 sm:px-2 py-0.5 sm:py-1 rounded-lg shrink-0">x{{ item.quantity }}</span>
                        {% endif %}
                        <span class="text-[9px] font-medium uppercase px-1.5 py-0.5 rounded shrink-0
                            {% if item.element == 'fire' %}bg-red-900/30 text-red-400
                            {% elseif item.element == 'water' %}bg-blue-900/30 text-blue-400
                            {% elseif item.element == 'earth' %}bg-amber-900/30 text-amber-400
                            {% elseif item.element == 'air' %}bg-cyan-900/30 text-cyan-400
                            {% elseif item.element == 'light' %}bg-yellow-900/30 text-yellow-300
                            {% elseif item.element == 'dark' %}bg-violet-900/30 text-violet-400
                            {% else %}bg-green-900/30 text-green-400{% endif %}">
                            {{ item.element }}
                        </span>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</turbo-frame>
{% endblock %}

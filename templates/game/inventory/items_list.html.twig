{% extends 'game/game.html.twig' %}

{% block title %}{{ 'game.inventory.items.title'|trans }}{% endblock %}

{% block game_content %}
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
    {% for item in inventory.items %}
        <div class="item-card bg-gray-800 rounded-lg p-4 cursor-pointer hover:bg-gray-700 transition-colors"
             data-item-id="{{ item.id }}"
             data-is-gear="{{ item.genericItem.isEquipment ? 'true' : 'false' }}">
            <div class="flex justify-between items-start">
                <h3 class="text-lg font-semibold text-purple-400">{{ item.genericItem|localized_name }}</h3>
                <span class="bg-gray-700 text-gray-300 px-2 py-1 rounded text-sm">{{ item.quantity }}</span>
            </div>
            <p class="text-gray-400 text-sm mt-1">{{ item.genericItem.type }}</p>
            <p class="text-gray-300 mt-2">{{ item.genericItem.description }}</p>
        </div>
    {% else %}
        <div class="col-span-full text-center py-8">
            <p class="text-gray-400">{{ 'game.inventory.items.empty'|trans }}</p>
        </div>
    {% endfor %}
</div>
{% endblock %} 
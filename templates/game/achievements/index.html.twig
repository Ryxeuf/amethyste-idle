{% extends 'game/game.html.twig' %}

{% block title %}Succes{% endblock %}

{% block game_content %}
<div class="game-page">
    <div class="game-card">
        <div class="game-card-header flex items-center justify-between">
            <h2 class="text-base sm:text-lg font-semibold text-white">Succes</h2>
            <span class="text-sm text-gray-400">{{ completedCount }}/{{ totalAchievements }}</span>
        </div>

        <div class="game-card-body">
            {% set category_labels = {
                'combat': 'Combat',
                'exploration': 'Exploration',
                'quests': 'Quetes',
                'gathering': 'Recolte',
                'craft': 'Artisanat',
                'secrets': 'Secrets'
            } %}

            {% set category_keys = categories|keys %}

            {# Tabs #}
            {% if category_keys|length > 1 %}
                <div class="flex border-b border-gray-700 mb-4 -mx-4 px-4 sm:mx-0 sm:px-0">
                    {% for key in category_keys %}
                        <button onclick="showAchievementTab('{{ key }}')" id="tab-{{ key }}"
                                class="px-4 py-2.5 text-sm font-medium border-b-2 {% if loop.first %}border-purple-500 text-purple-400{% else %}border-transparent text-gray-400 hover:text-gray-300{% endif %} touch-target">
                            {{ category_labels[key]|default(key|capitalize) }}
                        </button>
                    {% endfor %}
                </div>
            {% endif %}

            {# Panels #}
            {% for key, achievementList in categories %}
                <div id="panel-{{ key }}" class="{% if not loop.first %}hidden{% endif %}">
                    {% if achievementList is empty %}
                        <div class="text-center py-8">
                            <p class="text-gray-500 text-sm">Aucun succes dans cette categorie.</p>
                        </div>
                    {% else %}
                        <div class="space-y-2 sm:space-y-3">
                            {% for achievement in achievementList %}
                                {% set pa = playerAchievementMap[achievement.id]|default(null) %}
                                {% set isCompleted = pa and pa.completedAt is not null %}
                                {% set isHidden = achievement.hidden %}
                                {% set isDiscovered = pa is not null %}

                                {# Skip hidden achievements that haven't been discovered yet #}
                                {% if not isHidden or isDiscovered %}

                                {% set progress = pa ? pa.progress : 0 %}
                                {% set target = achievement.criteriaCount %}
                                {% set progressPercent = target > 0 ? ((progress / target) * 100)|round(0, 'floor') : 0 %}
                                {% if progressPercent > 100 %}{% set progressPercent = 100 %}{% endif %}

                                <div class="bg-gray-700/50 rounded-lg p-3 sm:p-4 border {% if isCompleted %}border-green-600/50{% elseif isHidden %}border-amber-600/50{% else %}border-gray-600{% endif %}">
                                    <div class="flex items-start justify-between gap-2 mb-1">
                                        <div class="min-w-0">
                                            <div class="flex items-center gap-2">
                                                {% if isHidden and not isCompleted %}
                                                    <h3 class="text-amber-300 font-semibold text-sm sm:text-base">???</h3>
                                                    <span class="text-amber-500 text-xs font-mono flex-shrink-0">Secret</span>
                                                {% else %}
                                                    <h3 class="text-white font-semibold text-sm sm:text-base {% if isCompleted %}text-green-300{% endif %}">
                                                        {{ achievement|localized_achievement_title }}
                                                    </h3>
                                                    {% if isCompleted %}
                                                        <span class="text-green-500 text-xs font-mono flex-shrink-0">Debloque</span>
                                                        {% if isHidden %}
                                                            <span class="text-amber-500 text-xs font-mono flex-shrink-0">Secret</span>
                                                        {% endif %}
                                                    {% endif %}
                                                {% endif %}
                                            </div>
                                            <p class="text-gray-400 text-xs sm:text-sm mt-0.5">
                                                {% if isHidden and not isCompleted %}
                                                    Ce succes est secret. Continuez a jouer pour le decouvrir...
                                                {% else %}
                                                    {{ achievement|localized_achievement_description }}
                                                {% endif %}
                                            </p>
                                        </div>
                                    </div>

                                    {# Progress bar #}
                                    {% if not isCompleted %}
                                        <div class="mt-2">
                                            <div class="flex justify-between text-[10px] sm:text-xs text-gray-400 mb-1">
                                                <span>Progression</span>
                                                {% if isHidden %}
                                                    <span>???</span>
                                                {% else %}
                                                    <span>{{ progress }}/{{ target }}</span>
                                                {% endif %}
                                            </div>
                                            <div class="progress-bar">
                                                <div class="progress-bar-fill {% if isHidden %}bg-amber-500{% else %}bg-purple-500{% endif %}"
                                                     style="width: {{ progressPercent }}%"></div>
                                            </div>
                                        </div>
                                    {% endif %}

                                    {# Reward #}
                                    {% set reward = achievement.reward %}
                                    {% if reward is not empty and (not isHidden or isCompleted) %}
                                        <div class="mt-2 pt-2 border-t border-gray-600">
                                            <span class="text-[10px] text-gray-500">Recompense :</span>
                                            <div class="flex gap-3 mt-0.5">
                                                {% if reward.gils is defined %}
                                                    <span class="text-yellow-400 text-xs">{{ reward.gils }} Gils</span>
                                                {% endif %}
                                                {% if reward.title is defined %}
                                                    <span class="text-purple-400 text-xs">Titre : {{ reward.title }}</span>
                                                {% endif %}
                                            </div>
                                        </div>
                                    {% endif %}
                                </div>

                                {% endif %}{# end if not hidden or discovered #}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </div>
</div>

<script>
function showAchievementTab(tab) {
    const keys = {{ categories|keys|json_encode|raw }};
    keys.forEach(function(key) {
        const panel = document.getElementById('panel-' + key);
        const tabBtn = document.getElementById('tab-' + key);
        if (panel) panel.classList.toggle('hidden', key !== tab);
        if (tabBtn) {
            tabBtn.className = key === tab
                ? 'px-4 py-2.5 text-sm font-medium border-b-2 border-purple-500 text-purple-400 touch-target'
                : 'px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-400 hover:text-gray-300 touch-target';
        }
    });
}
</script>
{% endblock %}

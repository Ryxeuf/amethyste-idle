{% extends 'base.html.twig' %}

{% block title %}{{ 'game.title'|trans }}{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h1 class="h3 mb-0">{{ 'game.welcome_message'|trans({'%email%': app.user.email}) }}</h1>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <p>{{ 'game.access_info'|trans }}</p>
                    </div>
                    
                    <div class="game-container mt-4 p-4 bg-light rounded">
                        <h2>{{ 'game.game_section.heading'|trans }}</h2>
                        <p>{{ 'game.game_section.description'|trans }}</p>
                        
                        <div class="game-controls mt-4">
                            <button class="btn btn-success me-2">{{ 'game.controls.start'|trans }}</button>
                            <button class="btn btn-warning me-2">{{ 'game.controls.pause'|trans }}</button>
                            <button class="btn btn-danger">{{ 'game.controls.stop'|trans }}</button>
                        </div>
                        
                        <div class="game-stats mt-4">
                            <h3>{{ 'game.statistics.heading'|trans }}</h3>
                            <ul class="list-group">
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    {{ 'game.statistics.score'|trans }}
                                    <span class="badge bg-primary rounded-pill">0</span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    {{ 'game.statistics.level'|trans }}
                                    <span class="badge bg-primary rounded-pill">1</span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    {{ 'game.statistics.game_time'|trans }}
                                    <span class="badge bg-primary rounded-pill">00:00</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <a href="{{ path('app_home') }}" class="btn btn-secondary">{{ 'game.footer.back_to_home'|trans }}</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Vous pouvez ajouter votre code JavaScript pour le jeu ici
    document.addEventListener('DOMContentLoaded', function() {
        console.log('Page de jeu chargée');
        
        // Exemple de minuteur simple
        let seconds = 0;
        const timerElement = document.querySelector('.game-stats .badge:last-child');
        
        setInterval(function() {
            seconds++;
            const minutes = Math.floor(seconds / 60);
            const remainingSeconds = seconds % 60;
            timerElement.textContent = `${minutes.toString().padStart(2, '0')}:${remainingSeconds.toString().padStart(2, '0')}`;
        }, 1000);
    });
</script>
{% endblock %} 
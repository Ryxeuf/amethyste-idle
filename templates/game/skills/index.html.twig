{% extends 'game/game.html.twig' %}

{% block title %}{{ "title.skills"|trans }}{% endblock %}

{% block game_content %}
    <div class="game-page">
        {# Page header #}
        <div class="mb-4 sm:mb-6 flex items-start justify-between">
            <div>
                <h1 class="text-xl sm:text-2xl font-bold text-white">{{ "title.skills"|trans }}</h1>
                <p class="text-gray-400 text-sm mt-0.5">{{ "game.skills.description"|trans }}</p>
            </div>
            {% if skillCount > 0 %}
                <button type="button"
                    onclick="document.getElementById('respec-modal').classList.remove('hidden')"
                    class="{% if canRespec %}bg-amber-600 hover:bg-amber-700{% else %}bg-gray-600 cursor-not-allowed{% endif %} text-white font-bold py-2 px-4 rounded text-sm transition-colors flex-shrink-0">
                    Redistribuer
                </button>
            {% endif %}
        </div>

        {# Respec confirmation modal #}
        {% if skillCount > 0 %}
            <div id="respec-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70" onclick="if(event.target===this)this.classList.add('hidden')">
                <div class="bg-gray-800 border border-gray-600 rounded-lg p-6 max-w-sm mx-4 shadow-xl">
                    <h3 class="text-lg font-bold text-white mb-3">Redistribuer les competences</h3>
                    <p class="text-gray-300 text-sm mb-2">
                        Toutes vos competences seront reinitialisees et les points d'experience restitues dans chaque domaine.
                    </p>
                    <div class="bg-gray-900 rounded p-3 mb-4 text-sm">
                        <div class="flex justify-between text-gray-400 mb-1">
                            <span>Competences a redistribuer</span>
                            <span class="text-white font-bold">{{ skillCount }}</span>
                        </div>
                        <div class="flex justify-between text-gray-400 mb-1">
                            <span>Cout</span>
                            <span class="text-amber-400 font-bold">{{ respecCost }} gils</span>
                        </div>
                        <div class="flex justify-between text-gray-400">
                            <span>Vos gils</span>
                            <span class="{% if canRespec %}text-green-400{% else %}text-red-400{% endif %} font-bold">{{ playerGils }} gils</span>
                        </div>
                    </div>
                    <div class="flex gap-3">
                        <button type="button"
                            onclick="document.getElementById('respec-modal').classList.add('hidden')"
                            class="flex-1 bg-gray-700 hover:bg-gray-600 text-white font-bold py-2 px-4 rounded text-sm transition-colors">
                            Annuler
                        </button>
                        {% if canRespec %}
                            <form action="{{ path('app_game_skill_respec') }}" method="post" class="flex-1">
                                <input type="hidden" name="_token" value="{{ csrf_token('respec') }}">
                                <button type="submit" class="w-full bg-amber-600 hover:bg-amber-700 text-white font-bold py-2 px-4 rounded text-sm transition-colors">
                                    Confirmer
                                </button>
                            </form>
                        {% else %}
                            <button type="button" disabled class="flex-1 bg-gray-600 text-gray-400 font-bold py-2 px-4 rounded text-sm cursor-not-allowed">
                                Fonds insuffisants
                            </button>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endif %}

        {# Global skill points limit #}
        <div class="mb-4 sm:mb-6 game-card p-4">
            <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-gray-300">Points de competence utilises</span>
                <span class="text-sm font-bold {% if totalUsedPoints >= maxTotalPoints %}text-red-400{% else %}text-white{% endif %}">
                    {{ totalUsedPoints }} / {{ maxTotalPoints }}
                </span>
            </div>
            <div class="w-full bg-gray-700 rounded-full h-2.5">
                {% set percentage = maxTotalPoints > 0 ? (totalUsedPoints / maxTotalPoints * 100) : 0 %}
                <div class="{% if percentage >= 100 %}bg-red-500{% elseif percentage >= 80 %}bg-amber-500{% else %}bg-purple-600{% endif %} h-2.5 rounded-full transition-all duration-300"
                     style="width: {{ percentage > 100 ? 100 : percentage }}%"></div>
            </div>
            {% if totalUsedPoints >= maxTotalPoints %}
                <p class="text-xs text-red-400 mt-1.5">Limite atteinte — redistribuez vos competences pour en apprendre de nouvelles.</p>
            {% elseif totalUsedPoints >= maxTotalPoints * 0.8 %}
                <p class="text-xs text-amber-400 mt-1.5">{{ maxTotalPoints - totalUsedPoints }} points restants avant la limite.</p>
            {% endif %}
        </div>

        {# Synergies cross-domaine #}
        {% if synergies is not empty %}
            <div class="mb-4 sm:mb-6 game-card overflow-hidden">
                <div class="bg-gradient-to-r from-purple-800 to-indigo-800 px-4 py-3 flex items-center justify-between">
                    <h2 class="text-base sm:text-lg font-bold text-white">Synergies cross-domaine</h2>
                    <span class="text-xs text-white/70">
                        {% set activeCount = synergies|filter(s => s.active)|length %}
                        {{ activeCount }}/{{ synergies|length }} actives
                    </span>
                </div>
                <div class="p-3 sm:p-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
                    {% for entry in synergies %}
                        {% set synergy = entry.synergy %}
                        <div class="rounded-lg border p-3 transition-all {{ entry.active ? 'border-purple-500/50 bg-purple-900/20' : 'border-gray-700 bg-gray-800/50 opacity-60' }}">
                            <div class="flex items-center justify-between mb-1.5">
                                <h3 class="text-sm font-semibold {{ entry.active ? 'text-purple-300' : 'text-gray-400' }}">{{ synergy.name }}</h3>
                                {% if entry.active %}
                                    <span class="text-xs bg-purple-600/50 text-purple-200 px-2 py-0.5 rounded-full">Active</span>
                                {% else %}
                                    <span class="text-xs bg-gray-700 text-gray-500 px-2 py-0.5 rounded-full">Inactive</span>
                                {% endif %}
                            </div>
                            <p class="text-xs text-gray-400 mb-2">{{ synergy.description }}</p>
                            <div class="flex items-center justify-between text-xs">
                                <span class="text-gray-500">
                                    {{ synergy.domainA.title }} + {{ synergy.domainB.title }}
                                </span>
                                <span class="{{ entry.active ? 'text-green-400' : 'text-gray-500' }} font-medium">
                                    +{{ synergy.bonusValue }} {{ synergy.bonusType }}
                                </span>
                            </div>
                            {% if not entry.active %}
                                <div class="mt-2 text-xs text-gray-600">
                                    {{ entry.xpA }}/{{ synergy.activationThreshold }} XP {{ synergy.domainA.title }}
                                    &middot;
                                    {{ entry.xpB }}/{{ synergy.activationThreshold }} XP {{ synergy.domainB.title }}
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {# Build Presets #}
        <div class="mb-4 sm:mb-6 game-card overflow-hidden">
            <div class="bg-gradient-to-r from-gray-700 to-gray-600 px-4 py-3 flex items-center justify-between">
                <h2 class="text-base sm:text-lg font-bold text-white">Presets de build</h2>
                <span class="text-xs text-white/70">{{ presets|length }}/{{ maxPresets }}</span>
            </div>
            <div class="p-3 sm:p-4">
                {# Save form #}
                {% if canSavePreset %}
                    <form action="{{ path('app_game_skill_preset_save') }}" method="post" class="flex gap-2 mb-3">
                        <input type="hidden" name="_token" value="{{ csrf_token('preset_save') }}">
                        <input type="text" name="preset_name" placeholder="Nom du preset..." maxlength="50" required
                            class="flex-1 bg-gray-800 border border-gray-600 rounded px-3 py-1.5 text-sm text-white placeholder-gray-500 focus:border-purple-500 focus:outline-none">
                        <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white font-bold py-1.5 px-4 rounded text-sm transition-colors flex-shrink-0">
                            Sauvegarder
                        </button>
                    </form>
                {% elseif skillCount > 0 %}
                    <p class="text-xs text-gray-500 mb-3">Limite de {{ maxPresets }} presets atteinte.</p>
                {% else %}
                    <p class="text-xs text-gray-500 mb-3">Apprenez des competences pour pouvoir sauvegarder un preset.</p>
                {% endif %}

                {# Preset list #}
                {% if presets|length > 0 %}
                    <div class="space-y-2">
                        {% for preset in presets %}
                            <div class="flex items-center justify-between bg-gray-800 rounded-lg p-3 border border-gray-700">
                                <div class="min-w-0 flex-1">
                                    <h3 class="text-sm font-semibold text-white truncate">{{ preset.name }}</h3>
                                    <p class="text-xs text-gray-400 mt-0.5">{{ preset.skillSlugs|length }} competence{{ preset.skillSlugs|length > 1 ? 's' : '' }}</p>
                                </div>
                                <div class="flex gap-2 flex-shrink-0 ml-3">
                                    <form action="{{ path('app_game_skill_preset_load', {id: preset.id}) }}" method="post">
                                        <input type="hidden" name="_token" value="{{ csrf_token('preset_load_' ~ preset.id) }}">
                                        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-1.5 px-3 rounded text-xs transition-colors"
                                            onclick="return confirm('Charger ce preset ? Vos competences actuelles seront redistribuees (cout en gils).')">
                                            Charger
                                        </button>
                                    </form>
                                    <form action="{{ path('app_game_skill_preset_delete', {id: preset.id}) }}" method="post">
                                        <input type="hidden" name="_token" value="{{ csrf_token('preset_delete_' ~ preset.id) }}">
                                        <button type="submit" class="bg-red-600/80 hover:bg-red-700 text-white font-bold py-1.5 px-3 rounded text-xs transition-colors"
                                            onclick="return confirm('Supprimer ce preset ?')">
                                            Supprimer
                                        </button>
                                    </form>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="text-xs text-gray-500 text-center py-2">Aucun preset sauvegarde.</p>
                {% endif %}
            </div>
        </div>

        {# Domain sections #}
        {% for domain in domains %}
            <div class="mb-4 sm:mb-6 game-card overflow-hidden">
                {# Domain header with color #}
                <div class="domain-header-{{ domain.slug }} px-4 py-3 flex items-center justify-between">
                    <h2 class="text-base sm:text-lg font-bold text-white">{{ domain.title }}</h2>
                    <div class="text-right">
                        <p class="text-xs text-white/80">
                            {{ "game.domains.experience.available"|trans }} : <span class="font-bold text-white">{{ domain.availableExperience }}</span>
                        </p>
                        <p class="text-xs text-white/70 hidden sm:block">
                            {{ "game.domains.experience.total"|trans }} : <span class="font-bold text-white">{{ domain.totalExperience }}</span>
                        </p>
                    </div>
                </div>

                {# Skills list — cards on mobile, table on desktop #}
                <div class="p-3 sm:p-4">
                    {# Mobile: card layout #}
                    <div class="lg:hidden space-y-2">
                        {% for skill in domain.skills %}
                            <div class="skill-card">
                                <div class="flex items-start justify-between gap-2 mb-1.5">
                                    <div class="min-w-0 flex-1">
                                        <h3 class="text-sm font-semibold text-white">{{ skill.title }}</h3>
                                        <p class="text-xs text-gray-400 mt-0.5">{{ skill.description }}</p>
                                    </div>
                                    <div class="flex-shrink-0">
                                        {% if not skill.acquired %}
                                            {% if skill.canBeAcquired %}
                                                <form action="{{ path('app_game_skill_acquire') }}" method="post">
                                                    <input type="hidden" name="skill_id" value="{{ skill.id }}">
                                                    <input type="hidden" name="domain_id" value="{{ domain.id }}">
                                                    <button type="submit" class="bg-purple-600 hover:bg-purple-700 active:bg-purple-800 text-white font-bold py-1.5 px-3 rounded text-xs touch-target transition-colors">
                                                        {{ "game.skills.learn"|trans }}
                                                    </button>
                                                </form>
                                            {% else %}
                                                <span class="bg-gray-700 text-gray-500 font-bold py-1.5 px-3 rounded text-xs cursor-not-allowed">
                                                    {{ "game.skills.learn"|trans }}
                                                </span>
                                            {% endif %}
                                        {% else %}
                                            <span class="bg-blue-600/80 text-white font-bold py-1.5 px-3 rounded text-xs">
                                                {{ "game.skills.learned"|trans }}
                                            </span>
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="flex items-center gap-3 text-xs">
                                    <span class="text-purple-400">{{ skill.requiredPoints }} pts</span>
                                    {% if skill.requirements|length > 0 %}
                                        <span class="text-gray-500">|</span>
                                        {% for requirement in skill.requirements %}
                                            <span class="{% if requirement.acquired %}text-green-400{% else %}text-red-400{% endif %}">
                                                {{ requirement.title }}
                                                {% if requirement.acquired %}&#10003;{% else %}&#10007;{% endif %}
                                            </span>
                                        {% endfor %}
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    {# Desktop: table layout #}
                    <div class="hidden lg:block overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-700">
                            <thead>
                                <tr>
                                    <th class="px-4 py-3 bg-gray-800 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">{{ "game.skills.title"|trans }}</th>
                                    <th class="px-4 py-3 bg-gray-800 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">{{ "game.skills.cost"|trans }}</th>
                                    <th class="px-4 py-3 bg-gray-800 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">{{ "game.skills.description"|trans }}</th>
                                    <th class="px-4 py-3 bg-gray-800 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">{{ "game.skills.requirements"|trans }}</th>
                                    <th class="px-4 py-3 bg-gray-800 text-right text-xs font-medium text-gray-300 uppercase tracking-wider"></th>
                                </tr>
                            </thead>
                            <tbody class="bg-gray-900 divide-y divide-gray-800">
                                {% for skill in domain.skills %}
                                    <tr>
                                        <td class="px-4 py-3 whitespace-nowrap text-sm font-medium text-white">{{ skill.title }}</td>
                                        <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-300">{{ skill.requiredPoints }}</td>
                                        <td class="px-4 py-3 text-sm text-gray-300">{{ skill.description }}</td>
                                        <td class="px-4 py-3 text-sm text-gray-300">
                                            {% for requirement in skill.requirements %}
                                                <span class="{% if requirement.acquired %}text-green-400{% else %}text-red-400{% endif %}">
                                                    {{ requirement.title }}
                                                    {% if requirement.acquired %}&#10003;{% else %}&#10007;{% endif %}
                                                </span>
                                                {% if not loop.last %}<br>{% endif %}
                                            {% endfor %}
                                        </td>
                                        <td class="px-4 py-3 whitespace-nowrap text-right text-sm font-medium">
                                            {% if not skill.acquired %}
                                                {% if skill.canBeAcquired %}
                                                    <form action="{{ path('app_game_skill_acquire') }}" method="post" class="inline">
                                                        <input type="hidden" name="skill_id" value="{{ skill.id }}">
                                                        <input type="hidden" name="domain_id" value="{{ domain.id }}">
                                                        <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white font-bold py-2 px-4 rounded text-xs transition-colors">
                                                            {{ "game.skills.learn"|trans }}
                                                        </button>
                                                    </form>
                                                {% else %}
                                                    <span class="bg-red-600 text-white font-bold py-2 px-4 rounded text-xs opacity-75 cursor-not-allowed">
                                                        {{ "game.skills.learn"|trans }}
                                                    </span>
                                                {% endif %}
                                            {% else %}
                                                <span class="bg-blue-600 text-white font-bold py-2 px-4 rounded text-xs">
                                                    {{ "game.skills.learned"|trans }}
                                                </span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Feu */
        .domain-header-pyromancien { background-color: #e02424; }
        .domain-header-berserker { background-color: #dc6b09; }
        .domain-header-artificier { background-color: #c44d00; }
        /* Eau */
        .domain-header-hydromancien { background-color: #0066ff; }
        .domain-header-guérisseur { background-color: #0099cc; }
        .domain-header-marémancien { background-color: #00ccee; color: #1f2937; }
        /* Air */
        .domain-header-foudromancien { background-color: #6b5fbf; }
        .domain-header-archer { background-color: #8a7fd4; }
        .domain-header-vagabond { background-color: #a89ed9; color: #1f2937; }
        /* Terre */
        .domain-header-géomancien { background-color: #5a7a3a; }
        .domain-header-défenseur { background-color: #387483; }
        .domain-header-gardien { background-color: #6b5a3a; }
        /* Metal */
        .domain-header-soldat { background-color: #777777; }
        .domain-header-chevalier { background-color: #555555; }
        .domain-header-ingénieur { background-color: #999999; color: #1f2937; }
        /* Bete */
        .domain-header-chasseur { background-color: #009007; }
        .domain-header-dompteur { background-color: #2d8040; }
        .domain-header-druide { background-color: #58ae5e; }
        /* Lumiere */
        .domain-header-paladin { background-color: #d4a017; color: #1f2937; }
        .domain-header-prêtre { background-color: #e8c547; color: #1f2937; }
        .domain-header-inquisiteur { background-color: #f0d77a; color: #1f2937; }
        /* Ombre */
        .domain-header-assassin { background-color: #480040; }
        .domain-header-nécromancien { background-color: #2d0033; }
        .domain-header-sorcier { background-color: #3a0050; }
        /* Recolte */
        .domain-header-mineur { background-color: #6b6b6b; }
        .domain-header-herboriste { background-color: #58ae5e; }
        .domain-header-pêcheur { background-color: #0037ff; }
        .domain-header-dépeceur { background-color: #bc6500; }
        /* Craft */
        .domain-header-forgeron { background-color: #333333; }
        .domain-header-tanneur { background-color: #8b6914; }
        .domain-header-alchimiste { background-color: #1a1a2e; }
        .domain-header-joaillier { background-color: #ba53a2; }
    </style>
{% endblock %}

{% extends 'game/game.html.twig' %}

{% block title %}{{ "title.skills"|trans }}{% endblock %}

{% block game_content %}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 {% if label == 'success' %}bg-green-100 border-l-4 border-green-500 text-green-700{% else %}bg-red-100 border-l-4 border-red-500 text-red-700{% endif %} p-4 rounded">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            {% if label == 'success' %}
                                <svg class="h-5 w-5 text-green-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                </svg>
                            {% else %}
                                <svg class="h-5 w-5 text-red-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                                </svg>
                            {% endif %}
                        </div>
                        <div class="ml-3">
                            <p class="text-sm">{{ message }}</p>
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endfor %}
        
        <div class="bg-gray-800 shadow-lg rounded-lg overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-700">
                <h1 class="text-2xl font-bold text-white">{{ "title.skills"|trans }}</h1>
                <p class="text-gray-400 mt-1">{{ "game.skills.description"|trans }}</p>
            </div>
            
            <div class="p-6">
                {% for domain in domains %}
                    <div class="mb-8 bg-gray-900 rounded-lg overflow-hidden shadow-md">
                        <div class="px-6 py-4 domain-header-{{ domain.slug }} flex justify-between items-center">
                            <h2 class="text-xl font-bold text-white">{{ domain.title }}</h2>
                            <div class="text-right">
                                <p class="text-sm text-gray-300">{{ "game.domains.experience.available"|trans }} : <span class="font-bold text-white">{{ domain.availableExperience }}</span></p>
                                <p class="text-sm text-gray-300">{{ "game.domains.experience.total"|trans }} : <span class="font-bold text-white">{{ domain.totalExperience }}</span></p>
                            </div>
                        </div>
                        
                        <div class="px-6 py-4">
                            <div class="grid grid-cols-1 gap-4">
                                <div id="skill-description-{{ domain.id }}" class="mb-4"></div>
                                
                                <div class="overflow-x-auto">
                                    <table class="min-w-full divide-y divide-gray-700">
                                        <thead>
                                            <tr>
                                                <th class="px-6 py-3 bg-gray-800 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">{{ "game.skills.title"|trans }}</th>
                                                <th class="px-6 py-3 bg-gray-800 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">{{ "game.skills.cost"|trans }}</th>
                                                <th class="px-6 py-3 bg-gray-800 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">{{ "game.skills.description"|trans }}</th>
                                                <th class="px-6 py-3 bg-gray-800 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">{{ "game.skills.requirements"|trans }}</th>
                                                <th class="px-6 py-3 bg-gray-800 text-right text-xs font-medium text-gray-300 uppercase tracking-wider"></th>
                                            </tr>
                                        </thead>
                                        <tbody class="bg-gray-900 divide-y divide-gray-800">
                                            {% for skill in domain.skills %}
                                                <tr>
                                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-white">{{ skill.title }}</td>
                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300">{{ skill.requiredPoints }}</td>
                                                    <td class="px-6 py-4 text-sm text-gray-300">{{ skill.description }}</td>
                                                    <td class="px-6 py-4 text-sm text-gray-300">
                                                        {% set requirements = [] %}
                                                        {% for requirement in skill.requirements %}
                                                            {% set requirements = requirements|merge([(requirement.title ~ ((requirement.acquired ? '&nbsp;<span class="text-green-500"><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg></span>' : '&nbsp;<span class="text-red-500"><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg></span>')|raw))]) %}
                                                        {% endfor %}
                                                        {{ requirements|join('<br>')|raw }}
                                                    </td>
                                                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                                        {% if not skill.acquired %}
                                                            {% if skill.canBeAcquired %}
                                                                <form action="{{ path('app_game_skill_acquire') }}" method="post" class="inline">
                                                                    <input type="hidden" name="skill_id" value="{{ skill.id }}">
                                                                    <input type="hidden" name="domain_id" value="{{ domain.id }}">
                                                                    <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white font-bold py-2 px-4 rounded text-xs">
                                                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline mr-1" viewBox="0 0 20 20" fill="currentColor">
                                                                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                                                        </svg>
                                                                        {{ "game.skills.learn"|trans }}
                                                                    </button>
                                                                </form>
                                                            {% else %}
                                                                <span class="bg-red-600 text-white font-bold py-2 px-4 rounded text-xs opacity-75 cursor-not-allowed">
                                                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline mr-1" viewBox="0 0 20 20" fill="currentColor">
                                                                        <path fill-rule="evenodd" d="M13.477 14.89A6 6 0 015.11 6.524l8.367 8.368zm1.414-1.414L6.524 5.11a6 6 0 018.367 8.367zM18 10a8 8 0 11-16 0 8 8 0 0116 0z" clip-rule="evenodd" />
                                                                    </svg>
                                                                    {{ "game.skills.learn"|trans }}
                                                                </span>
                                                            {% endif %}
                                                        {% else %}
                                                            <span class="bg-blue-600 text-white font-bold py-2 px-4 rounded text-xs">
                                                                {{ "game.skills.learned"|trans }}
                                                            </span>
                                                        {% endif %}
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Styles spécifiques pour la page des compétences */
        .domain-header-pyromancie {
            background-color: #e02424; /* red-600 */
        }
        .domain-header-soldat {
            background-color: #777777; /* grey-600 */
        }
        .domain-header-blacksmith {
            background-color: #333333; /* black */
        }
        .domain-header-necro {
            background-color: #480040; /* dark purple */
        }
        .domain-header-white_wizard {
            background-color: #ecf6b1; /* yellow */
        }
        .domain-header-druid {
            background-color: #009007; /* green */
        }
        .domain-header-herbalist {
            background-color: #58ae5e; /* green */
        }
        .domain-header-skinner {
            background-color: #bc6500; /* orange */
        }
        .domain-header-jeweller {
            background-color: #ba53a2; /* pink */
        }
        .domain-header-alchimist {
            background-color: #000000; /* black */
        }
        .domain-header-leatherworker {
            background-color: #ffcc00; /* yellow */
        }
        .domain-header-miner {
            background-color: #6b6b6b; /* grey */
        }
        .domain-header-fisherman {
            background-color: #0037ff; /* blue */
        }
        .domain-header-healer {
            background-color: #00ffea; /* cyan */
        }
        .domain-header-defender {
            background-color: #387483; /* blue */
        }
        
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // JavaScript pour la page des compétences
        });
    </script>
{% endblock %} 
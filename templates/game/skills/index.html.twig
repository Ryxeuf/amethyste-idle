{% extends 'game/game.html.twig' %}

{% block title %}{{ "title.skills"|trans }}{% endblock %}

{% block game_content %}

{# ─── Default active domain : premier avec une compétence disponible, sinon premier ─── #}
{% set activeDomainId = 0 %}
{% for domain in domains %}
    {% if activeDomainId == 0 %}
        {% for skill in domain.skills %}
            {% if skill.canBeAcquired and not skill.acquired and activeDomainId == 0 %}
                {% set activeDomainId = domain.id %}
            {% endif %}
        {% endfor %}
    {% endif %}
{% endfor %}
{% if activeDomainId == 0 and domains|length > 0 %}
    {% set activeDomainId = domains[0].id %}
{% endif %}

{# ─── Configuration des éléments ─── #}
{% set elementConfig = {
    'fire':  {label: 'Feu',     dot: 'bg-red-500',     text: 'text-red-400',     border: 'border-red-500/40'},
    'water': {label: 'Eau',     dot: 'bg-blue-500',    text: 'text-blue-400',    border: 'border-blue-500/40'},
    'air':   {label: 'Air',     dot: 'bg-purple-400',  text: 'text-purple-300',  border: 'border-purple-400/40'},
    'earth': {label: 'Terre',   dot: 'bg-green-600',   text: 'text-green-400',   border: 'border-green-500/40'},
    'metal': {label: 'Métal',   dot: 'bg-gray-400',    text: 'text-gray-300',    border: 'border-gray-400/40'},
    'beast': {label: 'Bête',    dot: 'bg-emerald-500', text: 'text-emerald-400', border: 'border-emerald-500/40'},
    'light': {label: 'Lumière', dot: 'bg-yellow-400',  text: 'text-yellow-300',  border: 'border-yellow-400/40'},
    'dark':  {label: 'Ombre',   dot: 'bg-indigo-600',  text: 'text-indigo-300',  border: 'border-indigo-500/40'},
} %}
{% set elementOrder = ['fire', 'water', 'air', 'earth', 'metal', 'beast', 'light', 'dark'] %}

<div class="game-page"
     data-controller="skills"
     data-skills-active-domain-value="{{ activeDomainId }}">

    {# ═══════════════════════════════════════════
       MODAL RESPEC
    ═══════════════════════════════════════════ #}
    {% if skillCount > 0 %}
        <div data-skills-target="respecModal"
             class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70"
             data-action="click->skills#closeRespecOnBackdrop">
            <div class="bg-gray-800 border border-gray-600 rounded-xl p-6 max-w-sm mx-4 shadow-2xl">
                <h3 class="text-lg font-bold text-white mb-3">Redistribuer les compétences</h3>
                <p class="text-gray-300 text-sm mb-3">
                    Toutes vos compétences seront réinitialisées et les points d'expérience restitués dans chaque domaine.
                </p>
                <div class="bg-gray-900 rounded-lg p-3 mb-4 text-sm space-y-1.5">
                    <div class="flex justify-between text-gray-400">
                        <span>Compétences à redistribuer</span>
                        <span class="text-white font-bold">{{ skillCount }}</span>
                    </div>
                    <div class="flex justify-between text-gray-400">
                        <span>Coût</span>
                        <span class="text-amber-400 font-bold">{{ respecCost }} gils</span>
                    </div>
                    <div class="flex justify-between text-gray-400">
                        <span>Vos gils</span>
                        <span class="{{ canRespec ? 'text-green-400' : 'text-red-400' }} font-bold">{{ playerGils }} gils</span>
                    </div>
                </div>
                <div class="flex gap-3">
                    <button type="button"
                            data-action="click->skills#closeRespec"
                            class="flex-1 bg-gray-700 hover:bg-gray-600 text-white font-bold py-2 px-4 rounded-lg text-sm transition-colors">
                        Annuler
                    </button>
                    {% if canRespec %}
                        <form action="{{ path('app_game_skill_respec') }}" method="post" class="flex-1">
                            <input type="hidden" name="_token" value="{{ csrf_token('respec') }}">
                            <button type="submit"
                                    class="w-full bg-amber-600 hover:bg-amber-700 text-white font-bold py-2 px-4 rounded-lg text-sm transition-colors">
                                Confirmer
                            </button>
                        </form>
                    {% else %}
                        <button type="button" disabled
                                class="flex-1 bg-gray-600 text-gray-400 font-bold py-2 px-4 rounded-lg text-sm cursor-not-allowed">
                            Fonds insuffisants
                        </button>
                    {% endif %}
                </div>
            </div>
        </div>
    {% endif %}

    {# ═══════════════════════════════════════════
       HEADER : Titre + barre de points + Respec
    ═══════════════════════════════════════════ #}
    <div class="mb-4">
        <div class="flex items-start justify-between mb-2">
            <div>
                <h1 class="text-xl sm:text-2xl font-bold text-white">{{ "title.skills"|trans }}</h1>
                <p class="text-gray-400 text-sm mt-0.5">{{ "game.skills.description"|trans }}</p>
            </div>
            {% if skillCount > 0 %}
                <button type="button"
                        data-action="click->skills#openRespec"
                        class="{{ canRespec ? 'bg-amber-600 hover:bg-amber-700' : 'bg-gray-600 cursor-not-allowed' }} text-white font-bold py-2 px-4 rounded-lg text-sm transition-colors flex-shrink-0 ml-4">
                    Redistribuer
                </button>
            {% endif %}
        </div>
        <div class="flex items-center gap-3">
            <span class="text-xs text-gray-500 flex-shrink-0">Points</span>
            <div class="flex-1 bg-gray-700/60 rounded-full h-1.5">
                {% set pct = maxTotalPoints > 0 ? (totalUsedPoints / maxTotalPoints * 100) : 0 %}
                <div class="{{ pct >= 100 ? 'bg-red-500' : (pct >= 80 ? 'bg-amber-500' : 'bg-purple-600') }} h-1.5 rounded-full transition-all duration-300"
                     style="width: {{ pct > 100 ? 100 : pct }}%"></div>
            </div>
            <span class="text-xs font-bold {{ totalUsedPoints >= maxTotalPoints ? 'text-red-400' : 'text-gray-300' }} flex-shrink-0">
                {{ totalUsedPoints }}/{{ maxTotalPoints }}
            </span>
        </div>
    </div>

    {# ═══════════════════════════════════════════
       RÉSUMÉ DU BUILD ACTIF
    ═══════════════════════════════════════════ #}
    <div class="mb-4 rounded-xl border border-purple-500/20 bg-purple-900/15 px-4 py-2.5">
        <div class="flex items-center gap-3 flex-wrap">
            <span class="text-xs font-semibold text-purple-400 uppercase tracking-wider flex-shrink-0">Build actif</span>
            {% if buildStats.count == 0 %}
                <span class="text-xs text-gray-600 italic">Aucune compétence apprise.</span>
            {% else %}
                <span class="text-xs text-gray-500">{{ buildStats.count }} compétence{{ buildStats.count > 1 ? 's' : '' }}</span>
                <div class="flex items-center gap-1.5 flex-wrap">
                    {% if buildStats.damage > 0 %}
                        <span class="stat-badge stat-badge-damage">⚔ +{{ buildStats.damage }} dég.</span>
                    {% endif %}
                    {% if buildStats.heal > 0 %}
                        <span class="stat-badge stat-badge-heal">✦ +{{ buildStats.heal }} soin</span>
                    {% endif %}
                    {% if buildStats.hit > 0 %}
                        <span class="stat-badge stat-badge-hit">🎯 +{{ buildStats.hit }} préc.</span>
                    {% endif %}
                    {% if buildStats.critical > 0 %}
                        <span class="stat-badge stat-badge-critical">💥 +{{ buildStats.critical }} crit.</span>
                    {% endif %}
                    {% if buildStats.life > 0 %}
                        <span class="stat-badge stat-badge-life">❤ +{{ buildStats.life }} vie</span>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>

    {# ═══════════════════════════════════════════
       PRESETS (collapsible)
    ═══════════════════════════════════════════ #}
    <div class="mb-4 game-card overflow-hidden">
        <button type="button"
                data-action="click->skills#togglePresets"
                class="w-full bg-gradient-to-r from-gray-700 to-gray-600 px-4 py-2.5 flex items-center justify-between hover:from-gray-600 hover:to-gray-500 transition-colors">
            <span class="text-sm font-semibold text-white">Presets de build</span>
            <span class="text-xs text-white/50">{{ presets|length }}/{{ maxPresets }} ▾</span>
        </button>
        <div data-skills-target="presetsPanel" class="hidden p-3 sm:p-4">
            {% if canSavePreset %}
                <form action="{{ path('app_game_skill_preset_save') }}" method="post" class="flex gap-2 mb-3">
                    <input type="hidden" name="_token" value="{{ csrf_token('preset_save') }}">
                    <input type="text" name="preset_name" placeholder="Nom du preset..." maxlength="50" required
                           class="flex-1 bg-gray-800 border border-gray-600 rounded-lg px-3 py-1.5 text-sm text-white placeholder-gray-500 focus:border-purple-500 focus:outline-none">
                    <button type="submit"
                            class="bg-purple-600 hover:bg-purple-700 text-white font-bold py-1.5 px-4 rounded-lg text-sm transition-colors flex-shrink-0">
                        Sauvegarder
                    </button>
                </form>
            {% elseif skillCount > 0 %}
                <p class="text-xs text-gray-500 mb-3">Limite de {{ maxPresets }} presets atteinte.</p>
            {% else %}
                <p class="text-xs text-gray-500 mb-3">Apprenez des compétences pour sauvegarder un preset.</p>
            {% endif %}
            {% if presets|length > 0 %}
                <div class="space-y-2">
                    {% for preset in presets %}
                        <div class="flex items-center justify-between bg-gray-800/60 rounded-lg p-3 border border-gray-700">
                            <div class="min-w-0 flex-1">
                                <span class="text-sm font-semibold text-white truncate block">{{ preset.name }}</span>
                                <span class="text-xs text-gray-500">{{ preset.skillSlugs|length }} compétence{{ preset.skillSlugs|length > 1 ? 's' : '' }}</span>
                            </div>
                            <div class="flex gap-2 flex-shrink-0 ml-3">
                                <form action="{{ path('app_game_skill_preset_load', {id: preset.id}) }}" method="post">
                                    <input type="hidden" name="_token" value="{{ csrf_token('preset_load_' ~ preset.id) }}">
                                    <button type="submit"
                                            class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-1.5 px-3 rounded-lg text-xs transition-colors"
                                            onclick="return confirm('Charger ce preset ? Vos compétences actuelles seront redistribuées (coût en gils).')">
                                        Charger
                                    </button>
                                </form>
                                <form action="{{ path('app_game_skill_preset_delete', {id: preset.id}) }}" method="post">
                                    <input type="hidden" name="_token" value="{{ csrf_token('preset_delete_' ~ preset.id) }}">
                                    <button type="submit"
                                            class="bg-red-600/80 hover:bg-red-700 text-white font-bold py-1.5 px-3 rounded-lg text-xs transition-colors"
                                            onclick="return confirm('Supprimer ce preset ?')">
                                        Supprimer
                                    </button>
                                </form>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-xs text-gray-500 text-center py-1">Aucun preset sauvegardé.</p>
            {% endif %}
        </div>
    </div>

    {# ═══════════════════════════════════════════
       MAIN : SIDEBAR + DOMAIN PANELS
    ═══════════════════════════════════════════ #}
    {% if domains|length == 0 %}
        <div class="game-card p-8 text-center">
            <p class="text-gray-400 text-sm">Vous n'avez pas encore progressé dans un domaine.</p>
            <p class="text-gray-500 text-xs mt-1">Combattez des ennemis et récoltez des ressources pour débloquer des domaines.</p>
        </div>
    {% else %}
        <div class="flex gap-4 lg:gap-5 items-start">

            {# ────────── SIDEBAR ────────── #}
            <aside class="skills-sidebar">

                {# Mobile : chips horizontales scrollables #}
                <div class="lg:hidden overflow-x-auto pb-2 -mx-0.5 px-0.5 mb-4">
                    <div class="flex gap-2 w-max">
                        {% for domain in domains %}
                            {% set availCount = domain.skills|filter(s => s.canBeAcquired and not s.acquired)|length %}
                            <button type="button"
                                    data-skills-target="domainBtn"
                                    data-action="click->skills#selectDomain"
                                    data-domain-id="{{ domain.id }}"
                                    aria-selected="{{ domain.id == activeDomainId ? 'true' : 'false' }}"
                                    class="skills-domain-btn skills-domain-chip flex-shrink-0 flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-gray-600 text-sm text-gray-300 whitespace-nowrap">
                                {% if domain.element and elementConfig[domain.element] is defined %}
                                    <span class="w-2 h-2 rounded-full flex-shrink-0 {{ elementConfig[domain.element].dot }}"></span>
                                {% endif %}
                                <span>{{ domain.title }}</span>
                                {% if availCount > 0 %}
                                    <span class="bg-purple-600 text-white text-xs font-bold px-1.5 py-0.5 rounded-full leading-none">{{ availCount }}</span>
                                {% endif %}
                            </button>
                        {% endfor %}
                    </div>
                </div>

                {# Desktop : sidebar groupée par élément #}
                <div class="hidden lg:block w-52 flex-shrink-0 sticky top-4 space-y-3">
                    {% for element in elementOrder %}
                        {% set groupDomains = domains|filter(d => d.element == element) %}
                        {% if groupDomains|length > 0 %}
                            {% set cfg = elementConfig[element] %}
                            <div>
                                <div class="flex items-center gap-1.5 px-2 pb-1 mb-0.5">
                                    <span class="w-1.5 h-1.5 rounded-full {{ cfg.dot }}"></span>
                                    <span class="text-xs font-semibold uppercase tracking-wider {{ cfg.text }}">{{ cfg.label }}</span>
                                </div>
                                {% for domain in groupDomains %}
                                    {% set availCount   = domain.skills|filter(s => s.canBeAcquired and not s.acquired)|length %}
                                    {% set acquiredCount = domain.skills|filter(s => s.acquired)|length %}
                                    <button type="button"
                                            data-skills-target="domainBtn"
                                            data-action="click->skills#selectDomain"
                                            data-domain-id="{{ domain.id }}"
                                            aria-selected="{{ domain.id == activeDomainId ? 'true' : 'false' }}"
                                            class="skills-domain-btn w-full text-left mb-0.5">
                                        <div class="flex items-center justify-between gap-1">
                                            <span class="text-sm font-medium text-gray-200 truncate">{{ domain.title }}</span>
                                            {% if availCount > 0 %}
                                                <span class="bg-purple-600 text-white text-xs font-bold px-1.5 py-0.5 rounded-full leading-none flex-shrink-0">{{ availCount }}</span>
                                            {% elseif acquiredCount > 0 %}
                                                <span class="text-green-600 text-xs font-semibold flex-shrink-0">✓{{ acquiredCount }}</span>
                                            {% endif %}
                                        </div>
                                        {% if domain.totalExperience is defined and domain.totalExperience > 0 %}
                                            <div class="mt-1 w-full bg-gray-700/60 rounded-full h-0.5">
                                                {% set xpPct = domain.totalExperience > 0 ? (domain.availableExperience / domain.totalExperience * 100) : 0 %}
                                                <div class="h-0.5 rounded-full {{ cfg.dot }} opacity-70 transition-all duration-500"
                                                     style="width: {{ xpPct > 100 ? 100 : xpPct }}%"></div>
                                            </div>
                                            <div class="text-xs text-gray-600 mt-0.5">{{ domain.availableExperience }} XP dispo</div>
                                        {% endif %}
                                    </button>
                                {% endfor %}
                            </div>
                        {% endif %}
                    {% endfor %}

                    {# Domaines hors éléments classifiés #}
                    {% set ungrouped = domains|filter(d => d.element is null or d.element not in elementOrder) %}
                    {% if ungrouped|length > 0 %}
                        <div>
                            <div class="flex items-center gap-1.5 px-2 pb-1 mb-0.5">
                                <span class="text-xs font-semibold uppercase tracking-wider text-gray-600">Autres</span>
                            </div>
                            {% for domain in ungrouped %}
                                {% set availCount = domain.skills|filter(s => s.canBeAcquired and not s.acquired)|length %}
                                <button type="button"
                                        data-skills-target="domainBtn"
                                        data-action="click->skills#selectDomain"
                                        data-domain-id="{{ domain.id }}"
                                        aria-selected="{{ domain.id == activeDomainId ? 'true' : 'false' }}"
                                        class="skills-domain-btn w-full text-left mb-0.5">
                                    <div class="flex items-center justify-between gap-1">
                                        <span class="text-sm font-medium text-gray-200 truncate">{{ domain.title }}</span>
                                        {% if availCount > 0 %}
                                            <span class="bg-purple-600 text-white text-xs font-bold px-1.5 py-0.5 rounded-full leading-none flex-shrink-0">{{ availCount }}</span>
                                        {% endif %}
                                    </div>
                                </button>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

            </aside>{# end sidebar #}

            {# ────────── DOMAIN PANELS ────────── #}
            <div class="flex-1 min-w-0">
                {% for domain in domains %}
                    <div data-skills-target="domainPanel"
                         data-domain-id="{{ domain.id }}"
                         class="{{ domain.id != activeDomainId ? 'hidden' : '' }}">

                        {# En-tête du domaine #}
                        <div class="domain-header-{{ domain.slug }} rounded-xl px-4 py-3 mb-4 flex items-center justify-between flex-wrap gap-2">
                            <div class="flex items-center gap-2.5">
                                <h2 class="text-base sm:text-lg font-bold text-white">{{ domain.title }}</h2>
                                {% if domain.element and elementConfig[domain.element] is defined %}
                                    <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-black/25 text-white/90">
                                        {{ elementConfig[domain.element].label }}
                                    </span>
                                {% endif %}
                            </div>
                            <div class="flex items-center gap-3 flex-wrap">
                                {% if domain.totalExperience is defined and domain.totalExperience > 0 %}
                                    <span class="text-xs text-white/80">
                                        XP dispo : <strong class="text-white">{{ domain.availableExperience }}</strong>
                                    </span>
                                    <span class="text-xs text-white/50 hidden sm:inline">
                                        Total : <strong class="text-white/70">{{ domain.totalExperience }}</strong>
                                    </span>
                                {% endif %}
                                {% if domain.damage is defined and domain.damage > 0 %}
                                    <span class="text-xs text-white/70">⚔ +{{ domain.damage }}</span>
                                {% endif %}
                                {% if domain.hit is defined and domain.hit > 0 %}
                                    <span class="text-xs text-white/70">🎯 +{{ domain.hit }}</span>
                                {% endif %}
                                {% if domain.critical is defined and domain.critical > 0 %}
                                    <span class="text-xs text-white/70">💥 +{{ domain.critical }}</span>
                                {% endif %}
                            </div>
                        </div>

                        {% set skillsAvailable = domain.skills|filter(s => s.canBeAcquired and not s.acquired) %}
                        {% set skillsAcquired  = domain.skills|filter(s => s.acquired) %}
                        {% set skillsLocked    = domain.skills|filter(s => not s.canBeAcquired and not s.acquired) %}

                        {# ── Section Disponibles ── #}
                        <div class="mb-5">
                            <h3 class="text-xs font-semibold uppercase tracking-wider text-purple-400 mb-2 px-0.5">
                                Disponibles
                                <span class="text-purple-700 ml-1">{{ skillsAvailable|length }}</span>
                            </h3>
                            {% if skillsAvailable|length == 0 %}
                                <p class="text-xs text-gray-600 italic px-0.5">Aucune compétence disponible pour l'instant.</p>
                            {% else %}
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                                    {% for skill in skillsAvailable %}
                                        <div class="skill-node skill-node--available rounded-xl p-3 border">
                                            <div class="flex items-start justify-between gap-2">
                                                <div class="min-w-0 flex-1">
                                                    <h4 class="text-sm font-semibold text-white">{{ skill.title }}</h4>
                                                    <p class="text-xs text-gray-400 mt-0.5 leading-relaxed">{{ skill.description }}</p>
                                                    <div class="flex flex-wrap gap-1 mt-2">
                                                        <span class="text-xs text-purple-300 font-semibold">{{ skill.requiredPoints }} pts XP</span>
                                                        {% for req in skill.requirements %}
                                                            <span class="text-xs px-1.5 py-0.5 rounded-full {{ req.acquired ? 'bg-green-900/50 text-green-400' : 'bg-red-900/50 text-red-400' }}">
                                                                {{ req.title }} {{ req.acquired ? '✓' : '✗' }}
                                                            </span>
                                                        {% endfor %}
                                                        {% if skill.damage > 0 %}<span class="stat-badge stat-badge-damage">+{{ skill.damage }} dég.</span>{% endif %}
                                                        {% if skill.heal > 0 %}<span class="stat-badge stat-badge-heal">+{{ skill.heal }} soin</span>{% endif %}
                                                        {% if skill.hit > 0 %}<span class="stat-badge stat-badge-hit">+{{ skill.hit }} préc.</span>{% endif %}
                                                        {% if skill.critical > 0 %}<span class="stat-badge stat-badge-critical">+{{ skill.critical }} crit.</span>{% endif %}
                                                        {% if skill.life > 0 %}<span class="stat-badge stat-badge-life">+{{ skill.life }} vie</span>{% endif %}
                                                    </div>
                                                </div>
                                                <form action="{{ path('app_game_skill_acquire') }}" method="post" class="flex-shrink-0">
                                                    <input type="hidden" name="skill_id" value="{{ skill.id }}">
                                                    <input type="hidden" name="domain_id" value="{{ domain.id }}">
                                                    <button type="submit"
                                                            class="bg-purple-600 hover:bg-purple-700 active:bg-purple-800 text-white font-bold py-1.5 px-3 rounded-lg text-xs transition-colors touch-target whitespace-nowrap">
                                                        {{ "game.skills.learn"|trans }}
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        {# ── Section Acquises ── #}
                        {% if skillsAcquired|length > 0 %}
                            <div class="mb-5">
                                <h3 class="text-xs font-semibold uppercase tracking-wider text-green-600 mb-2 px-0.5">
                                    Acquises
                                    <span class="text-green-800 ml-1">{{ skillsAcquired|length }}</span>
                                </h3>
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                                    {% for skill in skillsAcquired %}
                                        <div class="skill-node skill-node--acquired rounded-xl p-3 border">
                                            <div class="flex items-start justify-between gap-2">
                                                <div class="min-w-0 flex-1">
                                                    <div class="flex items-center gap-1.5">
                                                        <span class="text-green-500 text-xs leading-none">✓</span>
                                                        <h4 class="text-sm font-semibold text-gray-200">{{ skill.title }}</h4>
                                                    </div>
                                                    <p class="text-xs text-gray-500 mt-0.5 leading-relaxed">{{ skill.description }}</p>
                                                    {% set hasStats = skill.damage > 0 or skill.heal > 0 or skill.hit > 0 or skill.critical > 0 or skill.life > 0 %}
                                                    {% if hasStats %}
                                                        <div class="flex flex-wrap gap-1 mt-1.5">
                                                            {% if skill.damage > 0 %}<span class="stat-badge stat-badge-damage">+{{ skill.damage }} dég.</span>{% endif %}
                                                            {% if skill.heal > 0 %}<span class="stat-badge stat-badge-heal">+{{ skill.heal }} soin</span>{% endif %}
                                                            {% if skill.hit > 0 %}<span class="stat-badge stat-badge-hit">+{{ skill.hit }} préc.</span>{% endif %}
                                                            {% if skill.critical > 0 %}<span class="stat-badge stat-badge-critical">+{{ skill.critical }} crit.</span>{% endif %}
                                                            {% if skill.life > 0 %}<span class="stat-badge stat-badge-life">+{{ skill.life }} vie</span>{% endif %}
                                                        </div>
                                                    {% endif %}
                                                </div>
                                                <span class="bg-green-800/40 text-green-400 font-semibold py-1.5 px-3 rounded-lg text-xs flex-shrink-0">
                                                    {{ "game.skills.learned"|trans }}
                                                </span>
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}

                        {# ── Section Verrouillées ── #}
                        {% if skillsLocked|length > 0 %}
                            <div class="mb-4">
                                <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-600 mb-2 px-0.5">
                                    Verrouillées
                                    <span class="text-gray-700 ml-1">{{ skillsLocked|length }}</span>
                                </h3>
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                                    {% for skill in skillsLocked %}
                                        <div class="skill-node skill-node--locked rounded-xl p-3 border">
                                            <div class="flex items-start justify-between gap-2">
                                                <div class="min-w-0 flex-1">
                                                    <h4 class="text-sm font-medium text-gray-500">{{ skill.title }}</h4>
                                                    <p class="text-xs text-gray-700 mt-0.5 leading-relaxed">{{ skill.description }}</p>
                                                    <div class="flex flex-wrap gap-1 mt-2">
                                                        <span class="text-xs text-gray-600">{{ skill.requiredPoints }} pts XP requis</span>
                                                        {% for req in skill.requirements %}
                                                            <span class="text-xs px-1.5 py-0.5 rounded-full {{ req.acquired ? 'bg-green-900/25 text-green-700' : 'bg-red-900/25 text-red-700' }}">
                                                                {{ req.title }} {{ req.acquired ? '✓' : '✗' }}
                                                            </span>
                                                        {% endfor %}
                                                    </div>
                                                </div>
                                                <span class="bg-gray-800/60 text-gray-600 font-semibold py-1.5 px-3 rounded-lg text-xs flex-shrink-0 cursor-not-allowed">
                                                    Verrouillé
                                                </span>
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}

                    </div>{# end domain panel #}
                {% endfor %}
            </div>{# end panels #}

        </div>{# end flex layout #}
    {% endif %}

</div>{# end game-page #}
{% endblock %}


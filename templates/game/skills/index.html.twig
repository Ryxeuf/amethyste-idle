{% extends 'game/game.html.twig' %}

{% block title %}{{ "title.skills"|trans }}{% endblock %}

{% block game_content %}
    <div class="game-page">
        {# Flash messages #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-3 p-3 rounded-lg text-sm
                    {% if label == 'success' %}bg-green-900/50 border border-green-700 text-green-300
                    {% else %}bg-red-900/50 border border-red-700 text-red-300{% endif %}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {# Page header #}
        <div class="mb-4 sm:mb-6">
            <h1 class="text-xl sm:text-2xl font-bold text-white">{{ "title.skills"|trans }}</h1>
            <p class="text-gray-400 text-sm mt-0.5">{{ "game.skills.description"|trans }}</p>
        </div>

        {# Domain sections #}
        {% for domain in domains %}
            <div class="mb-4 sm:mb-6 game-card overflow-hidden">
                {# Domain header with color #}
                <div class="domain-header-{{ domain.slug }} px-4 py-3 flex items-center justify-between">
                    <h2 class="text-base sm:text-lg font-bold text-white">{{ domain.title }}</h2>
                    <div class="text-right">
                        <p class="text-xs text-white/80">
                            {{ "game.domains.experience.available"|trans }} : <span class="font-bold text-white">{{ domain.availableExperience }}</span>
                        </p>
                        <p class="text-xs text-white/70 hidden sm:block">
                            {{ "game.domains.experience.total"|trans }} : <span class="font-bold text-white">{{ domain.totalExperience }}</span>
                        </p>
                    </div>
                </div>

                {# Skills list — cards on mobile, table on desktop #}
                <div class="p-3 sm:p-4">
                    {# Mobile: card layout #}
                    <div class="lg:hidden space-y-2">
                        {% for skill in domain.skills %}
                            <div class="skill-card">
                                <div class="flex items-start justify-between gap-2 mb-1.5">
                                    <div class="min-w-0 flex-1">
                                        <h3 class="text-sm font-semibold text-white">{{ skill.title }}</h3>
                                        <p class="text-xs text-gray-400 mt-0.5">{{ skill.description }}</p>
                                    </div>
                                    <div class="flex-shrink-0">
                                        {% if not skill.acquired %}
                                            {% if skill.canBeAcquired %}
                                                <form action="{{ path('app_game_skill_acquire') }}" method="post">
                                                    <input type="hidden" name="skill_id" value="{{ skill.id }}">
                                                    <input type="hidden" name="domain_id" value="{{ domain.id }}">
                                                    <button type="submit" class="bg-purple-600 hover:bg-purple-700 active:bg-purple-800 text-white font-bold py-1.5 px-3 rounded text-xs touch-target transition-colors">
                                                        {{ "game.skills.learn"|trans }}
                                                    </button>
                                                </form>
                                            {% else %}
                                                <span class="bg-gray-700 text-gray-500 font-bold py-1.5 px-3 rounded text-xs cursor-not-allowed">
                                                    {{ "game.skills.learn"|trans }}
                                                </span>
                                            {% endif %}
                                        {% else %}
                                            <span class="bg-blue-600/80 text-white font-bold py-1.5 px-3 rounded text-xs">
                                                {{ "game.skills.learned"|trans }}
                                            </span>
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="flex items-center gap-3 text-xs">
                                    <span class="text-purple-400">{{ skill.requiredPoints }} pts</span>
                                    {% if skill.requirements|length > 0 %}
                                        <span class="text-gray-500">|</span>
                                        {% for requirement in skill.requirements %}
                                            <span class="{% if requirement.acquired %}text-green-400{% else %}text-red-400{% endif %}">
                                                {{ requirement.title }}
                                                {% if requirement.acquired %}&#10003;{% else %}&#10007;{% endif %}
                                            </span>
                                        {% endfor %}
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    {# Desktop: table layout #}
                    <div class="hidden lg:block overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-700">
                            <thead>
                                <tr>
                                    <th class="px-4 py-3 bg-gray-800 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">{{ "game.skills.title"|trans }}</th>
                                    <th class="px-4 py-3 bg-gray-800 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">{{ "game.skills.cost"|trans }}</th>
                                    <th class="px-4 py-3 bg-gray-800 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">{{ "game.skills.description"|trans }}</th>
                                    <th class="px-4 py-3 bg-gray-800 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">{{ "game.skills.requirements"|trans }}</th>
                                    <th class="px-4 py-3 bg-gray-800 text-right text-xs font-medium text-gray-300 uppercase tracking-wider"></th>
                                </tr>
                            </thead>
                            <tbody class="bg-gray-900 divide-y divide-gray-800">
                                {% for skill in domain.skills %}
                                    <tr>
                                        <td class="px-4 py-3 whitespace-nowrap text-sm font-medium text-white">{{ skill.title }}</td>
                                        <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-300">{{ skill.requiredPoints }}</td>
                                        <td class="px-4 py-3 text-sm text-gray-300">{{ skill.description }}</td>
                                        <td class="px-4 py-3 text-sm text-gray-300">
                                            {% for requirement in skill.requirements %}
                                                <span class="{% if requirement.acquired %}text-green-400{% else %}text-red-400{% endif %}">
                                                    {{ requirement.title }}
                                                    {% if requirement.acquired %}&#10003;{% else %}&#10007;{% endif %}
                                                </span>
                                                {% if not loop.last %}<br>{% endif %}
                                            {% endfor %}
                                        </td>
                                        <td class="px-4 py-3 whitespace-nowrap text-right text-sm font-medium">
                                            {% if not skill.acquired %}
                                                {% if skill.canBeAcquired %}
                                                    <form action="{{ path('app_game_skill_acquire') }}" method="post" class="inline">
                                                        <input type="hidden" name="skill_id" value="{{ skill.id }}">
                                                        <input type="hidden" name="domain_id" value="{{ domain.id }}">
                                                        <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white font-bold py-2 px-4 rounded text-xs transition-colors">
                                                            {{ "game.skills.learn"|trans }}
                                                        </button>
                                                    </form>
                                                {% else %}
                                                    <span class="bg-red-600 text-white font-bold py-2 px-4 rounded text-xs opacity-75 cursor-not-allowed">
                                                        {{ "game.skills.learn"|trans }}
                                                    </span>
                                                {% endif %}
                                            {% else %}
                                                <span class="bg-blue-600 text-white font-bold py-2 px-4 rounded text-xs">
                                                    {{ "game.skills.learned"|trans }}
                                                </span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .domain-header-pyromancie { background-color: #e02424; }
        .domain-header-soldat { background-color: #777777; }
        .domain-header-blacksmith { background-color: #333333; }
        .domain-header-necro { background-color: #480040; }
        .domain-header-white_wizard { background-color: #ecf6b1; color: #1f2937; }
        .domain-header-druid { background-color: #009007; }
        .domain-header-herbalist { background-color: #58ae5e; }
        .domain-header-skinner { background-color: #bc6500; }
        .domain-header-jeweller { background-color: #ba53a2; }
        .domain-header-alchimist { background-color: #000000; }
        .domain-header-leatherworker { background-color: #ffcc00; color: #1f2937; }
        .domain-header-miner { background-color: #6b6b6b; }
        .domain-header-fisherman { background-color: #0037ff; }
        .domain-header-healer { background-color: #00ffea; color: #1f2937; }
        .domain-header-defender { background-color: #387483; }
    </style>
{% endblock %}

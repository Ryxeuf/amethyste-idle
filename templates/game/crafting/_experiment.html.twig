{# Section d'experimentation - combinaison libre d'ingredients #}
<div class="bg-gray-800 border border-gray-700 rounded-lg p-6">
    <p class="text-gray-400 text-sm mb-4">
        Combinez des ingredients pour tenter de decouvrir de nouvelles recettes.
        <span class="text-yellow-400 font-medium">Attention :</span> en cas d'echec, certains materiaux peuvent etre consommes.
    </p>

    <form method="post" action="{{ path('app_game_craft_experiment') }}" class="space-y-4">
        <div id="experiment-ingredient-slots" class="space-y-2">
            {# Premier slot d'ingredient #}
            <div class="flex items-center gap-2">
                <select name="items[]"
                        class="flex-1 bg-gray-700 border border-gray-600 text-white rounded-md px-3 py-2 text-sm focus:ring-purple-500 focus:border-purple-500">
                    <option value="">-- Choisir un ingredient --</option>
                    {% for item in playerItems %}
                        <option value="{{ item.slug }}">{{ item.name }} (x{{ item.count }})</option>
                    {% endfor %}
                </select>
                <button type="button"
                        onclick="addExperimentSlot()"
                        class="bg-gray-600 hover:bg-gray-500 text-white px-3 py-2 rounded-md text-sm">
                    +
                </button>
            </div>
            {# Deuxieme slot d'ingredient #}
            <div class="flex items-center gap-2">
                <select name="items[]"
                        class="flex-1 bg-gray-700 border border-gray-600 text-white rounded-md px-3 py-2 text-sm focus:ring-purple-500 focus:border-purple-500">
                    <option value="">-- Choisir un ingredient --</option>
                    {% for item in playerItems %}
                        <option value="{{ item.slug }}">{{ item.name }} (x{{ item.count }})</option>
                    {% endfor %}
                </select>
                <button type="button"
                        onclick="this.parentElement.remove()"
                        class="bg-red-700 hover:bg-red-600 text-white px-3 py-2 rounded-md text-sm">
                    -
                </button>
            </div>
        </div>

        <div class="flex items-center gap-4">
            <button type="submit"
                    class="bg-purple-600 hover:bg-purple-500 text-white px-6 py-2 rounded-md text-sm font-medium transition-colors">
                Experimenter
            </button>
            <span class="text-xs text-gray-500">Minimum 2 ingredients requis</span>
        </div>
    </form>
</div>

<script>
    function addExperimentSlot() {
        var container = document.getElementById('experiment-ingredient-slots');
        var firstSelect = container.querySelector('select');
        if (!firstSelect) return;

        var div = document.createElement('div');
        div.className = 'flex items-center gap-2';
        div.innerHTML = '<select name="items[]" class="flex-1 bg-gray-700 border border-gray-600 text-white rounded-md px-3 py-2 text-sm focus:ring-purple-500 focus:border-purple-500">' +
            firstSelect.innerHTML +
            '</select>' +
            '<button type="button" onclick="this.parentElement.remove()" class="bg-red-700 hover:bg-red-600 text-white px-3 py-2 rounded-md text-sm">-</button>';
        container.appendChild(div);
    }
</script>

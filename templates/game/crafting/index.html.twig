{% extends 'game/game.html.twig' %}

{% block title %}Artisanat{% endblock %}

{% block game_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-purple-400 mb-2">Artisanat</h1>
        <p class="text-gray-300">Fabriquez des objets a partir de materiaux recoltes.</p>
    </div>

    {# Messages flash #}
    {% include 'game/crafting/_craft_result.html.twig' %}

    {# Onglets des professions d'artisanat #}
    <div class="mb-6">
        <div class="border-b border-gray-700">
            <nav class="flex flex-wrap space-x-4 md:space-x-8" id="craft-tabs">
                {% set craftLabels = {
                    'forgeron': 'Forge',
                    'tanneur': 'Tannerie',
                    'alchimiste': 'Alchimie',
                    'joaillier': 'Joaillerie'
                } %}

                {% for craft in crafts %}
                    <button type="button"
                            data-craft-tab="{{ craft }}"
                            class="craft-tab-btn whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm focus:outline-none
                                {% if loop.first %}
                                    border-purple-500 text-purple-400
                                {% else %}
                                    border-transparent text-gray-400 hover:text-gray-300 hover:border-gray-400
                                {% endif %}">
                        {{ craftLabels[craft] ?? craft|capitalize }}
                        <span class="ml-1 text-xs bg-gray-700 text-gray-300 px-2 py-0.5 rounded-full">
                            Niv. {{ craftLevels[craft] ?? 1 }}
                        </span>
                    </button>
                {% endfor %}
            </nav>
        </div>
    </div>

    {# Contenu des onglets #}
    {% for craft in crafts %}
        <div id="craft-panel-{{ craft }}"
             class="craft-panel {% if not loop.first %}hidden{% endif %}">

            {# Tool warning #}
            {% if craftToolStatus[craft] is defined and not craftToolStatus[craft].ok %}
                <div class="mb-4 p-3 bg-amber-900/30 border border-amber-500/30 rounded-lg flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                    <span class="text-xs sm:text-sm text-amber-200">{{ craftToolStatus[craft].message }}</span>
                </div>
            {% endif %}

            {# Indicateur de progression #}
            {% set nextUnlock = nextUnlockByCraft[craft] ?? {nextLevel: null, count: 0, totalLocked: 0} %}
            {% if nextUnlock.nextLevel is not null %}
                <div class="mb-4 p-3 bg-purple-900/20 border border-purple-500/20 rounded-lg flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-purple-400 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-xs sm:text-sm text-purple-200">
                        {{ nextUnlock.count }} recette{{ nextUnlock.count > 1 ? 's' : '' }} au niveau {{ nextUnlock.nextLevel }}
                        {% if nextUnlock.totalLocked > nextUnlock.count %}
                            ({{ nextUnlock.totalLocked }} verrouillee{{ nextUnlock.totalLocked > 1 ? 's' : '' }} au total)
                        {% endif %}
                    </span>
                </div>
            {% endif %}

            {% if recipesByCraft[craft] is defined and recipesByCraft[craft]|length > 0 %}
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    {% for recipe in recipesByCraft[craft] %}
                        {% set craftCheck = canCraftByCraft[craft][recipe.id] ?? {possible: false, missing: []} %}
                        {% set maxCraft = maxCraftByCraft[craft][recipe.id] ?? 0 %}
                        {% include 'game/crafting/_recipe_card.html.twig' with {
                            recipe: recipe,
                            craftCheck: craftCheck,
                            maxCraft: maxCraft
                        } %}
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-center text-gray-400 py-12">
                    <p class="text-lg">Aucune recette disponible pour cette profession.</p>
                    <p class="text-sm mt-2">Progressez dans le jeu pour debloquer de nouvelles recettes.</p>
                </div>
            {% endif %}

            {# Recettes verrouilees #}
            {% if lockedRecipesByCraft[craft] is defined and lockedRecipesByCraft[craft]|length > 0 %}
                <div class="mt-6">
                    <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-3 flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
                        </svg>
                        Recettes verrouilees ({{ lockedRecipesByCraft[craft]|length }})
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        {% for recipe in lockedRecipesByCraft[craft] %}
                            {% include 'game/crafting/_recipe_card_locked.html.twig' with {
                                recipe: recipe
                            } %}
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>
    {% endfor %}

    {# Section Enchantements #}
    <div class="mt-8 border-t border-gray-700 pt-6">
        <h2 class="text-xl font-semibold text-purple-300 mb-4">Enchantements</h2>
        {% include 'game/crafting/_enchantment.html.twig' with {
            enchantmentDefinitions: enchantmentDefinitions,
            equippedItems: equippedItems,
            activeEnchantments: activeEnchantments
        } %}
    </div>

    {# Section Experimentation #}
    <div class="mt-8 border-t border-gray-700 pt-6">
        <h2 class="text-xl font-semibold text-purple-300 mb-4">Experimentation</h2>
        {% include 'game/crafting/_experiment.html.twig' with {
            playerItems: playerItems
        } %}
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const tabButtons = document.querySelectorAll('.craft-tab-btn');
        const panels = document.querySelectorAll('.craft-panel');

        tabButtons.forEach(function(button) {
            button.addEventListener('click', function() {
                const craft = button.getAttribute('data-craft-tab');

                // Reset tous les onglets
                tabButtons.forEach(function(btn) {
                    btn.classList.remove('border-purple-500', 'text-purple-400');
                    btn.classList.add('border-transparent', 'text-gray-400');
                });

                // Cacher tous les panneaux
                panels.forEach(function(panel) {
                    panel.classList.add('hidden');
                });

                // Activer l'onglet clique
                button.classList.remove('border-transparent', 'text-gray-400');
                button.classList.add('border-purple-500', 'text-purple-400');

                // Afficher le panneau correspondant
                var panel = document.getElementById('craft-panel-' + craft);
                if (panel) {
                    panel.classList.remove('hidden');
                }
            });
        });
    });
</script>
{% endblock %}

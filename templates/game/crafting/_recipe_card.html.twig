{# Carte d'une recette d'artisanat #}
{% set canCraftRecipe = craftCheck.possible ?? false %}
{% set missingItems = craftCheck.missing ?? [] %}

{% set qualityColors = {
    'normal': 'text-gray-400 bg-gray-700 border-gray-600',
    'uncommon': 'text-green-400 bg-green-900 border-green-700',
    'rare': 'text-blue-400 bg-blue-900 border-blue-700',
    'epic': 'text-purple-400 bg-purple-900 border-purple-700',
    'legendary': 'text-orange-400 bg-orange-900 border-orange-700',
} %}

{% set qualityLabels = {
    'normal': 'Normal',
    'uncommon': 'Peu commun',
    'rare': 'Rare',
    'epic': 'Epique',
    'legendary': 'Legendaire',
} %}

<div class="bg-gray-800 border border-gray-700 rounded-lg p-4 hover:border-purple-600 transition-colors {% if not canCraftRecipe %}opacity-75{% endif %}">
    {# En-tete #}
    <div class="flex items-start justify-between mb-3">
        <div>
            <h3 class="text-lg font-semibold text-white">{{ recipe.name }}</h3>
            {% if recipe.description %}
                <p class="text-sm text-gray-400 mt-1">{{ recipe.description }}</p>
            {% endif %}
        </div>
        <div class="flex items-center gap-2 ml-2">
            {% if recipe.quality %}
                <span class="text-xs px-2 py-1 rounded-full border {{ qualityColors[recipe.quality] ?? qualityColors['normal'] }}">
                    {{ qualityLabels[recipe.quality] ?? 'Normal' }}
                </span>
            {% endif %}
            {% if recipe.requiredLevel > 1 %}
                <span class="text-xs bg-gray-700 text-gray-300 px-2 py-1 rounded-full whitespace-nowrap">
                    Niv. {{ recipe.requiredLevel }}
                </span>
            {% endif %}
        </div>
    </div>

    {# Ingredients #}
    <div class="mb-3">
        <h4 class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Ingredients</h4>
        <div class="flex flex-wrap gap-2">
            {% for ingredient in recipe.ingredients %}
                {% set ingredientSlug = ingredient.slug %}
                {% set ingredientQty = ingredient.quantity ?? 1 %}

                {# Verifier si cet ingredient est dans les manquants #}
                {% set isMissing = false %}
                {% set haveCount = ingredientQty %}
                {% for missing in missingItems %}
                    {% if missing.slug == ingredientSlug %}
                        {% set isMissing = true %}
                        {% set haveCount = missing.have %}
                    {% endif %}
                {% endfor %}

                <span class="inline-flex items-center px-2 py-1 rounded text-xs
                    {% if isMissing %}
                        bg-red-900 text-red-300 border border-red-700
                    {% else %}
                        bg-green-900 text-green-300 border border-green-700
                    {% endif %}">
                    {{ ingredientSlug|replace({'_': ' ', '-': ' '})|capitalize }}
                    <span class="ml-1 font-mono">{{ haveCount }}/{{ ingredientQty }}</span>
                </span>
            {% endfor %}
        </div>
    </div>

    {# Resultat #}
    <div class="mb-3">
        <h4 class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Resultat</h4>
        <span class="text-purple-300 font-medium">
            {{ recipe.result.name }}
            {% if recipe.resultQuantity > 1 %}
                x{{ recipe.resultQuantity }}
            {% endif %}
        </span>
    </div>

    {# Informations de craft #}
    <div class="flex items-center justify-between text-xs text-gray-500 mb-3">
        <span>Temps : {{ recipe.craftingTime }}s</span>
        <span>+{{ recipe.xpReward }} XP</span>
    </div>

    {# Bouton de fabrication #}
    <form method="post" action="{{ path('app_game_craft_execute', {slug: recipe.slug}) }}">
        <button type="submit"
                class="w-full py-2 px-4 rounded-md text-sm font-medium transition-colors
                    {% if canCraftRecipe %}
                        bg-purple-600 hover:bg-purple-500 text-white cursor-pointer
                    {% else %}
                        bg-gray-700 text-gray-500 cursor-not-allowed
                    {% endif %}"
                {% if not canCraftRecipe %}disabled{% endif %}>
            {% if canCraftRecipe %}
                Fabriquer
            {% else %}
                Ingredients manquants
            {% endif %}
        </button>
    </form>
</div>

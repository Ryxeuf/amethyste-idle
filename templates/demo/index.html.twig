{% extends 'base.html.twig' %}

{% block title %}Démo Live Component{% endblock %}

{% block body %}
<div class="container mx-auto py-8">
    <h1 class="text-3xl font-bold mb-6">Démo Live Component</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-gray-100 p-6 rounded-lg">
            <h2 class="text-xl font-semibold mb-4">Exemple de compteur</h2>
            {{ component('Counter') }}
        </div>
        
        <div class="bg-gray-100 p-6 rounded-lg">
            <h2 class="text-xl font-semibold mb-4">Un autre compteur</h2>
            {{ component('Counter', { count: 10 }) }}
        </div>
    </div>
</div>
{% endblock %} 
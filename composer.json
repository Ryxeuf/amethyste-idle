{
    "name": "symfony/skeleton",
    "type": "project",
    "license": "MIT",
    "description": "A minimal Symfony project recommended to create bare bones applications",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3.17",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-pcntl": "*",
        "cron/cron-bundle": "^3.1.1",
        "doctrine/dbal": "^3.9.4",
        "doctrine/doctrine-bundle": "^2.13.2",
        "doctrine/doctrine-migrations-bundle": "^3.4.1",
        "doctrine/orm": "^2.20.2",
        "runtime/frankenphp-symfony": "^0.2.0",
        "stof/doctrine-extensions-bundle": "^1.13",
        "symfony/asset": "7.2.*",
        "symfony/asset-mapper": "7.2.*",
        "symfony/console": "7.2.*",
        "symfony/css-selector": "7.2.*",
        "symfony/doctrine-messenger": "7.2.*",
        "symfony/dom-crawler": "7.2.*",
        "symfony/dotenv": "7.2.*",
        "symfony/flex": "^2.5.0",
        "symfony/form": "7.2.*",
        "symfony/framework-bundle": "7.2.*",
        "symfony/mercure": ">=0.6.5",
        "symfony/mercure-bundle": ">=0.3.9",
        "symfony/messenger": "7.2.*",
        "symfony/monolog-bundle": "^3.10",
        "symfony/runtime": "7.2.*",
        "symfony/security-bundle": "7.2.*",
        "symfony/translation": "7.2.*",
        "symfony/twig-bundle": "7.2.*",
        "symfony/ux-live-component": "^2.23",
        "symfony/ux-twig-component": "^2.23",
        "symfony/validator": "7.2.*",
        "symfony/yaml": "7.2.*",
        "symfonycasts/tailwind-bundle": "^0.8.0",
        "twig/extra-bundle": "^2.12|^3.20",
        "twig/twig": "^2.12|^3.20",
        "typesense/typesense-php": "^4.9.3"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.2.*",
            "docker": true
        }
    },
    "require-dev": {
        "doctrine/data-fixtures": "^2.0.2",
        "doctrine/doctrine-fixtures-bundle": "^4.0",
        "symfony/stopwatch": "7.2.*",
        "symfony/web-profiler-bundle": "7.2.*"
    }
}

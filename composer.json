{
    "name": "symfony/skeleton",
    "type": "project",
    "license": "MIT",
    "description": "A minimal Symfony project recommended to create bare bones applications",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4.0",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-pcntl": "*",
        "symfony/scheduler": "7.4.*",
        "doctrine/dbal": "^4.0",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/doctrine-migrations-bundle": "^3.4",
        "doctrine/orm": "^3.4",
        "runtime/frankenphp-symfony": "^0.2.0",
        "stof/doctrine-extensions-bundle": "^1.15",
        "symfony/asset": "7.4.*",
        "symfony/asset-mapper": "7.4.*",
        "symfony/console": "7.4.*",
        "symfony/css-selector": "7.4.*",
        "symfony/doctrine-messenger": "7.4.*",
        "symfony/dom-crawler": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/flex": "^2.10",
        "symfony/form": "7.4.*",
        "symfony/framework-bundle": "7.4.*",
        "symfony/mercure": ">=0.6.5",
        "symfony/mercure-bundle": ">=0.3.9",
        "symfony/messenger": "7.4.*",
        "symfony/monolog-bundle": "^3.10",
        "symfony/runtime": "7.4.*",
        "symfony/security-bundle": "7.4.*",
        "symfony/translation": "7.4.*",
        "symfony/twig-bundle": "7.4.*",
        "symfony/ux-live-component": "^2.23",
        "symfony/ux-turbo": "^2.24",
        "symfony/ux-twig-component": "^2.23",
        "symfony/validator": "7.4.*",
        "symfony/rate-limiter": "7.4.*",
        "symfony/web-profiler-bundle": "7.4.*",
        "symfony/yaml": "7.4.*",
        "symfonycasts/tailwind-bundle": "^0.10",
        "twig/extra-bundle": "^3.20",
        "twig/twig": "^3.20"
    },
    "config": {
        "platform": {
            "php": "8.4.0"
        },
        "allow-plugins": {
            "infection/extension-installer": true,
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "audit": {
            "abandoned": "report",
            "ignore": {
                "PKSA-365x-2zjk-pt47": "Dev environment, will fix with next Symfony update",
                "PKSA-b35n-565h-rs4q": "Dev environment, will fix with next Symfony update",
                "PKSA-t4rz-hp2g-57t1": "Dev environment, will fix with next Symfony update"
            }
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*",
            "docker": true
        }
    },
    "require-dev": {
        "dbrekelmans/bdi": "^1.4.1",
        "doctrine/data-fixtures": "^2.0",
        "doctrine/doctrine-fixtures-bundle": "^4.0",
        "friendsofphp/php-cs-fixer": "^3.65",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^11.5",
        "symfony/browser-kit": "7.4.*",
        "symfony/css-selector": "7.4.*",
        "symfony/panther": "^2.4",
        "symfony/phpunit-bridge": "^7.4",
        "infection/infection": "^0.29",
        "symfony/stopwatch": "7.4.*"
    }
}
